This parameter is required.', example='cn-hangzhou'),
  resourceGroupId?: string(name='ResourceGroupId', description='The resource group ID of the auto provisioning group.', example='rg-bp67acfmxazb4p****'),
  resourceOwnerAccount?: string(name='ResourceOwnerAccount'),
