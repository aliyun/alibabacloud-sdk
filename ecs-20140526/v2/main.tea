Default value: lowest-price.', example='prioritized'),
  payAsYouGoTargetCapacity?: string(name='PayAsYouGoTargetCapacity', description='The target capacity for pay-as-you-go instances in the auto provisioning group. Valid values: Integers less than or equal to the value of `TotalTargetCapacity`.', example='30'),
