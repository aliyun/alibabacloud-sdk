 */
@context("enableDiskEncryptionByDefaultWithContext")
async function enableDiskEncryptionByDefaultWithOptions(request: EnableDiskEncryptionByDefaultRequest, runtime: $RuntimeOptions): EnableDiskEncryptionByDefaultResponse {
  request.validate();
  var query = {};
  if (!$isNull(request.ownerAccount)) {
