 * @return SubmitMediaComprehensionJobResponse
 */
async function submitMediaComprehensionJobWithOptions(request: SubmitMediaComprehensionJobRequest, runtime: Util.RuntimeOptions): SubmitMediaComprehensionJobResponse {
