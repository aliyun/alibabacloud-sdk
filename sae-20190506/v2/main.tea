  name?: string(name='Name', description='The name of the container.', example='name'),
  postStart?: string(name='PostStart', description='The configuration for the postStart hook. This hook runs immediately after the container starts to perform initialization tasks.'),
  preStop?: string(name='PreStop', description='The configuration for the preStop hook. This hook runs immediately before the container is terminated to ensure a graceful shutdown.'),
  readiness?: string(name='Readiness', description='The configuration for the readiness probe. The readiness probe checks if the container is ready to handle requests. The system will not direct traffic to a container until its readiness probe succeeds.'),
