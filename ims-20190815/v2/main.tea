  maxIdleDaysForUsers?: int32(name='MaxIdleDaysForUsers', description='The maximum idle period of RAM users. If a RAM user who can log on to the console does not log on to the console for the specified period of time (SSO logons are not included), the console logon feature of the RAM user is disabled on the next day. You can set the value to one of the following numbers:

- 90

- 180

- 365

- 730 (default)', example='365'),
  operationForRiskLogin?: string(name='OperationForRiskLogin', description='This parameter is deprecated.', example='autonomous', deprecated=true),
  verificationTypes?: [ string ](name='VerificationTypes', description='The MFA methods.'),
