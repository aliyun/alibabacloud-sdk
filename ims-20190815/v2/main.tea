    issuanceLimitTime?: long(name='IssuanceLimitTime', description='The earliest time when an external IdP is allowed to issue an ID token. If the value of the iat field in the ID token is greater than the current time by more than this value, the request is rejected. Unit: hours. Valid values: 1 to 168.', example='12'),
