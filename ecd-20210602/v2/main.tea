 */
@context("listSkillsWithContext")
async function listSkillsWithOptions(request: ListSkillsRequest, runtime: $RuntimeOptions): ListSkillsResponse {
  request.validate();
  var query = {};
  if (!$isNull(request.pageNumber)) {
    query['PageNumber'] = request.pageNumber;
