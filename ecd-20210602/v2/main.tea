/**
 * @summary Creates a tenant skill.
 *
 * @param tmpReq CreateTenantSkillRequest
 * @param runtime runtime options for this request RuntimeOptions
 * @return CreateTenantSkillResponse
 */
@context("createTenantSkillWithContext")
async function createTenantSkillWithOptions(tmpReq: CreateTenantSkillRequest, runtime: $RuntimeOptions): CreateTenantSkillResponse {
  tmpReq.validate();
  var request = new CreateTenantSkillShrinkRequest{};
  OpenApiUtil.convert(tmpReq, request);
  if (!$isNull(tmpReq.envVars)) {
    request.envVarsShrink = OpenApiUtil.arrayToStringWithSpecifiedStyle(tmpReq.envVars, 'EnvVars', 'json');
  }
  var query = {};
  if (!$isNull(request.apiKey)) {
    query['ApiKey'] = request.apiKey;
  }
  if (!$isNull(request.description)) {
    query['Description'] = request.description;
  }
  if (!$isNull(request.displayName)) {
    query['DisplayName'] = request.displayName;
  }
  if (!$isNull(request.envVarsShrink)) {
    query['EnvVars'] = request.envVarsShrink;
  }
  if (!$isNull(request.iconETag)) {
    query['IconETag'] = request.iconETag;
  }
  if (!$isNull(request.skillChannel)) {
    query['SkillChannel'] = request.skillChannel;
  }
  if (!$isNull(request.skillIcon)) {
    query['SkillIcon'] = request.skillIcon;
  }
  if (!$isNull(request.skillVersion)) {
    query['SkillVersion'] = request.skillVersion;
  }
  if (!$isNull(request.slug)) {
    query['Slug'] = request.slug;
  }
  if (!$isNull(request.taskKey)) {
    query['TaskKey'] = request.taskKey;
  }
  var req = new OpenApiUtil.OpenApiRequest{ 
    query = OpenApiUtil.query(query),
  };
  var params = new OpenApiUtil.Params{
    action = 'CreateTenantSkill',
    version = '2021-06-02',
    protocol = 'HTTPS',
    pathname = '/',
    method = 'POST',
    authType = 'AK',
    style = 'RPC',
    reqBodyType = 'formData',
    bodyType = 'json',
  };
  return callApi(params, req, runtime);
}

/**
 * @summary Creates a tenant skill.
 *
 * @param request CreateTenantSkillRequest
 * @return CreateTenantSkillResponse
 */
async function createTenantSkill(request: CreateTenantSkillRequest): CreateTenantSkillResponse {
  var runtime = new $RuntimeOptions{};
  return createTenantSkillWithOptions(request, runtime);
}

