/**
 *
 */
import Util;
import OpenApi;
import OpenApiUtil;
import EndpointUtil;

extends OpenApi;


init(config: OpenApi.Config){
  super(config);
  @endpointRule = 'regional';
  @endpointMap = {
    'us-west-1' = 'ververica.us-west-1.aliyuncs.com',
    'us-east-1' = 'ververica.us-east-1.aliyuncs.com',
    'eu-west-1' = 'ververica.eu-west-1.aliyuncs.com',
    'eu-central-1' = 'ververica.eu-central-1.aliyuncs.com',
    'cn-zhangjiakou' = 'ververica.cn-zhangjiakou.aliyuncs.com',
    'cn-wulanchabu' = 'ververica.cn-wulanchabu.aliyuncs.com',
    'cn-shenzhen' = 'ververica.cn-shenzhen.aliyuncs.com',
    'cn-shanghai-finance-1' = 'ververica.cn-shanghai-finance-1.aliyuncs.com',
    'cn-shanghai' = 'ververica.cn-shanghai.aliyuncs.com',
    'cn-qingdao' = 'ververica.cn-qingdao.aliyuncs.com',
    'cn-hongkong' = 'ververica.cn-hongkong.aliyuncs.com',
    'cn-hangzhou' = 'ververica.cn-hangzhou.aliyuncs.com',
    'cn-chengdu' = 'ververica.cn-chengdu.aliyuncs.com',
    'cn-beijing' = 'ververica.cn-beijing.aliyuncs.com',
    'ap-southeast-5' = 'ververica.ap-southeast-5.aliyuncs.com',
    'ap-southeast-3' = 'ververica.ap-southeast-3.aliyuncs.com',
    'ap-southeast-1' = 'ververica.ap-southeast-1.aliyuncs.com',
    'ap-northeast-1' = 'ververica.ap-northeast-1.aliyuncs.com',
  };

  checkConfig(config);
  @endpoint = getEndpoint('ververica', @regionId, @endpointRule, @network, @suffix, @endpointMap, @endpoint);
}

function getEndpoint(productId: string, regionId: string, endpointRule: string, network: string, suffix: string, endpointMap: map[string]string, endpoint: string) throws: string{
  if (!Util.empty(endpoint)) {
    return endpoint;
  }
  
  if (!Util.isUnset(endpointMap) && !Util.empty(endpointMap[regionId])) {
    return endpointMap[regionId];
  }
  return EndpointUtil.getEndpointRules(productId, regionId, endpointRule, network, suffix);
}

model AiModel {
  comment?: string(name='comment'),
  inputSchema?: Schema(name='inputSchema'),
  name?: string(name='name', description='This parameter is required.'),
  options?: map[string]string(name='options', description='This parameter is required.'),
  outputSchema?: Schema(name='outputSchema'),
}

model Artifact {
  cdcYamlArtifact?: CdcYamlArtifact(name='cdcYamlArtifact', description='Required for a data ingestion job.'),
  jarArtifact?: JarArtifact(name='jarArtifact', description='Required for a JAR job.'),
  kind?: string(name='kind', description='Specifies the kind of job. This field is required and cannot be changed after creation.

- SQLSCRIPT: An SQL job.

- JAR: A JAR job.

- PYTHON: A Python job.

- CDCYAML: A CDC data ingestion job.', example='SQLSCRIPT'),
  pythonArtifact?: PythonArtifact(name='pythonArtifact', description='Required for a Python job.'),
  sqlArtifact?: SqlArtifact(name='sqlArtifact', description='Required for an SQL job.'),
}

model AsyncDraftDeployResult {
  artifactValidationDetail?: ValidateStatementResult(name='artifactValidationDetail', description='The verification result of the SQL syntax.'),
  deploymentId?: string(name='deploymentId', description='The deployment ID.', example='CBC799F0-AS7S-1D30-8A4F-882ED4DD****'),
  message?: string(name='message', description='The information about the deployment result.', example='"Validation error: SQL validate failed"'),
  success?: boolean(name='success', description='Indicates whether the request was successful.', example='true'),
  ticketStatus?: string(name='ticketStatus', description='The state of the execution.', example='FINISHED'),
}

model AsyncDraftValidateResult {
  draftValidationDetail?: DraftValidationDetail(name='draftValidationDetail'),
  message?: string(name='message'),
  success?: boolean(name='success'),
  ticketStatus?: string(name='ticketStatus'),
}

model AsyncResourcePlanOperationResult {
  message?: string(name='message', description='The information about the ticket. The value of this parameter is returned when the value of the ticketStatus parameter is FAILED or EXECUTING.', example='"create resource plan failed"'),
  plan?: string(name='plan', description='The resource configuration plan of the deployment in expert mode. The value of this parameter is returned when the value of the ticketStatus parameter is FINISHED.', example='{\\\\"ssgProfiles\\\\":[{\\\\"name\\\\":\\\\"default\\\\",\\\\"cpu\\\\":1.13,\\\\"heap\\\\":\\\\"1 gb\\\\",\\\\"offHeap\\\\":\\\\"32 mb\\\\",\\\\"managed\\\\":{},\\\\"extended\\\\":{}}],\\\\"nodes\\\\":[{\\\\"id\\\\":1,\\\\"type\\\\":\\\\"StreamExecTableSourceScan\\\\",\\\\"desc\\\\":\\\\"Source: datagen_source[78]\\\\",\\\\"profile\\\\":{\\\\"group\\\\":\\\\"default\\\\",\\\\"parallelism\\\\":1,\\\\"maxParallelism\\\\":32768,\\\\"minParallelism\\\\":1}},{\\\\"id\\\\":2,\\\\"type\\\\":\\\\"StreamExecSink\\\\",\\\\"desc\\\\":\\\\"Sink: blackhole_sink[79]\\\\",\\\\"profile\\\\":{\\\\"group\\\\":\\\\"default\\\\",\\\\"parallelism\\\\":1,\\\\"maxParallelism\\\\":32768,\\\\"minParallelism\\\\":1}}],\\\\"edges\\\\":[{\\\\"source\\\\":1,\\\\"target\\\\":2,\\\\"mode\\\\":\\\\"PIPELINED\\\\",\\\\"strategy\\\\":\\\\"FORWARD\\\\"}],\\\\"vertices\\\\":{\\\\"717c7b8afebbfb7137f6f0f99beb2a94\\\\":[1,2]}}'),
  ticketStatus?: string(name='ticketStatus', description='The status of the ticket that applies for an asynchronous operation. Valid values:

- EXECUTING

- FINISHED

- FAILED', example='FINISHED'),
}

model BasicResourceSetting {
  jobmanagerResourceSettingSpec?: BasicResourceSettingSpec(name='jobmanagerResourceSettingSpec', description='The resource configuration of the JobManager.'),
  parallelism?: long(name='parallelism', description='The parallelism for a deployment.', example='4'),
  taskmanagerResourceSettingSpec?: BasicResourceSettingSpec(name='taskmanagerResourceSettingSpec', description='The resource configuration of a TaskManager.'),
}

model BasicResourceSettingSpec {
  cpu?: double(name='cpu', description='The number of CPU cores.', example='2.0'),
  memory?: string(name='memory', description='The capacity of the memory. Unit: GiB.', example='4 GiB'),
}

model BatchResourceSetting {
  basicResourceSetting?: BasicResourceSetting(name='basicResourceSetting', description='The resource parameters in basic mode.'),
