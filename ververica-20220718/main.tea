    LocalVariable
  ](name='localVariables', description='Job variables.'),
  logging?: Logging(name='logging', description='Log configuration.'),
  modifiedAt?: string(name='modifiedAt', description='Modification time.', example='1714058843'),
  modifier?: string(name='modifier', description='Modifier.', example='27846363877456****'),
  modifierName?: string(name='modifierName', description='Name of the modifier.', example='****@streamcompute.onaliyun.com'),
  name?: string(name='name', description='Deployed job name.', example='deploymentName'),
  namespace?: string(name='namespace', description='The name of the namespace.', example='default-namespace'),
  referencedDeploymentDraftId?: string(name='referencedDeploymentDraftId', description='Associated job draft ID.', example='00000000-0000-0000-0000-000000000003'),
  streamingResourceSetting?: StreamingResourceSetting(name='streamingResourceSetting', description='Resource settings for a stream job.'),
