  executionMode?: string(name='executionMode', description='Execution mode.

- STREAMING: stream mode.

- BATCH: batch mode.', example='STREAMING'),
  flinkConf?: map[string]any(name='flinkConf', description='Flink configuration.', example='{"taskmanager.numberOfTaskSlots":"1"}'),
  jobSummary?: JobSummary(name='jobSummary', description='A summary of information about the job instances under the deployed job.'),
