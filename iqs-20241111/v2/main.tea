model ReadPageBody {
  formats?: [ string ](name='formats', description='The format of the parsing result.
- rawHtml: the HTML of the target website.
- html: the page content processed based on readabilityMode.
- markdown: the Markdown content converted from HTML.
- text: the text content extracted from HTML.'),
  location?: string(name='location', description='You do not need to specify this parameter.', example='null'),
  maxAge?: int32(name='maxAge', description='The maximum cache validity period. Unit: seconds. Default value: 1296000.

- If the cache duration is less than the value of maxAge, cached content is returned.

- If the value of maxAge is 0, caching is not used.', example='1296000'),
  pageTimeout?: int32(name='pageTimeout', description='The URL read timeout period. The value of pageTimeout must be less than the value of timeout.

Default value: 10000.', example='10000'),
  readability?: {
    excludeAllImages?: boolean(name='excludeAllImages', description='Specifies whether to exclude all images.

Default value: false.', example='false'),
    excludeAllLinks?: boolean(name='excludeAllLinks', description='Specifies whether to exclude all links.

Default value: false.', example='false'),
    excludedTags?: [ string ](name='excludedTags', description='The tags to exclude.'),
    readabilityMode?: string(name='readabilityMode', description='Valid values:
- none: does not remove any information. Default value: none.

- normal: removes irrelevant information from the target page, such as headers, footers, and navigation elements, based on a proprietary algorithm.

- article: extracts the main body content of the website based on a proprietary algorithm. This mode is suitable for blogs and news websites, but not for directory or navigation pages.', example='none'),
  }(name='readability', description='The readability configuration for the parsing result.'),
  timeout?: int32(name='timeout', description='The end-to-end processing timeout period. Unit: ms.

Valid values: [0, 180000].

Default value: 60000.', example='60000'),
  url?: string(name='url', description='The target URL to parse. The value must start with http:// or https://.

This parameter is required.', example='https://help.aliyun.com/document_detail/2837301.html?spm=a2c4g.11186623.help-menu-2837261.d_0_0_0.59ed3e95CppOt2&scm=20140722.H_2837301._.OR_help-T_cn~zh-V_1'),
}

model ReadPageItem {
  errorMessage?: string(name='errorMessage', description='The error related to the target URL.', example='null'),
  html?: string(name='html', description='The readable HTML of the target URL.', example='<html>\\\\n<head><title>Example Domain</title></head>\\\\n<body><div>\\\\n<h1>Example Domain</h1>\\\\n<p>This domain is for use in documentation examples without needing permission. Avoid use in operations.</p>\\\\n<p><a href=\\\\"https://iana.org/domains/example\\\\">Learn more</a></p>\\\\n</div></body>\\\\n</html>'),
  markdown?: string(name='markdown', description='The Markdown content of the target URL.', example='# Example Domain\\\\nThis domain is for use in documentation examples without needing permission. Avoid use in operations.\\\\n[Learn more](https://iana.org/domains/example)\\\\n'),
  rawHtml?: string(name='rawHtml', description='The raw HTML of the target URL.', example='<!doctype html><html lang=\\\\"en\\\\"><head><title>Example Domain</title><meta name=\\\\"viewport\\\\" content=\\\\"width=device-width, initial-scale=1\\\\"><style>body{background:#eee;width:60vw;margin:15vh auto;font-family:system-ui,sans-serif}h1{font-size:1.5em}div{opacity:0.8}a:link,a:visited{color:#348}</style><body><div><h1>Example Domain</h1><p>This domain is for use in documentation examples without needing permission. Avoid use in operations.<p><a href=\\\\"https://iana.org/domains/example\\\\">Learn more</a></div></body></html>\\\\n'),
  screenshot?: string(name='screenshot'),
  statusCode?: int32(name='statusCode', description='1. If the request to the target site succeeds, the HTTP status code of the target URL is returned.

2. If the request to the target site fails, a custom error code is returned:

    2.1 4030: The target site has security restrictions, such as robots.txt or security policies.
    
    2.2 4080: The request timed out.
    
    2.3 4290: The rate limiting policy of the site was triggered.
    
    2.4 5010: An unknown exception occurred.', example='200'),
  text?: string(name='text', description='The text content of the target URL.', example='# Example Domain\\\\nThis domain is for use in documentation examples without needing permission. Avoid use in operations.\\\\nLearn more\\\\n'),
}

model ReadPageScrapeBody {
  formats?: [ string ](name='formats', description='The format of the parsing result.

- rawHtml: the HTML of the target site.
- html: the page content processed based on readabilityMode.
- markdown: the Markdown content converted from the HTML.
- text: the text content extracted from the HTML.
- screenshot: a screenshot of the target site.'),
  location?: string(name='location', description='This parameter does not need to be specified.', example='null'),
  maxAge?: int32(name='maxAge', description='The maximum cache validity period. Unit: seconds. Default value: 1296000.
1. If the cache duration is less than the value of maxAge, cached content is returned.
2. If maxAge is set to 0, caching is not used.', example='1296000'),
  pageTimeout?: int32(name='pageTimeout', description='The timeout period for waiting for the target site resources to fully load. The value of pageTimeout must be less than the value of timeout.

Default value: 15000.', example='15000'),
  readability?: {
    excludeAllImages?: boolean(name='excludeAllImages', description='是否剔除所有图片

默认值：false', example='false'),
    excludeAllLinks?: boolean(name='excludeAllLinks', description='是否剔除所有链接

默认值：false', example='false'),
    excludedTags?: [ string ](name='excludedTags', description='指定排除的标签'),
    readabilityMode?: string(name='readabilityMode', description='none：不删除信息，默认为 none

normal: 基于自研算法，剔除目标页面无关信息（页头/页脚，导航等）

article: 基于自研算法，获取站点主要正文内容(适用于博客、新闻站点，不适用于目录页、导航页)', example='none'),
  }(name='readability', description='The readability configuration for the parsing result.'),
  timeout?: int32(name='timeout', description='The end-to-end processing timeout period. Unit: ms.

Valid values: [0, 180000].

Default value: 60000.', example='60000'),
  url?: string(name='url', description='The target URL to parse. The URL must start with http:// or https://.

This parameter is required.', example='https://www.example.com'),
}

model RequestContents {
  mainText?: boolean(name='mainText', description='Specifies whether to return the main text. Default value: false.'),
  markdownText?: boolean(name='markdownText', description='Specifies whether to return markdown. Default value: false.'),
  rerankScore?: boolean(name='rerankScore', description='Specifies whether to enable Rerank and return the RerankScore. Default value: true.'),
