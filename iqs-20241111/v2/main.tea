  imageUrl?: string(name='imageUrl', description='Image URL', example='http://pic.rmb.bdstatic.com/bjh/bb87f566c0c/241218/f7936f25837b20211e5ef88d7980c143.jpeg'),
  publishedTime?: string(name='publishedTime', description='Web page published time, in ISO time format', example='2022-07-05T00:54:42+08:00'),
