  page?: int32(name='page'),
  query?: string(name='query'),
  searchEngine?: string(name='searchEngine'),
  searchPlan?: string(name='searchPlan'),
  sessionId?: string(name='sessionId'),
  timeRange?: string(name='timeRange'),
}

