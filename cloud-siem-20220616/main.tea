  dataSourceType?: string(name='DataSourceType', description='The type of the data source. Valid values:

- obs: Huawei Cloud Object Storage Service (OBS).

- wafApi: Tencent Cloud Web Application Firewall (WAF) download API.

- ckafka: Tencent Cloud CKafka.', example='obs'),
  regionId?: string(name='RegionId', description='The region of the data management center for threat analysis. Select a region based on the location of your assets. Valid values:

