import Util;
import OpenApi;
import OpenApiUtil;
import EndpointUtil;

extends OpenApi;


init(config: OpenApi.Config){
  super(config);
  @endpointRule = 'regional';
  @endpointMap = {
    'ap-northeast-2-pop' = 'cs.aliyuncs.com',
    'cn-beijing-finance-pop' = 'cs.aliyuncs.com',
    'cn-beijing-gov-1' = 'cs.aliyuncs.com',
