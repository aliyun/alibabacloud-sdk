  controlplaneLogProject?: string(name='controlplane_log_project', description='The Simple Log Service project for control plane component logs. You can use an existing project for log storage or have the system automatically create a project. If you choose automatic creation, a Simple Log Service project named `k8s-log-{ClusterID}` is created.', example='k8s-log-xxx'),
