  securityGroupId?: string(name='security_group_id', description='The security group ID. Specify this parameter when creating a cluster with an existing security group. Mutually exclusive with `is_enterprise_security_group`. Cluster nodes are automatically added to this security group.', example='sg-bp1bdue0qc1g7k****'),
  securityHardeningOs?: boolean(name='security_hardening_os', description='**This field is deprecated.** For control plane configurations, use the `security_hardening_os` parameter under `control_plane_config` instead. For node pool configurations, use the `security_hardening_os` parameter under `scaling_group` in `nodepool` instead.

