    securityGroupIds?: [ string ](name='security_group_ids', description='List of security group IDs.'),
    spotInstancePools?: long(name='spot_instance_pools', description='Number of available instance types. The scaling group creates preemptible instances evenly across the lowest-cost instance types. Valid values: [1,10\\\\].', example='5'),
    spotInstanceRemedy?: boolean(name='spot_instance_remedy', description='Whether to enable supplementing preemptible instances. When enabled, the scaling group attempts to create new instances to replace preemptible instances that are about to be reclaimed upon receiving a system notification. Valid values:

- `true`: Enable supplementing preemptible instances.
- `false`: Disable supplementing preemptible instances.', example='false'),
    spotPriceLimit?: [ 
      {
        instanceType?: string(name='instance_type', description='Preemptible instance type.', example='ecs.c6.large'),
