    onDemandPercentageAboveBaseCapacity?: long(name='on_demand_percentage_above_base_capacity', description='Percentage of pay-as-you-go instances among the excess instances after the scaling group meets the minimum pay-as-you-go instance requirement (`on_demand_base_capacity`). Valid values: [0,100\\\\].', example='20'),
    period?: long(name='period', description='Subscription duration for nodes in the node pool. Takes effect and is required only when `instance_charge_type` is set to `PrePaid`.

