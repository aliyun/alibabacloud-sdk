    periodUnit?: string(name='period_unit', description='Billing period unit for nodes in the node pool. Takes effect and is required only when `instance_charge_type` is set to `PrePaid`.

- `Month`: billed on a monthly basis.
- `Week`: billed on a weekly basis.

Default value: `Month`.', example='Month'),
    platform?: string(name='platform', description='[Deprecated] Use the `image_type` parameter instead.

