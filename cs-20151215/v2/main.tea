model DescribeClustersForRegionRequest {
  clusterId?: string(name='cluster_id', description='The ID of the cluster.', example='c8155823d057948c69a****'),
  clusterSpec?: string(name='cluster_spec', description='The specification of the cluster. Valid values:

- `ack.standard`: Standard Edition

- `ack.pro.small`: Pro Edition

- `ack.pro.xlarge`: Pro XL

- `ack.pro.2xlarge`: Pro 2XL

- `ack.pro.4xlarge`: Pro 4XL (To use this specification, you must submit a ticket.)

