/**
 *
 */
import OpenApi;
import OpenApi.OpenApiUtil;

extends OpenApi;


init(config: OpenApiUtil.Config){
  super(config);
  @endpointRule = 'regional';
  @endpointMap = {
    'ap-northeast-2-pop' = 'cs.aliyuncs.com',
    'cn-beijing-finance-pop' = 'cs.aliyuncs.com',
    'cn-beijing-gov-1' = 'cs.aliyuncs.com',
    'cn-beijing-nu16-b01' = 'cs.aliyuncs.com',
    'cn-edge-1' = 'cs.aliyuncs.com',
    'cn-fujian' = 'cs.aliyuncs.com',
    'cn-haidian-cm12-c01' = 'cs.aliyuncs.com',
    'cn-hangzhou-bj-b01' = 'cs.aliyuncs.com',
    'cn-hangzhou-internal-prod-1' = 'cs.aliyuncs.com',
    'cn-hangzhou-internal-test-1' = 'cs.aliyuncs.com',
    'cn-hangzhou-internal-test-2' = 'cs.aliyuncs.com',
    'cn-hangzhou-internal-test-3' = 'cs.aliyuncs.com',
    'cn-hangzhou-test-306' = 'cs.aliyuncs.com',
    'cn-hongkong-finance-pop' = 'cs.aliyuncs.com',
    'cn-qingdao-nebula' = 'cs.aliyuncs.com',
    'cn-shanghai-et15-b01' = 'cs.aliyuncs.com',
    'cn-shanghai-et2-b01' = 'cs.aliyuncs.com',
    'cn-shanghai-inner' = 'cs.aliyuncs.com',
    'cn-shanghai-internal-test-1' = 'cs.aliyuncs.com',
    'cn-shenzhen-inner' = 'cs.aliyuncs.com',
    'cn-shenzhen-st4-d01' = 'cs.aliyuncs.com',
    'cn-shenzhen-su18-b01' = 'cs.aliyuncs.com',
    'cn-wuhan' = 'cs.aliyuncs.com',
    'cn-yushanfang' = 'cs.aliyuncs.com',
    'cn-zhangbei' = 'cs.aliyuncs.com',
    'cn-zhangbei-na61-b01' = 'cs.aliyuncs.com',
    'cn-zhangjiakou-na62-a01' = 'cs.aliyuncs.com',
    'cn-zhengzhou-nebula-1' = 'cs.aliyuncs.com',
    'eu-west-1-oxs' = 'cs.aliyuncs.com',
    'rus-west-1-pop' = 'cs.aliyuncs.com',
  };

  checkConfig(config);
  @endpoint = getEndpoint('cs', @regionId, @endpointRule, @network, @suffix, @endpointMap, @endpoint);
}

function getEndpoint(productId: string, regionId: string, endpointRule: string, network: string, suffix: string, endpointMap: map[string]string, endpoint: string) throws: string{
  if (!$isNull(endpoint)) {
    return endpoint;
  }
  
  if (!$isNull(endpointMap) && !$isNull(endpointMap[regionId])) {
    return endpointMap[regionId];
  }
  return OpenApiUtil.getEndpointRules(productId, regionId, endpointRule, network, suffix);
}

model DiskInit {
  diskName?: string(name='disk_name', description='This parameter is required.', example='disk0'),
  localDisk?: boolean(name='local_disk'),
  mkfsType?: string(name='mkfs_type', example='ext4'),
  mountForRuntime?: boolean(name='mount_for_runtime'),
  mountTarget?: string(name='mount_target', example='/mnt/disk0'),
}

model Hugepage {
  khugepagedAllocSleepMillisecs?: long(name='khugepagedAllocSleepMillisecs'),
  khugepagedDefrag?: long(name='khugepagedDefrag'),
  khugepagedPagesToScan?: long(name='khugepagedPagesToScan'),
  khugepagedScanSleepMillisecs?: long(name='khugepagedScanSleepMillisecs'),
  transparentDefrag?: string(name='transparentDefrag'),
  transparentEnabled?: string(name='transparentEnabled'),
}

model InstanceMetadataOptions {
  httpTokens?: string(name='http_tokens', description='Configuration of the ECS instance metadata access mode. Valid values:  

* `optional`: Compatible with both NAT mode and hardened mode.  
* `required`: Enables hardened mode only (IMDSv2). After this mode is enabled, applications within edge zones cannot access ECS instance metadata through NAT mode.  

Default Value: `optional`.  

>Notice:   

* This parameter is currently available only to users on the whitelist. To use it, submit a ticket to request access.  
* This parameter is supported only in ACK managed clusters of version 1.28 or later.  

  

> For more information about instance metadata access modes, see [Instance Metadata Access Mode](https://help.aliyun.com/document_detail/108460.html).', example='optional'),
}

model Addon {
  config?: string(name='config', description='The configuration of the component.', example='{\\\\"IngressSlbNetworkType\\\\":\\\\"internet\\\\"}'),
  disabled?: boolean(name='disabled', description='Specifies whether to disable automatic installation. When you create a cluster, some additional log components are automatically installed in addition to the required components. You can disable the automatic installations of a component and install the component later by calling the component API or in the corresponding console. Valid values:

*   `true`: disables the automatic installation of a component.
*   `false`: allows the automatic installation of a component.', example='false'),
  name?: string(name='name', description='The component name.', example='nginx-ingress-controller'),
  version?: string(name='version', description='The version of the component.', example='v1.9.3-aliyun.1'),
}

model ContainerdConfig {
  ignoreImageDefinedVolume?: boolean(name='ignoreImageDefinedVolume', description='Whether to ignore volumes defined in the image.'),
  insecureRegistries?: [ string ](name='insecureRegistries', description='A list of insecure registries that skip TLS certificate verification.'),
  limitCore?: long(name='limitCore', description='Maximum core dump size in bytes.'),
  limitMemLock?: long(name='limitMemLock', description='Maximum locked memory in bytes.'),
  limitNoFile?: long(name='limitNoFile', description='Maximum number of open file handles.'),
  maxConcurrentDownloads?: long(name='maxConcurrentDownloads', description='The maximum number of concurrent image layer downloads.'),
  registryMirrors?: [ string ](name='registryMirrors', description='A list of registry mirrors to accelerate image pulls.'),
}

model DataDisk {
  autoFormat?: boolean(name='auto_format', description='Specifies whether to automatically mount the data disk.', example='true', deprecated=true),
  autoSnapshotPolicyId?: string(name='auto_snapshot_policy_id', description='The ID of the automatic snapshot policy. The system performs automatic backup for a cloud disk based on the specified automatic snapshot policy.

By default, this parameter is empty, which indicates that automatic backup is disabled.', example='sp-2zej1nogjvovnz4z****'),
  burstingEnabled?: boolean(name='bursting_enabled', description='Specifies whether to enable the burst feature for the data disk. Valid values:

*   `true`: enables the burst feature.
*   `false`: disables the burst feature for the data disk.

This parameter is available only if `DiskCategory` is set to `cloud_auto`. For more information, see [ESSD AutoPL disks](https://help.aliyun.com/document_detail/368372.html).', example='true'),
  category?: string(name='category', description='The category of data disk. Valid values:

*   `cloud`: basic disk.
*   `cloud_efficiency`: ultra disk
*   `cloud_ssd`: standard SSD.
*   `cloud_essd`: Enterprise ESSD (ESSD).
*   `cloud_auto`: ESSD AutoPL disk.
*   `cloud_essd_entry`: ESSD Entry disk.
*   `elastic_ephemeral_disk_premium`: premium elastic ephemeral disk.
*   `elastic_ephemeral_disk_standard`: standard elastic ephemeral disk.

Default value: `cloud_efficiency`.', example='cloud_ssd'),
  device?: string(name='device', description='The mount target of the data disk. If you do not specify this parameter, the system automatically assigns a mount target when you create an Elastic Compute Service (ECS) instance. Valid values: /dev/xvdb to /dev/xvdz.', example='/dev/xvdb'),
  diskName?: string(name='disk_name', description='The data disk name. The name must be 2 to 128 characters in length. It must start with a letter and cannot start with http:// or https://. The name can contain letters, digits, colons (:), underscores (_), and hyphens (-).', example='DataDiskName'),
  encrypted?: string(name='encrypted', description='Specifies whether to encrypt the data disk. Valid values:

*   `true`: encrypts the data disk.
*   `false`: does not encrypt the data disk.

Default value: `false`.', example='true'),
  fileSystem?: string(name='file_system', description='The file system that is mounted. This parameter takes effect only if auto_format is set to true. Valid values: ext4 and xfs.', example='ext4', deprecated=true),
  kmsKeyId?: string(name='kms_key_id', description='The ID of the Key Management Service (KMS) key that is used to encrypt the data disk.', example='0e478b7a-4262-4802-b8cb-00d3fb40****'),
  mountTarget?: string(name='mount_target', description='The path to which the data disk is mounted. You must specify a valid path.', example='/mnt/path1', deprecated=true),
  performanceLevel?: string(name='performance_level', description='The performance level (PL) of the data disk. This parameter takes effect only for an ESSD. This parameter is related to the disk size. For more information, see [ESSDs](https://help.aliyun.com/document_detail/122389.html).', example='PL1'),
  provisionedIops?: long(name='provisioned_iops', description='The preset IOPS of the data disk. Valid values: 0 to min{50,000, 1,000 × Capacity - Baseline IOPS}. Baseline IOPS = min{1,800 + 50 × Capacity, 50,000}.

This parameter is available only if `DiskCategory` is set to `cloud_auto`. For more information, see [ESSD AutoPL disks](https://help.aliyun.com/document_detail/368372.html).', example='1000'),
  size?: long(name='size', description='The size of the data disk. Unit: GiB.

Valid values: 40 to 32768.

Default value: `120`.', example='40'),
  snapshotId?: string(name='snapshot_id', description='The ID of the snapshot that you want to use to create the data disk. If this parameter is specified, the specified size of the data disk is ignored. The size of the disk equals the size of the specified snapshot. If the snapshot was created on or before July 15, 2013, the API request is rejected and the InvalidSnapshot.TooOld message is returned.', example='s-280s7****'),
}

model InstancePatterns {
  architectures?: [ string ](name='architectures', description='[This parameter is deprecated and replaced by cpu_architectures] The architectures of instance types.', deprecated=true),
  burstPerformanceOption?: string(name='burst_performance_option', description='[This parameter is deprecated] Specifies whether to include burstable instance types.', example='Exclude', deprecated=true),
  core?: long(name='core', description='[This parameter is deprecated and replaced by cores] The number of vCores provided by the instance type.', example='4', deprecated=true),
  cores?: long(name='cores', description='The number of vCPU cores for the instance type.', example='4'),
  cpuArchitectures?: [ string ](name='cpu_architectures', description='The CPU architecture of the instance type.'),
  excludedInstanceTypes?: [ string ](name='excluded_instance_types', description='The instance type that you want to exclude.'),
  instanceCategories?: [ string ](name='instance_categories', description='The type of the instance.'),
  instanceFamilyLevel?: string(name='instance_family_level', description='The instance family level.', example='EnterpriseLevel'),
  instanceTypeFamilies?: [ string ](name='instance_type_families', description='The specified instance family.'),
  maxCpuCores?: long(name='max_cpu_cores', description='The maximum vCPU cores allowed for the instance type.', example='8'),
  maxMemorySize?: float(name='max_memory_size', description='The maximum allowed memory size. Unit: GiB.', example='16'),
  maxPrice?: float(name='max_price', description='[This parameter is deprecated] The maximum hourly price of the instance.', example='2', deprecated=true),
  maximumGpuAmount?: long(name='maximum_gpu_amount', description='The maximum allowed number of GPUs per instance.', example='8'),
  memory?: float(name='memory', description='The memory size of the instance type. Unit: GiB.', example='8'),
  minCpuCores?: long(name='min_cpu_cores', description='The minimum vCPU cores required for the instance type.', example='4'),
  minMemorySize?: float(name='min_memory_size', description='The minimum required memory size. Unit: GiB.', example='8'),
  minimumEniIpv6AddressQuantity?: long(name='minimum_eni_ipv6_address_quantity', description='The minimum required number of IPv6 addresses per ENI.', example='1'),
  minimumEniPrivateIpAddressQuantity?: long(name='minimum_eni_private_ip_address_quantity', description='The minimum required number of IPv4 addresses per ENI.', example='10'),
  minimumEniQuantity?: long(name='minimum_eni_quantity', description='The minimum required number of elastic network interfaces (ENIs) per instance.', example='3'),
}

model KubeletConfig {
  allowedUnsafeSysctls?: [ string ](name='allowedUnsafeSysctls', description='The whitelisted unsafe sysctls.'),
  clusterDNS?: [ string ](name='clusterDNS', description='The list of IP addresses of the DNS servers.'),
  containerLogMaxFiles?: long(name='containerLogMaxFiles', description='The maximum number of log files that can be stored in each container.', example='5'),
  containerLogMaxSize?: string(name='containerLogMaxSize', description='The maximum size that a log file can reach before it is rotated.', example='10Mi'),
  containerLogMaxWorkers?: int32(name='containerLogMaxWorkers', description='The maximum number of concurrent programs that rotate logs', example='1'),
  containerLogMonitorInterval?: string(name='containerLogMonitorInterval', description='The duration at which the container logs are monitored for rotating logs.', example='10s'),
  cpuCFSQuota?: boolean(name='cpuCFSQuota', description='Specifies whether to use Completely Fair Scheduler (CFS) quota to enforce pod CPU limits.', example='true'),
  cpuCFSQuotaPeriod?: string(name='cpuCFSQuotaPeriod', description='The duration for the CPU CFS quota.', example='100ms'),
  cpuManagerPolicy?: string(name='cpuManagerPolicy', description='The CPU management policy used by kubelet.', example='none'),
  eventBurst?: long(name='eventBurst', description='The maximum number of burst peaks for the event records.', example='10'),
  eventRecordQPS?: long(name='eventRecordQPS', description='Specifies the maximum number of events that can be generated per second.', example='5'),
  evictionHard?: map[string]any(name='evictionHard', description='A set of eviction thresholds that will trigger a pod eviction if met.'),
  evictionSoft?: map[string]any(name='evictionSoft', description='A set of eviction thresholds that will trigger a pod eviction if met over a corresponding grace period.'),
  evictionSoftGracePeriod?: map[string]any(name='evictionSoftGracePeriod', description='A set of grace periods for eviction thresholds.'),
  featureGates?: map[string]any(name='featureGates', description='A feature gate that is used to enable an experimental feature.'),
  imageGCHighThresholdPercent?: int32(name='imageGCHighThresholdPercent', description='The percentage of disk usage after which image garbage collection always runs.', example='85'),
  imageGCLowThresholdPercent?: int32(name='imageGCLowThresholdPercent', description='The percentage of disk usage before which image garbage collection never runs.', example='80'),
  kubeAPIBurst?: long(name='kubeAPIBurst', description='The maximum number of burst requests sent to the API server per second.', example='10'),
  kubeAPIQPS?: long(name='kubeAPIQPS', description='The QPS when kubelet communicates with the Kubernetes API server.', example='5'),
  kubeReserved?: map[string]any(name='kubeReserved', description='A set of configurations that specify resources reserved for the Kubernetes system.'),
  maxPods?: long(name='maxPods', description='The maximum number of running pods.', example='110'),
  memoryManagerPolicy?: string(name='memoryManagerPolicy', description='The name of the policy to be used by the memory manager.', example='none'),
  podPidsLimit?: long(name='podPidsLimit', description='The maximum number of processes per pod.', example='-1'),
  readOnlyPort?: long(name='readOnlyPort', description='The read-only port.', example='0'),
  registryBurst?: long(name='registryBurst', description='The maximum number of images that can be pulled from bursty image pulls.', example='10'),
  registryPullQPS?: long(name='registryPullQPS', description='The maximum queries per second (QPS) of the image repository.', example='5'),
  reservedMemory?: [ 
    {
      limits?: map[string]any(name='limits', description='The memory limit.', example='{"memory": "1Gi"}'),
      numaNode?: int32(name='numaNode', description='The NUMA node identifier.', example='0'),
    }
  ](name='reservedMemory', description='A list of configurations that specify memory reservations for non-uniform memory access (NUMA) nodes.'),
  serializeImagePulls?: boolean(name='serializeImagePulls', description='Specifies whether to pull one image at a time.', example='true'),
  serverTLSBootstrap?: boolean(name='serverTLSBootstrap', description='启用 kubelet 服务端证书的自动签发与轮换功能。启用时，需同时在 kubelet 的 featureGates 中配置 "RotateKubeletServerCertificate": true

> - 仅 1.30 及以上版本的集群可用。
> - 1.30 至 v1.33 版本的集群需提交工单申请。', example='true'),
  systemReserved?: map[string]any(name='systemReserved', description='A set of configurations that specify reserved resources for the system.'),
  topologyManagerPolicy?: string(name='topologyManagerPolicy', description='The name of the Topology Manager policy that you want to use.', example='restricted'),
  tracing?: {
    endpoint?: string(name='endpoint', description='The endpoint of the collector.', example='localhost:4317'),
    samplingRatePerMillion?: int32(name='samplingRatePerMillion', description='The number of samples to be collected per million spans.', example='200000'),
  }(name='tracing', description='The versioned configuration information for the Managed Service for OpenTelemetry client.'),
}

model MaintenanceWindow {
  duration?: string(name='duration', description='The duration of the cluster maintenance window. 

Valid values: 1 to 24. 

Unit: hours.

Default value: 3.', example='3h'),
  enable?: boolean(name='enable', description='Specifies whether to enable the cluster maintenance window. Valid values:

*   `true`: enables the cluster maintenance window.
*   `false`: disables the cluster maintenance window.

Default value: `false`.', example='false'),
  maintenanceTime?: string(name='maintenance_time', description='The start time of the cluster maintenance window. The value follows a standard time format in Golang. Example: 15:04:05Z.', example='2020-10-15T12:31:00.000+08:00'),
  recurrence?: string(name='recurrence', description='Defines a maintenance window recurrence rule by using the RFC5545 recurrence rule. Currently, only FREQ=WEEKLY is supported, and you cannot specify COUNT or UNTIL.', example='FREQ=WEEKLY;INTERVAL=4;BYDAY=MO,TU'),
  weeklyPeriod?: string(name='weekly_period', description='The day of the week when maintenance is performed. Separate multiple days with commas (,). 

Valid values: Monday, Tuesday, Wednesday, Thursday, Friday, Saturday, and Sunday.

Default value: `Thursday`.', example='Monday,Thursday'),
}

model Nodepool {
  autoScaling?: {
    eipBandwidth?: long(name='eip_bandwidth', description='This parameter is deprecated.

The peak bandwidth of the EIP. Unit: Mbit/s.', example='5', deprecated=true),
    eipInternetChargeType?: string(name='eip_internet_charge_type', description='This parameter is deprecated.

The billing method of the EIP. Valid values:

- `PayByBandwidth`: Pay-by-bandwidth.

- `PayByTraffic`: Pay-by-traffic.

Default value: PayByBandwidth.', example='PayByBandwidth', deprecated=true),
    enable?: boolean(name='enable', description='Specifies whether to enable auto-scaling.

- `true`: Enables auto-scaling for the node pool.

- `false`: Disables auto-scaling. If you set this parameter to false, other parameters in the `auto_scaling` object do not take effect.

Default value: `false`.

This parameter is required.', example='true'),
    isBondEip?: boolean(name='is_bond_eip', description='This parameter is deprecated.

Specifies whether to associate an EIP. Valid values:

- `true`: Associates an EIP.

- `false`: Does not associate an EIP.

Default value: `false`.', example='true', deprecated=true),
    maxInstances?: long(name='max_instances', description='The maximum number of instances in the scaling group.

This parameter is required.', example='10'),
    minInstances?: long(name='min_instances', description='The minimum number of instances in the scaling group.

This parameter is required.', example='0'),
    type?: string(name='type', description='The type of auto-scaling, which is determined by the instance type. Valid values:

- `cpu`: Standard instances.

- `gpu`: GPU-accelerated instances.

- `gpushare`: Shared GPU instances.

- `spot`: Spot instances.

Default value: `cpu`.', example='cpu'),
  }(name='auto_scaling', description='The auto-scaling configurations for the node pool.'),
  count?: long(name='count', description='This parameter is deprecated. Use desired_size instead.

The number of nodes in the node pool.', example='1', deprecated=true),
  interconnectConfig?: {
    bandwidth?: long(name='bandwidth', description='This parameter is deprecated.

The network bandwidth of the enhanced edge node pool. Unit: Mbit/s.', example='10', deprecated=true),
    ccnId?: string(name='ccn_id', description='This parameter is deprecated.

The CCN instance ID (CCNID) bound to the enhanced edge node pool.', example='ccn-qm5i0i0q9yi*******', deprecated=true),
    ccnRegionId?: string(name='ccn_region_id', description='This parameter is deprecated.

The region where the CCN instance bound to the enhanced edge node pool is located.', example='cn-shanghai', deprecated=true),
    cenId?: string(name='cen_id', description='This parameter is deprecated.

The CEN instance ID (CENID) bound to the enhanced edge node pool.', example='cen-ey9k9nfhz0f*******', deprecated=true),
    improvedPeriod?: string(name='improved_period', description='This parameter is deprecated.

The subscription duration of the enhanced edge node pool. Unit: month.', example='1', deprecated=true),
  }(name='interconnect_config', description='This parameter is deprecated.

The edge node pool configurations.', deprecated=true),
  interconnectMode?: string(name='interconnect_mode', description='The network type of the edge node pool. This parameter is only meaningful for node pools of type `edge`. Valid values:

- `basic`: Basic.

- `private`: Private. Supported in versions 1.22 and later.', example='basic'),
  kubernetesConfig?: {
    cmsEnabled?: boolean(name='cms_enabled', description='Specifies whether to install Cloud Monitor on ECS nodes. After installation, you can view monitoring information about the created ECS instances in the Cloud Monitor console. We recommend that you enable this feature. Valid values:

- `true`: Installs Cloud Monitor on ECS nodes.

- `false`: Does not install Cloud Monitor on ECS nodes.

Default value: `false`.', example='true'),
    cpuPolicy?: string(name='cpu_policy', description='The CPU management policy for the node. The following policies are supported for clusters of Kubernetes v1.12.6 or later:

- `static`: Allows pods with specific resource characteristics on the node to be granted enhanced CPU affinity and exclusivity.

- `none`: Indicates that the existing default CPU affinity scheme is enabled.

Default value: `none`.', example='none'),
    labels?: [
      Tag
    ](name='labels', description='The node labels. Adds labels to the nodes of the Kubernetes cluster.'),
    nodeNameMode?: string(name='node_name_mode', description='The node name consists of three parts: a prefix, the node IP address, and a suffix.

- The prefix and suffix can each consist of one or more parts separated by periods (.). Each part can contain lowercase letters, digits, and hyphens (-). The node name must start and end with a lowercase letter or a digit.

- The node IP address is the complete private IP address of the node.

The parameter consists of four parts separated by commas. For example, if you pass the string "customized,aliyun,ip,com", the node name is aliyun.192.168.xxx.xxx.com. In this example, "customized" and "ip" are fixed strings, "aliyun" is the prefix, and "com" is the suffix.', example='customized,aliyun,ip,com'),
    runtime?: string(name='runtime', description='The container runtime. Valid values:

- `containerd`: Recommended. This option is supported for all cluster versions.

- `Sandboxed-Container.runv`: A sandboxed container that provides higher isolation. This option is supported for clusters of Kubernetes v1.24 or earlier.

- `docker`: This option is supported for clusters of Kubernetes v1.22 or earlier.

Default value: `containerd`

This parameter is required.', example='containerd'),
    runtimeVersion?: string(name='runtime_version', description='The container runtime version.

This parameter is required.', example='1.6.20'),
    taints?: [
      Taint
    ](name='taints', description='The taint configurations.'),
    userData?: string(name='user_data', description='The custom data of the node.', example='MXM='),
  }(name='kubernetes_config', description='The cluster configurations.'),
  management?: {
    autoFaultDiagnosis?: boolean(name='auto_fault_diagnosis'),
    autoRepair?: boolean(name='auto_repair', description='Auto repair. This takes effect only when `enable=true`.

- `true`: Enables auto repair.

- `false`: Disables auto repair.', example='false'),
    autoRepairPolicy?: {
      restartNode?: boolean(name='restart_node', description='Specifies whether to allow restarting nodes.', example='true'),
    }(name='auto_repair_policy', description='The auto-repair policy for nodes.'),
    autoUpgrade?: boolean(name='auto_upgrade', description='Specifies whether to enable auto-upgrade.', example='true'),
    autoUpgradePolicy?: {
      autoUpgradeKubelet?: boolean(name='auto_upgrade_kubelet', description='Specifies whether to allow auto-upgrading the kubelet.', example='true'),
    }(name='auto_upgrade_policy', description='The auto-upgrade policy.'),
    autoVulFix?: boolean(name='auto_vul_fix', description='Specifies whether to automatically fix CVEs.', example='true'),
    autoVulFixPolicy?: {
      restartNode?: boolean(name='restart_node', description='Specifies whether to allow restarting nodes.', example='true'),
      vulLevel?: string(name='vul_level', description='The vulnerability levels that are allowed to be automatically fixed, separated by commas.', example='asap,nntf'),
    }(name='auto_vul_fix_policy', description='The auto-fix policy for CVEs.'),
    enable?: boolean(name='enable', description='Specifies whether to enable the managed node pool. Valid values:

- `true`: Enables the managed node pool.

- `false`: Disables the managed node pool. Other related configurations take effect only when `enable=true`.', example='false'),
    upgradeConfig?: {
      autoUpgrade?: boolean(name='auto_upgrade', description='Specifies whether to enable auto-upgrade. Valid values:

- `true`: Enables auto-upgrade.

- `false`: Disables auto-upgrade.', example='false'),
      maxUnavailable?: long(name='max_unavailable', description='The maximum number of unavailable nodes. Value range: [1, 1000].

Default value: 1.', example='0'),
      surge?: long(name='surge', description='The number of extra nodes.', example='0'),
      surgePercentage?: long(name='surge_percentage', description='The percentage of extra nodes. You must specify this parameter or `surge`.', example='0'),
    }(name='upgrade_config', description='The auto-upgrade configurations. This takes effect only when `enable=true`.', deprecated=true),
  }(name='management', description='The managed node pool configurations.'),
  maxNodes?: long(name='max_nodes', description='The maximum number of nodes that the edge node pool can contain. This parameter must be greater than or equal to 0. A value of 0 indicates no extra limit (limited only by the total number of nodes the cluster can accommodate, with no additional limit on the node pool itself). The value of this parameter for an edge node pool is often greater than 0. For ess type node pools and default edge type node pools, this parameter is 0.', example='10'),
  nodeComponents?: [ 
    {
      config?: {
        customConfig?: map[string]string(name='custom_config', description='The custom configuration of the node component.'),
      }(name='config', description='The configuration of the node component.'),
      name?: string(name='name', description='The name of the node component.', example='kubelet'),
      version?: string(name='version', description='The version of the node component.', example='1.33.3-aliyun.1'),
    }
  ](name='node_components', description='The list of node components.'),
  nodeConfig?: {
    kubeletConfiguration?: KubeletConfig(name='kubelet_configuration', description='The Kubelet parameter settings.'),
  }(name='node_config', description='The node configurations.'),
  nodepoolInfo?: {
