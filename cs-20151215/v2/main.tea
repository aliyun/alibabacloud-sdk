import OpenApi;
import OpenApi.OpenApiUtil;

extends OpenApi;


init(config: OpenApiUtil.Config){
  super(config);
  @endpointRule = 'regional';
  @endpointMap = {
    'ap-northeast-2-pop' = 'cs.aliyuncs.com',
    'cn-beijing-finance-pop' = 'cs.aliyuncs.com',
