                      itemName?: string(name='ItemName', example='Dangerous Tools Without Confirmation'),
                      line?: string(name='Line', example='2555'),
                    }
                  ](name='Detail'),
                }(name='Config'),
                guardrail?: {
                  detail?: [ 
                    {
                      level?: string(name='Level', example='high'),
                      result?: [ 
                        {
                          confidence?: float(name='Confidence', example='25'),
