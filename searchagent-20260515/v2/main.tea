model ExecuteAcpCommandRequest {
  agentName?: string(name='agentName'),
  id?: string(name='id'),
  jsonrpc?: string(name='jsonrpc'),
  method?: string(name='method'),
  params?: map[string]any(name='params'),
}

model ExecuteAcpCommandResponseBody = {
  code?: string(name='code'),
  data?: {
    id?: string(name='id'),
    jsonrpc?: string(name='jsonrpc'),
    requestId?: string(name='requestId'),
    result?: map[string]any(name='result'),
    timestamp?: long(name='timestamp'),
  }(name='data'),
  message?: string(name='message'),
  requestId?: string(name='requestId'),
}

model ExecuteAcpCommandResponse = {
  headers?: map[string]string(name='headers'),
  statusCode?: int32(name='statusCode'),
  body?: ExecuteAcpCommandResponseBody(name='body'),
}

/**
 * @summary search agent acp 接口
 *
 * @param request ExecuteAcpCommandRequest
 * @param headers map
 * @param runtime runtime options for this request RuntimeOptions
 * @return ExecuteAcpCommandResponse
 */
@context("executeAcpCommandWithContext")
async function executeAcpCommandWithOptions(workspaceName: string, request: ExecuteAcpCommandRequest, headers: map[string]string, runtime: $RuntimeOptions): ExecuteAcpCommandResponse {
  request.validate();
  var body : map[string]any = {};
  if (!$isNull(request.agentName)) {
    body['agentName'] = request.agentName;
  }
  if (!$isNull(request.id)) {
    body['id'] = request.id;
  }
  if (!$isNull(request.jsonrpc)) {
    body['jsonrpc'] = request.jsonrpc;
  }
  if (!$isNull(request.method)) {
    body['method'] = request.method;
  }
  if (!$isNull(request.params)) {
    body['params'] = request.params;
  }

  var req = new OpenApiUtil.OpenApiRequest{ 
    headers = headers,
    body = OpenApiUtil.parseToMap(body),
  };
  var params = new OpenApiUtil.Params{
    action = 'ExecuteAcpCommand',
    version = '2026-05-15',
    protocol = 'HTTPS',
    pathname = `/v3/openapi/workspaces/${workspaceName}/agent/acp`,
    method = 'POST',
    authType = 'AK',
    style = 'ROA',
    reqBodyType = 'json',
    bodyType = 'json',
  };
  return execute(params, req, runtime);
}

/**
 * @summary search agent acp 接口
 *
 * @param request ExecuteAcpCommandRequest
 * @return ExecuteAcpCommandResponse
 */
async function executeAcpCommand(workspaceName: string, request: ExecuteAcpCommandRequest): ExecuteAcpCommandResponse {
  var runtime = new $RuntimeOptions{};
  var headers : map[string]string = {};
  return executeAcpCommandWithOptions(workspaceName, request, headers, runtime);
}

model GenerateAcpCompletionRequest {
