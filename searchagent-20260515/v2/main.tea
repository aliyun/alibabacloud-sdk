/**
 * @summary 生成 acp stream
 *
 * @param request GenerateAcpCompletionRequest
 * @param headers map
 * @param runtime runtime options for this request RuntimeOptions
 * @return GenerateAcpCompletionResponse
 */
@sse(true)
@context("generateAcpCompletionWithSSECtx")
async function generateAcpCompletionWithSSE(workspaceName: string, request: GenerateAcpCompletionRequest, headers: map[string]string, runtime: $RuntimeOptions): asyncIterator[GenerateAcpCompletionResponse] {
  request.validate();
  var body : map[string]any = {};
  if (!$isNull(request.agentName)) {
    body['agentName'] = request.agentName;
  }
  if (!$isNull(request.id)) {
    body['id'] = request.id;
  }
  if (!$isNull(request.jsonrpc)) {
    body['jsonrpc'] = request.jsonrpc;
  }
  if (!$isNull(request.method)) {
    body['method'] = request.method;
  }
  if (!$isNull(request.params)) {
    body['params'] = request.params;
  }

  var req = new OpenApiUtil.OpenApiRequest{ 
    headers = headers,
    body = OpenApiUtil.parseToMap(body),
  };
  var params = new OpenApiUtil.Params{
    action = 'GenerateAcpCompletion',
    version = '2026-05-15',
    protocol = 'HTTPS',
    pathname = `/v3/openapi/workspaces/${workspaceName}/agent/acp`,
    method = 'POST',
    authType = 'AK',
    style = 'ROA',
    reqBodyType = 'json',
    bodyType = 'string',
  };
  var sseResp = callSSEApi(params, req, runtime);
  for (var resp : sseResp) {
    if (!$isNull(resp.event) && !$isNull(resp.event.data)) {
      var data = resp.event.data;
      yield {
        statusCode = resp.statusCode,
        headers = resp.headers,
        id = resp.event.id,
        event = resp.event.event,
        body = data
      };
    }
  }
}
