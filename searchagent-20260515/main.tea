import Util;
import GatewayClient;
import OpenApi;
import OpenApiUtil;

extends OpenApi;


init(config: OpenApi.Config){
  super(config);
  @productId = 'SearchAgent';
  var gatewayClient = new GatewayClient();
  @spi = gatewayClient;
  @endpointRule = '';
  }

model ExecuteAcpCommandRequest {
  agentName?: string(name='agentName'),
  id?: string(name='id'),
  jsonrpc?: string(name='jsonrpc'),
  method?: string(name='method'),
  params?: map[string]any(name='params'),
}

model ExecuteAcpCommandResponseBody = {
  code?: string(name='code'),
  data?: {
    id?: string(name='id'),
    jsonrpc?: string(name='jsonrpc'),
    requestId?: string(name='requestId'),
    result?: map[string]any(name='result'),
    timestamp?: long(name='timestamp'),
  }(name='data'),
  message?: string(name='message'),
  requestId?: string(name='requestId'),
}

model ExecuteAcpCommandResponse = {
  headers?: map[string]string(name='headers'),
  statusCode?: int32(name='statusCode'),
  body?: ExecuteAcpCommandResponseBody(name='body'),
}

/**
 * @summary search agent acp 接口
 *
 * @param request ExecuteAcpCommandRequest
 * @param headers map
 * @param runtime runtime options for this request RuntimeOptions
 * @return ExecuteAcpCommandResponse
 */
async function executeAcpCommandWithOptions(workspaceName: string, request: ExecuteAcpCommandRequest, headers: map[string]string, runtime: Util.RuntimeOptions): ExecuteAcpCommandResponse {
  Util.validateModel(request);
  var body : map[string]any = {};
  if (!Util.isUnset(request.agentName)) {
    body['agentName'] = request.agentName;
  }
  if (!Util.isUnset(request.id)) {
    body['id'] = request.id;
  }
  if (!Util.isUnset(request.jsonrpc)) {
    body['jsonrpc'] = request.jsonrpc;
  }
  if (!Util.isUnset(request.method)) {
    body['method'] = request.method;
  }
  if (!Util.isUnset(request.params)) {
    body['params'] = request.params;
  }

  var req = new OpenApi.OpenApiRequest{ 
    headers = headers,
    body = OpenApiUtil.parseToMap(body),
  };
  var params = new OpenApi.Params{
    action = 'ExecuteAcpCommand',
    version = '2026-05-15',
    protocol = 'HTTPS',
    pathname = `/v3/openapi/workspaces/${workspaceName}/agent/acp`,
    method = 'POST',
    authType = 'AK',
    style = 'ROA',
    reqBodyType = 'json',
    bodyType = 'json',
  };
  return execute(params, req, runtime);
}

/**
 * @summary search agent acp 接口
 *
 * @param request ExecuteAcpCommandRequest
 * @return ExecuteAcpCommandResponse
 */
async function executeAcpCommand(workspaceName: string, request: ExecuteAcpCommandRequest): ExecuteAcpCommandResponse {
  var runtime = new Util.RuntimeOptions{};
  var headers : map[string]string = {};
  return executeAcpCommandWithOptions(workspaceName, request, headers, runtime);
}

model GenerateAcpCompletionRequest {
  agentName?: string(name='agentName'),
  id?: string(name='id'),
  jsonrpc?: string(name='jsonrpc'),
  method?: string(name='method'),
  params?: map[string]any(name='params'),
}

model GenerateAcpCompletionResponse = {
  headers?: map[string]string(name='headers'),
  statusCode?: int32(name='statusCode'),
  body?: string(name='body'),
}

/**
 * @summary 生成 acp stream
 *
 * @param request GenerateAcpCompletionRequest
 * @param headers map
 * @param runtime runtime options for this request RuntimeOptions
 * @return GenerateAcpCompletionResponse
 */
async function generateAcpCompletionWithOptions(workspaceName: string, request: GenerateAcpCompletionRequest, headers: map[string]string, runtime: Util.RuntimeOptions): GenerateAcpCompletionResponse {
  Util.validateModel(request);
  var body : map[string]any = {};
  if (!Util.isUnset(request.agentName)) {
    body['agentName'] = request.agentName;
  }
  if (!Util.isUnset(request.id)) {
    body['id'] = request.id;
  }
  if (!Util.isUnset(request.jsonrpc)) {
    body['jsonrpc'] = request.jsonrpc;
  }
  if (!Util.isUnset(request.method)) {
    body['method'] = request.method;
  }
  if (!Util.isUnset(request.params)) {
    body['params'] = request.params;
  }

  var req = new OpenApi.OpenApiRequest{ 
    headers = headers,
    body = OpenApiUtil.parseToMap(body),
  };
  var params = new OpenApi.Params{
    action = 'GenerateAcpCompletion',
    version = '2026-05-15',
    protocol = 'SSE',
    pathname = `/v3/openapi/workspaces/${workspaceName}/agent/acp`,
    method = 'POST',
    authType = 'AK',
    style = 'ROA',
    reqBodyType = 'json',
    bodyType = 'string',
  };
  return execute(params, req, runtime);
}

/**
 * @summary 生成 acp stream
 *
 * @param request GenerateAcpCompletionRequest
 * @return GenerateAcpCompletionResponse
 */
async function generateAcpCompletion(workspaceName: string, request: GenerateAcpCompletionRequest): GenerateAcpCompletionResponse {
  var runtime = new Util.RuntimeOptions{};
