      dataProcessingOptionsCountry?: long(name='DataProcessingOptionsCountry', description='Required if you send LDU under data_processing_options.
The country you want to associate with this data processing option. Currently accepted values are 1 (representing the United States) or 0 (requesting that we geolocate this event).', example='100'),
      dataProcessingOptionsState?: long(name='DataProcessingOptionsState', description='Required in some cases. (See the notes below for details.)
The state you want to associate with this data processing option. Currently accepted values are 1000 (representing California) or 0 (requesting that we geolocate this event).', example='26'),
