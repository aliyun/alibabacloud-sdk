model CreateChatappTemplateRequest {
  allowCategoryChange?: boolean(name='AllowCategoryChange', description='Indicates whether to allow Facebook to automatically change the category of the template. This can increase the approval rate of the template. This parameter is valid only when TemplateType is set to WHATSAPP.
>Notice: This property is deprecated. WhatsApp no longer supports this property.', example='true', deprecated=true),
  category?: string(name='Category', description='WhatsApp template categories:

- **UTILITY**: Transactional.

- **MARKETING**: Marketing.

- **AUTHENTICATION**: Authentication.

Viber template categories:

- **UTILITY**: Transactional.

- **MARKETING**: Marketing.

- **AUTHENTICATION**: Authentication.

This parameter is required.', example='UTILITY'),
  categoryChangePaused?: boolean(name='CategoryChangePaused'),
  components?: [ 
    {
      addSecretRecommendation?: boolean(name='AddSecretRecommendation', description='This parameter is valid for WhatsApp templates when Category is set to AUTHENTICATION and the component type is Body. It indicates that a security recommendation is displayed above the body, advising the user not to share the verification code.', example='true'),
      buttons?: [ 
        {
          autofillText?: string(name='AutofillText', description='This parameter is required for WhatsApp templates when Category is set to AUTHENTICATION and the button type is ONE_TAP or ZERO_TAP. It specifies the button text for the WhatsApp autofill action.', example='Autofill'),
          couponCode?: string(name='CouponCode', description='The value of the coupon code. It supports only letters and digits. You can pass a variable such as $(couponCode) and then pass the actual coupon code when sending the message.', example='120293'),
          flowAction?: string(name='FlowAction', description='The flow data event type. Valid values:

- DATA_EXCHANGE: Data exchange.

- NAVIGATE: Navigation.', example='NAVIGATE'),
          flowId?: string(name='FlowId', description='The flow ID.', example='479884093605****'),
          isOptOut?: boolean(name='IsOptOut', description='This parameter is valid for WhatsApp templates when Category is set to Marketing and the button type is QUICK_REPLY. It indicates that the button is a marketing opt-out button. If a customer clicks this button and you have configured sending control operations in ChatApp, subsequent marketing messages will not be sent to the customer.', example='false'),
          navigateScreen?: string(name='NavigateScreen', description='The screen to navigate to. This parameter is required when FlowAction is set to NAVIGATE.', example='DETAILS'),
          packageName?: string(name='PackageName', description='Use the properties under SupportedApps.', example='com.demo', deprecated=true),
          phoneNumber?: string(name='PhoneNumber', description='The phone number. This parameter is valid only when the button type is **PHONE_NUMBER**.', example='+861368897****'),
          signatureHash?: string(name='SignatureHash', description='Use the properties under SupportedApps.', example='wi299382', deprecated=true),
          supportedApps?: [ 
            {
              packageName?: string(name='PackageName', description='This parameter is required for WhatsApp templates when Category is set to AUTHENTICATION and the button type is ONE_TAP or ZERO_TAP. It specifies the package name of the app that WhatsApp will launch.', example='com.kuaidian.waimaistaff'),
              signatureHash?: string(name='SignatureHash', description='This parameter is required for WhatsApp templates when Category is set to AUTHENTICATION and the button type is ONE_TAP or ZERO_TAP. It specifies the signature hash of the app that WhatsApp will launch.', example='ieid83kdiek'),
            }
          ](name='SupportedApps', description='The list of supported apps.'),
          text?: string(name='Text', description='The name displayed on the button.', example='Call Me'),
          type?: string(name='Type', description='The button type.

- **PHONE_NUMBER**: A call button.

- **URL**: A URL button.

- **QUICK_REPLY**: A quick reply button.

- **COPY_CODE**: A button to copy a verification code or coupon code.

- **ONE_TAP**: An autofill button for AUTHENTICATION templates.

- **ZERO_TAP**: An autofill button for AUTHENTICATION templates.

- **MPM**: A multi-product message.

- **CATALOG**: A catalog.

- **FLOW**: Opens a WhatsApp flow.

