model CreateChatRequest {
  sessionId: string(name='SessionId', description='This parameter is required.', example='se-982******q0j9f', position='Path'),
  extraData?: string(name='ExtraData', example='{"solutionDetail":{"formValues":{"params":{"InstanceId":"dsw-g54******qg9"},"content":{"EcsSpec":"ecs.gn6i-c8g1.2xlarge"}},"success":true}}', position='Body'),
  payload?: map[string]any(name='Payload', position='Body'),
  question?: ChatDetail(name='Question', position='Body'),
  title?: string(name='Title', position='Body'),
}

model CreateChatResponseBody = {
  answer?: ChatDetail(name='Answer'),
  chatId?: string(name='ChatId', example='chat-jkd******'),
  errorCode?: string(name='ErrorCode', example='2187322'),
  errorMessage?: string(name='ErrorMessage', example='Stream error'),
  gmtCreateTime?: string(name='GmtCreateTime', description='Use the UTC time format: yyyy-MM-ddTHH:mm:ssZ', example='2021-01-21T17:12:35Z'),
  requestId?: string(name='RequestId', example='44553E9A-******-37ADC33FE2'),
  sessionId?: string(name='SessionId', example='se-dss******'),
  status?: string(name='Status', example='Running'),
}

model CreateChatResponse = {
  headers?: map[string]string(name='headers'),
  statusCode?: int32(name='statusCode'),
  body?: CreateChatResponseBody(name='body'),
}

/**
  * @param request  the request parameters of CreateChat  CreateChatRequest
  * @return CreateChatResponse
 */
async function createChat(request: CreateChatRequest): CreateChatResponse {
  @handler.validateRequestModel(request);
  return @handler.do('RESTFUL', 'CreateChat', 'POST', '/api/v1/sessions/{SessionId}/chats', 'json', false, 'json', request);
}

function createChatWithResponseIterable(request: CreateChatRequest): iterator[CreateChatResponseBody] {
  @handler.validateRequestModel(request);
  yield @handler.doSSERequest('SSE', 'CreateChat', 'POST', '/api/v1/sessions/{SessionId}/chats', 'json', false, 'json', request);
}

