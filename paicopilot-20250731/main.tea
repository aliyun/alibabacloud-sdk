import Util;
import OpenApi;
import OpenApiUtil;
import EndpointUtil;

extends OpenApi;


init(config: OpenApi.Config){
  super(config);
  @endpointRule = '';
  
  checkConfig(config);
  @endpoint = getEndpoint('paicopilot', @regionId, @endpointRule, @network, @suffix, @endpointMap, @endpoint);
}

function getEndpoint(productId: string, regionId: string, endpointRule: string, network: string, suffix: string, endpointMap: map[string]string, endpoint: string) throws: string{
  if (!Util.empty(endpoint)) {
    return endpoint;
  }
  
  if (!Util.isUnset(endpointMap) && !Util.empty(endpointMap[regionId])) {
    return endpointMap[regionId];
  }
  return EndpointUtil.getEndpointRules(productId, regionId, endpointRule, network, suffix);
}

model Chat {
  answer?: ChatDetail(name='Answer'),
  chatId?: string(name='ChatId', example='chat-jkd******'),
  extraData?: string(name='ExtraData', example='{"solutionDetail":{"formValues":{"params":{"InstanceId":"dsw-g54******qg9"},"content":{"EcsSpec":"ecs.gn6i-c8g1.2xlarge"}},"success":true}}'),
  gmtCreateTime?: string(name='GmtCreateTime', description='Use the UTC time format: yyyy-MM-ddTHH:mm:ss.SSSZ', example='2021-01-21T17:12:35Z'),
  gmtModified?: string(name='GmtModified', description='Use the UTC time format: yyyy-MM-ddTHH:mm:ss.SSSZ', example='2026-01-20T09:41:23Z'),
  message?: string(name='Message', example='how to ******'),
  ownerId?: string(name='OwnerId', example='1500******860'),
  question?: ChatDetail(name='Question'),
  sessionId?: string(name='SessionId', example='se-dss******'),
  status?: string(name='Status', example='Running'),
  title?: string(name='Title', example='how to ******'),
  userId?: string(name='UserId', example='2100******360'),
}

model ChatDetail {
  content?: string(name='Content'),
  gmtCreateTime?: string(name='GmtCreateTime', description='Use the UTC time format: yyyy-MM-ddTHH:mm:ss.SSSZ', example='2021-01-21T17:12:35Z'),
  userInfo?: {
    name?: string(name='Name', example='to******'),
    role?: string(name='Role', example='assistant'),
  }(name='UserInfo'),
}

model Feedback {
  chatId?: string(name='ChatId'),
  feedbackAction?: string(name='FeedbackAction'),
  feedbackId?: string(name='FeedbackId'),
