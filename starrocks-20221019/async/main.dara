  storagePerformanceLevel?: string(name='storagePerformanceLevel'),
  storageSize?: int32(name='storageSize'),
}

model AddBackupPolicyRequest {
  regionId?: string(name='RegionId', position='Host'),
  expireDays?: int32(name='ExpireDays', example='7', position='Body'),
  hour?: int32(name='Hour', example='2', minimum=0, maximum=23, position='Body'),
  instanceId?: string(name='InstanceId', example='c-0104730e9de40215', position='Body'),
  minute?: int32(name='Minute', example='30', minimum=0, maximum=59, position='Body'),
  recurrenceType?: string(name='RecurrenceType', example='MONTHLY', position='Body'),
  recurrenceValues?: [ int32 ](name='RecurrenceValues', position='Body'),
  timeoutSeconds?: int32(name='TimeoutSeconds', example='3600', position='Body'),
}

model AddBackupPolicyResponseBody = {
  accessDeniedDetail?: string(name='AccessDeniedDetail', description='AccessDeniedDetail', example='{     "PolicyType": "AccountLevelIdentityBasedPolicy",     "AuthPrincipalOwnerId": "xxx",     "EncodedDiagnosticMessage": "xxx",     "AuthPrincipalType": "xxx",     "AuthPrincipalDisplayName": "xxx",     "NoPermissionType": "ImplicitDeny",     "AuthAction": "sr:xxx"   }'),
  data?: boolean(name='Data', example='true'),
  errCode?: string(name='ErrCode', example='InvalidParams'),
  errMessage?: string(name='ErrMessage', example='Invalid params: [Region id should be select from set [cn-beijing, cn-hangzhou]]'),
  httpStatusCode?: int32(name='HttpStatusCode', example='200'),
  requestId?: string(name='RequestId', example='32A44F0D-BFF6-5664-999A-218BBDE7****'),
  success?: boolean(name='Success', example='false'),
}

model AddBackupPolicyResponse = {
  headers?: map[string]string(name='headers'),
  statusCode?: int32(name='statusCode'),
  body?: AddBackupPolicyResponseBody(name='body'),
}

/**
  * @param request  the request parameters of AddBackupPolicy  AddBackupPolicyRequest
  * @return AddBackupPolicyResponse
 */
async function addBackupPolicy(request: AddBackupPolicyRequest): AddBackupPolicyResponse {
  @handler.validateRequestModel(request);
  return @handler.do('RESTFUL', 'AddBackupPolicy', 'POST', '/webapi/backupRestore/policy/add', 'json', false, 'json', request);
}

