import OpenApi;
import OpenApi.OpenApiUtil;

extends OpenApi;


init(config: OpenApiUtil.Config){
  super(config);
  @endpointRule = 'regional';
  @endpointMap = {
    'us-west-1' = 'aiccs.aliyuncs.com',
    'us-east-1' = 'aiccs.aliyuncs.com',
    'me-east-1' = 'aiccs.aliyuncs.com',
    'eu-west-1' = 'aiccs.aliyuncs.com',
    'eu-central-1' = 'aiccs.aliyuncs.com',
    'cn-zhangjiakou' = 'aiccs.aliyuncs.com',
    'cn-wulanchabu' = 'aiccs.aliyuncs.com',
    'cn-shenzhen-finance-1' = 'aiccs.aliyuncs.com',
    'cn-shenzhen' = 'aiccs.aliyuncs.com',
    'cn-shanghai-finance-1' = 'aiccs.aliyuncs.com',
    'cn-shanghai' = 'aiccs.aliyuncs.com',
    'cn-qingdao' = 'aiccs.aliyuncs.com',
    'cn-north-2-gov-1' = 'aiccs.aliyuncs.com',
    'cn-huhehaote' = 'aiccs.aliyuncs.com',
    'cn-hongkong' = 'aiccs.aliyuncs.com',
    'cn-hangzhou-finance' = 'aiccs.aliyuncs.com',
    'cn-hangzhou' = 'aiccs.aliyuncs.com',
    'cn-chengdu' = 'aiccs.aliyuncs.com',
    'cn-beijing-finance-1' = 'aiccs.aliyuncs.com',
    'cn-beijing' = 'aiccs.aliyuncs.com',
    'ap-southeast-5' = 'aiccs.aliyuncs.com',
    'ap-southeast-3' = 'aiccs.aliyuncs.com',
    'ap-southeast-1' = 'aiccs.aliyuncs.com',
    'ap-northeast-1' = 'aiccs.aliyuncs.com',
  };

  checkConfig(config);
  @endpoint = getEndpoint('aiccs', @regionId, @endpointRule, @network, @suffix, @endpointMap, @endpoint);
}

function getEndpoint(productId: string, regionId: string, endpointRule: string, network: string, suffix: string, endpointMap: map[string]string, endpoint: string) throws: string{
  if (!$isNull(endpoint)) {
    return endpoint;
  }
  
  if (!$isNull(endpointMap) && !$isNull(endpointMap[regionId])) {
    return endpointMap[regionId];
  }
  return OpenApiUtil.getEndpointRules(productId, regionId, endpointRule, network, suffix);
}

model AddHotlineNumberRequest {
  description?: string(name='Description', description='Description of the number.

This parameter is required.', example='热线号码'),
  enableInbound?: boolean(name='EnableInbound', description='Indicates whether the number is used for inbound calls.

This parameter is required.', example='true'),
  enableInboundEvaluation?: boolean(name='EnableInboundEvaluation', description='Whether inbound satisfaction evaluation is enabled.

This parameter is required.', example='true'),
  enableOutbound?: boolean(name='EnableOutbound', description='Whether it is used for outbound calls.

This parameter is required.', example='true'),
  enableOutboundEvaluation?: boolean(name='EnableOutboundEvaluation', description='Indicates whether outbound call satisfaction evaluation is enabled.

This parameter is required.', example='true'),
  evaluationLevel?: int32(name='EvaluationLevel', description='Satisfaction Level. Valid values:  

- **2**: Two-level (Satisfied, Not satisfied)  
- **3**: Three-level (Satisfied, Neutral, Not satisfied)  
- **4**: Four-level (Very satisfied, Satisfied, Neutral, Not satisfied)  
- **5**: Five-level (Very satisfied, Satisfied, Neutral, Not satisfied, Very poor)', example='2'),
  hotlineNumber?: string(name='HotlineNumber', description='Hotline number.

This parameter is required.', example='05710000****'),
  inboundFlowId?: long(name='InboundFlowId', description='The IVR flow ID for inbound calls. You can obtain it on the SaaS Workbench > Channel Integration > IVR Flow Management page.', example='123456'),
  instanceId?: string(name='InstanceId', description='The Artificial Intelligence Cloud Call Service (AICCS) instance ID. You can obtain it in the Intelligent Contact Center console.

This parameter is required.', example='ccc_xp_pre-cn-***'),
  outboundAllDepart?: boolean(name='OutboundAllDepart', description='Whether outbound calls apply to all departments under the instance.

This parameter is required.', example='true'),
  outboundRangeList?: [ 
    {
      departmentId?: long(name='DepartmentId', description='Effective department ID.', example='123456'),
      groupIdList?: [ long ](name='GroupIdList', description='List of effective skill groups.  
> If the skill group list is empty, the setting applies to the entire department. Otherwise, it applies only to the specified skill groups under the department.'),
    }
  ](name='OutboundRangeList', description='Outbound call effective scope.'),
}

