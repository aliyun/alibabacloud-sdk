  resourceOwnerAccount?: string(name='ResourceOwnerAccount'),
  resourceOwnerId?: long(name='ResourceOwnerId'),
  sessionTimeout?: int32(name='SessionTimeout', description='Maximum call duration, in seconds. The call is automatically disconnected after timeout.', example='120'),
  speed?: int32(name='Speed', description='This parameter is not currently supported.', example='1'),
  ttsConf?: boolean(name='TtsConf', description='Whether to configure TTS voice parameters.
