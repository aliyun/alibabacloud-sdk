  ttsStyle?: string(name='TtsStyle', description='Voice style used during TTS variable playback. Default value: **xiaoyun**. For available styles, see the voice style list.', example='xiaoyun'),
  ttsVolume?: int32(name='TtsVolume', description='The volume for TTS variable playback. Valid values range from **0 to 100**. The default value is **0**.', example='10'),
  voiceCode?: string(name='VoiceCode', description='The Intelligent Outbound Call playback audio file supports both network files and TTS. Multiple files and TTS parameters can be mixed for playback, separated by commas (,). The replacement values for TTS parameters are specified in **VoiceCodeParam**.

