  officeSiteId?: string(name='OfficeSiteId', description='The office network ID.', example='cn-hangzhou+dir-643067****'),
  password?: string(name='Password', description='The logon password of the workstation.', example='YourPassword123'),
  period?: int32(name='Period', description='The subscription duration.', example='1'),
  periodUnit?: string(name='PeriodUnit', description='The unit of the subscription duration.', example='Month'),
  promotionId?: string(name='PromotionId', description='The promotion ID.


> If PromotionId is specified, the corresponding discount is applied.', example='17440009****'),
  savingPlanId?: string(name='SavingPlanId'),
  serverInstanceType?: string(name='ServerInstanceType', description='The workstation instance type.', example='eds.proworkstation_flagship_elite_ne.96c384g.192g4x'),
