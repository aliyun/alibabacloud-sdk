/**
 * @summary Adds an entry to the whitelist of an instance.
 *
 * @param tmpReq AddInstanceWhiteListRequest
 * @param runtime runtime options for this request RuntimeOptions
 * @return AddInstanceWhiteListResponse
 */
@context("addInstanceWhiteListWithContext")
async function addInstanceWhiteListWithOptions(tmpReq: AddInstanceWhiteListRequest, runtime: $RuntimeOptions): AddInstanceWhiteListResponse {
  tmpReq.validate();
  var request = new AddInstanceWhiteListShrinkRequest{};
  OpenApiUtil.convert(tmpReq, request);
  if (!$isNull(tmpReq.whiteListItem)) {
    request.whiteListItemShrink = OpenApiUtil.arrayToStringWithSpecifiedStyle(tmpReq.whiteListItem, 'WhiteListItem', 'json');
  }
  var query = {};
  if (!$isNull(request.instanceId)) {
    query['InstanceId'] = request.instanceId;
  }
  if (!$isNull(request.whiteListItemShrink)) {
    query['WhiteListItem'] = request.whiteListItemShrink;
  }
  if (!$isNull(request.whiteListType)) {
    query['WhiteListType'] = request.whiteListType;
  }
  var req = new OpenApiUtil.OpenApiRequest{ 
    query = OpenApiUtil.query(query),
  };
  var params = new OpenApiUtil.Params{
    action = 'AddInstanceWhiteList',
    version = '2019-12-12',
    protocol = 'HTTPS',
    pathname = '/',
    method = 'POST',
    authType = 'AK',
    style = 'RPC',
    reqBodyType = 'formData',
    bodyType = 'json',
  };
  return callApi(params, req, runtime);
}

/**
 * @summary Adds an entry to the whitelist of an instance.
 *
 * @param request AddInstanceWhiteListRequest
 * @return AddInstanceWhiteListResponse
 */
async function addInstanceWhiteList(request: AddInstanceWhiteListRequest): AddInstanceWhiteListResponse {
  var runtime = new $RuntimeOptions{};
  return addInstanceWhiteListWithOptions(request, runtime);
}

