  * @return UpdateApiKeyResponse
 */
async function updateApiKey(request: UpdateApiKeyRequest): UpdateApiKeyResponse {
  @handler.validateRequestModel(request);
  return @handler.do('RESTFUL', 'UpdateApiKey', 'PUT', '/modelstudio/apikeys/{apiKeyId}', 'json', true, 'form', request);
}

