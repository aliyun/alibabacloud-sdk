  * @return AddOrganizationMemberResponse
 */
async function addOrganizationMember(request: AddOrganizationMemberRequest): AddOrganizationMemberResponse {
  @handler.validateRequestModel(request);
  return @handler.do('RESTFUL', 'AddOrganizationMember', 'POST', '/tokenplan/organization/member-additions', 'json', false, 'json', request);
}

