  instanceId?: string(name='InstanceId', description='The ID of the instance.

This parameter is required.', example='12f3dd08-0c55-44ce-9b64-e69d35ed3a76'),
  jobGroupId?: string(name='JobGroupId', description='The ID of the job group.

This parameter is required.', example='d004cfd2-6a81-491c-83c6-cbe186620c95'),
  jobsJson?: [ string ](name='JobsJson', description='A JSON array containing job data. For the required format, see the example.

