>Notice: This parameter is required.', example='10'),
  queryText?: string(name='QueryText', description='The search query for a specific job, such as the contact\\\\"s phone number.', example='1882020****'),
  startActualTimeFilter?: long(name='StartActualTimeFilter', description='Filters for calls that started on or after the specified time. Specify the time as a UNIX timestamp in milliseconds.', example='1579055782000'),
