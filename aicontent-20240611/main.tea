  serviceCode?: string(name='serviceCode', description='The unique code for the service.', example='online_ai_algorithm_personalized_text_to_image_call_count'),
  serviceName?: string(name='serviceName', description='The display name of the service.', example='AI算法模型-个性化文生图-在线按量调用'),
}

