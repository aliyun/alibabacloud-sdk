  Util.validateModel(request);
  var body : map[string]any = {};
  if (!Util.isUnset(request.billingType)) {
    body['billingType'] = request.billingType;
  }
  if (!Util.isUnset(request.effectiveTime)) {
    body['effectiveTime'] = request.effectiveTime;
