model ETL {
  configuration?: ETLConfiguration(name='configuration', description='The configurations of the data transformation job.

This parameter is required.'),
  createTime?: long(name='createTime', description='The time when the data transformation job was created.', example='1714274900'),
  description?: string(name='description', description='job description', example='ETL'),
  displayName?: string(name='displayName', description='job displayName

This parameter is required.', example='ETL'),
  lastModifiedTime?: long(name='lastModifiedTime', description='The time when the data transformation job was last modified.', example='1714274900'),
  name?: string(name='name', description='job name

This parameter is required.', example='ETL'),
