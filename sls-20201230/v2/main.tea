model ETLConfiguration {
  accessKeyId?: string(name='accessKeyId', description='The AccessKey ID that is required to read data from the source Logstore. This parameter is required. If you use a RAM role for authorization, set this parameter to an empty string.', deprecated=true),
  accessKeySecret?: string(name='accessKeySecret', description='The AccessKey secret that is required to read data from the source Logstore. This parameter is required. If you use a RAM role for authorization, set this parameter to an empty string.', deprecated=true),
  fromTime?: long(name='fromTime', description='The start time of the data transformation. The value is a UNIX timestamp. Unit: seconds. This parameter is required. To start the data transformation from the earliest log in the source Logstore, set this parameter to 0.

This parameter is required.', example='0'),
  lang?: string(name='lang', description='The language of the data transformation script.', example='SPL'),
  logstore?: string(name='logstore', description='The name of the source Logstore.

This parameter is required.', example='test-logstore'),
  parameters?: map[string]any(name='parameters', description='Advanced parameters.', example='config.vpc.vpc_id.test1：vpc-uf6mskb0b****n9yj'),
  roleArn?: string(name='roleArn', description='The ARN of the RAM role that is authorized to read data from the source Logstore.

This parameter is required.', example='acs:ram::13234:role/logtarget'),
  script?: string(name='script', description='The data transformation script.

This parameter is required.', example='* | extend key=\\\\"value\\\\"'),
  sinks?: [
    ETLConfigurationSink
  ](name='sinks', description='The output destinations of the data transformation.

This parameter is required.'),
  toTime?: long(name='toTime', description='The end time of the data transformation. The value is a UNIX timestamp. Unit: seconds. This parameter is required. To continuously perform the data transformation until you manually stop it, set this parameter to 0.

This parameter is required.', example='0'),
}

