}

model GCSIngestionConfiguration {
  logstore?: string(name='logstore', description='The name of the destination logstore.

This parameter is required.', example='myLogstore'),
  source?: GCSIngestionConfigurationSource(name='source', description='The data source configuration.

This parameter is required.'),
}

model GCSIngestionConfigurationSource {
  accessKeyId?: string(name='accessKeyId', description='The access key ID for authenticating with the GCS service. This parameter is required.

This parameter is required.'),
  accessKeySecret?: string(name='accessKeySecret', description='The secret access key corresponding to the `accessKeyId`. This value is sensitive and must be managed securely.

This parameter is required.'),
  advancedParameters?: map[string]any(name='advancedParameters', description='A nested object for specifying advanced configuration options as key-value pairs.'),
  bucket?: string(name='bucket', description='The name of the GCS bucket that contains the source data files.

This parameter is required.', example='gcsbucket'),
  compressionCodec?: string(name='compressionCodec', description='The compression format of the source files. Supported values are `none`, `gzip`, and `zstd`. If not specified, the system infers the format from the file extension.

This parameter is required.', example='none'),
  encoding?: string(name='encoding', description='The character encoding of the source files. The default value is `UTF-8`.

This parameter is required.', example='UTF-8'),
  endTime?: long(name='endTime', description='The end of the time range for data ingestion, specified as a Unix timestamp (in seconds). Only objects modified before this time are ingested.', example='1714360481'),
  endpoint?: string(name='endpoint', description='The service endpoint for GCS. You can use a custom endpoint for private or accelerated connections.', example='oss-cn-hangzhou.aliyuncs.com'),
  format?: map[string]any(name='format', description='A nested object that defines the format of the source data, such as CSV, JSON, or Parquet.

This parameter is required.'),
  interval?: string(name='interval', description='The interval for checking for new data. Specify the value in a duration format, such as `15m` for 15 minutes. Set to `never` to perform a one-time ingestion.

This parameter is required.', example='never'),
  pattern?: string(name='pattern', description='A regular expression that specifies which files to ingest. The pattern is matched against the full object key within the specified prefix.', example='.*'),
  prefix?: string(name='prefix', description='The object key prefix used to discover files. This limits the scope of ingestion to a specific "folder" within the bucket.', example='prefix'),
  processorId?: string(name='processorId', description='The unique ID of the processor or pipeline that handles the ingested data.', example='ingest-processor-1756802123-953901'),
  restoreObjectEnabled?: boolean(name='restoreObjectEnabled', description='Specifies whether to automatically restore objects from archival storage classes before ingestion. Set to `true` to enable this feature. The default is `false`.'),
  startTime?: long(name='startTime', description='The start of the time range for data ingestion, specified as a Unix timestamp (in seconds). Only objects modified at or after this time are ingested.', example='1714274081'),
  tagPackId?: boolean(name='tagPackId', description='The ID of a predefined tag pack to apply to the ingested data. Tag packs contain rules for data enrichment and categorization.'),
  timeField?: string(name='timeField', description='The name of the field in your data that contains the timestamp. This timestamp is used as the event time for the ingested records.', example='__time__'),
  timeFormat?: string(name='timeFormat', description='The format of the timestamp in the `timeField`, specified using the Java `SimpleDateFormat` pattern. For example: `yyyy-MM-dd\\\\"T\\\\"HH:mm:ss.SSSZ`.', example='yyyy-MM-dd HH:mm:ss'),
  timePattern?: string(name='timePattern', description='A regular expression used to extract a timestamp from unstructured data, such as a log entry or filename, if a structured `timeField` is not available.', example='[0-9]{0,2}\\\\/[0-9a-zA-Z]+\\\\/[0-9:,]+'),
  timeZone?: string(name='timeZone', description='The time zone for parsing timestamps that lack explicit time zone information. Specify a valid time zone identifier, such as `UTC` or `America/Los_Angeles`.', example='GMT+08:00'),
}

