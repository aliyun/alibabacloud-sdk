import GatewayClient;
import OpenApi;
import OpenApi.OpenApiUtil;

extends OpenApi;


init(config: OpenApiUtil.Config){
  super(config);
  @productId = 'Sls';
  var gatewayClient = new GatewayClient();
  @spi = gatewayClient;
  @endpointRule = 'regional';
  @endpointMap = {
    'us-west-1' = 'us-west-1.log.aliyuncs.com',
    'us-southeast-1' = 'us-southeast-1.log.aliyuncs.com',
    'us-east-1' = 'us-east-1.log.aliyuncs.com',
    'me-east-1' = 'me-east-1.log.aliyuncs.com',
    'me-central-1' = 'me-central-1.log.aliyuncs.com',
    'eu-west-1' = 'eu-west-1.log.aliyuncs.com',
    'eu-central-1' = 'eu-central-1.log.aliyuncs.com',
    'cn-zhangjiakou' = 'cn-zhangjiakou.log.aliyuncs.com',
    'cn-wulanchabu' = 'cn-wulanchabu.log.aliyuncs.com',
    'cn-shenzhen-finance-1' = 'cn-shenzhen-finance-1.log.aliyuncs.com',
    'cn-shenzhen' = 'cn-shenzhen.log.aliyuncs.com',
    'cn-shanghai-finance-1' = 'cn-shanghai-finance-1.log.aliyuncs.com',
    'cn-shanghai' = 'cn-shanghai.log.aliyuncs.com',
    'cn-qingdao' = 'cn-qingdao.log.aliyuncs.com',
    'cn-nanjing' = 'cn-nanjing.log.aliyuncs.com',
    'cn-huhehaote' = 'cn-huhehaote.log.aliyuncs.com',
    'cn-hongkong' = 'cn-hongkong.log.aliyuncs.com',
    'cn-heyuan-acdr-1' = 'cn-heyuan-acdr-1-intranet.log.aliyuncs.com',
    'cn-heyuan' = 'cn-heyuan.log.aliyuncs.com',
    'cn-hangzhou-finance' = 'cn-hangzhou-finance.log.aliyuncs.com',
    'cn-hangzhou' = 'cn-hangzhou.log.aliyuncs.com',
    'cn-guangzhou' = 'cn-guangzhou.log.aliyuncs.com',
    'cn-fuzhou' = 'cn-fuzhou.log.aliyuncs.com',
    'cn-chengdu' = 'cn-chengdu.log.aliyuncs.com',
    'cn-beijing-finance-1' = 'cn-beijing-finance-1.log.aliyuncs.com',
    'cn-beijing' = 'cn-beijing.log.aliyuncs.com',
    'ap-southeast-7' = 'ap-southeast-7.log.aliyuncs.com',
    'ap-southeast-6' = 'ap-southeast-6.log.aliyuncs.com',
    'ap-southeast-5' = 'ap-southeast-5.log.aliyuncs.com',
    'ap-southeast-3' = 'ap-southeast-3.log.aliyuncs.com',
    'ap-southeast-2' = 'ap-southeast-2.log.aliyuncs.com',
    'ap-southeast-1' = 'ap-southeast-1.log.aliyuncs.com',
    'ap-south-1' = 'ap-south-1.log.aliyuncs.com',
    'ap-northeast-2' = 'ap-northeast-2.log.aliyuncs.com',
    'ap-northeast-1' = 'ap-northeast-1.log.aliyuncs.com',
  };
}

model AgentInstanceConfigGrayConfigs {
  condition?: string(name='condition', description='The matching rule.', example='appVersion="1.0.0"'),
  content?: string(name='content', description='The content of the canary release configuration.', example='{"enable":true}'),
}

model Alert {
  configuration?: AlertConfiguration(name='configuration', description='The configuration of the alert rule.

This parameter is required.'),
  createTime?: long(name='createTime', description='The time when the alert rule was created.', example='1695090077'),
  description?: string(name='description', description='The description of the alert rule.', example='Alert Desc'),
  displayName?: string(name='displayName', description='The name of the alert rule.

This parameter is required.', example='alertNameExample'),
  lastModifiedTime?: long(name='lastModifiedTime', description='The time when the alert rule was last modified.', example='1714274900'),
  name?: string(name='name', description='The ID of the alert rule.

This parameter is required.', example='alert-123456'),
  schedule?: Schedule(name='schedule', description='The scheduling configuration.

This parameter is required.'),
  status?: string(name='status', description='The status of the alert rule.', example='ENABLED/DISABLED'),
}

model AlertConfiguration {
  annotations?: [
    AlertTag
  ](name='annotations', description='The alert annotations.'),
  autoAnnotation?: boolean(name='autoAnnotation', description='Specifies whether to enable automatic annotation.

This parameter is required.', example='false'),
  conditionConfiguration?: ConditionConfiguration(name='conditionConfiguration', description='The alert trigger condition.'),
  dashboard?: string(name='dashboard', description='The ID of the dashboard to which the alert is attached.', example='DasnboardExample'),
  groupConfiguration?: GroupConfiguration(name='groupConfiguration', description='The group evaluation configuration.

This parameter is required.'),
  joinConfigurations?: [
    JoinConfiguration
  ](name='joinConfigurations', description='The configurations for joining the results of query statements.'),
  labels?: [
    AlertTag
  ](name='labels', description='The alert labels.'),
  muteUntil?: long(name='muteUntil', description='The time until which the alert is muted.', example='1698907508'),
  noDataFire?: boolean(name='noDataFire', description='Specifies whether to enable no-data alerts.

This parameter is required.', example='false'),
  noDataSeverity?: int32(name='noDataSeverity', description='The severity of no-data alerts.', example='6'),
  policyConfiguration?: PolicyConfiguration(name='policyConfiguration', description='The configuration for the SLS alert notification service.'),
  queryList?: [
    AlertQuery
  ](name='queryList', description='The list of query statements.

This parameter is required.'),
  sendResolved?: boolean(name='sendResolved', description='Specifies whether to send recovery alerts.

This parameter is required.', example='false'),
  severityConfigurations?: [
    SeverityConfiguration
  ](name='severityConfigurations', description='The alert severity configurations.

This parameter is required.'),
  sinkAlerthub?: SinkAlerthubConfiguration(name='sinkAlerthub', description='The configuration for sending alerts to the SLS alert management service.'),
  sinkCms?: SinkCmsConfiguration(name='sinkCms', description='The configuration for sending alerts to Cloud Monitor.'),
  sinkEventStore?: SinkEventStoreConfiguration(name='sinkEventStore', description='The configuration for sending alerts to the eventstore.'),
  tags?: [ string ](name='tags', description='The custom alert tags.'),
  templateConfiguration?: TemplateConfiguration(name='templateConfiguration', description='The alert template configuration.'),
  threshold?: int32(name='threshold', description='The consecutive trigger threshold.

This parameter is required.', example='1'),
  type?: string(name='type', description='The type of the alert rule.', example='default'),
  version?: string(name='version', description='The version.

This parameter is required.', example='2.0'),
}

model AlertQuery {
  chartTitle?: string(name='chartTitle', description='Chart name', example='chartExmaple'),
  dashboardId?: string(name='dashboardId', description='Dashboard ID', example='dashboardExample'),
  end?: string(name='end', description='End time

This parameter is required.', example='now'),
  powerSqlMode?: string(name='powerSqlMode', description='Whether to enable Dedicated SQL', example='auto'),
  project?: string(name='project', description='Project name

This parameter is required.', example='projectExample'),
  query?: string(name='query', description='Query and analysis statement

This parameter is required.', example='* | select *'),
  region?: string(name='region', description='Region

This parameter is required.', example='cn-hangzhou'),
  roleArn?: string(name='roleArn', description='Role ARN'),
  start?: string(name='start', description='Start time

This parameter is required.', example='-5m'),
  store?: string(name='store', description='Store name

This parameter is required.', example='store Example'),
  storeType?: string(name='storeType', description='Store type

This parameter is required.', example='log'),
  timeSpanType?: string(name='timeSpanType', description='Time span type

This parameter is required.', example='Relative'),
  ui?: string(name='ui', description='Used by the frontend for specific-scenario alerts'),
}

model AlertTag {
  key?: string(name='key', description='The key name.', example='title'),
  value?: string(name='value', description='The key value.', example='example value'),
}

model AsyncSqlResponseData {
  asyncSqlMetaPB?: {
    cpuCores?: int32(name='cpu_cores', description='The number of CPU cores used.', example='10'),
    cpuSec?: double(name='cpu_sec', description='The total CPU time consumed in seconds.', example='0.2'),
    elapsedMilli?: long(name='elapsed_milli', description='The SQL query running time in milliseconds.', example='30000'),
    keys?: [ string ](name='keys', description='The names of the columns in the SQL result. The keys correspond one-to-one with the fields in the SELECT statement.'),
    processedRows?: long(name='processed_rows', description='The number of raw data rows processed.', example='10000000'),
    progress?: string(name='progress', description='Indicates whether the SQL result is accurate. Valid values are:

- Complete: The result is accurate.

- Incomplete: The result is not accurate.', example='Complete'),
    resultRows?: int32(name='result_rows', description='The total number of rows in the result. When you read the results, the offset value must not exceed this value.', example='12000'),
  }(name='AsyncSqlMetaPB', description='The metadata of the SQL query.'),
  errorCode?: string(name='error_code', description='If the SQL query fails to execute, this parameter contains the specific error code.', example='InvalidQuery'),
  errorMessage?: string(name='error_message', description='If the SQL query fails to execute, this parameter contains the specific error message.', example='line 37:14: Column \\\\"xyz\\\\" cannot be resolved'),
  id?: string(name='id', description='The ID of the asynchronous SQL query.

This parameter is required.', example='690C4F2A16FBD65C40000484_14'),
  rows?: [[ string ]  ](name='rows', description='The SQL result. Each element in the array is also an array that corresponds to a specific row of the result.'),
  state?: string(name='state', description='The current execution state of the asynchronous SQL query. Valid values are:

- RUNNING

- FINISHED

- FAILED

- CANCELLED

RUNNING is a temporary state that indicates the SQL query is still running. You can read the results only when the state is FINISHED. The error_code and error_message parameters are valid only when the state is FAILED.

This parameter is required.', example='FINISHED'),
}

model AzureBlobIngestion {
  configuration?: AzureBlobIngestionConfiguration(name='configuration', description='This parameter is required.'),
  createTime?: long(name='createTime', example='1714360481'),
  description?: string(name='description', example='azure blob ingestion'),
  displayName?: string(name='displayName', description='This parameter is required.', example='azure blob ingestion'),
  lastModifiedTime?: long(name='lastModifiedTime', example='1714360481'),
  name?: string(name='name', description='This parameter is required.', example='ingest-azure-blob-123456'),
  processorId?: string(name='processorId', example='ingest-processor-1756802123-953901'),
  schedule?: Schedule(name='schedule', description='This parameter is required.'),
  scheduleId?: string(name='scheduleId', example='c7f01719d9feb105fc9d8df92af62010'),
  status?: string(name='status', example='RUNNING'),
}

model AzureBlobIngestionConfiguration {
  logstore?: string(name='logstore', example='myLogstore'),
  source?: AzureBlobIngestionConfigurationSource(name='source'),
}

model AzureBlobIngestionConfigurationSource {
  accountKey?: string(name='accountKey', description='The access key for the Azure Blob Storage account.

This parameter is required.', example='dGVzdGtleQ=='),
  accountName?: string(name='accountName', description='The name of the Azure Blob Storage account.

This parameter is required.', example='test001'),
  advancedParameters?: map[string]any(name='advancedParameters', description='Advanced configuration options.'),
  compressionCodec?: string(name='compressionCodec', description='The compression codec for the source data. Valid values are `none`, `snappy`, and `gzip`.

This parameter is required.', example='none'),
  containerName?: string(name='containerName', description='The name of the container in Azure Blob Storage.

This parameter is required.', example='test-container'),
  encoding?: string(name='encoding', description='The character encoding of the source files.

This parameter is required.', example='UTF-8'),
  endTime?: long(name='endTime', description='Ingests only files modified before this time, specified as a Unix timestamp.', example='1714360481'),
  endpoint?: string(name='endpoint', description='The service endpoint for Azure Blob Storage.', example='https://your-storage.blob.core.windows.net'),
  format?: map[string]any(name='format', description='The format of the source data.

This parameter is required.'),
  interval?: string(name='interval', description='The interval at which to check for new files to ingest.

This parameter is required.', example='30m'),
  pattern?: string(name='pattern', description='A pattern used to filter files by path.', example='.*'),
  prefix?: string(name='prefix', description='The file path prefix used to filter files.', example='prefix'),
  processorId?: string(name='processorId', description='The ID of the processor that receives the data.', example='ingest-processor-1756802123-953901'),
  startTime?: long(name='startTime', description='Ingests only files modified after this time, specified as a Unix timestamp.', example='1714274081'),
  tagPackId?: boolean(name='tagPackId', description='Specifies whether to enable context query.', example='false'),
  timeField?: string(name='timeField', description='The source field for the time value.', example='__time__'),
  timeFormat?: string(name='timeFormat', description='The format of the time field.', example='yyyy-MM-dd HH:mm:ss'),
  timePattern?: string(name='timePattern', description='The pattern used to extract the time value.', example='[0-9]{0,2}\\\\/[0-9a-zA-Z]+\\\\/[0-9:,]+'),
  timeZone?: string(name='timeZone', description='The time zone of the time field.', example='GMT+08:00'),
}

model ConditionConfiguration {
  condition?: string(name='condition', description='The evaluate expression.', example='cnt > 100'),
  countCondition?: string(name='countCondition', description='The number of entries that match the evaluate expression to return.', example='__count__ > 5'),
}

model ConsumeProcessor {
  configuration?: ConsumeProcessorConfiguration(name='configuration', description='Processor配置

This parameter is required.'),
  createTime?: long(name='createTime', description='创建时间', example='1717171200'),
  description?: string(name='description', description='Processor描述', example='过滤content字段'),
  displayName?: string(name='displayName', description='Processor名称

This parameter is required.', example='字段过滤处理'),
  processorName?: string(name='processorName', description='Processor ID

This parameter is required.', example='consume-processor-1'),
  updateTime?: long(name='updateTime', description='更新时间', example='1717171200'),
}

model ConsumeProcessorConfiguration {
  spl?: string(name='spl', description='SPL statement

This parameter is required.', example='* | project content'),
}

model ConsumerGroup {
  name?: string(name='name', description='The name of the consumer group.', example='test-consumer-group'),
  order?: boolean(name='order', description='Specifies whether to consume data in sequence. Valid values:

*   true: If a shard is split, the data in the original shard is consumed first. Then, the data in the new shards is consumed at the same time. If shards are merged, the data in the original shards is consumed first. Then, the data in the new shard is consumed.
*   false: The data in all shards is consumed at the same time. If a new shard is generated after a shard is split or shards are merged, the data in the new shard is immediately consumed.', example='false'),
  timeout?: int32(name='timeout', description='The timeout period. If Simple Log Service does not receive heartbeats from a consumer within the timeout period, Simple Log Service deletes the consumer. Unit: seconds.', example='300'),
}

