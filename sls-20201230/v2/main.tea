  status?: string(name='status', description='The status of the data transformation job. Valid values:

1.  RUNNING
2.  STOPPING
3.  STOPPED
4.  SUCCEEDED
5.  FAILED
6.  STARTING
7.  RESTARTING', example='RUNNING'),
