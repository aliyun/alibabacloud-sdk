model ETL {
  configuration?: ETLConfiguration(name='configuration', description='数据加工配置

This parameter is required.'),
  createTime?: long(name='createTime', description='创建时间', example='1714274900'),
  description?: string(name='description', description='job description', example='加工作业'),
  displayName?: string(name='displayName', description='job displayName

This parameter is required.', example='etljob'),
  lastModifiedTime?: long(name='lastModifiedTime', description='最近一次修改时间', example='1714274900'),
  name?: string(name='name', description='job name

This parameter is required.', example='etl-20240426'),
  scheduleId?: string(name='scheduleId', description='调度ID', example='f0eb655e501a8780808d1970ef6d04c4'),
  status?: string(name='status', description='加工状态，表示返回加工任务的状态，取值包括：
1. RUNNING：运行中
2. STOPPING: 停止中
3. STOPPED: 已停止
4. SUCCEEDED: 运行成功
5. FAILED: 运行失败
6. STARTING：启动中
7. RESTARTING：重启中', example='RUNNING'),
}

model ETLConfiguration {
  accessKeyId?: string(name='accessKeyId', description='授权读取源Logstore的AccessKey ID，必填。使用角色授权时，填入空字符串', deprecated=true),
  accessKeySecret?: string(name='accessKeySecret', description='授权读取源Logstore的AccessKey Secret，必填。使用角色授权时，填入空字符串。', deprecated=true),
  fromTime?: long(name='fromTime', description='加工时间起点时间戳（精确到秒），必填。从源Logstore中最早接收到的第一条日志开始消费时，填入0

This parameter is required.', example='0'),
  lang?: string(name='lang', description='数据加工语法类型', example='SPL'),
  logstore?: string(name='logstore', description='源Logstore名称

This parameter is required.', example='test-logstore'),
  parameters?: map[string]any(name='parameters', description='高级参数配置', example='config.vpc.vpc_id.test1：vpc-uf6mskb0b****n9yj'),
  roleArn?: string(name='roleArn', description='授权读取源Logstore的角色ARN

This parameter is required.', example='acs:ram::13234:role/logtarget'),
  script?: string(name='script', description='加工脚本

This parameter is required.', example='* | extend key=\\\\"value\\\\"'),
  sinks?: [
    ETLConfigurationSink
  ](name='sinks', description='加工结果输出目标列表

This parameter is required.'),
  toTime?: long(name='toTime', description='加工时间结束时间戳（精确到秒），必填。持续消费至手动停止时，填入0

This parameter is required.', example='0'),
}

