import Util;
import GatewayClient;
import HttpClient;
import OpenApi;
import OpenApiUtil;

extends OpenApi;


init(config: OpenApi.Config){
  super(config);
  @productId = 'Sls';
  var gatewayClient = new GatewayClient();
  @spi = gatewayClient;
  if (Util.isUnset(config.httpClient)) {
    var defaultHttpClient = new HttpClient();
    @httpClient = defaultHttpClient;
  }

  @endpointRule = 'central';
  }

model AgentInstanceConfigGrayConfigs {
  condition?: string(name='condition'),
  content?: string(name='content'),
}

model Alert {
  configuration?: AlertConfiguration(name='configuration', description='告警规则配置

This parameter is required.'),
  createTime?: long(name='createTime', description='创建时间'),
  description?: string(name='description', description='告警规则描述', example='Alert Desc'),
  displayName?: string(name='displayName', description='告警规则名称

This parameter is required.', example='alertNameExample'),
  lastModifiedTime?: long(name='lastModifiedTime', description='最近一次修改时间'),
  name?: string(name='name', description='告警规则ID

This parameter is required.', example='alert-123456'),
  schedule?: Schedule(name='schedule', description='调度配置

This parameter is required.'),
  status?: string(name='status', description='告警状态', example='ENABLED/DISABLED'),
}

model AlertConfiguration {
  annotations?: [
    AlertTag
  ](name='annotations', description='告警标注'),
  autoAnnotation?: boolean(name='autoAnnotation', description='是否开启自动标注

This parameter is required.', example='false'),
  conditionConfiguration?: ConditionConfiguration(name='conditionConfiguration', description='告警触发条件'),
  dashboard?: string(name='dashboard', description='告警绑定的dashboardId', example='dasnboardExample'),
  groupConfiguration?: GroupConfiguration(name='groupConfiguration', description='分组评估配置

This parameter is required.'),
  joinConfigurations?: [
    JoinConfiguration
  ](name='joinConfigurations', description='告警查询分析语句集合操作配置'),
  labels?: [
    AlertTag
  ](name='labels', description='告警标签'),
  muteUntil?: long(name='muteUntil', description='临时关闭时间', example='1698907508'),
  noDataFire?: boolean(name='noDataFire', description='是否开启无数据告警

This parameter is required.', example='false'),
  noDataSeverity?: int32(name='noDataSeverity', description='无数据告警严重度', example='6'),
  policyConfiguration?: PolicyConfiguration(name='policyConfiguration', description='SLS告警通知服务配置'),
  queryList?: [
    AlertQuery
  ](name='queryList', description='查询语句列表

This parameter is required.'),
  sendResolved?: boolean(name='sendResolved', description='是否发送恢复告警

This parameter is required.', example='false'),
  severityConfigurations?: [
    SeverityConfiguration
  ](name='severityConfigurations', description='告警严重度配置

This parameter is required.'),
  sinkAlerthub?: SinkAlerthubConfiguration(name='sinkAlerthub', description='发送给SLS告警管理服务配置'),
  sinkCms?: SinkCmsConfiguration(name='sinkCms', description='发送给云监控配置'),
  sinkEventStore?: SinkEventStoreConfiguration(name='sinkEventStore', description='发送给EventStore配置'),
  tags?: [ string ](name='tags', description='告警自定义标签'),
  templateConfiguration?: TemplateConfiguration(name='templateConfiguration', description='告警模板配置'),
  threshold?: int32(name='threshold', description='连续触发阈值

This parameter is required.', example='1'),
  type?: string(name='type', description='告警规则类型', example='default'),
  version?: string(name='version', description='版本

This parameter is required.', example='2.0'),
}

model AlertQuery {
  chartTitle?: string(name='chartTitle', description='图表名称', example='chartExmaple'),
  dashboardId?: string(name='dashboardId', description='仪表盘ID', example='dashboardExample'),
  end?: string(name='end', description='结束时间

This parameter is required.', example='now'),
  powerSqlMode?: string(name='powerSqlMode', description='是否开启独享SQL', example='auto'),
  project?: string(name='project', description='项目名称

This parameter is required.', example='projectExample'),
  query?: string(name='query', description='查询分析语句

This parameter is required.', example='* | select *'),
  region?: string(name='region', description='区域

This parameter is required.', example='cn-hangzhou'),
  roleArn?: string(name='roleArn', description='角色ARN'),
  start?: string(name='start', description='开始时间

This parameter is required.', example='-5m'),
  store?: string(name='store', description='store名称

This parameter is required.', example='store Example'),
  storeType?: string(name='storeType', description='store类型

This parameter is required.', example='log'),
  timeSpanType?: string(name='timeSpanType', description='时间片类型

This parameter is required.', example='Relative'),
  ui?: string(name='ui', description='特定场景告警前端使用'),
}

model AlertTag {
  key?: string(name='key', description='键名', example='title'),
  value?: string(name='value', description='值', example='example value'),
}

model AsyncSqlResponseData {
  asyncSqlMetaPB?: {
    cpuCores?: int32(name='cpu_cores', example='10'),
    cpuSec?: double(name='cpu_sec', example='0.2'),
    elapsedMilli?: long(name='elapsed_milli', example='30000'),
    keys?: [ string ](name='keys'),
    processedRows?: long(name='processed_rows', example='10000000'),
    progress?: string(name='progress', example='Complete'),
    resultRows?: int32(name='result_rows', example='12000'),
  }(name='AsyncSqlMetaPB'),
  errorCode?: string(name='error_code', example='InvalidQuery'),
  errorMessage?: string(name='error_message', example='line 37:14: Column \\\\"xyz\\\\" cannot be resolved'),
  id?: string(name='id', description='This parameter is required.', example='690C4F2A16FBD65C40000484_14'),
  rows?: [[ string ]  ](name='rows'),
  state?: string(name='state', description='This parameter is required.', example='FINISHED'),
}

