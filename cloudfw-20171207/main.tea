 * @return AddAclBackupDataResponse
 */
async function addAclBackupDataWithOptions(request: AddAclBackupDataRequest, runtime: Util.RuntimeOptions): AddAclBackupDataResponse {
  Util.validateModel(request);
  var query = {};
  if (!Util.isUnset(request.backUpTime)) {
    query['BackUpTime'] = request.backUpTime;
  }
  if (!Util.isUnset(request.description)) {
    query['Description'] = request.description;
  }
  if (!Util.isUnset(request.lang)) {
    query['Lang'] = request.lang;
  }
  if (!Util.isUnset(request.sourceIp)) {
    query['SourceIp'] = request.sourceIp;
  }
  var req = new OpenApi.OpenApiRequest{ 
    query = OpenApiUtil.query(query),
  };
  var params = new OpenApi.Params{
    action = 'AddAclBackupData',
    version = '2017-12-07',
    protocol = 'HTTPS',
    pathname = '/',
    method = 'POST',
    authType = 'AK',
    style = 'RPC',
    reqBodyType = 'formData',
    bodyType = 'json',
  };
  return callApi(params, req, runtime);
}

/**
 * @summary Creates an access control backup.
 *
 * @param request AddAclBackupDataRequest
 * @return AddAclBackupDataResponse
 */
async function addAclBackupData(request: AddAclBackupDataRequest): AddAclBackupDataResponse {
  var runtime = new Util.RuntimeOptions{};
  return addAclBackupDataWithOptions(request, runtime);
}

