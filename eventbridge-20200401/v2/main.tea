    form?: string(name='Form', description='Defines how the parameter\\\\"s value is created. Use `CONSTANT` to specify a static string in the `value` field. Use `JSONPATH` to extract data from the event payload with a JSONPath expression in the `value` field. Use `TEMPLATE` to build the value from the `template` field.'),
    template?: string(name='Template', description='The template to use to build the parameter value. This field is used only when the `form` is set to `TEMPLATE`. You can use variables, such as `${event.id}`, in the template to reference event data.'),
    value?: string(name='Value', description='The static value or JSONPath expression for the parameter. This field applies only when the `form` is set to `CONSTANT` or `JSONPATH`.'),
  }(name='HeaderParameters', description='The custom HTTP header parameters to add to the request, specified as key-value pairs.'),
  name?: string(name='Name', description='The name of the API destination.'),
  queryStringParameters?: {
    form?: string(name='Form', description='Defines how the parameter\\\\"s value is created. Use `CONSTANT` to specify a static string in the `value` field. Use `JSONPATH` to extract data from the event payload with a JSONPath expression in the `value` field. Use `TEMPLATE` to build the value from the `template` field.'),
    template?: string(name='Template', description='The template to use to build the parameter value. This field is used only when the `form` is set to `TEMPLATE`. You can use variables, such as `${event.id}`, in the template to reference event data.'),
    value?: string(name='Value', description='The static value or JSONPath expression for the parameter. This field applies only when the `form` is set to `CONSTANT` or `JSONPATH`.'),
  }(name='QueryStringParameters', description='The query string parameters to add to the endpoint URL, specified as key-value pairs.'),
  timeout?: int32(name='Timeout', description='The timeout for the API call, in seconds. If the endpoint does not respond within this period, the call fails. The valid range is 1 to 60.'),
}

model SinkBaiLianParameters {
  after?: {
