  apiKey?: string(name='ApiKey'),
  messages?: [ 
    {
      form?: string(name='Form'),
      role?: string(name='Role'),
      template?: string(name='Template'),
      value?: string(name='Value'),
    }
  ](name='Messages'),
  model?: string(name='Model'),
  requestPerMinute?: long(name='RequestPerMinute'),
  structuredOutputJsonSchema?: string(name='StructuredOutputJsonSchema'),
