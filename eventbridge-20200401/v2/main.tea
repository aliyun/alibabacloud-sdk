}

model EventHouseRuntime {
  cu?: int32(name='Cu', description='The number of CUs that last took effect for the EventHouse Runtime.', example='2'),
  errorCode?: string(name='ErrorCode', description='The stable error code returned when the creation or specification change operation fails.', example='RUNTIME_OPERATION_TIMEOUT'),
  errorMessage?: string(name='ErrorMessage', description='The desensitized error message returned when the creation or specification change operation fails.', example='Runtime operation timed out'),
  name?: string(name='Name', description='The name of the EventHouse Runtime. Typically set to default in the initial phase.', example='default'),
  progress?: int32(name='Progress', description='The progress of the current creation or specification change operation. Valid values: 0 to 100.', example='80'),
  stage?: string(name='Stage', description='The current stage of the creation or specification change operation.', example='RUNTIME_HEALTH_CHECK'),
  status?: string(name='Status', description='The current status of the EventHouse Runtime. RUNNING indicates that the Runtime is ready and can accept queries. Valid values: CREATING, RUNNING, UPDATING, RECOVERING, CLOSED, CREATE_FAILED, and UPDATE_FAILED.', example='RUNNING'),
  targetCu?: int32(name='TargetCu', description='The target number of CUs during creation, specification change, or the corresponding failed state. This parameter is not returned when the Runtime is running stably.', example='2'),
}

model EventTableQueryHistogram {
  count?: long(name='Count'),
  from?: long(name='From'),
  to?: long(name='To'),
}

model ExecutionResult {
  isTruncated?: boolean(name='IsTruncated', description='Whether truncated due to the maxRows limit', example='false'),
  rowCount?: int32(name='RowCount', description='Number of rows returned this time', example='2'),
  rows?: string(name='Rows', description='Two-dimensional array, one array per row', example='[["北京",120],["上海",98]]'),
  schema?: [
    SchemaColumn
  ](name='Schema', description='Schema information'),
  totalRows?: int32(name='TotalRows', description='Total number of rows that meet the criteria. Different from RowCount when IsTruncated=true', example='2'),
}

model Metadata {
  attachments?: [ 
    {
      arn?: string(name='Arn', description='ARN of the associated data', example='acs:eventbridge:cn-hangzhou:12345:eventhouse/system-rocketmq/namespace/rmq-cn-xxx/table/order'),
      mimeType?: string(name='MimeType', description='Data type', example='inner-resource/event-table'),
    }
  ](name='Attachments', description='Associated data'),
}

model Namespace {
  catalog?: string(name='Catalog', description='The name of the data catalog to which the namespace belongs

This parameter is required.', example='my_catalog'),
  comment?: string(name='Comment', description='The description information of the namespace', example='测试命名空间'),
  name?: string(name='Name', description='The unique identifier name of the namespace', example='my_namespace'),
  properties?: string(name='properties', description='The extended properties of the namespace', example='{"key":"value"}'),
}

model QueryAskLumaLogResult {
  entries?: [
    AskLumaLogEntry
  ](name='Entries', description='The log entries returned by the query.'),
  hasMore?: boolean(name='HasMore', description='Specifies whether more results are available. The value is `true` if more results can be retrieved, and `false` otherwise.'),
  lastKey?: string(name='LastKey', description='The token to use for retrieving the next page of results. If present, pass this value as the `LastKey` parameter in a subsequent request to fetch more data. This field is omitted when all results have been retrieved.'),
}

model QueryAttachment {
  query?: string(name='Query', description='Query statement', example='"SELECT city, COUNT(*) AS cnt FROM events GROUP BY city"'),
  result?: ExecutionResult(name='Result', description='Query execution result'),
}

model Row {
  columns?: [
    Column
  ](name='Columns', description='Column data for each row.'),
}

model SchemaColumn {
  name?: string(name='Name', description='Column name', example='name'),
  type?: string(name='Type', description='Column type', example='VARCHAR'),
}

