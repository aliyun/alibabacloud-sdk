import OpenApi;
import OpenApi.OpenApiUtil;

extends OpenApi;


init(config: OpenApiUtil.Config){
  super(config);
  @endpointRule = 'regional';
  @endpointMap = {
    'us-west-1' = 'eventbridge-console.us-west-1.aliyuncs.com',
    'us-east-1' = 'eventbridge-console.us-east-1.aliyuncs.com',
    'eu-west-1' = 'eventbridge-console.eu-west-1.aliyuncs.com',
    'eu-central-1' = 'eventbridge-console.eu-central-1.aliyuncs.com',
    'cn-zhangjiakou' = 'eventbridge-console.cn-zhangjiakou.aliyuncs.com',
    'cn-wulanchabu' = 'eventbridge-console.cn-wulanchabu.aliyuncs.com',
    'cn-shenzhen-finance-1' = 'eventbridge-console.cn-shenzhen-finance-1.aliyuncs.com',
    'cn-shenzhen' = 'eventbridge-console.cn-shenzhen.aliyuncs.com',
    'cn-shanghai-finance-1' = 'eventbridge-console.cn-shanghai-finance-1.aliyuncs.com',
    'cn-shanghai' = 'eventbridge-console.cn-shanghai.aliyuncs.com',
    'cn-qingdao' = 'eventbridge-console.cn-qingdao.aliyuncs.com',
    'cn-huhehaote' = 'eventbridge-console.cn-huhehaote.aliyuncs.com',
    'cn-hongkong' = 'eventbridge-console.cn-hongkong.aliyuncs.com',
    'cn-heyuan' = 'eventbridge-console.cn-heyuan.aliyuncs.com',
    'cn-hangzhou' = 'eventbridge-console.cn-hangzhou.aliyuncs.com',
    'cn-guangzhou' = 'eventbridge-console.cn-guangzhou.aliyuncs.com',
    'cn-chengdu' = 'eventbridge-console.cn-chengdu.aliyuncs.com',
    'cn-beijing-finance-1' = 'eventbridge-console.cn-beijing-finance-1.aliyuncs.com',
    'cn-beijing' = 'eventbridge-console.cn-beijing.aliyuncs.com',
    'ap-southeast-7' = 'eventbridge-console.ap-southeast-7.aliyuncs.com',
    'ap-southeast-6' = 'eventbridge-console.ap-southeast-6.aliyuncs.com',
    'ap-southeast-5' = 'eventbridge-console.ap-southeast-5.aliyuncs.com',
    'ap-southeast-3' = 'eventbridge-console.ap-southeast-3.aliyuncs.com',
    'ap-southeast-1' = 'eventbridge-console.ap-southeast-1.aliyuncs.com',
    'ap-northeast-2' = 'eventbridge-console.ap-northeast-2.aliyuncs.com',
    'ap-northeast-1' = 'eventbridge-console.ap-northeast-1.aliyuncs.com',
  };

  checkConfig(config);
  @endpoint = getEndpoint('eventbridge', @regionId, @endpointRule, @network, @suffix, @endpointMap, @endpoint);
}

function getEndpoint(productId: string, regionId: string, endpointRule: string, network: string, suffix: string, endpointMap: map[string]string, endpoint: string) throws: string{
  if (!$isNull(endpoint)) {
    return endpoint;
  }
  
  if (!$isNull(endpointMap) && !$isNull(endpointMap[regionId])) {
    return endpointMap[regionId];
  }
  return OpenApiUtil.getEndpointRules(productId, regionId, endpointRule, network, suffix);
}

model Agent {
  createdAt?: long(name='CreatedAt'),
  description?: string(name='Description'),
  metadata?: Metadata(name='Metadata'),
  name?: string(name='Name'),
  prompt?: string(name='Prompt'),
  updatedAt?: long(name='UpdatedAt'),
}

model AguiMessage {
  content?: string(name='Content', description='The text content of the message.', example='根据您的问题，我将查询过去7天的事件量...'),
  id?: string(name='Id', description='The unique identifier of the message.', example='msg_123456_a1b2c3d4'),
  metadata?: {
    attachments?: {
      name?: string(name='Name', description='The name of the extension data.', example='acs:eventbridge:cn-hangzhou:12345:eventhouse/system-rocketmq/namespace/rmq-cn-xxx/table/order'),
      type?: string(name='Type', description='The type of the extension data.', example='inner-resource/event-table'),
    }(name='Attachments', description='The extension data.'),
  }(name='Metadata', description='The extension metadata.'),
  reasoning?: string(name='Reasoning'),
  role?: string(name='Role', description='The role of the message.', example='assistant'),
  toolCallId?: string(name='ToolCallId', description='The associated tool invocation ID.', example='call_xxx'),
  toolCalls?: [ 
    {
      function?: {
        arguments?: string(name='Arguments', description='The arguments of the tool calling function.', example='{}'),
        name?: string(name='Name', description='The name of the tool calling function.', example='discoverMetadata'),
      }(name='Function', description='The tool calling function.'),
      id?: string(name='Id', description='The tool calling ID.', example='call_xxx'),
      type?: string(name='Type', description='The tool calling type.', example='function'),
    }
  ](name='ToolCalls', description='The tool invocation list.'),
}

model AskLumaLogEntry {
  agentName?: string(name='AgentName', description='Agent name', example='my-agent'),
  clarificationNeeded?: boolean(name='ClarificationNeeded', description='Whether clarification is needed', example='false'),
  clarificationQuestion?: string(name='ClarificationQuestion', description='Clarification question text', example='您指的是哪张表？'),
  content?: Content(name='Content', description='Structured result body'),
  conversationId?: string(name='ConversationId', description='Conversation ID', example='conv_xxx'),
  createdAt?: string(name='CreatedAt', description='Creation time (milliseconds)', example='1717200000000'),
  durationMs?: long(name='DurationMs', description='Invocation duration (milliseconds)', example='3200'),
  errorCode?: string(name='ErrorCode', description='Error code', example='ExecutionFailed'),
  errorMessage?: string(name='ErrorMessage', description='Error details', example='Agent with name \\\\"xxx\\\\" not found for account 1186xxx'),
  isError?: boolean(name='IsError', description='Whether it is an error', example='false'),
  messageId?: string(name='MessageId', description='Message ID', example='msg_xxx'),
  question?: string(name='Question', description='Input question', example='帮我统计一下最近的订单数据。'),
  source?: string(name='Source', description='Log source', example='MCP, CHAT'),
  status?: string(name='Status', description='Execution status', example='RUNNING, SUCCEEDED, FAILED, TIMEOUT'),
}

model AskLumaResult {
  clarificationNeeded?: boolean(name='ClarificationNeeded', description='Whether clarification is needed', example='false'),
  clarificationQuestion?: string(name='ClarificationQuestion', description='Clarification question text', example='您指的是哪个数据库中的员工表？'),
  constraints?: Constraints(name='Constraints', description='Query constraints'),
  content?: Content(name='Content', description='Structured result body'),
  conversationId?: string(name='ConversationId', description='Conversation identifier, used for multi-turn follow-up questions', example='conv_xxx'),
  errorCode?: string(name='ErrorCode', description='Error code', example='ExecutionFailed, Timeout, RateLimited, InternalError, ConversationExpired'),
  errorMessage?: string(name='ErrorMessage', description='Error details', example='Agent with name \\\\"xxx\\\\" not found for account 1186xxx'),
  isError?: boolean(name='IsError', description='Whether it is an error. false = query succeeded or clarification (including empty result set); true = execution failed / timeout / rate limited / internal error', example='false'),
  messageId?: string(name='MessageId', description='Message identifier, used for PollAskResult polling', example='msg_xxx'),
  status?: string(name='Status', description='Execution status', example='RUNNING, SUCCEEDED, FAILED, TIMEOUT'),
  storageTruncated?: boolean(name='StorageTruncated', description='Whether the result was truncated due to exceeding the storage limit. Only appears in large result set scenarios', example='true'),
}

model BaiLianAgentTransformParameters {
  apiKey?: string(name='ApiKey'),
  applicationId?: string(name='ApplicationId'),
  prompt?: {
    form?: string(name='Form'),
    template?: string(name='Template'),
    value?: string(name='Value'),
  }(name='Prompt'),
  requestPerMinute?: long(name='RequestPerMinute'),
  tokenPerMinute?: long(name='TokenPerMinute'),
}

model Catalog {
  comment?: string(name='Comment', description='The comment or description of the data catalog', example='测试数据目录'),
  connectionName?: string(name='ConnectionName', description='The connection name associated with a mounted-type Catalog. Only has a value when Provider is MySQL/PostgreSQL/Elasticsearch', example='my_connection'),
  name?: string(name='Name', description='The unique identifier name of the data catalog', example='my_catalog'),
  properties?: map[string]any(name='Properties', description='Extended properties (JSON object). The Elasticsearch type contains information such as IndexPattern', example='{"IndexPattern":"my-index-*"}'),
  provider?: string(name='Provider', description='The data source provider. EventHouse is the built-in storage; MySQL/PostgreSQL/Elasticsearch are externally mounted', example='EventHouse'),
  type?: string(name='Type', description='The type of the data catalog, such as RELATIONAL', example='RELATIONAL'),
}

model Column {
  isNull?: boolean(name='IsNull', description='Whether the value is NULL. When true, it should be treated as NULL.', example='false'),
  name?: string(name='Name', description='Column name.', example='index'),
  type?: string(name='Type', description='Column type.', example='text'),
  value?: string(name='Value', description='Column value.', example='product_info'),
}

model Constraints {
  beginTime?: long(name='BeginTime', description='Start of the query time window (Unix milliseconds)', example='1717200000000'),
  endTime?: long(name='EndTime', description='End of the query time window (Unix milliseconds)', example='1717200000000'),
}

model Content {
  messageAttachments?: [
    AguiMessage
  ](name='MessageAttachments', description='This field is included only in records where Source is set to CHAT. The value is a list of messages in AGUI format.'),
  queryAttachments?: [
    QueryAttachment
  ](name='QueryAttachments', description='The array of executed queries and their query results.'),
  textAttachments?: [ string ](name='TextAttachments', description='The array of Markdown summaries generated by the LLM.'),
}

model Conversation {
  createdAt?: long(name='CreatedAt'),
  id?: string(name='Id'),
  status?: string(name='Status'),
  title?: string(name='Title'),
  updatedAt?: long(name='UpdatedAt'),
}

