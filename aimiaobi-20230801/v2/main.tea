}

model OutlineSearchResult {
  articles?: [
    OutlineWritingArticle
  ](name='Articles', description='A list of retrieved materials.'),
  outline?: string(name='Outline', description='The retrieved outline.', example='晨光中的自律：清晨6:30的校园'),
  outlineId?: string(name='OutlineId', description='The unique identifier of the outline.', example='xxxxxx'),
  primaryOutline?: string(name='PrimaryOutline', description='The primary outline.', example='大学生正能量的一天'),
  query?: string(name='Query', description='The retrieval query.', example='高校环保义卖案例 大学生旧物循环利用率的文章'),
}

model OutlineWritingArticle {
  content?: string(name='Content', description='Content', example='新闻内容'),
  outline?: string(name='Outline', description='The leaf outline this material belongs to', example='大纲名称'),
  primaryOutline?: string(name='PrimaryOutline', description='The primary outline this material belongs to', example='一级大纲名称'),
  pubTime?: string(name='PubTime', description='Publish time', example='2023-04-11 06:14:07'),
  searchSource?: string(name='SearchSource', description='Retrieval source encoding', example='检索源编码'),
  searchSourceName?: string(name='SearchSourceName', description='Retrieval name', example='检索源名称'),
  title?: string(name='Title', description='News title', example='新闻标题'),
  url?: string(name='Url', description='News URL', example='http://www.example.com/xxxx.html'),
}

model TopicSelection {
  outlines?: [ 
    {
      outline?: string(name='Outline', description='The topic outline.', example='大纲'),
      summary?: string(name='Summary', description='The summary of the outline.', example='摘要'),
    }
  ](name='Outlines', description='A list of topic outlines.'),
  point?: string(name='Point', description='The perspective of the topic.', example='选题视角'),
  summary?: string(name='Summary', description='The summary of the topic.', example='摘要'),
}

model WritingOutline {
  articles?: [
    OutlineWritingArticle
  ](name='Articles', description='List of articles referenced in the outline'),
  children?: [
    WritingOutline
  ](name='Children', description='List of sub-outlines'),
  outline?: string(name='Outline', description='Outline', example='大纲名称'),
  outlineId?: string(name='OutlineId', description='Unique outline identifier', example='xxx'),
  searchKeyWordList?: [ string ](name='SearchKeyWordList', description='Outline writing search keyword list'),
