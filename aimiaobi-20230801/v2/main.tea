/**
 *
 */
import OpenApi;
import OpenApi.OpenApiUtil;

extends OpenApi;


init(config: OpenApiUtil.Config){
  super(config);
  @endpointRule = 'regional';
  @endpointMap = {
    'cn-beijing' = 'aimiaobi.cn-beijing.aliyuncs.com',
  };

  checkConfig(config);
  @endpoint = getEndpoint('aimiaobi', @regionId, @endpointRule, @network, @suffix, @endpointMap, @endpoint);
}

function getEndpoint(productId: string, regionId: string, endpointRule: string, network: string, suffix: string, endpointMap: map[string]string, endpoint: string) throws: string{
  if (!$isNull(endpoint)) {
    return endpoint;
  }
  
  if (!$isNull(endpointMap) && !$isNull(endpointMap[regionId])) {
    return endpointMap[regionId];
  }
  return OpenApiUtil.getEndpointRules(productId, regionId, endpointRule, network, suffix);
}

model GenerateTraceability {
  news?: [ 
    {
      index?: int32(name='Index', description='The index \\\\`n\\\\` that corresponds to the \\\\`[[n]]\\\\` marker in the original article. The index starts from 1.', example='2'),
      pubTime?: string(name='PubTime', description='The publish time.', example='2024-01-22 10:29:00'),
      searchSource?: string(name='SearchSource', description='The unique identity of the retrieval source.', example='检索源唯一标识'),
      searchSourceName?: string(name='SearchSourceName', description='The name of the retrieval source.', example='检索源编码'),
      title?: string(name='Title', description='The title.', example='新闻标题'),
      url?: string(name='Url', description='The URL.', example='http://www.example.com/xxx.html'),
    }
  ](name='News', description='The list of traceability news.'),
}

model HottopicNews {
