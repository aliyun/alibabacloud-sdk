          endTime?: long(name='EndTime', description='The end time in milliseconds.', example='2000'),
          startTime?: long(name='StartTime', description='The start time in milliseconds.', example='1000'),
          text?: string(name='Text', description='The speech or caption information.', example='xxx'),
        }
      ](name='AsrSentences', description='The speech or caption information.'),
      keyValues?: [ 
        {
          key?: string(name='Key', description='The name.', example='xx'),
          value?: string(name='Value', description='The parameter value.', example='xx'),
        }
      ](name='KeyValues', description='The metadata in a key-value structure.'),
      text?: string(name='Text', description='The description of the metadata. This field is deprecated.', example='xxx'),
      videoShots?: [ 
        {
          endTime?: long(name='EndTime', description='The end time in milliseconds.', example='2000'),
          startTime?: long(name='StartTime', description='The start time in milliseconds.', example='1000'),
          text?: string(name='Text', description='The text information from the video shot analysis.', example='xxx'),
        }
      ](name='VideoShots', description='The video shot information.'),
    }(name='Metadata', description='The metadata.'),
    multimodalIndexName?: string(name='MultimodalIndexName', description='Deprecated. This parameter is not available.', example='xxxx'),
    multimodalMedias?: [ 
      {
        fileUrl?: string(name='FileUrl', description='The URL of the file. The URL must be accessible over the public network.', example='http://xxx'),
        mediaId?: string(name='MediaId', description='The unique identifier of the multimodal data. The system automatically generates this ID. You do not need to specify this parameter.', example='xxxx'),
        mediaType?: string(name='MediaType', description='The type of the multimodal data.

- image: an image

- video: a video', example='image'),
      }
    ](name='MultimodalMedias', description='A list of multimodal data in the document.

- If a document, such as a rich text document, contains multimodal data like images or videos, you can pass the data using this parameter. This allows the data to be retrieved in search results.

- If the document itself is multimodal data, leave this field empty and specify the data using the docType and url parameters.'),
    pubTime?: string(name='PubTime', description='The publishing time.', example='2024-12-09 13:35:40'),
    sourceFrom?: string(name='SourceFrom', description='The source.', example='xxx媒体'),
    summary?: string(name='Summary', description='The summary of the article.', example='文章摘要'),
    tags?: [ string ](name='Tags', description='The tag name.'),
    title?: string(name='Title', description='The title of the document.', example='标题'),
    url?: string(name='Url', description='The URL of the article. The URL must be accessible over the public network.', example='http://xxx'),
  }(name='Document', description='The document.

This parameter is required.'),
  workspaceId?: string(name='WorkspaceId', description='The unique identifier of the Model Studio workspace. For more information, see [Obtain a workspaceId](https://help.aliyun.com/document_detail/2782167.html).

This parameter is required.', example='llm-xx'),
}

