- text
- binary', example='binary'),
  secretName?: string(name='SecretName', description='The name of the credential.', example='secret001'),
  secretType?: string(name='SecretType', description='The type of the credential. Valid values:
- Generic: generic secret.  
- Rds: RDS credential.  
- Redis: Redis/Tair credential.
- RAMCredentials: RAM credential.  
- ECS: ECS credential.
- PolarDB: PolarDB credential.', example='Generic'),
  versionId?: string(name='VersionId', description='The version number of the credential.', example='v1'),
  versionStages?: {
    versionStage?: [ string ](name='VersionStage')
  }(name='VersionStages'),
}

