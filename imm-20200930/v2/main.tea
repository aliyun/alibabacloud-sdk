  loss?: CustomParams(name='Loss', description='The custom parameters for model training.'),
  name?: string(name='Name', description='The name of the model. The available model names vary with the model category.

This parameter is required.', example='ClsResNet'),
  neck?: CustomParams(name='Neck', description='The custom parameters for model training.'),
  numLandmarks?: long(name='NumLandmarks', description='The number of face landmarks. This parameter is required for face detection. In most cases, you can set the parameter to 5.', example='5'),
