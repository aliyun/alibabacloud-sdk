  name?: string(name='Name', description='The name of the parameter.', example='Normalize'),
  properties?: [
    Property
  ](name='Properties', description='The properties.'),
}

model CustomPrompt {
  roleDefinition?: string(name='RoleDefinition'),
}

model DataIngestion {
  actions?: [ 
    {
      fastFailPolicy?: FastFailPolicy(name='FastFailPolicy', description='The configuration of the fast-fail policy for data processing.'),
      name?: string(name='Name', description='The template name.', example='doc/convert'),
      parameters?: [ string ](name='Parameters', description='The template parameters.'),
    }
  ](name='Actions', description='A list of processing templates.'),
  createTime?: string(name='CreateTime', description='The time when the task was created.', example='2020-11-10T03:50:28Z'),
  error?: string(name='Error', description='The error message.', example='api returns error: SDKError: StatusCode: 404 Code: ResourceNotFound'),
  id?: string(name='Id', description='The unique ID of the data ingestion.', example='trigger-9f72636a-0f0c-4baf-ae78-38b27bfe****'),
  input?: Input(name='Input', description='The data source information.'),
  marker?: string(name='Marker', description='The task execution position.', example='MTIzNDU2Nzg6aW1tdGVzdDpleGFtcGxlYnVja2V0OmRhdGFzZXQwMDE6b3NzOi8vZXhhbXBsZWJ1Y2tldC9zYW1wbGVvYmplY3QxLmpw****'),
  notification?: {
    endpoint?: string(name='Endpoint', description='The MNS Endpoint.', example='http://1111111111.mns.cn-hangzhou.aliyuncs.com'),
    MNS?: MNS(name='MNS', description='MNS'),
    rocketMQ?: RocketMQ(name='RocketMQ', description='RocketMQ'),
    topic?: string(name='Topic', description='The MNS topic.', example='topic1'),
  }(name='Notification', description='The notification for task completion.'),
  phase?: string(name='Phase', description='The scanning phase.', example='IncrementalScanning'),
  serviceRole?: string(name='ServiceRole', description='The service authorization role.', example='AliyunIMMBatchTriggerRole'),
  state?: string(name='State', description='The state of the batch processing task:

- Ready: The task is ready. A newly created task is in the Ready state.

- Running: The task is running. This is the state of a task that is executing normally.

- Failed: The task failed. An error occurred during task execution, and the task cannot be automatically recovered.

- Suspended: The task is paused.

- Succeeded: The task is complete.', example='Succeeded'),
  statistic?: {
    skipFiles?: long(name='SkipFiles', description='The number of skipped files.', example='0'),
    submitFailure?: long(name='SubmitFailure', description='The number of failed submissions.', example='1'),
    submitSuccess?: long(name='SubmitSuccess', description='The number of successful submissions.', example='10'),
  }(name='Statistic', description='The statistics information.'),
  tags?: map[string]any(name='Tags', description='The task tags.'),
  updateTime?: string(name='UpdateTime', description='The time when the task was last updated.', example='2021-12-18T07:40:29Z'),
}

model Dataset {
  bindCount?: long(name='BindCount', description='The number of OSS buckets currently bound to the dataset.', example='2'),
  createTime?: string(name='CreateTime', description='The timestamp when the dataset was created, in RFC3339Nano format.', example='2021-06-29T14:50:13.011643661+08:00'),
  datasetMaxBindCount?: long(name='DatasetMaxBindCount', description='The maximum number of bindings allowed for each dataset.', example='10'),
  datasetMaxEntityCount?: long(name='DatasetMaxEntityCount', description='The maximum number of metadata entities allowed in the dataset.', example='10000000000'),
  datasetMaxFileCount?: long(name='DatasetMaxFileCount', description='The maximum number of files allowed in the dataset.', example='100000000'),
  datasetMaxRelationCount?: long(name='DatasetMaxRelationCount', description='The maximum number of metadata relationships allowed in the dataset.', example='100000000000'),
  datasetMaxTotalFileSize?: long(name='DatasetMaxTotalFileSize', description='The maximum total file size allowed in the dataset, in bytes.', example='90000000000000000'),
  datasetName?: string(name='DatasetName', description='The dataset name.', example='dataset001'),
  description?: string(name='Description', description='The description of the dataset.', example='测试数据集'),
  fileCount?: long(name='FileCount', description='The current number of files in the dataset.', example='10'),
  projectName?: string(name='ProjectName', description='The project name.', example='immtest'),
  templateId?: string(name='TemplateId', description='The workflow template ID.', example='Official:ImageManagement'),
  totalFileSize?: long(name='TotalFileSize', description='The total file size in the dataset, in bytes.', example='100000'),
  updateTime?: string(name='UpdateTime', description='The timestamp when the dataset was last modified, in RFC3339Nano format.

>If the dataset has not been updated since it was created, this timestamp is the same as the creation timestamp.', example='2021-06-29T14:50:13.011643661+08:00'),
  workflowParameters?: [
    WorkflowParameter
  ](name='WorkflowParameters', description='The custom parameters.', deprecated=true, nullable=true),
}

