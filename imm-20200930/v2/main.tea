  insights?: InsightsConfig(name='Insights', description='The content awareness configuration.'),
  reverseImage?: ReverseImageConfig(name='ReverseImage'),
  smartCluster?: SmartClusterConfig(name='SmartCluster', description='The intelligent clustering configuration.'),
}

model DatasetTaskStatus {
  lastSucceededTime?: string(name='LastSucceededTime', description='The time of the last completion.', example='2024-06-29T14:50:13.011643661+08:00'),
  startTime?: string(name='StartTime', description='The start time of the task.', example='2024-06-29T14:50:13.011643661+08:00'),
  status?: string(name='Status', description='The status of the task.', example='Succeeded'),
}

model DocumentChapterSummarizeOption {
  limit?: int32(name='Limit', description='The number of section-by-section summaries. If neither Marker nor Index is specified, the entire article is summarized by default. Marker and Index must either both be specified or both be omitted.', example='5'),
  marker?: int32(name='Marker', description='The start position for section-by-section summarization.', example='0'),
  version?: string(name='Version', description='The version of section-by-section summarization.', example='v1'),
}

model DocumentChapterSummary {
  data?: [
    ChapterSummary
  ](name='Data'),
  nextMarker?: int32(name='NextMarker'),
  version?: string(name='Version'),
}

model DocumentParseKeywordOption {
  count?: int32(name='Count', description='The number of keywords to extract. The value must be an integer from 0 to 10.', example='1'),
  extract?: boolean(name='Extract', description='Specifies whether to extract keywords.'),
}

model DocumentParseNarratorOption {
  narrate?: boolean(name='Narrate', description='The summary of the document.'),
}

model DocumentParseOption {
  keyword?: DocumentParseKeywordOption(name='Keyword', description='Document parsing keyword extraction options'),
  narrator?: DocumentParseNarratorOption(name='Narrator', description='Document parsing guidance options'),
  question?: DocumentParseQuestionOption(name='Question', description='Document parsing question generation options'),
  summary?: DocumentParseSummaryOption(name='Summary', description='Document parsing summary options'),
}

model DocumentParseQuestionOption {
  count?: int32(name='Count', description='Number of questions (range: 0 to 10)', example='1'),
  extract?: boolean(name='Extract', description='Whether to extract'),
}

model DocumentParseSummaryOption {
  chapterSummarize?: boolean(name='ChapterSummarize', description='Document chapter summary'),
  summarize?: boolean(name='Summarize', description='Article summary'),
}

model DocumentReadKeywordOption {
  count?: int32(name='Count', description='The number of keywords. Valid values: 0 to 10.', example='1'),
  extract?: boolean(name='Extract', description='Specifies whether to extract keywords.', example='true'),
}

model DocumentReadNarratorOption {
  narrate?: boolean(name='Narrate', description='Specifies whether to fetch.', example='true'),
}

model DocumentReadOption {
  keyword?: DocumentReadKeywordOption(name='Keyword', description='The document intensive reading keyword extraction options.'),
  narrator?: DocumentReadNarratorOption(name='Narrator', description='The document intensive reading guide options.'),
  question?: DocumentReadQuestionOption(name='Question', description='The document intensive reading question guide options.'),
  summary?: DocumentReadSummaryOption(name='Summary', description='The document intensive reading summary options.'),
}

model DocumentReadQuestionOption {
  count?: int32(name='Count'),
  extract?: boolean(name='Extract'),
}

model DocumentReadSummaryOption {
  chapterSummarize?: boolean(name='ChapterSummarize', description='Specifies whether to extract the chapter-level summary of the article.', example='true'),
  chapterSummarizeOption?: DocumentChapterSummarizeOption(name='ChapterSummarizeOption', description='The chapter-level summary options for the article.'),
  summarize?: boolean(name='Summarize', description='Specifies whether to extract the article summary.', example='true'),
}

model Element {
  elementContents?: [
    ElementContent
  ](name='ElementContents', description='The element contents.'),
  elementRelations?: [
    ElementRelation
  ](name='ElementRelations', description='The relationships between the current element and other elements.'),
  elementType?: string(name='ElementType', description='The element type.', example='title - 标题； image - 图片 ； table - 表格 ； narrative-text - 正文'),
  objectId?: string(name='ObjectId', description='The unique ID of the element.', example='id1'),
  semanticSimilarity?: float(name='SemanticSimilarity', description='The similarity between the current file and its extracted semantics.', example='0.8'),
}

model ElementContent {
  content?: string(name='Content', description='The content of the element.

If the value of the Type parameter is image or link, this parameter indicates the placeholder text.', example='文本片段'),
  timeRange?: [ long ](name='TimeRange', description='The time range. The array length is fixed to 2. One element indicates the start time and the other one indicates the end time. Unit: milliseconds.'),
  type?: string(name='Type', description='The type of the element content.

Valid values:

*   text
*   image
*   link', example='text'),
  URL?: string(name='URL', description='The link to the element content. This parameter takes effect only if the Type parameter is set to image or link.', example='http://aliyun.com'),
}

model ElementRelation {
  objectId?: string(name='ObjectId', description='The ID of the element.', example='id1'),
  type?: string(name='Type', description='The type.', example='child，parent'),
}

model FastFailPolicy {
  action?: string(name='Action', description='The action when the batch processor or trigger encounters an error.

Enumerated values:

*   abort: stops running.
*   ignore: ignores the error and keeps running.', example='abort'),
}

model Figure {
  age?: long(name='Age', description='The age.', example='29'),
  ageSD?: float(name='AgeSD', description='The age standard deviation.', example='5'),
  attractive?: float(name='Attractive', description='The face attractiveness score. A higher score indicates greater attractiveness. Valid values: 0 to 1.', example='0.96'),
  beard?: string(name='Beard', description='Indicates whether the person has a beard.', example='none'),
  beardConfidence?: float(name='BeardConfidence', description='The confidence score for whether the person has a beard. Valid values: 0 (lowest confidence) to 1 (highest confidence).', example='1'),
  boundary?: Boundary(name='Boundary', description='The face boundary information.'),
  emotion?: string(name='Emotion', description='The emotion.', example='happiness'),
  emotionConfidence?: float(name='EmotionConfidence', description='The emotion confidence score. Valid values: 0 (lowest confidence) to 1 (highest confidence).', example='0.707845687866210'),
  faceQuality?: float(name='FaceQuality', description='The face quality score, which evaluates whether the image quality is suitable for face recognition. A higher score indicates better quality. Valid values: 0 to 1.', example='0.960875928401947'),
  figureClusterConfidence?: float(name='FigureClusterConfidence', description='The clustering confidence score. Valid values: 0 (lowest confidence) to 1 (highest confidence).', example='1'),
  figureClusterId?: string(name='FigureClusterId', description='The figure cluster ID. The following reserved special cluster ID names are included:

- figure-cluster-id-independent: The face does not currently belong to any suitable group. After new images are added to the dataset and face clustering is performed, the face may be assigned to a group.

- figure-cluster-id-unavailable: The face has not been clustered yet. This means that after new images were added to the dataset, face clustering has not been performed.', example='Cluster-dbe72fec-b84c-4ab6-885b-3678e64****'),
  figureConfidence?: float(name='FigureConfidence', description='The confidence score of the figure object. Valid values: 0 (lowest confidence) to 1 (highest confidence).', example='1'),
  figureId?: string(name='FigureId', description='The ID of the figure object.', example='868a9e74-cde5-4c7a-9013-28bb984****'),
  figureType?: string(name='FigureType', description='The figure type.', example='face'),
  gender?: string(name='Gender', description='The gender.', example='female'),
  genderConfidence?: float(name='GenderConfidence', description='The gender confidence score. Valid values: 0 (lowest confidence) to 1 (highest confidence).', example='1'),
  glasses?: string(name='Glasses', description='Indicates whether the person is wearing glasses.', example='none'),
  glassesConfidence?: float(name='GlassesConfidence', description='The confidence score for whether the person is wearing glasses. Valid values: 0 (lowest confidence) to 1 (highest confidence).', example='0.8'),
  hat?: string(name='Hat', description='Indicates whether the person is wearing a hat.', example='none'),
  hatConfidence?: float(name='HatConfidence', description='The confidence score for whether the person is wearing a hat. Valid values: 0 (lowest confidence) to 1 (highest confidence).', example='1'),
  headPose?: HeadPose(name='HeadPose', description='The head pose information.'),
  mask?: string(name='Mask', description='Indicates whether the person is wearing a mask.', example='none'),
  maskConfidence?: float(name='MaskConfidence', description='The confidence score for whether the person is wearing a mask. Valid values: 0 (lowest confidence) to 1 (highest confidence).', example='1'),
  mouth?: string(name='Mouth', description='Indicates whether the mouth is open.', example='close'),
  mouthConfidence?: float(name='MouthConfidence', description='The confidence score for whether the mouth is open. Valid values: 0 (lowest confidence) to 1 (highest confidence).', example='1'),
  sharpness?: float(name='Sharpness', description='The sharpness score. A higher score indicates a clearer face. Valid values: 0 to 1.', example='0.7'),
}

model FigureCluster {
  averageAge?: float(name='AverageAge', description='The average age.', example='26'),
  cover?: File(name='Cover', description='The cover image.'),
  createTime?: string(name='CreateTime', description='The creation time.', example='2022-01-14T10:10:52.83948013+08:00'),
  customId?: string(name='CustomId', description='The custom ID.', example='abc'),
  customLabels?: map[string]any(name='CustomLabels', description='The custom labels. You can search for clusters by label.', example='{"Bucket": "examplebucket"}'),
  datasetName?: string(name='DatasetName', description='The name of the dataset.', example='dataset001'),
  faceCount?: long(name='FaceCount', description='The number of faces.', example='3'),
  gender?: string(name='Gender', description='The gender.', example='female'),
  imageCount?: long(name='ImageCount', description='The number of images.', example='5'),
  maxAge?: float(name='MaxAge', description='The maximum age.', example='44'),
  metaLockVersion?: long(name='MetaLockVersion', description='The version of the metadata lock. A metadata lock version can be obtained by using a get or list operation. If you include the MetaLockVersion parameter in a request to update the cluster, the server checks consistency between the MetaLockVersion parameter value sent in the request and the one on the server side and updates the cluster only when they are consistent. This parameter prevents update conflicts in concurrent scenarios. The initial version is 0. The version is automatically increased by 1 after each successful update.', example='0'),
  minAge?: float(name='MinAge', description='The minimum age.', example='12'),
  name?: string(name='Name', description='The name of the cluster.', example='abc'),
  objectId?: string(name='ObjectId', description='The ID of the cluster.', example='Cluster-ae6e3472-999e-410b-b54e-cd5dba****'),
  objectType?: string(name='ObjectType', description='The type of the cluster.', example='figure-cluster'),
  ownerId?: string(name='OwnerId', description='The user ID.', example='102321002****'),
  projectName?: string(name='ProjectName', description='The name of the project.', example='immtest'),
  updateTime?: string(name='UpdateTime', description='The update time.', example='2022-01-14T10:10:52.83948013+08:00'),
  videoCount?: long(name='VideoCount', description='The number of videos.', example='3'),
}

model FigureClusterConfig {
  autoClustering?: boolean(name='AutoClustering', description='Whether to automatically group similar figures into clusters.'),
  autoGenerate?: boolean(name='AutoGenerate', description='Whether to automatically generate metadata for each cluster, such as a representative cover image.'),
  enabledFeatures?: [ string ](name='EnabledFeatures', description='An array of strings specifying the clustering strategies to use.'),
  minEntityCount?: long(name='MinEntityCount', description='The minimum number of figures required to form a cluster.'),
}

model FigureClusterForReq {
  cover?: {
    figures?: [ 
      {
        figureId?: string(name='FigureId', description='The figure ID.', example='2cb3c51e-b406-4b0c-af1b-897d88e1****'),
      }
    ](name='Figures', description='The figure list.'),
  }(name='Cover', description='The cover of the cluster.'),
  customId?: string(name='CustomId', description='The custom ID.', example='abc'),
  customLabels?: map[string]any(name='CustomLabels', description='A key-value map of custom labels that can be used to search for the figure cluster.', example='{"Bucket": "examplebucket"}'),
  metaLockVersion?: long(name='MetaLockVersion', description='The metadata lock version. This parameter enables optimistic locking to prevent conflicting updates during high concurrency. To ensure data consistency, pass the current MetaLockVersion value when updating a figure cluster. You can retrieve this value from a Get or List operation. The service proceeds with the update only if the provided version matches the system\\\\"s current version. The initial value is 0 and is incremented by 1 after each successful update.', example='1'),
  name?: string(name='Name', description='The cluster name.', example='abc'),
  objectId?: string(name='ObjectId', description='The object ID of the cluster.', example='Cluster-99b1c333-86dc-45da-8c6****'),
}

model File {
  accessControlAllowOrigin?: string(name='AccessControlAllowOrigin', description='The allowed origins for cross-origin requests.', example='https://aliyundoc.com'),
  accessControlRequestMethod?: string(name='AccessControlRequestMethod', description='The allowed methods for the cross-origin request.', example='PUT'),
  addresses?: [
    Address
  ](name='Addresses', description='The address information.'),
  album?: string(name='Album', description='The album.', example='FirstAlbum'),
  albumArtist?: string(name='AlbumArtist', description='The album artist.', example='Jane'),
  artist?: string(name='Artist', description='The artist.', example='Jane'),
  audioCovers?: [
    Image
  ](name='AudioCovers', description='The cover images for the audio.'),
  audioStreams?: [
    AudioStream
  ](name='AudioStreams', description='A list of audio streams.'),
  bitrate?: long(name='Bitrate', description='The bitrate, in bit/s.', example='13091201'),
  cacheControl?: string(name='CacheControl', description='The web cache behavior that the browser should use when the object is downloaded.

This parameter is returned only if the Cache-Control HTTP header is set for the OSS object. For more information, see [Manage object metadata](https://help.aliyun.com/document_detail/31859.html).', example='no-cache'),
  composer?: string(name='Composer', description='The composer.', example='Jane'),
  contentDisposition?: string(name='ContentDisposition', description='The name of the object when it is downloaded.

This parameter is returned only if the Content-Disposition HTTP header is set for the OSS object. For more information, see [Manage object metadata](https://help.aliyun.com/document_detail/31859.html).', example='attachment; filename =test.jpg'),
  contentEncoding?: string(name='ContentEncoding', description='The content encoding format of the object when it is downloaded.

This parameter is returned only if the Content-Encoding HTTP header is set for the OSS object. For more information, see [Manage object metadata](https://help.aliyun.com/document_detail/31859.html).', example='UTF-8'),
  contentLanguage?: string(name='ContentLanguage', description='The language of the object content.

This parameter is returned only if the Content-Language HTTP header is set for the OSS object. For more information, see [Manage object metadata](https://help.aliyun.com/document_detail/31859.html).', example='zh-CN'),
  contentMd5?: string(name='ContentMd5', description='The MD5 hash of the object content.', example='HZwoCnxPZ/fvhz4oRJ2+Fw=='),
  contentType?: string(name='ContentType', description='The content type of the file (MIME type).', example='image/jpeg'),
  createTime?: string(name='CreateTime', description='The time when the metadata was created. The time is in the RFC3339Nano format.', example='2021-06-29T14:50:13.011643661+08:00'),
  croppingSuggestions?: [
    CroppingSuggestion
  ](name='CroppingSuggestions', description='The cropping suggestions for the image.

> This feature is not supported.'),
  customId?: string(name='CustomId', description='The custom ID of the file, which you can use to associate the file with an ID in your business system. When the file is indexed into a dataset, this ID is stored as a metadata attribute. We recommend using a globally unique value.', example='member-image-id-0001'),
  customLabels?: map[string]any(name='CustomLabels', description='Custom key-value labels for the file. This parameter is optional and can be used to store business-specific data and to filter queries.', example='{
      "MemberName": "Tim",
      "Enabled": "True",
      "ItemCount": "10"
}'),
  datasetName?: string(name='DatasetName', description='The dataset name. For more information, see [Create a dataset](https://help.aliyun.com/document_detail/478160.html).', example='test-dataset'),
  duration?: double(name='Duration', description='The total duration of the video, in seconds.', example='15.263000'),
  ETag?: string(name='ETag', description='An ETag is generated when an object is created. The ETag identifies the content of an object.', example='"1D9C280A7C4F67F7EF873E28449****"'),
  EXIF?: string(name='EXIF', description='The original EXIF information of the image, stored as a serialized JSON object. For more information, see [Obtain image information](https://help.aliyun.com/document_detail/44975.html).', example='{"Compression":{"value":"6"},"DateTime":{"value":"2020:08:19 17:11:11"}}'),
  elements?: [
    Element
  ](name='Elements', description='A list of document fragments that match the current search content when you use the SemanticQuery API to perform a semantic search.'),
  figureCount?: long(name='FigureCount', description='The number of figures.', example='10'),
  figures?: [
    Figure
  ](name='Figures', description='A list of figures detected by the AI model.'),
  fileAccessTime?: string(name='FileAccessTime', description='The time when the file was last accessed. The time is in the RFC3339Nano format.', example='2021-06-29T14:50:13.011643661+08:00'),
  fileCreateTime?: string(name='FileCreateTime', description='The time when the file was created. The time is in the RFC3339Nano format.', example='2021-06-29T14:50:13.011643661+08:00'),
  fileHash?: string(name='FileHash', description='The hash of the file.', example='1d9c280a7c4f67f7ef873e28449dbe17'),
  fileModifiedTime?: string(name='FileModifiedTime', description='The time when the file was last modified. The time is in the RFC3339Nano format.', example='2021-06-29T14:50:13.011643661+08:00'),
  filename?: string(name='Filename', description='The name of the file. For an OSS object, this parameter is the ObjectKey.', example='sampleobject.jpg'),
  formatLongName?: string(name='FormatLongName', description='The full name of the media format.', example='QuickTime / MOV'),
  formatName?: string(name='FormatName', description='The name of the media format.', example='mov'),
  imageHeight?: long(name='ImageHeight', description='The height of the image, in pixels (px).', example='500'),
  imageScore?: ImageScore(name='ImageScore', description='The image score information, detected by an AI model.'),
  imageWidth?: long(name='ImageWidth', description='The width of the image, in pixels (px).', example='270'),
  insights?: Insights(name='Insights', description='Summary and description of the file.

> Currently not supported', nullable=true),
  labels?: [
    Label
  ](name='Labels', description='A list of AI-detected labels for the file.'),
  language?: string(name='Language', description='The language in BCP 47 format.', example='eng'),
  latLong?: string(name='LatLong', description='The GPS latitude and longitude.', example='30.134390,120.074997'),
  mediaType?: string(name='MediaType', description='The media type of the file.', example='image'),
  OCRContents?: [
    OCRContents
  ](name='OCRContents', description='The OCR results.

> This feature is not supported.'),
  OCRTexts?: string(name='OCRTexts', description='The text detected in the image.', example='阿里云IMM'),
  OSSCRC64?: string(name='OSSCRC64', description='The CRC-64 value of the object.', example='559890638950338001'),
  OSSDeleteMarker?: string(name='OSSDeleteMarker', description='The OSS delete marker.', example='CAEQMhiBgIDXiaaB0BYiIGQzYmRkZGUxMTM1ZDRjOTZhNjk4YjRjMTAyZjhl****'),
  OSSExpiration?: string(name='OSSExpiration', description='The expiration time of the OSS object.

This parameter is returned only if the Expires HTTP header is set for the OSS object. For more information, see [Manage object metadata](https://help.aliyun.com/document_detail/31859.html).', example='2120-01-01T12:00:00.000Z'),
  OSSObjectType?: string(name='OSSObjectType', description='The type of the OSS object. A common value is `Normal`.', example='Normal'),
  OSSStorageClass?: string(name='OSSStorageClass', description='The storage class of the OSS object.', example='Standard'),
  OSSTagging?: map[string]any(name='OSSTagging', description='The tags of the OSS object.

For more information, see [Object tagging](https://help.aliyun.com/document_detail/106678.html).', example='{"key": "val"}'),
  OSSTaggingCount?: long(name='OSSTaggingCount', description='The number of tags on the OSS object.

This parameter is returned only if tags are set for the OSS object. For more information, see [Object tagging](https://help.aliyun.com/document_detail/106678.html).', example='2'),
  OSSURI?: string(name='OSSURI', description='The URI of the OSS file. This parameter is returned only if the URI is a PDS address.', example='oss://examplebucket/sampleobject.jpg'),
  OSSUserMeta?: map[string]any(name='OSSUserMeta', description='The user-defined metadata of the OSS object.

This parameter is returned only if user-defined metadata is set for the OSS object. For more information, see [Manage object metadata](https://help.aliyun.com/document_detail/31859.html).', example='{"key": "val"}'),
  OSSVersionId?: string(name='OSSVersionId', description='The version ID of the OSS object.

This parameter is returned only if versioning is enabled for the bucket. For more information, see [Overview of versioning](https://help.aliyun.com/document_detail/109695.html).', example='CAEQNhiBgMDJgZCA0BYiIDc4MGZjZGI2OTBjOTRmNTE5NmU5NmFhZjhjYmY0****'),
  objectACL?: string(name='ObjectACL', description='The access control list (ACL) of the OSS object.', example='default'),
  objectId?: string(name='ObjectId', description='The unique ID of the object.', example='75d5de2c50754e3dadd5c35dbca5f9949369e37eb342a73821f690c94c36c7f7'),
  objectStatus?: string(name='ObjectStatus', description='File index status.', example='Indexed'),
  objectType?: string(name='ObjectType', description='The type of the object. The value is always **file**.', example='file'),
  orientation?: long(name='Orientation', description='The rotation value of the image, read from its EXIF data.

This parameter is returned only if this value is available in the EXIF data.', example='0'),
  ownerId?: string(name='OwnerId', description='The ID of the Alibaba Cloud account.', example='102321002467****'),
  pageCount?: long(name='PageCount', description='The number of pages.

> This feature is not supported.', example='5'),
  performer?: string(name='Performer', description='The performer.', example='Jane'),
  produceTime?: string(name='ProduceTime', description='The time when the photo was taken.', example='2021-06-29T14:50:13.011643661+08:00'),
  programCount?: long(name='ProgramCount', description='The number of programs in the media container.', example='1'),
  projectName?: string(name='ProjectName', description='The project name. For more information, see [Create a project](https://help.aliyun.com/document_detail/478153.html).', example='test-project'),
  reason?: string(name='Reason', description='The reason the file failed to be indexed.', example='[InternalError] The request has been failed due to some unknown error. status: 500, requestId: CC5ACFBD-BB7A-496D-A9D6-****'),
  sceneElements?: [
    SceneElement
  ](name='SceneElements', description='A list of scene elements extracted from the video by the AI model during analysis.'),
  semanticTypes?: [ string ](name='SemanticTypes', description='Indicates why this file was returned when you use the SemanticQuery API to perform a semantic search.'),
  serverSideDataEncryption?: string(name='ServerSideDataEncryption', description='The encryption algorithm of the object.

This parameter is returned only if server-side encryption is enabled for the bucket. For more information, see [Server-side encryption](https://help.aliyun.com/document_detail/31871.html).', example='SM4'),
  serverSideEncryption?: string(name='ServerSideEncryption', description='The server-side encryption method.

This parameter is returned only if server-side encryption is enabled for the bucket. For more information, see [Server-side encryption](https://help.aliyun.com/document_detail/31871.html).', example='AES256'),
  serverSideEncryptionCustomerAlgorithm?: string(name='ServerSideEncryptionCustomerAlgorithm', description='The encryption algorithm used for server-side encryption with customer-provided keys.', example='SM4'),
  serverSideEncryptionKeyId?: string(name='ServerSideEncryptionKeyId', description='The ID of the customer master key (CMK) that is managed by KMS.

This parameter is returned only if server-side encryption is enabled for the bucket. For more information, see [Server-side encryption](https://help.aliyun.com/document_detail/31871.html).', example='9468da86-3509-4f8d-a61e-6eab1eac****'),
  size?: long(name='Size', description='The size of the file, in bytes.', example='1000'),
  startTime?: double(name='StartTime', description='The start time of the first frame, in seconds.', example='0.000000'),
  streamCount?: long(name='StreamCount', description='The number of media streams in the media container.', example='1'),
  subtitles?: [
    SubtitleStream
  ](name='Subtitles', description='A list of subtitle streams.'),
  timezone?: string(name='Timezone', description='The timezone.

> This feature is not supported.', example='""'),
  title?: string(name='Title', description='The title of the file.', example='test'),
  travelClusterId?: string(name='TravelClusterId', description='A reserved parameter.

> This feature is not supported.', example='-'),
  URI?: string(name='URI', description='The address of the file.

An OSS URI must be in the `oss://${Bucket}/${Object}` format, where `${Bucket}` is the name of the bucket in the same region as the current project and `${Object}` is the full path to the object, including the file extension.

A PDS URI must be in the `pds://domains/${domain}/drives/${drive}/files/${file}/revisions/${revision}` format.', example='oss://test-bucket/test-object.jpg'),
  updateTime?: string(name='UpdateTime', description='The time when the metadata was last updated. The time is in the RFC3339Nano format.', example='2021-06-29T14:50:13.011643661+08:00'),
  videoHeight?: long(name='VideoHeight', description='The height of the video, in pixels (px).', example='1920'),
  videoStreams?: [
    VideoStream
  ](name='VideoStreams', description='A list of video streams.'),
  videoWidth?: long(name='VideoWidth', description='The width of the video, in pixels (px).', example='1080'),
}

model FileSmartCluster {
  similarity?: float(name='Similarity', description='Similarity', example='0.9'),
  smartClusterId?: string(name='SmartClusterId', description='SmartClusterId', example='SmartCluster-12cd1645-deae-4b5e-9434-613747b75f6d'),
}

model FunctionCall {
  arguments?: string(name='Arguments', description='The parameters detected by the large language model.', example='{
                    "type": "object",
                        "name": {
                            "type": "string", 
                            "description": "需要检索的文件的文件名。可以为空 null"
                        }, 
                    "required": [
                        "category"
                    ]
}'),
  name?: string(name='Name', description='The function name.

This parameter is required.', example='search_file'),
}

model GetDocumentAnalysisOption {
  chapterSummary?: boolean(name='ChapterSummary', description='Specifies whether to retrieve chapter-by-chapter summaries of the document.', example='false'),
  chapterSummaryOption?: DocumentChapterSummarizeOption(name='ChapterSummaryOption', description='The options for retrieving chapter-by-chapter summaries of the document.'),
  images?: boolean(name='Images', description='Specifies whether to retrieve images extracted from the document, such as pictures, tables, and formulas.', example='false'),
  keyword?: boolean(name='Keyword', description='Specifies whether to retrieve keywords.', example='false'),
  layouts?: boolean(name='Layouts', description='Specifies whether to retrieve the layout.jsonl file.', example='false'),
  narrator?: boolean(name='Narrator', description='Specifies whether to retrieve the document reading guide results.', example='false'),
  question?: boolean(name='Question', description='Specifies whether to retrieve the generated questions and corresponding answers.', example='false'),
  summary?: boolean(name='Summary', description='Specifies whether to retrieve the full-text summary.', example='true'),
}

model GetVideoAnalysisOption {
  chapterSummary?: boolean(name='ChapterSummary', description='Specifies whether to retrieve the chapter-based summary of the video.', example='false'),
  keyword?: boolean(name='Keyword', description='Specifies whether to retrieve keywords.', example='false'),
  PPT?: boolean(name='PPT', description='Specifies whether to retrieve the PPT from the video. Default value: false.', example='false'),
  question?: boolean(name='Question', description='Specifies whether to retrieve the generated questions and corresponding answers.', example='false'),
  summary?: boolean(name='Summary', description='Specifies whether to retrieve the full-text summary.', example='false'),
  transcript?: boolean(name='Transcript', description='Specifies whether to retrieve the dialogue in the video. Default value: false.', example='false'),
  transcriptChapterSummary?: boolean(name='TranscriptChapterSummary', description='Specifies whether to retrieve the segmented summary generated from the dialogue in the video. Default value: false.', example='false'),
  transcriptSummary?: boolean(name='TranscriptSummary', description='Specifies whether to retrieve the summary generated from the dialogue in the video. Default value: false.', example='false'),
}

model GuidingQuestion {
  answer?: string(name='Answer', description='The answer.', example='"将场景文本检测和布局分析统一起来是重要的，因为这两个任务虽然在文献中通常被独立研究，但实际上是紧密相关的。"'),
  question?: string(name='Question', description='The question.', example='"为什么将场景文本检测和布局分析统一起来是重要的？"'),
}

model HeadPose {
  pitch?: float(name='Pitch', description='The angel of elevation or depression of the head. Unit: degree. Valid values: -180 to 180. A recommended range for reliable results is from -30 to 30.', example='18.385589599609375'),
  roll?: float(name='Roll', description='The angle of the tilt to the side. Unit: degree. Valid values: -180 to 180. A recommended range for reliable results is from -45 to 45.', example='4.204030513763428'),
  yaw?: float(name='Yaw', description='The angle of leftward or rightward rotation of the head. Unit: degree. Valid values: -180 to 180. A recommended range for reliable results is from -80 to 80.', example='2.4945924282073975'),
}

model Hyperparameters {
  backupInterval?: long(name='BackupInterval', description='The frequency at which the model configuration is saved. If you set this parameter to 1, model configuration is saved every epoch.', example='1'),
  batchSize?: long(name='BatchSize', description='The batch size for model training.', example='32'),
  dataLoaderWorkers?: long(name='DataLoaderWorkers', description='The number of threads used to read the training data.', example='4'),
  evaluator?: CustomParams(name='Evaluator', description='The custom parameters for model training.

This parameter is required.'),
  inputSize?: [ long ](name='InputSize', description='The image size. The array contains the width and height of the image.

This parameter is required.'),
  maxEpoch?: long(name='MaxEpoch', description='The number of epochs.', example='10'),
  optimization?: Optimization(name='Optimization', description='The optimization algorithm.'),
  schedule?: Schedule(name='Schedule', description='The learning rate scheduler.'),
}

model Illustration {
  imageIndex?: int32(name='ImageIndex', description='The index of the image.', example='0'),
  imagePath?: string(name='ImagePath', description='The relative path of the image.', example='"imgs/page_0_img_image_box_770_540_1367_860.png"'),
  normalizedBox?: [ float ](name='NormalizedBox', description='The normalized coordinate of the image on the page.'),
  pageNumber?: int32(name='PageNumber', description='The page number where the image is located.', example='1'),
  text?: string(name='Text', description='The text result recognized by optical character recognition (OCR) from the image.', example='"图片"'),
  type?: string(name='Type', description='The type of the image.', example='image、table、code'),
}

model Image {
  croppingSuggestions?: [
    CroppingSuggestion
  ](name='CroppingSuggestions', description='The image cropping suggestions. This parameter is reserved and not available.'),
  EXIF?: string(name='EXIF', description='The original EXIF information about the image. The EXIF information is stored in the serialized JSON format. For more information, see [Query image information](https://help.aliyun.com/document_detail/44975.html).', example='{"FileSize":{"value":"29304"},"Format":{"value":"jpg"}}'),
  imageHeight?: long(name='ImageHeight', description='The height of the image. Unit: pixels.', example='820'),
  imageScore?: ImageScore(name='ImageScore', description='The image scoring information.'),
  imageWidth?: long(name='ImageWidth', description='The width of the image. Unit: pixels.', example='500'),
  OCRContents?: [
    OCRContents
  ](name='OCRContents', description='The results of optical character recognition (OCR). This parameter is reserved and not available.'),
}

model ImageInsight {
  caption?: string(name='Caption', description='Image summary.

>  Not supported.', example='无。', nullable=true),
