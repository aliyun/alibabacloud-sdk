model ClusterForReq {
  cover?: {
    figures?: [ 
      {
        figureId?: string(name='FigureId', description='The person ID.', example='2cb3c51e-b406-4b0c-af1b-897d88e1****'),
      }
    ](name='Figures', description='The persons.'),
  }(name='Cover', description='The cover.'),
  customId?: string(name='CustomId', description='The custom ID.', example='abc'),
  customLabels?: map[string]any(name='CustomLabels', description='The custom labels.', example='{"Bucket": "examplebucket"}'),
  name?: string(name='Name', description='The name of the cluster.', example='abc'),
  objectId?: string(name='ObjectId', description='The ID of the cluster.', example='Cluster-99b1c333-86dc-45da-8c6****'),
}

model Codes {
  boundary?: Boundary(name='Boundary', description='The boundary of the code.'),
  confidence?: float(name='Confidence', description='The confidence level of the code. A greater value indicates a higher confidence level. A value exceeding 0.8 signifies a high degree of confidence in the result.', example='0.9'),
  content?: string(name='Content', description='The content of the code.', example='https://www.example.com'),
  type?: string(name='Type', description='The type of the code.

Enumerated values:

*   qrcode
*   barcode', example='qrcode'),
}

model ContextualFile {
  contentType?: string(name='ContentType', description='The Multipurpose Internet Mail Extensions (MIME) type of the file.', example='text/x-imm-faq'),
  datasetName?: string(name='DatasetName', description='The dataset name.', example='test-dataset'),
  elements?: [
    Element
  ](name='Elements', description='Elements.'),
  mediaType?: string(name='MediaType', description='The media type of the file.', example='document'),
  OSSURI?: string(name='OSSURI', description='The URI path of the OSS file. This parameter is used only when the URI is a PDS address.', example='oss://test-bucket/test-object.jpg'),
  objectId?: string(name='ObjectId', description='The identifier of the file in the dataset.', example='0939d7ed-73fa-4009-bbe6-fbbe07b92b2e'),
  ownerId?: string(name='OwnerId', description='The user ID.', example='1482910009923706'),
  projectName?: string(name='ProjectName', description='The project name.', example='test-project'),
  URI?: string(name='URI', description='The URI of the file.
The format of an OSS URI is oss\\\\://${bucketname}/${objectname}. ${bucketname} is the name of an OSS bucket in the same region as the current project. ${objectname} is the file path.
The format of a PDS URI is pds\\\\://domains/${domain}/drives/${drive}/files/${file}/revisions/${revision}.', example='oss://test-bucket'),
}

model ContextualMessage {
  content?: string(name='Content', description='The message content.', example='你好'),
  files?: [
    ContextualFile
  ](name='Files', description='The files involved in the dialogue.'),
  role?: string(name='Role', description='The role in the dialogue.', example='user'),
}

model CredentialConfig {
  chain?: [ 
    {
      assumeRoleFor?: string(name='AssumeRoleFor', description='The ID of the account that you use to grant permissions.', example='10232100246xxxxx'),
      role?: string(name='Role', description='The RAM role that can be assumed.', example='AliyunOSSRole'),
      roleType?: string(name='RoleType', description='The role type. Valid values:

*   user: Alibaba Cloud account.
*   service: Alibaba Cloud service.', example='user'),
    }
  ](name='Chain', description='The authorization chains. All roles in the array must have the `sts:AssumeRole` permission. You need to only grant other permissions, such as read and write permissions on OSS, to the last role in the array. You can grant permissions in the RAM console.'),
  policy?: string(name='Policy', description='The policy that is attached to the role specified by the ServiceRole parameter. For example, the policy allows access to OSS. This parameter is optional.', example='{"Statement": [{"Action": "oss:*","Effect": "Allow","Resource": "*"}],"Version": "1"}'),
  serviceRole?: string(name='ServiceRole', description='The service role in the account that is used to call an IMM API operation. The role must have the `sts:AssumeRole` permission. You can configure permissions for the role in the Resource Access Management (RAM) console.', example='AliyunSTSAssumeForIMMServiceRole'),
}

model CroppingSuggestion {
