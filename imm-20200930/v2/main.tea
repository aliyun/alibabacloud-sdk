  objectStatus?: string(name='ObjectStatus', description='The status of the grouping.', example='Succeeded'),
  objectType?: string(name='ObjectType', description='The grouping type.', example='smart-cluster'),
  ownerId?: string(name='OwnerId', description='The user ID.', example='1023210024677934'),
  projectName?: string(name='ProjectName', description='The project name.', example='MyProject'),
  reason?: string(name='Reason', description='The reason why the grouping failed.', example='[InvalidArgument.BaseURIs] Each BaseURI must contain exactly one figure'),
  rule?: SmartClusterRule(name='Rule', description='The grouping rule. This parameter is deprecated. Use the Rules parameter instead.'),
  rules?: [
    SmartClusterRule
  ](name='Rules', description='The list of grouping rules.'),
  updateTime?: string(name='UpdateTime', description='The time when the grouping was last updated.', example='2022-01-14T10:17:18.102700407+08:00'),
}

