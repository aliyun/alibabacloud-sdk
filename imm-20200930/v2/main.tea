  projectName?: string(name='ProjectName', description='The name of the project.', example='immtest'),
  storyEndTime?: string(name='StoryEndTime', description='The time when the story ends.', example='2022-01-14T10:17:18.102700407+08:00'),
  storyName?: string(name='StoryName', description='The name of the story.', example='name1'),
  storyStartTime?: string(name='StoryStartTime', description='The time when the story starts.', example='2022-01-14T10:17:18.102700407+08:00'),
  storySubType?: string(name='StorySubType', description='The subtype of the story.', example='ImportantPerson'),
  storyType?: string(name='StoryType', description='The story type.', example='PeopleMemory'),
