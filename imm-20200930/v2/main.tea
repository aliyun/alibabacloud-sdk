/**
 *
 */
import OpenApi;
import OpenApi.OpenApiUtil;

extends OpenApi;


init(config: OpenApiUtil.Config){
  super(config);
  @endpointRule = 'regional';
  @endpointMap = {
    'cn-beijing-gov-1' = 'imm-vpc.cn-beijing-gov-1.aliyuncs.com',
    'us-west-1' = 'imm.us-west-1.aliyuncs.com',
    'us-east-1' = 'imm.us-east-1.aliyuncs.com',
    'eu-west-1' = 'imm.eu-west-1.aliyuncs.com',
    'eu-central-1' = 'imm.eu-central-1.aliyuncs.com',
    'cn-zhangjiakou' = 'imm.cn-zhangjiakou.aliyuncs.com',
    'cn-wulanchabu' = 'imm.cn-wulanchabu.aliyuncs.com',
    'cn-shenzhen' = 'imm.cn-shenzhen.aliyuncs.com',
    'cn-shanghai' = 'imm.cn-shanghai.aliyuncs.com',
    'cn-qingdao' = 'imm.cn-qingdao.aliyuncs.com',
    'cn-north-2-gov-1' = 'imm.cn-north-2-gov-1.aliyuncs.com',
    'cn-hongkong' = 'imm.cn-hongkong.aliyuncs.com',
    'cn-hangzhou' = 'imm.cn-hangzhou.aliyuncs.com',
    'cn-guangzhou' = 'imm.cn-guangzhou.aliyuncs.com',
    'cn-chengdu' = 'imm.cn-chengdu.aliyuncs.com',
    'cn-beijing' = 'imm.cn-beijing.aliyuncs.com',
    'ap-southeast-5' = 'imm.ap-southeast-5.aliyuncs.com',
    'ap-southeast-2' = 'imm.ap-southeast-2.aliyuncs.com',
    'ap-southeast-1' = 'imm.ap-southeast-1.aliyuncs.com',
    'ap-south-1' = 'imm.ap-south-1.aliyuncs.com',
  };

  checkConfig(config);
  @endpoint = getEndpoint('imm', @regionId, @endpointRule, @network, @suffix, @endpointMap, @endpoint);
}

function getEndpoint(productId: string, regionId: string, endpointRule: string, network: string, suffix: string, endpointMap: map[string]string, endpoint: string) throws: string{
  if (!$isNull(endpoint)) {
    return endpoint;
  }
  
  if (!$isNull(endpointMap) && !$isNull(endpointMap[regionId])) {
    return endpointMap[regionId];
  }
  return OpenApiUtil.getEndpointRules(productId, regionId, endpointRule, network, suffix);
}

model Address {
  addressLine?: string(name='AddressLine', description='The full address.', example='中国浙江省杭州市余杭区文一西路969号'),
  city?: string(name='City', description='The city.', example='杭州市'),
  country?: string(name='Country', description='The country or region.', example='中国'),
  district?: string(name='District', description='The district.', example='余杭区'),
  language?: string(name='Language', description='The BCP 47 language code.', example='zh-Hans'),
  province?: string(name='Province', description='The province.', example='浙江省'),
  township?: string(name='Township', description='The street.', example='文一西路'),
}

model AddressForStory {
  city?: string(name='City', description='The city.', example='杭州市'),
  country?: string(name='Country', description='The country.', example='中国'),
  district?: string(name='District', description='The district.', example='滨江区'),
  province?: string(name='Province', description='The province.', example='浙江省'),
  township?: string(name='Township', description='The township.', example='长河街道'),
}

model AlgorithmDefinition {
  algorithmDefinitionId?: string(name='AlgorithmDefinitionId', description='The ID of the algorithm definition.', example='8fc6e718-8d19-495f-a510-bcee3c598588'),
  createTime?: string(name='CreateTime', description='The creation time.', example='2023-05-31T10:19:40.572325888+08:00'),
  customLabels?: [ map[string]string ](name='CustomLabels', description='Custom labels.'),
  description?: string(name='Description', description='The description.', example='test'),
  name?: string(name='Name', description='The name of the algorithm.', example='algoName'),
  ownerId?: string(name='OwnerId', description='The ID of the Alibaba Cloud account.', example='user1'),
  projectName?: string(name='ProjectName', description='The name of the project.', example='traningtest'),
  trainingSpecification?: TrainingSpecification(name='TrainingSpecification', description='The model training parameters.'),
  updateTime?: string(name='UpdateTime', description='The update time.', example='2023-05-31T10:19:40.572325888+08:00'),
}

model Answer {
  content?: string(name='Content', description='The answer.', example='你好'),
  references?: [
    ReferenceFile
  ](name='References', description='The reference sources of the answer.'),
}

model App {
  appDescription?: string(name='AppDescription', description='AppDescription', example='中国最大的电商购物商城'),
  appId?: string(name='AppId', description='AppId', example='1234567890'),
  appKey?: string(name='AppKey', description='AppKey', example='ryBOBW0Z6NnQ3fV9'),
  appName?: string(name='AppName', description='AppName', example='淘宝'),
  appRegion?: long(name='AppRegion', description='AppRegion', example='0'),
  appType?: long(name='AppType', description='AppType', example='0'),
  englishName?: string(name='EnglishName', description='EnglishName', example='Taobao'),
  ownerId?: string(name='OwnerId', description='OwnerId', example='1023210024677934'),
  packageName?: string(name='PackageName', description='PackageName', example='ThisIsAPackageName'),
}

model AssumeRoleChain {
  chain?: [
    AssumeRoleChainNode
  ](name='Chain', description='The authorization chains.'),
  policy?: string(name='Policy', description='The policy.', example='{
  "Statement": [
    {
      "Action": "oss:*",
      "Effect": "Allow",
      "Resource": "*"
    }
  ],
  "Version": "1"
}'),
}

model AssumeRoleChainNode {
  ownerId?: string(name='OwnerId', description='The UID of the account.

This parameter is required.', example='10232100********'),
  role?: string(name='Role', description='The role.

This parameter is required.', example='test-role'),
  type?: string(name='Type', description='The type of the account. Valid values:

*   user: Alibaba Cloud account.
*   service: Alibaba Cloud service.

This parameter is required.', example='user'),
}

model AudioStream {
  bitrate?: long(name='Bitrate', description='The bitrate. Unit: bit/s.', example='320087'),
  channelLayout?: string(name='ChannelLayout', description='The sound channel layout.', example='stereo'),
  channels?: long(name='Channels', description='The number of sound channels.', example='2'),
  codecLongName?: string(name='CodecLongName', description='The full name of the codec.', example='AAC (Advanced Audio Coding)'),
  codecName?: string(name='CodecName', description='The abbreviated name of the codec.', example='aac'),
  codecTag?: string(name='CodecTag', description='The tag of the codec.', example='0x6134706d'),
  codecTagString?: string(name='CodecTagString', description='The description of the codec tag.', example='mp4a'),
  codecTimeBase?: string(name='CodecTimeBase', description='The time base of the codec.', example='1/44100'),
  duration?: double(name='Duration', description='The duration of the audio stream in seconds.', example='3.690667'),
  frameCount?: long(name='FrameCount', description='The number of frames.', example='173'),
  index?: long(name='Index', description='The index number of the audio stream.', example='1'),
  language?: string(name='Language', description='The audio language in the BCP 47 standard.', example='en'),
  lyric?: string(name='Lyric', description='The lyric.', example='test'),
  sampleFormat?: string(name='SampleFormat', description='The sample format.', example='fltp'),
  sampleRate?: long(name='SampleRate', description='The sampling rate. Unit: Hz.', example='48000'),
  startTime?: double(name='StartTime', description='The start time of the audio stream in seconds.', example='0.0235'),
  timeBase?: string(name='TimeBase', description='The time base.', example='1/48000'),
}

model Binding {
  createTime?: string(name='CreateTime', description='The timestamp when the binding between the dataset and the OSS bucket was created. The format is RFC3339Nano.', example='2021-06-29T14:50:13.011643661+08:00'),
  datasetName?: string(name='DatasetName', description='The name of the dataset.', example='dataset001'),
  phase?: string(name='Phase', description='The scan type. Valid values:

- FullScanning: A full scan is in progress.

- IncrementalScanning: An incremental scan is in progress.', example='FullScanning'),
  projectName?: string(name='ProjectName', description='The name of the project.', example='immtest'),
  reason?: string(name='Reason', description='Reason', example='pause usage'),
  state?: string(name='State', description='The state of the binding between the dataset and the OSS bucket. Valid values:

- Ready: The binding is being prepared after it is created.

- Stopped: The binding is paused.

- Running: The binding is running.

- Retrying: The binding is being retried after it is created.

- Failed: The binding failed to be created.

- Deleted: The binding is deleted.', example='Running'),
  URI?: string(name='URI', description='The URI of the Object Storage Service (OSS) bucket attached to the dataset.

The format of an OSS bucket URI is `oss://${bucketname}`. The `bucketname` is the name of an OSS bucket that is in the same region as the current project.', example='oss://examplebucket'),
  updateTime?: string(name='UpdateTime', description='The timestamp when the binding between the dataset and the OSS bucket was last modified. The format is RFC3339Nano.

> After a binding is created, if the binding has not been paused or restarted, this timestamp is the same as the creation timestamp.', example='2021-06-29T14:50:13.011643661+08:00'),
}

model Body {
  boundary?: Boundary(name='Boundary', description='The boundary of the human body.'),
  confidence?: float(name='Confidence', description='The confidence level of the result. A higher value indicates greater confidence. Specifically, a value exceeding 0.8 signifies a high degree of confidence in the result.', example='0.82'),
}

model Boundary {
  height?: long(name='Height', description='The height. Unit: pixel.', example='300'),
  left?: long(name='Left', description='The distance from the X-coordinate of the vertex to the left edge.', example='10'),
  polygon?: [
    PointInt64
  ](name='Polygon', description='The polygon formed by a number of points. This parameter takes effect only when the boundary describes a polygon rather than a rectangle.

>  This parameter is mutually exclusive to the following parameters that form a rectangle: Width, Height, Left, and Top. A boundary describes only a rectangle or a polygon.'),
  top?: long(name='Top', description='The distance from the Y-coordinate of the vertex to the top.', example='30'),
  width?: long(name='Width', description='The width. Unit: pixel.', example='200'),
}

model Car {
  boundary?: Boundary(name='Boundary', description='The boundary information.'),
  carColor?: string(name='CarColor', description='The vehicle color. Valid values

*   white
*   grey
*   yellow
*   red
*   green
*   blue
*   black
*   purple
*   brown', example='white'),
  carColorConfidence?: double(name='CarColorConfidence', description='The confidence level of the vehicle color. Valid values: 0 to 1. The value 0 indicates the lowest confidence level. The value 1 indicates the highest confidence level.', example='0.604'),
  carType?: string(name='CarType', description='The vehicle type. Valid values:

*   car
*   bus
*   truck
*   van', example='van'),
  carTypeConfidence?: double(name='CarTypeConfidence', description='The confidence level of the vehicle type. Valid values: 0 to 1. The value 0 indicates the lowest confidence level. The value 1 indicates the highest confidence level.', example='0.516'),
  confidence?: double(name='Confidence', description='The confidence level of the vehicle detection result. Valid values: 0 to 1. The value 0 indicates the lowest confidence level. The value 1 indicates the highest confidence level.', example='0.999'),
  licensePlates?: [
    LicensePlate
  ](name='LicensePlates', description='The license plates.'),
}

