  * - 如果尝试更新其他类型的Endpoint，将返回400错误。
  * - 当`endpointId`不存在或不属于当前用户实例时，将返回404错误。
  * - 更新域名时，系统会创建或复用新的HTTPS domain，并将其绑定到原endpoint route上，同时解绑旧domain，但不会删除旧domain。
  * - 若不提供`domain`或`certIdentifier`参数，则保持原有设置不变。
  * - 其他如`component`、`gatewayType`等字段即使传入也不会被更新。
  * @param request  the request parameters of UpdateServiceEndpoint  UpdateServiceEndpointRequest
  * @return UpdateServiceEndpointResponse
 */
async function updateServiceEndpoint(request: UpdateServiceEndpointRequest): UpdateServiceEndpointResponse {
  @handler.validateRequestModel(request);
  return @handler.do('RPC', 'UpdateServiceEndpoint', 'POST', '/', 'json', true, 'form', request);
}

