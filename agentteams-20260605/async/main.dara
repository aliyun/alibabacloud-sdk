model CreateInstanceRequest {
  regionId?: string(name='RegionId', description='This parameter is required.', example='cn-hangzhou', position='Host'),
  clientToken?: string(name='ClientToken', example='client-token-xxx', position='Body'),
  instanceName: string(name='InstanceName', description='This parameter is required.', example='agentteams-demo', position='Query'),
  instanceSpec: string(name='InstanceSpec', description='This parameter is required.', example='SMALL_X1', position='Query'),
  networkType: string(name='NetworkType', description='This parameter is required.', example='PRIVATE_NET', position='Query'),
  paymentType?: string(name='PaymentType', example='Subscription', position='Body'),
  vpcId: string(name='VpcId', description='This parameter is required.', example='vpc-bp1xxxx', position='Query'),
  zones?: [ 
    {
      vSwitchId?: string(name='VSwitchId', example='vsw-bp1xxxx'),
      zoneId?: string(name='ZoneId', example='cn-hangzhou-h'),
    }
  ](name='Zones', example='[]', shrink='json', position='Query'),
}

model CreateInstanceResponseBody = {
  code?: string(name='Code', example='SUCCESS'),
  data?: {
    instanceId?: string(name='InstanceId', example='agentteams-test-001'),
    orderId?: string(name='OrderId', example='open-create-agentteams-test-001-req-create-001'),
  }(name='Data', example='{}'),
  httpStatusCode?: int32(name='HttpStatusCode', example='200'),
  instanceId?: string(name='InstanceId', description='InstanceId', example='agentteams-test-001'),
  message?: string(name='Message', example='success'),
  requestId?: string(name='RequestId', example='req-create-001'),
  success?: boolean(name='Success', example='true'),
}

model CreateInstanceResponse = {
