model SubscribeRequest {
  dlqPolicy?: {
    deadLetterTargetQueue?: string(name='DeadLetterTargetQueue'),
    enabled?: boolean(name='Enabled'),
  }(name='DlqPolicy'),
  dmAttributes?: {
    accountName?: string(name='AccountName'),
    subject?: string(name='Subject'),
  }(name='DmAttributes', description='邮箱推送相关属性，当 PushType=dm 时必填。JSON 格式，包含以下字段：
- **AccountName**：发信地址，即 DirectMail 中配置的发信地址（如 `notify@example.com`）。
- **Subject**：邮件主题。'),
  dysmsAttributes?: {
    signName?: string(name='SignName'),
    templateCode?: string(name='TemplateCode'),
  }(name='DysmsAttributes', description='短信推送相关属性，当 PushType=alisms 时必填。JSON 格式，包含以下字段：
- **TemplateCode**：短信模板 Code，在短信服务控制台中获取。
- **SignName**：短信签名名称。'),
  endpoint?: string(name='Endpoint', description='接收消息的终端地址，格式根据 PushType 不同而不同：
- **PushType=http**：HTTP/HTTPS 回调 URL，如 `http://example.com/callback` 或 `https://example.com/callback`。
- **PushType=queue**：目标队列 ARN，格式为 `acs:mns:{RegionId}:{主账号UID}:queues/{QueueName}`。
- **PushType=dm**：邮箱推送终端，格式固定为 `smq-ep:dm:{主账号UID}:__dynamic`，其中 `{主账号UID}` 替换为您的阿里云主账号 UID。
- **PushType=dysms**：短信推送终端，格式为 `smq-ep:dysms:{主账号UID}:{手机号码}`。
- **PushType=kafka**：Kafka 推送终端，格式为 `smq-ep:kafka:{主账号UID}:{InstanceId}`。
- **PushType=fc**：函数计算终端，格式为 `acs:fc:{RegionId}:{主账号UID}:services/{ServiceName}/functions/{FunctionName}`。
- **PushType=eventbus**：事件总线终端，格式为 `acs:eventbridge:{RegionId}:{主账号UID}:eventbus/{EventBusName}`。

This parameter is required.', example='acs:mns:cn-hangzhou:1234567890:queues/MyQueue'),
  kafkaAttributes?: {
    businessMode?: string(name='BusinessMode'),
  }(name='KafkaAttributes', description='Kafka 推送相关属性。JSON 格式，包含以下字段：
- **BusinessMode**：业务模式。'),
  messageTag?: string(name='MessageTag', description='消息过滤标签（不超过 16 个字符），仅当消息带有相同标签时才会被推送到该订阅。不设置则表示不过滤，所有消息均推送。', example='important'),
  notifyContentFormat?: string(name='NotifyContentFormat', description='推送的消息内容格式。取值：
- **XML**：消息体以 XML 格式推送（默认）。
- **JSON**：消息体以 JSON 格式推送。
- **SIMPLIFIED**：仅推送消息体原始内容，不包含 SMQ 的元信息包装。', example='SIMPLIFIED'),
  notifyStrategy?: string(name='NotifyStrategy', description='推送消息出现错误时的重试策略。取值：
- **BACKOFF_RETRY**：退避重试策略，重试间隔逐渐递增（推荐）。
- **EXPONENTIAL_DECAY_RETRY**：指数衰减重试策略。', example='BACKOFF_RETRY'),
  pushType?: string(name='PushType', description='订阅的推送类型。取值：
- **http**：HTTP/HTTPS 推送，将消息推送到指定的 HTTP 或 HTTPS 回调地址。
- **queue**：队列推送，将消息推送到指定的 SMQ 队列。
- **dm**：邮箱推送，通过邮件服务（DirectMail）发送通知。需同时设置 DmAttributes 和 StsRoleArn 参数。
- **dysms**：短信推送，通过阿里云短信服务发送通知。需同时设置 DysmsAttributes 参数。
- **kafka**：Kafka 推送。需同时设置 KafkaAttributes 参数。
- **fc**：函数计算推送，将消息推送到阿里云函数计算（FC）。
- **eventbus**：事件总线推送，将消息推送到 EventBridge 事件总线。

> 以下值已废弃，仅用于兼容旧订阅：mpush（移动推送）、alisms（旧版短信）、email（旧版邮箱，请使用 dm）。

This parameter is required.', example='queue'),
