@context("authorizeEndpointAclWithContext")
async function authorizeEndpointAclWithOptions(tmpReq: AuthorizeEndpointAclRequest, runtime: $RuntimeOptions): AuthorizeEndpointAclResponse {
  tmpReq.validate();
