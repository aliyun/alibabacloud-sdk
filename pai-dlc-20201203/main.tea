model ExtraPodSpec {
  initContainers?: [
    ContainerSpec
  ](name='InitContainers', description='A list of init containers that run to completion before the main container starts.'),
  lifecycle?: Lifecycle(name='Lifecycle', description='Defines lifecycle hooks for the main container.'),
  mainContainerSecurityContext?: SecurityContext(name='MainContainerSecurityContext', description='Defines the security context for the main container.'),
  podAnnotations?: map[string]string(name='PodAnnotations', description='Key-value pairs to apply to the pod as annotations. Use annotations to attach arbitrary, non-identifying metadata.', deprecated=true),
  podLabels?: map[string]string(name='PodLabels', description='Key-value pairs to apply to the pod as labels. Use labels to organize and select pods.', deprecated=true),
  sharedVolumeMountPaths?: [ string ](name='SharedVolumeMountPaths', description='A list of local directory paths to mount and share among all containers in the pod.'),
  sideCarContainers?: [
    ContainerSpec
  ](name='SideCarContainers', description='A list of sidecar containers.'),
}

