    'cn-shenzhen-st4-d01' = 'pai-dlc.aliyuncs.com',
    'cn-shenzhen-su18-b01' = 'pai-dlc.aliyuncs.com',
    'cn-wuhan' = 'pai-dlc.aliyuncs.com',
