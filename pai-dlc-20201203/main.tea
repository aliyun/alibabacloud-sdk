  allowUnschedulableNodes?: boolean(name='AllowUnschedulableNodes'),
  businessUserId?: string(name='BusinessUserId', description='The user ID associated with the job.', example='16****'),
  caller?: string(name='Caller', description='The caller.', example='SilkFlow'),
  dataJuicerConfig?: DataJuicerConfig(name='DataJuicerConfig', description='The DataJuicer task configuration.'),
  disableEcsStockCheck?: boolean(name='DisableEcsStockCheck', description='Specifies whether to skip the inventory check. Valid values:
- true
- false', example='false'),
  driver?: string(name='Driver', description='The NVIDIA driver configuration.', example='535.54.03'),
  enableCPUAffinity?: boolean(name='EnableCPUAffinity', description='The CPU affinity setting. This setting takes effect only when general-purpose subscription computing resources are used.', example='true'),
  enableDSWDev?: boolean(name='EnableDSWDev'),
  enableErrorMonitoringInAIMaster?: boolean(name='EnableErrorMonitoringInAIMaster', description='Specifies whether to enable fault tolerance monitoring for the job. Valid values:
- true
- false', example='false'),
  enableOssAppend?: boolean(name='EnableOssAppend', description='Specifies whether OSS append writes are allowed. Valid values:
- true
- false', example='true'),
  enableRDMA?: boolean(name='EnableRDMA', description='Specifies whether the job is allowed to use RDMA. Valid values:
- true
- false', example='true'),
  enableSanityCheck?: boolean(name='EnableSanityCheck', description='Specifies whether to enable computing power health check for the job. Valid values:
- true
- false', example='true'),
  enableTideResource?: boolean(name='EnableTideResource', description='Specifies whether the job is allowed to use tidal resources. Valid values:
- true
- false', example='true'),
  errorMonitoringArgs?: string(name='ErrorMonitoringArgs', description='The configuration parameters for fault tolerance monitoring after it is enabled. For example, you can specify whether to enable log hang-based detection.', example='--enable-log-hang-detection true'),
  jobReservedMinutes?: int32(name='JobReservedMinutes', description='The duration (in minutes) for which the job is retained after it ends.', example='30'),
  jobReservedPolicy?: string(name='JobReservedPolicy', description='The retention policy after the job ends.', example='Always'),
  modelConfig?: ModelConfig(name='ModelConfig', description='The output model configuration. This parameter currently takes effect only in federated training scenarios.'),
  oversoldType?: string(name='OversoldType', description='The oversold resource usage mode for the job (not accepted, acceptable, or only accepted).', example='AcceptQuotaOverSold'),
  pipelineId?: string(name='PipelineId', description='The workflow ID.', example='pid-12****'),
  sanityCheckArgs?: string(name='SanityCheckArgs', description='The configuration parameters for computing power health check.', example='--sanity-check-timing=AfterJobFaultTolerant --sanity-check-timeout-ops=MarkJobFail'),
  shell?: string(name='Shell', example='/bin/bash'),
  tags?: map[string]string(name='Tags', description='The custom tags.'),
  terminationGracePeriodSeconds?: long(name='TerminationGracePeriodSeconds'),
}

