  imageConfig?: ImageConfig(name='ImageConfig', description='The private image configuration.'),
  isCheif?: boolean(name='IsCheif', description='Deprecated due to a spelling error.', deprecated=true),
  isChief?: boolean(name='IsChief', description='Indicates whether this role is the Chief role. Only one Chief role is allowed.'),
  localMountSpecs?: [
    LocalMountSpec
  ](name='LocalMountSpecs', description='The list of local mount configurations.'),
  oversoldType?: string(name='OversoldType'),
  podCount?: long(name='PodCount', description='The number of replicas.', example='1'),
  quotaId?: string(name='QuotaId'),
  resourceConfig?: ResourceConfig(name='ResourceConfig', description='The resource configuration.'),
  restartPolicy?: string(name='RestartPolicy', description='The restart policy. Valid values: Always, Never, OnFailure, and ExitCode.', example='ExitCode'),
  serviceSpec?: ServiceSpec(name='ServiceSpec', description='The service configuration.'),
  spotSpec?: SpotSpec(name='SpotSpec', description='The spot instance configuration.'),
  startupDependencies?: [
    StartupDependency
  ](name='StartupDependencies', description='The dependencies required before this role starts.'),
  systemDisk?: SystemDisk(name='SystemDisk'),
  type?: string(name='Type', description='Type is closely related to Job Type. Different Job Types support different Worker Types.

- **TFJob**: Supports Chief, PS, Worker, Evaluator, and GraphLearn.

- **PyTorchJob**: Supports Worker and Master.

- **XGBoostJob**: Supports Worker and Master.
- **OneFlowJob**: Supports Worker and Master.
- **ElasticBatch**: Supports Worker and Master.
- **RayJob**: Supports Head, Worker, and Worker[-xxx].

Master is optional in PyTorchJob, XGBoostJob, OneFlowJob, and ElasticBatch. If Master is not specified, the system automatically designates the first Worker node as Master.', example='Worker'),
  useSpotInstance?: boolean(name='UseSpotInstance', description='Specifies whether to use spot instances.', example='false', deprecated=true),
}

