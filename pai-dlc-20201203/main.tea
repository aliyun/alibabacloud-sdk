  ecsSpec?: string(name='EcsSpec', description='The hardware specifications of the worker. Visit [PAI-DLC billing](https://help.aliyun.com/document_detail/171758.html) for the detailed list of specifications.>Notice: Prices vary depending on the specifications.', example='ecs.c6.large'),
