  minParallelism?: int32(name='MinParallelism', example='1'),
  PSMaxParallelism?: int32(name='PSMaxParallelism', example='10'),
  PSMinParallelism?: int32(name='PSMinParallelism', example='4'),
}

model JobItem {
  accessibility?: string(name='Accessibility', description='The visibility.', example='PUBLIC'),
  clusterId?: string(name='ClusterId', description='The cluster ID.', example='****1316721349****'),
  codeSource?: {
    branch?: string(name='Branch', description='The code repository branch.', example='master'),
    codeSourceId?: string(name='CodeSourceId', description='The code source configuration ID.', example='code-20210111103721-********'),
    commit?: string(name='Commit', description='The commit ID of the code repository used for this job.', example='44da109b59f8596152987eaa8f3b2487bb******'),
    mountPath?: string(name='MountPath', description='The local mount path of the code.', example='/mnt/data'),
  }(name='CodeSource', description='The code source configuration used by this job.'),
  credentialConfig?: CredentialConfig(name='CredentialConfig', description='The access credential configuration associated with the job.'),
  dataSources?: [ 
    {
      dataSourceId?: string(name='DataSourceId', description='The datasource config ID.', example='data-20210114104214-********'),
      mountPath?: string(name='MountPath', description='The local mount path of the data source.', example='/mnt/data'),
    }
  ](name='DataSources', description='The list of all datasource configs used by this job.'),
  displayName?: string(name='DisplayName', description='The job name.', example='tf-mnist-test'),
  duration?: long(name='Duration', description='The job running duration, in seconds.', example='243'),
  elasticSpec?: JobElasticSpec(name='ElasticSpec', description='The elastic job parameters.'),
  enablePreemptibleJob?: boolean(name='EnablePreemptibleJob', description='Indicates whether PreemptibleJob is enabled.', example='false'),
  enabledDebugger?: boolean(name='EnabledDebugger', description='Indicates whether Debugger analysis is enabled.', example='false'),
  envs?: map[string]string(name='Envs', description='The environment variables injected at job runtime.'),
  gmtCreateTime?: string(name='GmtCreateTime', description='The time when the job was created, in UTC format.', example='2025-04-16T07:25:34Z'),
  gmtFailedTime?: string(name='GmtFailedTime', description='The time when the job failed, in UTC format.', example='null'),
  gmtFinishTime?: string(name='GmtFinishTime', description='The time when the job finished, in UTC format.', example='2025-04-16T07:28:20Z'),
  gmtModifiedTime?: string(name='GmtModifiedTime', description='The time when the job was last modified, in UTC format.', example='2025-04-16T07:28:22Z'),
  gmtRunningTime?: string(name='GmtRunningTime', description='The time when the job started running, in UTC format.', example='2025-04-16T07:26:41Z'),
  gmtStoppedTime?: string(name='GmtStoppedTime', description='The time when the job was stopped, in UTC format.', example='null'),
  gmtSubmittedTime?: string(name='GmtSubmittedTime', description='The time when the job was submitted, in UTC format.', example='2025-04-16T07:26:14Z'),
  gmtSuccessedTime?: string(name='GmtSuccessedTime', description='The time when the job completed successfully, in UTC format.', example='2025-04-16T07:28:20Z'),
  isDeleted?: boolean(name='IsDeleted', description='Indicates whether the job is deleted.', example='false'),
  jobId?: string(name='JobId', description='The job ID.', example='dlc-20210126170216-********'),
  jobMaxRunningTimeMinutes?: long(name='JobMaxRunningTimeMinutes', description='The maximum running duration of the job.', example='0'),
  jobReplicaStatuses?: [
    JobReplicaStatus
  ](name='JobReplicaStatuses'),
  jobSpecs?: [
    JobSpec
  ](name='JobSpecs', description='The node configurations of the job at runtime.'),
  jobType?: string(name='JobType', description='The job type. Valid values:
- TFJob
- PyTorchJob
- MPIJob
- XGBoostJob
- OneFlowJob
- ElasticBatchJob
- RayJob
- SlurmJob', example='TFJob'),
  nodeCount?: string(name='NodeCount', description='The number of nodes.', example='1'),
  nodeNames?: [ string ](name='NodeNames', description='The node names.'),
  pods?: [
    PodItem
  ](name='Pods', description='The pods.'),
  priority?: int32(name='Priority', description='The job priority.', example='1'),
  reasonCode?: string(name='ReasonCode', description='The reason code for the current job status. Valid values:
- InvalidParameter
- JobSucceeded
- JobStoppedByUser', example='JobStoppedByUser'),
  reasonMessage?: string(name='ReasonMessage', description='The detailed description of the reason for the current job status.', example='Job is stopped by user.'),
  requestCPU?: long(name='RequestCPU', description='The requested CPU resources.', example='1'),
  requestGPU?: string(name='RequestGPU', description='The requested GPU resources.', example='1'),
  requestMemory?: string(name='RequestMemory', description='The requested memory resources.', example='1Gi'),
  resourceId?: string(name='ResourceId', description='The ID of the resource group in which the job runs.', example='dlc-quota'),
  resourceLevel?: string(name='ResourceLevel', description='The resource level of the job at runtime.', example='L0'),
  resourceName?: string(name='ResourceName', description='The name of the resource on which the job runs.', example='my_resource_group'),
  resourceQuotaName?: string(name='ResourceQuotaName', description='The resource quota name.', example='test'),
  resourceType?: string(name='ResourceType', description='The resource type. Valid values: ECS, Lingjun, and ACS.', example='ECS'),
  restartTimes?: string(name='RestartTimes', description='The number of times the job has been restarted.', example='1'),
  retryCount?: int32(name='RetryCount'),
  schedulingStrategy?: string(name='SchedulingStrategy'),
  settings?: JobSettings(name='Settings', description='The additional parameters of the job.'),
  status?: string(name='Status', description='The job status. Valid values:
- Succeeded
- Failed', example='Stopped'),
  statusHistory?: [
    StatusTransitionItem
  ](name='StatusHistory', description='The job status transition history.'),
  subStatus?: string(name='SubStatus', description='The job substatus, such as the preemption retry status.', example='Restarting'),
  systemEnvs?: map[string]string(name='SystemEnvs', description='The system environment variable configurations.'),
  templateId?: string(name='TemplateId'),
  templateName?: string(name='TemplateName'),
  tenantId?: string(name='TenantId', description='The tenant ID.', example='****93955616****'),
  thirdpartyLibDir?: string(name='ThirdpartyLibDir', description='The directory where the third-party library file Requirements.txt is located.', example='/root/code/'),
  thirdpartyLibs?: [ string ](name='ThirdpartyLibs', description='The list of third-party Python libraries installed before the job runs.'),
  useOversoldResource?: boolean(name='UseOversoldResource', description='Indicates whether the job uses idle resources.', example='false'),
  userCommand?: string(name='UserCommand', description='The startup command that runs on each node of the job.', example='python /root/code/mnist.py'),
  userId?: string(name='UserId', description='The UID of the user who owns the job.', example='123456789'),
  userScript?: string(name='UserScript', description='The user script.', example='ls'),
  userVpc?: {
    defaultRoute?: string(name='DefaultRoute', description='The default routing. Valid values:
- eth0: uses the default network interface controller (NIC) to access external networks through the public gateway.
- eth1: uses the user elastic network interfaces (ENIs) to access external networks through the private gateway.', example='eth0'),
    extendedCidrs?: [ string ](name='ExtendedCidrs', description='The extended CIDR blocks to connect.'),
    securityGroupId?: string(name='SecurityGroupId', description='The security group ID.', example='sg-2zeef***'),
    switchId?: string(name='SwitchId', description='The vSwitch ID.', example='vsw-2ze6***'),
    vpcId?: string(name='VpcId', description='VPC ID', example='vpc-2zed***'),
  }(name='UserVpc', description='The user VPC.', example='vpc-1'),
  username?: string(name='Username', description='The username of the user who submitted the job.', example='pai-dlc-role'),
  workingDir?: string(name='WorkingDir', description='The working directory.', example='/mnt/data'),
  workspaceId?: string(name='WorkspaceId', description='The ID of the workspace to which the job belongs.', example='268'),
  workspaceName?: string(name='WorkspaceName', description='The name of the workspace to which the job belongs.', example='dlc-workspace'),
}

