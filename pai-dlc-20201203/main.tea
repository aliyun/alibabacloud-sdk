}

model DebuggerResult {
  debuggerConfigContent?: string(name='DebuggerConfigContent', example='{\\"description\\":\\"这是一个新的pytorchjob模板\\"}'),
  debuggerJobIssues?: string(name='DebuggerJobIssues', example='{ "ProfileReport": { "Name": "CPUBottleneck","Triggered": 10,"Violations": 2,"Details": "{}"}, "LowCPU": { "Name": "CPUBottleneck","Triggered": 10,"Violations": 2,"Details": "{}"}}'),
  debuggerJobStatus?: string(name='DebuggerJobStatus', example='{"Running": 1, "Failed": 1, "Succeeded": 2}'),
  debuggerReportURL?: string(name='DebuggerReportURL', example='http://xxx.com/debug/report/download/new_xxxx.html'),
  jobDisplayName?: string(name='JobDisplayName', example='dlc debugger test'),
  jobId?: string(name='JobId', example='dlc-20210126170216-mtl37ge7gkvdz'),
  jobUserId?: string(name='JobUserId', example='12344556'),
}

model DownloadJobResult {
  displayName?: string(name='DisplayName', description='The display name of the download job.'),
  downloadJobId?: string(name='DownloadJobId', description='The ID of the download job.'),
  downloadUrl?: string(name='DownloadUrl', description='A temporary, pre-signed URL for downloading the result file.'),
  endTime?: string(name='EndTime', description='The completion time of the download job, in UTC format.'),
  fileType?: string(name='FileType', description='The type of file to download, such as `logs` or `output`.'),
  gmtCreated?: string(name='GmtCreated', description='The creation time of the download job, in UTC format.'),
  gmtModified?: string(name='GmtModified', description='The last modification time of the download job, in UTC format.'),
  logCount?: int32(name='LogCount', description='The number of log entries included in the download.'),
  podIds?: [ string ](name='PodIds', description='The IDs of the pods for the source job.'),
  podUids?: [ string ](name='PodUids', description='The UIDs of the pods for the source job.'),
  sourceJobId?: string(name='SourceJobId', description='The ID of the source job whose results are downloaded.'),
  startTime?: string(name='StartTime', description='The start time of the download job, in UTC format.'),
  status?: string(name='Status', description='The status of the download job. Valid values: `Running`, `Succeeded`, and `Failed`.'),
  tenantId?: string(name='TenantId', description='The ID of the tenant that the job belongs to.'),
  type?: string(name='Type', description='The type of the download job.'),
  urlExpireTime?: string(name='UrlExpireTime', description='The time when the download URL expires, in UTC format.'),
  userId?: string(name='UserId', description='The ID of the user who created the job.'),
  workspaceId?: string(name='WorkspaceId', description='The ID of the workspace where the job was created.'),
}

model EcsSpec {
  acceleratorType?: string(name='AcceleratorType', description='The accelerator type. Valid values:

*   CPU
*   GPU', example='GPU'),
  cpu?: int32(name='Cpu', description='The number of CPU cores.', example='12'),
  defaultGPUDriver?: string(name='DefaultGPUDriver', description='The default GPU driver version.', example='470.199.02'),
  gpu?: int32(name='Gpu', description='The number of GPUs.', example='1'),
  gpuMemory?: int32(name='GpuMemory', description='The GPU memory size.', example='80'),
  gpuType?: string(name='GpuType', description='The GPU type.', example='NVIDIA v100'),
  instanceType?: string(name='InstanceType', description='The instance type.', example='ecs.gn6e-c12g1.3xlarge'),
  isAvailable?: boolean(name='IsAvailable', description='Indicates whether the instance type is available. Valid values:

*   true
*   false', example='true'),
  memory?: int32(name='Memory', description='The memory size. Unit: MiB or GiB.', example='92'),
  nonProtectSpotDiscount?: float(name='NonProtectSpotDiscount', description='The discount on the current price of the preemptible instance.', example='0.1'),
  paymentTypes?: [ string ](name='PaymentTypes', description='The billing methods.'),
  resourceType?: string(name='ResourceType', description='The resource type. Valid values:

*   ECS
*   Lingjun', example='ECS'),
  spotStockStatus?: string(name='SpotStockStatus', description='The inventory status of preemptible instance.', example='WithStock'),
  supportedGPUDrivers?: [ string ](name='SupportedGPUDrivers', description='The GPU driver versions.'),
}

model ElasticSpotSpec {
  instanceType?: string(name='InstanceType', description='The spot instance type.'),
  spotDiscountLimit?: double(name='SpotDiscountLimit', description='The maximum discount percentage for the spot instance. The system does not select an instance if its discount exceeds this limit. For example, if you set this parameter to `90`, the system considers only instances with a discount of 90% or less.'),
  spotPriceLimit?: double(name='SpotPriceLimit', description='The maximum hourly price you are willing to pay for a spot instance. If omitted, the on-demand price is the default.'),
  spotStrategy?: string(name='SpotStrategy', description='The strategy for allocating spot instances. Valid values:

- `LowestPrice`: Launches instances from the spot capacity pool offering the lowest price. This is the default strategy.

- `CapacityOptimized`: Launches instances from the spot capacity pool offering optimal capacity.'),
}

model EnvVar {
  name?: string(name='Name', description='The name of the environment variable.', example='ENABLE_DEBUG'),
  value?: string(name='Value', description='The value of the environment variable.', example='true'),
}

model EventInfo {
  content?: string(name='Content'),
  id?: string(name='Id'),
  podId?: string(name='PodId'),
