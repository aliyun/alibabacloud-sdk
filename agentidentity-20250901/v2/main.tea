/**
 *
 */
import OpenApi;
import OpenApi.OpenApiUtil;

extends OpenApi;


init(config: OpenApiUtil.Config){
  super(config);
  @endpointRule = 'regional';
  
  checkConfig(config);
  @endpoint = getEndpoint('agentidentity', @regionId, @endpointRule, @network, @suffix, @endpointMap, @endpoint);
}

function getEndpoint(productId: string, regionId: string, endpointRule: string, network: string, suffix: string, endpointMap: map[string]string, endpoint: string) throws: string{
  if (!$isNull(endpoint)) {
    return endpoint;
  }
  
  if (!$isNull(endpointMap) && !$isNull(endpointMap[regionId])) {
    return endpointMap[regionId];
  }
  return OpenApiUtil.getEndpointRules(productId, regionId, endpointRule, network, suffix);
}

model AuthorizationRequest {
  endpoint?: string(name='Endpoint'),
}

model AuthorizationServerMetadata {
  authorizationRequest?: AuthorizationRequest(name='AuthorizationRequest'),
  issuer?: string(name='Issuer'),
  PKCE?: PKCE(name='PKCE'),
  tokenRequest?: TokenReqeust(name='TokenRequest'),
}

model CustomOAuth2ProviderConfig {
  clientId?: string(name='ClientId'),
  clientSecret?: string(name='ClientSecret'),
  OAuth2Discovery?: OAuth2Discovery(name='OAuth2Discovery'),
}

model Definition {
  cedar?: {
    statement?: string(name='Statement'),
  }(name='Cedar'),
}

model EncryptionConfig {
  keyType?: string(name='KeyType'),
  kmsKeyArn?: string(name='KmsKeyArn'),
}

model IncludedOAuth2ProviderConfig {
  authorizationEndpoint?: string(name='AuthorizationEndpoint'),
  clientId?: string(name='ClientId'),
  clientSecret?: string(name='ClientSecret'),
  tokenEndpoint?: string(name='TokenEndpoint'),
}

model OAuth2Discovery {
  authorizationServerMetadata?: AuthorizationServerMetadata(name='AuthorizationServerMetadata'),
  discoveryURL?: string(name='DiscoveryURL'),
}

model OAuth2ProviderConfig {
  customOAuth2ProviderConfig?: CustomOAuth2ProviderConfig(name='CustomOAuth2ProviderConfig'),
  includedOAuth2ProviderConfig?: IncludedOAuth2ProviderConfig(name='IncludedOAuth2ProviderConfig'),
}

model PKCE {
  enabled?: boolean(name='Enabled'),
}

model TokenReqeust {
  endpoint?: string(name='Endpoint'),
}

