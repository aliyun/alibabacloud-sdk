model SimpleSubtask {
  items?: [ 
    {
      abandonFlag?: boolean(name='AbandonFlag', description='Abandon flag.', example='false'),
      abandonRemark?: string(name='AbandonRemark', description='Abandonment remark.', example='原始数据有问题'),
      dataId?: string(name='DataId', description='Date ID.', example='175296157992643****'),
      feedbackFlag?: boolean(name='FeedbackFlag', description='Feedback flag.', example='false'),
      feedbackRemark?: string(name='FeedbackRemark', description='Validation feedback.', example='验收完成'),
      fixedFlag?: boolean(name='FixedFlag', description='Failed mark.', example='false'),
      itemId?: long(name='ItemId', description='Data item ID.', example='15116***94667356160', nullable=true),
      mine?: long(name='Mine', description='Assigned to me:
- 0: Not assigned to me.
- 1: Assigned to me.', example='0'),
      rejectFlag?: boolean(name='RejectFlag', description='Skip flag.', example='false'),
      state?: string(name='State', description='Status:

- INIT: Initial status.
- TOPUBLISH: Pending publish.
- CREATED: Created.
- HANDLING: In progress.
- VOTING: Voting in progress.
- FINISHED: Completed.
- FAIL: Failed.
- EXPIRE: Timeout.
- DISCARDED: Passively abandoned.
- DISABLE: Actively abandoned.
- LOCKED: Edit Lock.
- OFFLINE: Unpublished.
- MERGING: Merging results.', example='HANDLING'),
      weight?: long(name='Weight', description='Weight.', example='311011'),
    }
  ](name='Items', description='List of items for subtasks.'),
  status?: string(name='Status', description='Status.', example='FINISHED'),
  subtaskId?: long(name='SubtaskId', description='Subtask ID.', example='1500***457270333440'),
}

