  jobId?: string(name='JobId', description='Job ID.', example='147***441221943296'),
  jobResult?: {
    resultLink?: string(name='ResultLink', description='Return value link, which is the OSS path where the annotation results are stored.', example='oss://****-hz-oss.oss-cn-hangzhou.aliyuncs.com/output/ocr_demo001.manifest'),
  }(name='JobResult', description='Task Result.'),
  jobType?: string(name='JobType', description='Task Type. Currently, only DOWNLOWD_MARKRESULT_FLOW is supported.', example='DOWNLOWD_MARKRESULT_FLOW'),
  status?: string(name='Status', description='Job status. Possible values:
- init: initialization
- running: running
- pause: pause
- stop: stopped
- succ: Succeeded
- fail: failed', example='succ'),
}

