model TaskStatistic {
  acceptItemCount?: float(name='AcceptItemCount', description='Data items that passed', example='0'),
  checkAbandon?: float(name='CheckAbandon', description='Quantity abandoned in the check flow', example='0'),
  checkAccuracy?: float(name='CheckAccuracy', description='Inspection accuracy', example='0'),
  checkEfficiency?: float(name='CheckEfficiency', description='Inspection efficiency (items/hour)', example='0'),
  checkedAccuracy?: float(name='CheckedAccuracy', description='Check accuracy', example='0'),
  checkedError?: float(name='CheckedError', description='Number of errors found in the inspection flow', example='0'),
  checkedRejectCount?: float(name='CheckedRejectCount', description='Number of checks', example='0'),
  finalAbandonCount?: float(name='FinalAbandonCount', description='Discarded data items', example='0'),
  finishedItemCount?: long(name='FinishedItemCount', description='Completed data items', example='3'),
  finishedSubtaskCount?: long(name='FinishedSubtaskCount', description='Quantity of completed subtasks', example='3'),
  markEfficiency?: float(name='MarkEfficiency', description='Annotation efficiency (items/hour)', example='0'),
  preMarkFixedCount?: float(name='PreMarkFixedCount', description='Quantity of corrections made during pre-annotation', example='0', nullable=true),
  sampledAccuracy?: float(name='SampledAccuracy', description='Sampling accuracy', example='0'),
  sampledErrorCount?: float(name='SampledErrorCount', description='Number of sampled fault samples', example='0'),
  sampledRejectCount?: float(name='SampledRejectCount', description='Number of samples denied', example='0'),
  samplingAccuracy?: float(name='SamplingAccuracy', description='Sampling accuracy', example='0'),
  totalCheckCount?: float(name='TotalCheckCount', description='Total number of check flow steps', example='0'),
  totalCheckTime?: float(name='TotalCheckTime', description='Total check time (hours)', example='0'),
  totalCheckedCount?: float(name='TotalCheckedCount', description='Total number of checks', example='0'),
  totalItemCount?: long(name='TotalItemCount', description='Total number of data items', example='3'),
