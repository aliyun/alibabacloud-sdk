/**
 *
 */
import OpenApi;
import OpenApi.OpenApiUtil;

extends OpenApi;


init(config: OpenApiUtil.Config){
  super(config);
  @endpointRule = 'regional';
  @endpointMap = {
    'cn-shenzhen' = 'openitag.cn-shenzhen.aliyuncs.com',
    'cn-shanghai' = 'openitag.cn-shanghai.aliyuncs.com',
    'cn-hangzhou' = 'openitag.cn-hangzhou.aliyuncs.com',
    'cn-beijing' = 'openitag.cn-beijing.aliyuncs.com',
  };

  checkConfig(config);
  @endpoint = getEndpoint('openitag', @regionId, @endpointRule, @network, @suffix, @endpointMap, @endpoint);
}

function getEndpoint(productId: string, regionId: string, endpointRule: string, network: string, suffix: string, endpointMap: map[string]string, endpoint: string) throws: string{
  if (!$isNull(endpoint)) {
    return endpoint;
  }
  
  if (!$isNull(endpointMap) && !$isNull(endpointMap[regionId])) {
    return endpointMap[regionId];
  }
  return OpenApiUtil.getEndpointRules(productId, regionId, endpointRule, network, suffix);
}

model CreateTaskDetail {
  admins?: {
    users?: [
      SimpleUser
    ](name='Users', description='List of administrators.'),
  }(name='Admins', description='Administrators; defaults to the Creator.'),
  allowAppendData?: boolean(name='AllowAppendData', description='Indicates whether appending new data is supported. Valid values:
- true: Supported
- false: Not supported', example='true'),
  assignConfig?: TaskAssginConfig(name='AssignConfig', description='Job assignment mechanism.

This parameter is required.'),
  datasetProxyRelations?: [
    DatasetProxyConfig
  ](name='DatasetProxyRelations', description='List of dataset configurations.

This parameter is required.'),
  exif?: map[string]any(name='Exif', description='Additional configuration. JSON format.', example='{  "TaskCaptionType": "DOC_LINK"}'),
  tags?: [ string ](name='Tags', description='List of job labels.'),
  taskName?: string(name='TaskName', description='Job name.

This parameter is required.', example='测试任务202208101424'),
  taskTemplateConfig?: TaskTemplateConfig(name='TaskTemplateConfig', description='Template Configuration.'),
  taskWorkflow?: [ 
    {
      nodeName?: string(name='NodeName', description='Node name. Valid values:
- MARK: Annotate.
- CHECK: Check.
- SAMPLING: Validate.', example='MARK'),
    }
  ](name='TaskWorkflow', description='List of pipelines.

This parameter is required.'),
  templateId?: string(name='TemplateId', description='Template ID. For more information, see [ListTemplates](https://help.aliyun.com/document_detail/454654.html).

This parameter is required.', example='152936***8342353920'),
  UUID?: string(name='UUID', description='Unique identifier (UUID), controlled by the business side.

This parameter is required.', example='16623***80757311'),
  voteConfigs?: map[string]CreateTaskDetailVoteInfo(name='VoteConfigs', description='Vote configuration'),
}

model CreateTaskDetailVoteInfo {
  minVote?: long(name='MinVote', example='3'),
  voteNum?: long(name='VoteNum', example='3'),
}

model DatasetProxyConfig {
  datasetType?: string(name='DatasetType', description='Dataset type. Only LABEL is supported.', example='LABEL'),
  source?: string(name='Source', description='Dataset source. Only PAI is supported.', example='PAI'),
  sourceDatasetId?: string(name='SourceDatasetId', description='Source dataset ID. For information about how to obtain a dataset ID, see [ListDatasets](https://help.aliyun.com/document_detail/457222.html).

This parameter is required.', example='214***12514'),
}

model FlowJobInfo {
