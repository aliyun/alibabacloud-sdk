  jobType?: string(name='JobType', description='Task Type. Currently, only DOWNLOWD_MARKRESULT_FLOW is supported.', example='DOWNLOWD_MARKRESULT_FLOW'),
  messageId?: string(name='MessageId', description='Message ID.', example='792B76F4000E681A95155146A002D5F8'),
  processType?: string(name='ProcessType', description='Processing information.', example='NEW_INIT'),
  taskId?: string(name='TaskId', description='Job ID.', example='1543***518306500608'),
}

model Job {
  creator?: SimpleUser(name='Creator', description='Job creator.'),
  gmtCreateTime?: string(name='GmtCreateTime', description='Creation Time.', example='2021-12-28 11:42:19'),
