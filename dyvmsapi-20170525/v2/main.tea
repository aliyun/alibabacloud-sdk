  isQualityCheck?: long(name='IsQualityCheck', description='是否开启座席质检；取值说明：0：不开启，1：开启，默认开启', example='1'),
  isRandom?: string(name='IsRandom', description='随机外显；取值说明 0:否，1:是。当obClidType值为4时需要传值，默认值为0', example='1'),
  name?: string(name='Name', description='座席姓名；需进行UTF-8格式的URLEncode编码', example='示例值示例值示例值'),
  obClid?: string(name='ObClid', description='透传号码；可传入企业中继号码或设置好的客户侧外显号码，当obClidType值为2或3时必选', example='22223333'),
  obClidProperty?: string(name='ObClidProperty', description='外显属性；取值：{"isMatchCapital":0,"areaCodeRule":1}；obClidType=4时，isMatchCapital表示是否匹配省会号码，1是 0否，areaCodeRule表示区号匹配规则，1座席区号 2客户号码区号（注意：json格式数据需要URLencode）', example='{"isMatchCapital":0,"areaCodeRule":1}'),
  obClidType?: long(name='ObClidType', description='外显规则；取值：1:默认 2:随机 3:按区号 4 动态外显 ，默认值为1', example='1'),
  obRecord?: long(name='ObRecord', description='外呼是否录音；取值说明 0：不录音，1：录音，默认录音', example='1'),
  ownerId?: long(name='OwnerId'),
  permitObPreviewTime?: string(name='PermitObPreviewTime', description='可外呼时间段；格式：08:00,20:00', example='08:00,20:00'),
  power?: long(name='Power', description='座席权限；取值1或0，取值说明 1：班长席，0：普通座席，默认为0 普通座席', example='1'),
  resourceOwnerAccount?: string(name='ResourceOwnerAccount'),
  resourceOwnerId?: long(name='ResourceOwnerId'),
  skillIds?: string(name='SkillIds', description='所选的技能id；可选择多个，多个之间使用英文标点逗号间隔.例如:"1,2,3"；skillIds为"0"时代表清空座席所有技能，不为"0"时需要同时传入skillLevels', example='1,2,3'),
  skillLevels?: string(name='SkillLevels', description='所选的技能的等级；值越小技能越高，多个间用英文标点逗号间隔。(与技能id相对应) 例如:"5,1,1"表示技能id为1的等级是5; 技能id为2的等级是1; 技能id为3的等级是1.', example='5,1,1'),
  webrtcUrlType?: long(name='WebrtcUrlType', description='webrtc软电话返回地址；取值说明：0：企业默认 1：公网域名 2：专线域名 3：公网IP 4：专线IP', example='1'),
  wrapup?: long(name='Wrapup', description='整理时间；单位秒数，默认10秒', example='22'),
}

