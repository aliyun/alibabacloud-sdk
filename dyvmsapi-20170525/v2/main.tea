  retry?: long(name='Retry', description='重试次数；最大5次，使用的企业需要开启webcall自动重试开关', example='2'),
  retryInterval?: long(name='RetryInterval', description='重试间隔，单位分钟，最小0分钟，最大59分钟', example='3'),
