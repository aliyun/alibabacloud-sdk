/**
 *
 */
import OpenApi;
import OpenApi.OpenApiUtil;

extends OpenApi;


init(config: OpenApiUtil.Config){
  super(config);
  @endpointRule = 'regional';
  
  checkConfig(config);
  @endpoint = getEndpoint('btripopen', @regionId, @endpointRule, @network, @suffix, @endpointMap, @endpoint);
}

function getEndpoint(productId: string, regionId: string, endpointRule: string, network: string, suffix: string, endpointMap: map[string]string, endpoint: string) throws: string{
  if (!$isNull(endpoint)) {
    return endpoint;
  }
  
  if (!$isNull(endpointMap) && !$isNull(endpointMap[regionId])) {
    return endpointMap[regionId];
  }
  return OpenApiUtil.getEndpointRules(productId, regionId, endpointRule, network, suffix);
}

model KeywordSuggestInfo {
  address?: string(name='address', description='The address.', example='杭州湖墅南路XX号'),
  businessAreaWithCity?: KeywordSuggestInfo(name='business_area_with_city', description='The business area.'),
  cityCode?: int32(name='city_code', description='The city code.', example='300100'),
  cityName?: string(name='city_name', description='The city name.', example='杭州'),
  displayName?: string(name='display_name', description='The display name.', example='杭州JW万豪酒店'),
  hotelId?: string(name='hotel_id', description='The hotel ID.', example='53853318'),
  icon?: string(name='icon', description='The icon.', example='https://gw.alicdn.com/imgextra/i3/O1CN01qKg25r1rKLOKxT3vB_!!6000000005612-2-tps-32-32.png'),
  point?: string(name='point', description='The rating.', example='4.8分'),
  price?: string(name='price', description='The hotel starting price, in CNY.', example='524'),
  region?: int32(name='region', description='The region.', example='0'),
  type?: int32(name='type', description='The type.', example='10'),
  typeDesc?: string(name='type_desc', description='The type description.', example='酒店'),
}

model ModulePriceMapValue = {
  price?: long(name='price', description='The price, in cents.', example='10000'),
  serviceNo?: string(name='service_no', description='The service number, such as a flight number or train number.', example='MU1234'),
}

