        quantity?: string(name='quantity', description='The number of remaining seats in the cabin. Valid values: 0-9 (0 to 9 seats remaining) or A (more than 9 seats).', example='8'),
        cabinClassMemo?: string(name='cabin_class_memo', description='The cabin class description.', example='经济舱'),
        specification?: string(name='specification', description='The domestic special notes.', example='经济舱'),
      }(name='cabin_info', description='The detailed cabin information.'),
    }
  ](name='cabin_quantity_list', description='The remaining cabin inventory for each segment.'),
  searchPrice?: {
    totalAmount?: long(name='total_amount', description='The total amount, in cents.', example='1000'),
    handlingAmount?: long(name='handling_amount', description='The service fee amount in cents.', example='100'),
    upgradeAmount?: long(name='upgrade_amount', description='The upgrade fee amount, in cents.', example='1000'),
    taxDiffAmount?: long(name='tax_diff_amount', description='The tax difference amount, in cents.', example='100'),
    hasPrice?: boolean(name='has_price', description='Indicates whether a direct quote is available. Default value: true.', example='true'),
    nonPriceText?: string(name='non_price_text', description='The text prompt displayed when no direct quote is available.', example='待服务商确认'),
  }(name='search_price', description='The rebooking search price.'),
  segmentPriceList?: [ 
    {
      segmentPosition?: {
        journeyIndex?: int32(name='journey_index', description='The journey ordinal number, starting from 0.', example='0'),
        segmentIndex?: int32(name='segment_index', description='The segment ordinal number, starting from 0 within the same journey.', example='0'),
      }(name='segment_position', description='The segment position information, indicating which journey and which segment within the overall itinerary.'),
      searchPrice?: {
        totalAmount?: long(name='total_amount', description='The total amount in cents.', example='1000'),
        handlingAmount?: long(name='handling_amount', description='The service fee amount in cents.', example='1000'),
        upgradeAmount?: long(name='upgrade_amount', description='The upgrade fee amount in cents.', example='1000'),
        taxDiffAmount?: long(name='tax_diff_amount', description='The tax difference amount in cents.', example='1000'),
        hasPrice?: boolean(name='has_price', description='Indicates whether a direct quote is available. Default value: true.', example='1000'),
        nonPriceText?: string(name='non_price_text', description='The text prompt displayed when no direct quote is available.', example='待服务商确认'),
      }(name='search_price', description='The rebooking quote.'),
    }
  ](name='segment_price_list', description='The price for each segment. This field may not have a value because airline bundled products may not have prices broken down by segment.'),
}

