model AccessTokenRequest {
  appSecret?: string(name='app_secret', description='The API secret of the application. For information about how to obtain the secret, see [Application credentials](/#/document/server/application-of-basic-information?handbookId=development-support).

This parameter is required.', example='ggZADk********eDxdaD'),
}

model AccessTokenResponseBody = {
  code?: string(name='code', description='The status code.', example='SUCCESS'),
  data?: {
    expire?: long(name='expire', description='**Deprecated. Use the** `module` **field instead**.', example='-'),
    token?: string(name='token', description='**Deprecated. Use the** `module` **field instead**.', example='-'),
  }(name='data', description='The response data. **Deprecated. Use the** `module` **field instead**.'),
  message?: string(name='message', description='The response message.', example='成功'),
  module?: {
    expire?: long(name='expire', description='The validity duration of the token. The initial value is 2 hours (7200000 ms). To prevent token expiration, set the refresh interval to: **5 minutes ≤ interval ≤ 2 hours**. If you refresh within this interval, the token obtained from the previous request remains valid.', example='7200000'),
    start?: long(name='start', description='The time when the token takes effect.', example='1652410740914'),
    token?: string(name='token', description='The application access token.', example='37***df'),
  }(name='module', description='The response data.'),
  requestId?: string(name='requestId', description='The unique identifier of this request.', example='407543AF-****-****-****-9D1AB7218B27'),
  success?: boolean(name='success', description='Indicates whether the request was successful.', example='true'),
  traceId?: string(name='traceId', description='The global trace identifier of the request, typically used for troubleshooting.', example='21041ce********056433edbb2'),
}

model AccessTokenResponse = {
  headers?: map[string]string(name='headers'),
  statusCode?: int32(name='statusCode'),
  body?: AccessTokenResponseBody(name='body'),
}

/**
 * @summary This operation has been discontinued (existing enterprise users are not affected).
 *
 * @description Starting now, when calling enterprise data, you only need to pass in:
 * * [corpToken](https://openapi.alibtrip.com/doc/toDocDetail?docId=3769985): Applicable for regular enterprises to obtain travel data within their own enterprise.
 * * [groupCorpToken](https://openapi.alibtrip.com/doc/toDocDetail?docId=4210653): Applicable for group enterprises to obtain data of the parent enterprise or subsidiary enterprises.
 *
 * @param request AccessTokenRequest
