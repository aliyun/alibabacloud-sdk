  type?: string(name='type', description='The type of protocol for Managed Service for OpenTelemetry. Only Jaeger is supported.', example='Jaeger'),
}

model Trigger {
  createdTime?: string(name='createdTime', description='The time when the trigger was created.', example='2020-08-20T02:28:21Z'),
  description?: string(name='description', description='The description of the trigger.', example='test_description'),
  httpTrigger?: HTTPTrigger(name='httpTrigger', description='The information about the HTTP trigger.'),
  invocationRole?: string(name='invocationRole', description='The role that is used by the event source such as OSS to invoke the function.', example='acs:ram::151641468453****:role/my-role'),
  lastModifiedTime?: string(name='lastModifiedTime', description='The time when the trigger was last modified.', example='2020-04-23T06:32:43Z'),
  qualifier?: string(name='qualifier', description='The version or alias of the function.', example='LATEST'),
  sourceArn?: string(name='sourceArn', description='The Alibaba Cloud Resource Name (ARN) of the event source for the trigger.', example='acs:oss:cn-hangzhou:151641468453****:my-bucket'),
  status?: string(name='status', description='The status of the trigger.', example='OK'),
  targetArn?: string(name='targetArn', description='The ARN of the function.', example='acs:oss:cn-hangzhou:151641468453****:my-bucket'),
  triggerConfig?: string(name='triggerConfig', description='The configurations of the trigger. The configurations vary based on trigger types.', example='{
      "events": [
            "oss:ObjectCreated:*"
      ],
      "filter": {
            "key": {
                  "prefix": "/prefix",
                  "suffix": ".zip"
            }
      }
}'),
  triggerId?: string(name='triggerId', description='The unique ID of the trigger.', example='546959b5-ce1a-4991-8891-df7a02b25086'),
  triggerName?: string(name='triggerName', description='The name of the trigger. The name contains only letters, digits, hyphens (-), and underscores (_). The name must be 1 to 128 characters in length and cannot start with a digit or hyphen (-).', example='defaultTrigger'),
  triggerType?: string(name='triggerType', description='The type of the trigger.', example='http'),
}

