  minInstances?: long(name='minInstances'),
  residentPoolId?: string(name='residentPoolId'),
  scalingPolicies?: [
    ScalingPolicy
  ](name='scalingPolicies'),
  scheduledPolicies?: [
    ScheduledPolicy
  ](name='scheduledPolicies'),
  targetInstances?: long(name='targetInstances'),
