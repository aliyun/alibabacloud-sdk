model CreateCollectionRequest {
  algorithm?: string(name='Algorithm', description='The vector index algorithm.

Valid values:

- `hnswflat`: (Default) An HNSW index without quantization compression.

- `novam`: A graph index without quantization compression. This algorithm is suitable for high-performance scenarios, such as real-time recommendations.

- `novad`: A partitioned index with `rabitq` quantization. This algorithm is suitable for large-scale, low-cost retrieval scenarios.', example='hnswflat'),
  collection?: string(name='Collection', description='The name of the collection to create.

> The name must comply with PostgreSQL object naming conventions.

This parameter is required.', example='document'),
  DBInstanceId?: string(name='DBInstanceId', description='The instance ID.

> You can call the [DescribeDBInstances](https://help.aliyun.com/document_detail/86911.html) operation to query the IDs of all AnalyticDB for PostgreSQL instances in a specific region.', example='gp-bp152460513z****'),
  dimension?: long(name='Dimension', description='The vector dimension.

> If you specify this parameter, a vector index is created. In subsequent calls to the [UpsertCollectionData](https://help.aliyun.com/document_detail/2401493.html) operation, the length of `Rows.Vector` must match this dimension. If you do not specify this parameter, you must call the [CreateVectorIndex](https://help.aliyun.com/document_detail/2401499.html) operation to create an index later.', example='1024'),
  externalStorage?: int32(name='ExternalStorage', description='Specifies whether to use `mmap` to build the HNSW index. The default value is 0. We recommend setting this to 1 if your data does not require deletion and you need high-performance data ingestion.

Valid values:

- `0`: (Default) Builds the index by using segmented page storage. This mode can use the `shared_buffer` in PostgreSQL for caching and supports `DELETE` and `UPDATE` operations.

- `1`: Builds the index by using `mmap`. This mode does not support `DELETE` or `UPDATE` operations.

>Notice: 

The `ExternalStorage` parameter is available only for AnalyticDB for PostgreSQL v6.0 instances and is not supported in v7.0.', example='0'),
  fullTextRetrievalFields?: string(name='FullTextRetrievalFields', description='The fields to use for full-text search. Use commas (`,`) to separate multiple field names. These fields must be keys defined in the `Metadata` parameter.', example='title,content'),
  hnswEfConstruction?: string(name='HnswEfConstruction', description='The size of the candidate set for HNSW index construction. The value must be greater than or equal to `2 * HnswM`.

> Value range:
>
> - For AnalyticDB for PostgreSQL V6.0 instances: 40 to 4000.
>
> - For AnalyticDB for PostgreSQL V7.0 instances: 4 to 1000. The default value is 64.', example='128'),
  hnswM?: int32(name='HnswM', description='The maximum number of neighbors for the HNSW algorithm. You do not typically need to set this parameter, as the system automatically determines a value based on the vector dimension.

