model MasterNodeConfiguration {
  amount?: long(name='amount', description='The number of dedicated master nodes.

This parameter is required.', example='3'),
  disk?: long(name='disk', description='The storage space of dedicated master nodes. Unit: GB.

This parameter is required.', example='20'),
  diskType?: string(name='diskType', description='The storage type of dedicated master nodes. Valid values:
- cloud_ssd: standard SSD
- cloud_essd (default): Enterprise SSD (ESSD).

This parameter is required.', example='cloud_essd'),
  spec?: string(name='spec', description='The node specifications of dedicated master nodes. For more information, see [Product specifications](https://help.aliyun.com/document_detail/271718.html).

This parameter is required.', example='elasticsearch.sn2ne.large'),
}

model MigrationJob {
  currentState?: string(name='currentState'),
  disableSourceClusterAuth?: boolean(name='disableSourceClusterAuth'),
  disableTargetClusterAuth?: boolean(name='disableTargetClusterAuth'),
  endTime?: long(name='endTime'),
  migrationJobId?: string(name='migrationJobId'),
  phase?: string(name='phase'),
  sourceCluster?: {
    instanceId?: string(name='instanceId'),
    type?: string(name='type'),
  }(name='sourceCluster'),
  startTime?: long(name='startTime'),
  statusResult?: [ 
    {
      code?: string(name='code'),
      success?: boolean(name='success'),
    }
  ](name='statusResult'),
  targetCluster?: {
    instanceId?: string(name='instanceId'),
    type?: string(name='type'),
  }(name='targetCluster'),
  updateTime?: long(name='updateTime'),
}

model NetworkConfig {
  lbReplica?: int32(name='lbReplica'),
  loadBalanceConfig?: [ 
    {
      vsArea?: string(name='vsArea', description='可用区信息，如: cn-hangzhou-i'),
      vswitchId?: string(name='vswitchId', description='vswitchId', example='vsw-xxxx'),
    }
  ](name='loadBalanceConfig'),
  loadBalanceType?: string(name='loadBalanceType', description='The load balancing type. Default value: DEFAULT.', example='DEFAULT'),
  type?: string(name='type', description='The network type. Only Virtual Private Cloud (VPC) is supported.', example='vpc'),
  vpcId?: string(name='vpcId', description='The VPC ID.', example='vpc-bp1xk0naij7jx4ph1****'),
  vsArea?: string(name='vsArea', description='The zone ID of the network.', example='cn-hangzhou-e'),
  vswitchId?: string(name='vswitchId', description='The vSwitch ID.', example='vsw-bp1ogpdintii5qvyx****'),
  whiteIpGroupList?: [
    WhiteIpGroup
  ](name='whiteIpGroupList', description='The IP whitelist group configuration. You do not need to set this parameter when you call the createInstance operation to create an instance because the setting does not take effect during instance creation. Use a separate API operation to configure whitelists for different roles.'),
}

model NodeInfo {
  host?: string(name='host', description='The IP address of the node.', example='172.16.xx.xx'),
  hostName?: string(name='hostName', description='The node name. This parameter is supported only for instances of version 7.16 deployed on ACK.', example='es-cn-tl32vdghe0005cd99-data-b-2'),
  port?: long(name='port', description='The port number of the node.', example='9200'),
  zoneId?: string(name='zoneId', description='The zone ID of the node.', example='cn-hangzhou-b'),
}

model NodeSpec {
  disk?: int32(name='disk', description='Storage space size of data nodes, in GB.', example='20'),
  diskEncryption?: boolean(name='diskEncryption', description='Whether to enable cloud disk encryption for data nodes:

- true: Enabled
- false: Disabled', example='false'),
  diskPreference?: string(name='diskPreference', description='Storage preference.'),
  diskType?: string(name='diskType', description='Storage type of data nodes. Supported values:

- cloud_ssd: SSD cloud disk
- cloud_essd: ESSD cloud disk
- cloud_efficiency: Ultra cloud disk', example='cloud_ssd'),
  performanceLevel?: string(name='performanceLevel', description='Performance level of ESSD cloud disks. Required when the disk type of data nodes is ESSD cloud disk. Supported values: PL1, PL2, PL3.', example='PL1'),
  spec?: string(name='spec', description='Data node specification. Specification details can be viewed in [Product Specifications](https://help.aliyun.com/document_detail/271718.html).

This parameter is required.', example='elasticsearch.sn2ne.large'),
}

model PaymentInfo {
  autoRenewDuration?: long(name='autoRenewDuration', description='The auto-renewal cycle. Unit: month. This parameter is required when **isAutoRenew** is set to **true**. The valid values are the same as those on the buy page.', example='3'),
  duration?: long(name='duration', description='The subscription duration. This parameter is required. You can specify the duration in months or years.', example='1'),
  isAutoRenew?: boolean(name='isAutoRenew', description='Specifies whether to enable auto-renewal. Valid values:

- true: enabled.
- false (default): disabled.', example='true'),
  pricingCycle?: string(name='pricingCycle', description='The unit of the subscription duration. This parameter is required. Valid values:

- Year: year
- Month: month.', example='Month'),
}

model ReadWritePolicy {
  autoGeneratePk?: boolean(name='autoGeneratePk', description='Specifies whether to automatically generate a document hash primary key when no primary key exists. Valid values:

- true (default): automatically generates a primary key.
- false: does not automatically generate a primary key.

>Notice:  autoGeneratePk cannot be modified independently. The autoGeneratePk setting takes effect only when writeHa is changed from false to true.
.', example='true'),
  writeHa?: boolean(name='writeHa', description='Specifies whether to enable the write high-availability feature. Valid values:

- true: enabled.
- false: not enabled.', example='true'),
  writePolicy?: string(name='writePolicy', description='Temporarily switches between synchronous and asynchronous high availability. Valid values:

- sync: temporarily switches from asynchronous write high availability to synchronous write.
- async: restores asynchronous write high availability after synchronous write is temporarily enabled.

> This field takes effect only when high availability is enabled, that is, writeHa is set to true. You do not need to pass in the writeHa field when setting this field.', example='sync'),
}

model Tag {
  tagKey?: string(name='tagKey', description='The tag key.', example='env'),
  tagValue?: string(name='tagValue', description='The tag value.', example='dev'),
}

model WarmNodeConfiguration {
  amount?: long(name='amount', description='The number of cold data nodes.', example='3'),
  disk?: long(name='disk', description='The storage space size of cold data nodes, in GB.', example='500'),
  diskEncryption?: boolean(name='diskEncryption', description='Specifies whether to enable cloud disk encryption for cold data nodes. Valid values:

- true: enabled.
- false: not enabled.', example='false'),
  diskType?: string(name='diskType', description='The storage type of cold data nodes. Only cloud_efficiency (ultra cloud disk) is supported.', example='cloud_efficiency'),
  performanceLevel?: string(name='performanceLevel', description='The performance level (PL) of the ESSD cloud disk. This parameter is required when the disk type of cold data nodes is a standard SSD. Valid values: PL1, PL2, and PL3.', example='PL1'),
  spec?: string(name='spec', description='The node specifications of cold data nodes. For more information, see [Product specifications](https://help.aliyun.com/document_detail/271718.html).

This parameter is required.', example='elasticsearch.sn2ne.large'),
}

model WhiteIpGroup {
  whiteIpType?: string(name='WhiteIpType', description='The type of the IP address whitelist. Valid values:

- PRIVATE_ES: Elasticsearch private network access whitelist
- PUBLIC_ES: Elasticsearch public network access whitelist
- PRIVATE_KIBANA: Kibana private network access whitelist
- PUBLIC_KIBANA: Kibana public network access whitelist.', example='PRIVATE_ES'),
  groupName?: string(name='groupName', description='The name of the IP address whitelist group.', example='test_group'),
  ips?: [ string ](name='ips', description='The list of IP addresses in the whitelist group.'),
}

model ZoneInfo {
  status?: string(name='status', description='The zone status. Valid values:

- ISOLATION: offline
- NORMAL: Normal.', example='NORMAL'),
  zoneId?: string(name='zoneId', description='The zone ID, which uniquely identifies the zone.', example='cn-hangzhou-b'),
}

model ResultSpecInfoMapValue = {
  cpuCount?: string(name='cpuCount'),
  memorySize?: string(name='memorySize'),
  enable?: string(name='enable'),
  spec?: string(name='spec'),
