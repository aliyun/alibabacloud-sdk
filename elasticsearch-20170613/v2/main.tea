- true: The instance contains Kibana nodes.
- false: The instance does not contain Kibana nodes.', example='true'),
  ikHotDicts?: [
    DictInfo
  ](name='ikHotDicts', description='The IK hot dictionary configuration.'),
  instanceId?: string(name='instanceId', description='The instance ID.', example='es-cn-3h4k3axh33th9****'),
  kibanaConfiguration?: KibanaNodeConfiguration(name='kibanaConfiguration', description='The Kibana node configuration.'),
  kibanaDomain?: string(name='kibanaDomain', description='The public network access address of Kibana.', example='es-cn-3h4k3axh33th9****.kibana.elasticsearch.aliyuncs.com'),
  kibanaIPWhitelist?: [ string ](name='kibanaIPWhitelist', description='The public network access whitelist configuration of Kibana.'),
  kibanaPort?: long(name='kibanaPort', description='The public network access port of Kibana.', example='5601'),
  kibanaPrivateDomain?: string(name='kibanaPrivateDomain', description='The private network access address of Kibana.', example='es-cn-tl329rbpc0001****-kibana.internal.elasticsearch.aliyuncs.com'),
  kibanaPrivateIPWhitelist?: [ string ](name='kibanaPrivateIPWhitelist', description='The IP whitelist configuration for private network access to Kibana.'),
  kibanaPrivatePort?: long(name='kibanaPrivatePort', description='The private network access port of Kibana.', example='5601'),
  kibanaProtocol?: string(name='kibanaProtocol', description='The access protocol for Kibana. Valid values: HTTP and HTTPS.', example='HTTPS'),
  masterConfiguration?: MasterNodeConfiguration(name='masterConfiguration', description='The dedicated master node configuration.'),
  networkConfig?: NetworkConfig(name='networkConfig', description='The network configuration of the instance.'),
  nodeAmount?: long(name='nodeAmount', description='The number of data nodes in the instance.', example='2'),
  nodeSpec?: NodeSpec(name='nodeSpec', description='The data node configuration.'),
  paymentType?: string(name='paymentType', description='The billing method of the instance. Valid values:

- prepaid: subscription.
- postpaid: pay-as-you-go.', example='prepaid'),
  port?: long(name='port', description='The private network access port of the instance.', example='9200'),
  privateNetworkIpWhiteList?: [ string ](name='privateNetworkIpWhiteList', description='The private network address access whitelist configuration of the instance.'),
  productType?: string(name='productType', description='The instance edition. Valid values:

- logEnhancement: Advanced Edition.
- generalBusiness: general commercial edition.', example='generalBusiness'),
  protocol?: string(name='protocol', description='The access protocol of the instance. Valid values: HTTP and HTTPS.', example='HTTP'),
  publicDomain?: string(name='publicDomain', description='The public network access address of the Elasticsearch instance.', example='es-cn-3h4k3axh33th9****.elasticsearch.aliyuncs.com'),
  publicIpWhitelist?: [ string ](name='publicIpWhitelist', description='The public network access whitelist configuration of the instance.'),
  publicPort?: long(name='publicPort', description='The public network access port of the Elasticsearch instance.', example='9200'),
  readWritePolicy?: ReadWritePolicy(name='readWritePolicy', description='The high availability configuration of the instance.'),
  resourceGroupId?: string(name='resourceGroupId', description='The ID of the resource group to which the instance belongs.', example='rg-aekzvowej3i****'),
  serviceVpc?: boolean(name='serviceVpc', description='Indicates whether the instance is in the Elasticsearch service VPC. Valid values:

- true: The instance is in the service VPC.
- false: The instance is not in the service VPC.', example='true'),
  status?: string(name='status', description='The status of the instance. Valid values:

- active: Normal.
- activating: Taking effect.
- inactive: Frozen.
- invalid: Expired.', example='active'),
  synonymsDicts?: [
    DictInfo
  ](name='synonymsDicts', description='The synonym dictionary configuration of the instance.'),
  tags?: [
    Tag
  ](name='tags', description='The instance tags.'),
  updatedAt?: string(name='updatedAt', description='The time when the instance was last updated.', example='2018-07-13T03:58:07.253Z'),
  warmNode?: boolean(name='warmNode', description='Indicates whether warm data nodes are enabled. Valid values:

- true: Enabled.
- false: Disabled.', example='false'),
  warmNodeConfiguration?: WarmNodeConfiguration(name='warmNodeConfiguration', description='The warm data node configuration.'),
  zoneCount?: long(name='zoneCount', description='The number of zones for the instance.', example='1'),
  zoneInfos?: [
    ZoneInfo
  ](name='zoneInfos', description='The zone information of the instance.'),
}

