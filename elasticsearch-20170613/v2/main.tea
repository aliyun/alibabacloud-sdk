  dataNode?: boolean(name='dataNode', description='Indicates whether the instance contains data nodes. Valid values:

- true: The instance contains data nodes.
- false: The instance does not contain data nodes.', example='true'),
  dedicateMaster?: boolean(name='dedicateMaster', description='Indicates whether the instance contains legacy dedicated master nodes (deprecated).', example='false'),
  description?: string(name='description', description='The instance name.', example='es-cn-abc'),
  dictList?: [
    DictInfo
  ](name='dictList', description='The IK dictionary configuration.'),
  domain?: string(name='domain', description='The private network access address of the Elasticsearch instance.', example='es-cn-3h4k3axh33th9****.elasticsearch.aliyuncs.com'),
