- **cn-shenzhen**: China (Shenzhen)

- **cn-hongkong**: China (Hong Kong)', example='cn-hangzhou'),
  sourceIp?: string(name='SourceIp', description='This parameter is deprecated.', example='106.11.XX.XX'),
  userName?: string(name='UserName', description='The username for the database.', example='y*****m'),
}

