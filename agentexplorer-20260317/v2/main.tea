/**
 *
 */
import OpenApi;
import OpenApi.OpenApiUtil;

extends OpenApi;


init(config: OpenApiUtil.Config){
  super(config);
  @endpointRule = 'regional';
  @endpointMap = {
    'public' = 'agentexplorer.aliyuncs.com',
    'cn-hangzhou' = 'agentexplorer.aliyuncs.com',
  };

  checkConfig(config);
  @endpoint = getEndpoint('agentexplorer', @regionId, @endpointRule, @network, @suffix, @endpointMap, @endpoint);
}

function getEndpoint(productId: string, regionId: string, endpointRule: string, network: string, suffix: string, endpointMap: map[string]string, endpoint: string) throws: string{
  if (!$isNull(endpoint)) {
    return endpoint;
  }
  
  if (!$isNull(endpointMap) && !$isNull(endpointMap[regionId])) {
    return endpointMap[regionId];
  }
  return OpenApiUtil.getEndpointRules(productId, regionId, endpointRule, network, suffix);
}

model Category {
  children?: [ 
    {
      code?: string(name='code', description='Level 2 Category Code', example='ecs'),
      name?: string(name='name', description='Level 2 Category Name', example='弹性计算'),
    }
  ](name='children', description='Sub-categories'),
  code?: string(name='code', description='Level 1 Category Code', example='compute'),
  name?: string(name='name', description='Level 1 Category Name', example='计算'),
}

model Skill {
  categoryCode?: string(name='categoryCode', description='The primary category code.', example='compute'),
  categoryName?: string(name='categoryName', description='The primary category name.', example='计算'),
  categoryNameEn?: string(name='categoryNameEn'),
  createdAt?: string(name='createdAt', description='The time when the Agent Skill was created.', example='2026-01-01T00:00:00Z'),
  description?: string(name='description', description='The description of the Agent Skill.', example='ECS 实例管理'),
  descriptionEn?: string(name='descriptionEn'),
  displayName?: string(name='displayName', description='The display name of the Agent Skill.', example='ECS 实例管理'),
  githubPath?: string(name='githubPath'),
  installCount?: int32(name='installCount', description='The number of installations.', example='1024'),
  likeCount?: int32(name='likeCount', description='The number of likes.', example='128'),
  nameEn?: string(name='nameEn'),
  skillName?: string(name='skillName', description='The English name of the Agent Skill, which serves as a unique identifier.', example='deploy-to-vercel'),
  subCategoryCode?: string(name='subCategoryCode', description='The secondary category code.', example='ecs'),
  subCategoryName?: string(name='subCategoryName', description='The secondary category name.', example='弹性计算'),
  subCategoryNameEn?: string(name='subCategoryNameEn'),
  updatedAt?: string(name='updatedAt', description='The time when the Agent Skill was last updated.', example='2026-03-17T00:00:00Z'),
}

model GetSkillContentRequest {
}

model GetSkillContentResponseBody = {
  content?: string(name='content', description='SKILL.md file content', example='---
name: alibabacloud-find-skills
description: "Search for official Alibaba Cloud Agent Skills based on user requirements"
---

Agent Skill Body Content Here'),
  requestId?: string(name='requestId', description='Id of the request', example='1764D64D-5262-55DA-BDBF-1F949B1B34F7'),
}

model GetSkillContentResponse = {
  headers?: map[string]string(name='headers'),
  statusCode?: int32(name='statusCode'),
  body?: GetSkillContentResponseBody(name='body'),
}

/**
 * @summary Get the SKILL.md file content of the specified Agent Skill
 *
 * @param request GetSkillContentRequest
 * @param headers map
 * @param runtime runtime options for this request RuntimeOptions
 * @return GetSkillContentResponse
 */
@context("getSkillContentWithContext")
async function getSkillContentWithOptions(skillName: string, request: GetSkillContentRequest, headers: map[string]string, runtime: $RuntimeOptions): GetSkillContentResponse {
  request.validate();
  var req = new OpenApiUtil.OpenApiRequest{ 
    headers = headers,
  };
  var params = new OpenApiUtil.Params{
    action = 'GetSkillContent',
    version = '2026-03-17',
    protocol = 'HTTPS',
    pathname = `/openapi/skills/${$URL.percentEncode(skillName)}`,
    method = 'GET',
    authType = 'AK',
    style = 'ROA',
    reqBodyType = 'json',
    bodyType = 'json',
  };
  return callApi(params, req, runtime);
}

/**
 * @summary Get the SKILL.md file content of the specified Agent Skill
 *
 * @param request GetSkillContentRequest
 * @return GetSkillContentResponse
 */
async function getSkillContent(skillName: string, request: GetSkillContentRequest): GetSkillContentResponse {
  var runtime = new $RuntimeOptions{};
  var headers : map[string]string = {};
  return getSkillContentWithOptions(skillName, request, headers, runtime);
}

model ListCategoriesRequest {
}

model ListCategoriesResponseBody = {
  data?: [
    Category
  ](name='data', description='The returned category list'),
  message?: string(name='message', description='Response message', example='success'),
  requestId?: string(name='requestId', description='request ID', example='099A671E-FA21-5A36-8A73-918572DDEF53'),
}

model ListCategoriesResponse = {
  headers?: map[string]string(name='headers'),
  statusCode?: int32(name='statusCode'),
  body?: ListCategoriesResponseBody(name='body'),
}

/**
 * @summary List all Alibaba Cloud Skills categories.
 *
 * @param request ListCategoriesRequest
 * @param headers map
 * @param runtime runtime options for this request RuntimeOptions
 * @return ListCategoriesResponse
 */
@context("listCategoriesWithContext")
async function listCategoriesWithOptions(request: ListCategoriesRequest, headers: map[string]string, runtime: $RuntimeOptions): ListCategoriesResponse {
  request.validate();
  var req = new OpenApiUtil.OpenApiRequest{ 
    headers = headers,
  };
  var params = new OpenApiUtil.Params{
    action = 'ListCategories',
    version = '2026-03-17',
    protocol = 'HTTPS',
    pathname = `/openapi/categories`,
    method = 'GET',
    authType = 'AK',
    style = 'ROA',
    reqBodyType = 'json',
    bodyType = 'json',
  };
  return callApi(params, req, runtime);
}

/**
 * @summary List all Alibaba Cloud Skills categories.
 *
 * @param request ListCategoriesRequest
 * @return ListCategoriesResponse
 */
async function listCategories(request: ListCategoriesRequest): ListCategoriesResponse {
  var runtime = new $RuntimeOptions{};
  var headers : map[string]string = {};
  return listCategoriesWithOptions(request, headers, runtime);
}

model SearchSkillsRequest {
  categoryCode?: string(name='categoryCode', description='The skill category code. Separate multiple codes with commas. For a second-level category, use the format: first-level category.second-level category.', example='compute.serverless,network'),
  keyword?: string(name='keyword', description='The search keyword.', example='ecs'),
  maxResults?: int32(name='maxResults', description='The maximum number of entries per page for a paged query. Maximum value: 100. Default value: 20.', example='20'),
  nextToken?: string(name='nextToken', description='The token for the next query. Set this to the NextToken value returned by the previous API call.', example='AAAAAZjtYxxxxxxxx'),
  searchMode?: string(name='searchMode'),
  skip?: int32(name='skip', description='The number of entries to skip for pagination.', example='10'),
}

model SearchSkillsResponseBody = {
  data?: [
    Skill
  ](name='data', description='The list of skills returned.'),
  maxResults?: int32(name='maxResults', description='The maximum number of entries per page for a paged query. Maximum value: 100. Default value: 20.', example='20'),
  nextToken?: string(name='nextToken', description='The NextToken value, which is used to retrieve more results.', example='AAAAAZjtYxxxxxxxx'),
  requestId?: string(name='requestId', description='Id of the request', example='53EAEBC0-4DEC-5AF4-AA21-3923D5A819C3'),
  totalCount?: int32(name='totalCount', description='The total number of records.', example='22'),
}

model SearchSkillsResponse = {
  headers?: map[string]string(name='headers'),
  statusCode?: int32(name='statusCode'),
  body?: SearchSkillsResponseBody(name='body'),
}

/**
 * @summary Searches for Alibaba Cloud Agent Skills by keyword or category.
 *
 * @param request SearchSkillsRequest
 * @param headers map
 * @param runtime runtime options for this request RuntimeOptions
 * @return SearchSkillsResponse
 */
@context("searchSkillsWithContext")
async function searchSkillsWithOptions(request: SearchSkillsRequest, headers: map[string]string, runtime: $RuntimeOptions): SearchSkillsResponse {
  request.validate();
  var query : map[string]any = {};
  if (!$isNull(request.categoryCode)) {
    query['categoryCode'] = request.categoryCode;
  }
  if (!$isNull(request.keyword)) {
    query['keyword'] = request.keyword;
  }
  if (!$isNull(request.maxResults)) {
    query['maxResults'] = request.maxResults;
  }
  if (!$isNull(request.nextToken)) {
    query['nextToken'] = request.nextToken;
  }
  if (!$isNull(request.searchMode)) {
    query['searchMode'] = request.searchMode;
  }
  if (!$isNull(request.skip)) {
    query['skip'] = request.skip;
  }

  var req = new OpenApiUtil.OpenApiRequest{ 
    headers = headers,
    query = OpenApiUtil.query(query),
  };
  var params = new OpenApiUtil.Params{
    action = 'SearchSkills',
    version = '2026-03-17',
    protocol = 'HTTPS',
    pathname = `/openapi/skills`,
    method = 'GET',
    authType = 'AK',
    style = 'ROA',
    reqBodyType = 'json',
    bodyType = 'json',
  };
  return callApi(params, req, runtime);
}

/**
 * @summary Searches for Alibaba Cloud Agent Skills by keyword or category.
 *
 * @param request SearchSkillsRequest
 * @return SearchSkillsResponse
 */
async function searchSkills(request: SearchSkillsRequest): SearchSkillsResponse {
  var runtime = new $RuntimeOptions{};
  var headers : map[string]string = {};
  return searchSkillsWithOptions(request, headers, runtime);
}

