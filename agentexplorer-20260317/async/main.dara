/**
  *
  */
import BaseClientBuilder;
import TeaAsyncHandler;
import TeaRequest;
import AsyncRequestBody;
import RequestBody;
import AsyncResponseHandler;
import ClientConfiguration;
import ClientExecutionParams;
extends BaseClientBuilder;
type @product = string
type @version = string
type @endpointRule = string
type @endpointMap = map[string]string
type @REQUEST = TeaRequest
type @handler = TeaAsyncHandler

init(configuration: ClientConfiguration){
  @handler = new TeaAsyncHandler(configuration);
  @product = 'AgentExplorer';
  @version = '2026-03-17';
  @endpointRule = 'regional';
  @endpointMap = {
    'public' = 'agentexplorer.aliyuncs.com',
    'cn-hangzhou' = 'agentexplorer.aliyuncs.com',
  };
}

function close(): void {
  @handler.close();
}

model Category {
  children?: [ 
    {
      code?: string(name='code', example='ecs'),
      name?: string(name='name', example='弹性计算'),
    }
  ](name='children'),
  code?: string(name='code', example='compute'),
  name?: string(name='name', example='计算'),
}

model Skill {
  categoryCode?: string(name='categoryCode', example='compute'),
  categoryName?: string(name='categoryName', example='计算'),
  categoryNameEn?: string(name='categoryNameEn'),
  createdAt?: string(name='createdAt', example='2026-01-01T00:00:00Z'),
  description?: string(name='description', example='ECS 实例管理'),
  descriptionEn?: string(name='descriptionEn'),
  displayName?: string(name='displayName', example='ECS 实例管理'),
  githubPath?: string(name='githubPath'),
  installCount?: int32(name='installCount', example='1024'),
  likeCount?: int32(name='likeCount', example='128'),
  nameEn?: string(name='nameEn'),
  skillName?: string(name='skillName', example='deploy-to-vercel'),
  subCategoryCode?: string(name='subCategoryCode', example='ecs'),
  subCategoryName?: string(name='subCategoryName', example='弹性计算'),
  subCategoryNameEn?: string(name='subCategoryNameEn'),
  updatedAt?: string(name='updatedAt', example='2026-03-17T00:00:00Z'),
}

model GetSkillContentRequest {
  skillName: string(name='skillName', description='skill name

This parameter is required.', example='ecs-manager', position='Path'),
}

model GetSkillContentResponseBody = {
  content?: string(name='content', example='---
name: alibabacloud-find-skills
description: "Search for official Alibaba Cloud Agent Skills based on user requirements"
---

Agent Skill Body Content Here'),
  requestId?: string(name='requestId', description='Id of the request', example='1764D64D-5262-55DA-BDBF-1F949B1B34F7'),
}

model GetSkillContentResponse = {
  headers?: map[string]string(name='headers'),
  statusCode?: int32(name='statusCode'),
  body?: GetSkillContentResponseBody(name='body'),
}

/**
  * @param request  the request parameters of GetSkillContent  GetSkillContentRequest
  * @return GetSkillContentResponse
 */
async function getSkillContent(request: GetSkillContentRequest): GetSkillContentResponse {
  @handler.validateRequestModel(request);
  return @handler.do('RESTFUL', 'GetSkillContent', 'GET', '/openapi/skills/{skillName}', 'json', false, 'json', request);
}

model ListCategoriesRequest {
}

model ListCategoriesResponseBody = {
  data?: [
    Category
  ](name='data'),
  message?: string(name='message', example='success'),
  requestId?: string(name='requestId', example='099A671E-FA21-5A36-8A73-918572DDEF53'),
}

model ListCategoriesResponse = {
  headers?: map[string]string(name='headers'),
  statusCode?: int32(name='statusCode'),
  body?: ListCategoriesResponseBody(name='body'),
}

/**
  * @param request  the request parameters of ListCategories  ListCategoriesRequest
  * @return ListCategoriesResponse
 */
async function listCategories(request: ListCategoriesRequest): ListCategoriesResponse {
  @handler.validateRequestModel(request);
  return @handler.do('RESTFUL', 'ListCategories', 'GET', '/openapi/categories', 'json', false, 'json', request);
}

model SearchSkillsRequest {
  categoryCode?: string(name='categoryCode', example='compute.serverless,network', position='Query'),
  keyword?: string(name='keyword', example='ecs', position='Query'),
  maxResults?: int32(name='maxResults', example='20', position='Query'),
  nextToken?: string(name='nextToken', example='AAAAAZjtYxxxxxxxx', position='Query'),
  searchMode?: string(name='searchMode', position='Query'),
  skip?: int32(name='skip', example='10', position='Query'),
}

model SearchSkillsResponseBody = {
  data?: [
    Skill
  ](name='data'),
  maxResults?: int32(name='maxResults', example='20'),
  nextToken?: string(name='nextToken', example='AAAAAZjtYxxxxxxxx'),
  requestId?: string(name='requestId', description='Id of the request', example='53EAEBC0-4DEC-5AF4-AA21-3923D5A819C3'),
  totalCount?: int32(name='totalCount', example='22'),
}

model SearchSkillsResponse = {
  headers?: map[string]string(name='headers'),
  statusCode?: int32(name='statusCode'),
  body?: SearchSkillsResponseBody(name='body'),
}

/**
  * @param request  the request parameters of SearchSkills  SearchSkillsRequest
  * @return SearchSkillsResponse
 */
async function searchSkills(request: SearchSkillsRequest): SearchSkillsResponse {
  @handler.validateRequestModel(request);
  return @handler.do('RESTFUL', 'SearchSkills', 'GET', '/openapi/skills', 'json', false, 'json', request);
}

