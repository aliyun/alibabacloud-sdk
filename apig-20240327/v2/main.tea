import OpenApi;
import OpenApi.OpenApiUtil;

extends OpenApi;


init(config: OpenApiUtil.Config){
  super(config);
  @endpointRule = 'regional';
  @endpointMap = {
    'us-west-1' = 'apig.us-west-1.aliyuncs.com',
    'us-east-1' = 'apig.us-east-1.aliyuncs.com',
    'me-east-1' = 'apig.me-east-1.aliyuncs.com',
    'me-central-1' = 'apig.me-central-1.aliyuncs.com',
    'eu-west-1' = 'apig.eu-west-1.aliyuncs.com',
    'eu-central-1' = 'apig.eu-central-1.aliyuncs.com',
    'cn-zhangjiakou' = 'apig.cn-zhangjiakou.aliyuncs.com',
    'cn-wulanchabu' = 'apig.cn-wulanchabu.aliyuncs.com',
    'cn-shenzhen' = 'apig.cn-shenzhen.aliyuncs.com',
    'cn-shanghai' = 'apig.cn-shanghai.aliyuncs.com',
    'cn-qingdao' = 'apig.cn-qingdao.aliyuncs.com',
    'cn-hongkong' = 'apig.cn-hongkong.aliyuncs.com',
    'cn-heyuan' = 'apig.cn-heyuan.aliyuncs.com',
    'cn-hangzhou' = 'apig.cn-hangzhou.aliyuncs.com',
    'cn-guangzhou' = 'apig.cn-guangzhou.aliyuncs.com',
    'cn-chengdu' = 'apig.cn-chengdu.aliyuncs.com',
    'cn-beijing' = 'apig.cn-beijing.aliyuncs.com',
    'ap-southeast-7' = 'apig.ap-southeast-7.aliyuncs.com',
    'ap-southeast-6' = 'apig.ap-southeast-6.aliyuncs.com',
    'ap-southeast-5' = 'apig.ap-southeast-5.aliyuncs.com',
    'ap-southeast-3' = 'apig.ap-southeast-3.aliyuncs.com',
    'ap-southeast-2' = 'apig.ap-southeast-2.aliyuncs.com',
    'ap-southeast-1' = 'apig.ap-southeast-1.aliyuncs.com',
    'ap-northeast-2' = 'apig.ap-northeast-2.aliyuncs.com',
    'ap-northeast-1' = 'apig.ap-northeast-1.aliyuncs.com',
  };

  checkConfig(config);
  @endpoint = getEndpoint('apig', @regionId, @endpointRule, @network, @suffix, @endpointMap, @endpoint);
}

function getEndpoint(productId: string, regionId: string, endpointRule: string, network: string, suffix: string, endpointMap: map[string]string, endpoint: string) throws: string{
  if (!$isNull(endpoint)) {
    return endpoint;
  }
  
  if (!$isNull(endpointMap) && !$isNull(endpointMap[regionId])) {
    return endpointMap[regionId];
  }
  return OpenApiUtil.getEndpointRules(productId, regionId, endpointRule, network, suffix);
}

model AgentServiceConfig {
  address?: string(name='address', description='The address.

This parameter is required.', example='https://dashscope.aliyuncs.com/api/v1'),
  customConfig?: {
    apiKey?: string(name='apiKey', description='apiKey', example='app-xxx'),
    apiKeyGenerateMode?: string(name='apiKeyGenerateMode', description='API key generation mode.', example='Reference'),
  }(name='customConfig', description='User-defined configuration'),
  dashScopeConfig?: {
    appCredentials?: [ 
      {
        apiKey?: string(name='apiKey', description='apiKey', example='sk-xxx'),
        appId?: string(name='appId', description='The application ID.', example='app-xxx'),
      }
    ](name='appCredentials', description='The application configuration.'),
  }(name='dashScopeConfig', description='The Model Studio service configuration.'),
  difyConfig?: {
    apiKey?: string(name='apiKey', description='API Key', example='app-xxx'),
    botType?: string(name='botType', description='The interaction type.', example='chatbot'),
  }(name='difyConfig', description='The Dify service configuration.'),
  enableHealthCheck?: boolean(name='enableHealthCheck', description='Specifies whether to enable health check.', example='true'),
  enableOutlierDetection?: boolean(name='enableOutlierDetection', description='Whether to enable outlier detection', example='true'),
  protocols?: [ string ](name='protocols', description='The protocol.'),
  provider?: string(name='provider', description='The service provider.

This parameter is required.', example='qwen'),
}

model AiCacheConfig {
  cacheKeyStrategy?: string(name='cacheKeyStrategy', description='The cache key strategy, which determines how the system generates a unique key for each cacheable request. Valid values: `DEFAULT` and `CUSTOM`.'),
  cacheMode?: string(name='cacheMode', description='The cache mode, which defines the caching behavior. Valid values are `NORMAL` for standard key-value caching and `SEMANTIC` for vector-based similarity caching.'),
  cacheTTL?: int32(name='cacheTTL', description='The cache Time-to-Live (TTL) in seconds. This specifies the duration that a cached response remains valid. After the TTL expires, the cache removes the response.'),
  embeddingConfig?: {
    modelName?: string(name='modelName', description='The model name to use for generating embeddings, such as `text-embedding-v1`.'),
    serviceId?: string(name='serviceId', description='The service ID of the deployed embedding model.'),
    timeout?: int32(name='timeout', description='The request timeout in milliseconds. A request to the embedding service fails if it exceeds this duration. Default: `10000`.'),
    type?: string(name='type', description='The type of embedding service. For example, specify `Tongyi` for Alibaba Cloud\\\\"s Tongyi Qwen model series.'),
  }(name='embeddingConfig', description='The embedding configuration. Specifies the service that converts text queries into vector embeddings for semantic search.'),
  pluginStatus?: AiPluginStatus(name='pluginStatus', description='The plugin status. Set to `enable` to activate the plugin or `disable` to deactivate it.', nullable=true),
  redisConfig?: AiPolicyRedisConfig(name='redisConfig', description='The Redis configuration, required if you use a Redis instance as the cache backend.', nullable=true),
  vectorConfig?: {
    apiKey?: string(name='apiKey', description='The API key to authenticate with the vector database service.'),
    collectionId?: string(name='collectionId', description='The unique ID of the collection or index within the vector database for search and storage.'),
    serviceHost?: string(name='serviceHost', description='The endpoint URL of the vector database service.'),
    threshold?: float(name='threshold', description='The similarity threshold for a vector search to qualify as a cache hit. The value must be between 0.0 and 1.0. A higher value means a stricter similarity requirement.'),
    timeout?: int32(name='timeout', description='The request timeout in milliseconds. A request to the vector service fails if it exceeds this duration. Default: `10000`.'),
    type?: string(name='type', description='The type of vector database service. For example, specify `DashVector` for Alibaba Cloud\\\\"s vector search service.'),
  }(name='vectorConfig', description='The vector configuration for semantic caching. This enables the cache to retrieve results based on semantic similarity instead of exact matches.'),
}

model AiFallbackConfig {
  onlyRedirectUpstreamCode?: boolean(name='onlyRedirectUpstreamCode', description='Determines whether fallback is triggered solely by the upstream service\\\\"s status code. If `true`, fallback occurs only if the upstream service returns an error code. If `false`, other conditions, such as timeouts, can also trigger the fallback.'),
  serviceConfigs?: [ 
    {
      name?: string(name='name', description='The name of the fallback service.'),
      passThroughModelName?: boolean(name='passThroughModelName', description='Determines whether to pass the original model name to the fallback service. If `true`, the model name from the original request is used. If `false`, the value of `targetModelName` is used instead.'),
      serviceId?: string(name='serviceId', description='The unique ID of the fallback service.'),
      targetModelName?: string(name='targetModelName', description='The name of the model to use for the fallback request.'),
    }
  ](name='serviceConfigs', description='A list of fallback service configurations.'),
}

model AiNetworkConfigSearchEngine {
  apiKey?: string(name='apiKey', description='Required. The API key to authenticate requests to the search engine service.'),
  contentMode?: string(name='contentMode', description='The search content mode, which determines how the service interprets the query and returns results.'),
  count?: int32(name='count', description='The number of search results to return. If this parameter is omitted, the service uses a default value.'),
  endpoint?: string(name='endpoint', description='The endpoint URL for the search engine service.'),
  industry?: string(name='industry', description='The industry context for tailoring search results to a specific domain.'),
  optionArgs?: map[string]string(name='optionArgs', description='Optional. A key-value map for service-specific parameters not covered by the standard configuration.'),
  start?: int32(name='start', description='The starting offset for the search results, used for pagination. For example, a value of 10 skips the first 10 results. The default is 0.'),
  timeRange?: string(name='timeRange', description='The time range for filtering results by their creation or modification date.'),
  timeoutMillisecond?: int32(name='timeoutMillisecond', description='The request timeout in milliseconds. If a request exceeds this time, the service terminates it.'),
  type?: string(name='type', description='Specifies the search engine service to use.'),
}

model AiNetworkSearchConfig {
  defaultEnable?: boolean(name='defaultEnable', description='Whether the network search feature is enabled by default.'),
  defaultLang?: string(name='defaultLang', description='The default language for the search query.'),
  needReference?: boolean(name='needReference', description='Whether to include references in the search results.'),
  pluginStatus?: AiPluginStatus(name='pluginStatus', description='The status of the AI plugin.', nullable=true),
  referenceFormat?: string(name='referenceFormat', description='The format of the references.'),
  referenceLocation?: string(name='referenceLocation', description='The location of the references in the response.'),
  searchEngineConfig?: AiNetworkConfigSearchEngine(name='searchEngineConfig', description='The search engine configuration.'),
  searchFrom?: [
    AiNetworkConfigSearchEngine
  ](name='searchFrom', description='A list of search engine configurations for the network search.'),
  searchRewrite?: {
    enable?: boolean(name='enable', description='Whether to enable the search query rewrite feature.'),
    maxCount?: int32(name='maxCount', description='The maximum number of rewritten queries to generate.'),
    modelName?: string(name='modelName', description='The name of the model to use for query rewriting.'),
    serviceId?: string(name='serviceId', description='The ID of the query rewriting service.'),
    timeoutMillisecond?: int32(name='timeoutMillisecond', description='Timeout for the query rewriting operation, in milliseconds.'),
  }(name='searchRewrite', description='Configuration for search query rewriting.'),
}

model AiPluginStatus {
  errorLogs?: [ map[string]any ](name='errorLogs', description='An object containing error logs, where each key is a string identifying an error and the value is a string describing that error.'),
  pluginId?: string(name='pluginId', description='The unique identifier of the plugin.'),
  serviceHealthy?: boolean(name='serviceHealthy', description='Indicates if the service is healthy. `true` indicates normal operation, and `false` indicates an issue.'),
