  overwrite?: boolean(name='overwrite', description='Specifies whether to allow overwriting when a conflict exists. If overwriting is allowed, the conflicting principals (consumers) are unbound from the old rule and bound to the new rule.'),
  quotaLimit?: long(name='quotaLimit', description='The updated total available quota.', example='1000'),
  removeIds?: [ string ](name='removeIds', description='The list of principal (consumer) IDs to unbind.', example='cs003,cs-004'),
