model AiPolicyRedisConfig {
  databaseNumber?: int32(name='databaseNumber', description='The zero-based index of the Redis database to use. The default value is 0.'),
  host?: string(name='host', description='The hostname of the Redis instance.'),
  password?: string(name='password', description='The password for Redis authentication.'),
  port?: int32(name='port', description='The port number of the Redis instance.'),
  timeout?: int32(name='timeout', description='The connection timeout in milliseconds.'),
  username?: string(name='username', description='The username for Redis authentication.'),
}

model AiSecurityGuardConfig {
  bufferLimit?: int32(name='bufferLimit', description='The buffer limit in bytes for streaming content checks. The service buffers content up to this limit before sending it for analysis.'),
  checkRequest?: boolean(name='checkRequest', description='Specifies whether to check the content of incoming requests.'),
  checkRequestImage?: boolean(name='checkRequestImage', description='Specifies whether to check incoming requests for image content. Requires `checkRequest` to be `true`.'),
  checkResponse?: boolean(name='checkResponse', description='Specifies whether to check the content of outgoing responses.'),
  checkResponseImage?: boolean(name='checkResponseImage', description='Specifies whether to check outgoing responses for image content. Requires `checkResponse` to be `true`.'),
  consumerRequestCheckService?: [ 
    {
      matchType?: string(name='matchType', description='The match type for identifying the consumer. For example: `header` or `query`.'),
      modalityType?: string(name='modalityType', description='The modality type for this rule. For example: `text` or `image`.'),
      name?: string(name='name', description='The identifier of the consumer.'),
      requestCheckService?: string(name='requestCheckService', description='The identifier of the request check service for text content for this consumer.'),
      requestImageCheckService?: string(name='requestImageCheckService', description='The identifier of the request check service for image content for this consumer.'),
    }
  ](name='consumerRequestCheckService', description='Specifies consumer-specific configurations for the request check service.'),
  consumerResponseCheckService?: [ 
    {
      matchType?: string(name='matchType', description='The match type for identifying the consumer. For example: `header` or `query`.'),
      modalityType?: string(name='modalityType', description='The modality type for this rule. For example: `text` or `image`.'),
      name?: string(name='name', description='The identifier of the consumer.'),
      responseCheckService?: string(name='responseCheckService', description='The identifier of the response check service for text content for this consumer.'),
      responseImageCheckService?: string(name='responseImageCheckService', description='The identifier of the response check service for image content for this consumer.'),
    }
  ](name='consumerResponseCheckService', description='Specifies consumer-specific configurations for the response check service.'),
  consumerRiskLevel?: [ 
    {
      level?: string(name='level', description='The risk level to apply to the specified consumer and risk type. For example: `low`, `medium`, or `high`.'),
      matchType?: string(name='matchType', description='The match type for identifying the consumer. For example: `header` or `query`.'),
      name?: string(name='name', description='The identifier of the consumer.'),
      type?: string(name='type', description='The type of risk to configure. For example: `profanity` or `spam`.'),
    }
  ](name='consumerRiskLevel', description='Specifies customized risk thresholds for different consumers.'),
  pluginStatus?: AiPluginStatus(name='pluginStatus', description='Controls whether the AI Security Guard plugin is enabled or disabled.', nullable=true),
  requestCheckService?: string(name='requestCheckService', description='The identifier of the request check service for text content.'),
  requestImageCheckService?: string(name='requestImageCheckService', description='The identifier of the request check service for image content.'),
  responseCheckService?: string(name='responseCheckService', description='The identifier of the response check service for text content.'),
  responseImageCheckService?: string(name='responseImageCheckService', description='The identifier of the response check service for image content.'),
  riskAlertLevel?: string(name='riskAlertLevel', description='The risk alert level. The service triggers an alert when a detected risk meets or exceeds this level.'),
  riskConfig?: [ 
    {
      consumerRules?: {
        matchType?: string(name='matchType', description='The location in the request to search for the `pattern`. For example: `header` or `query`.'),
        pattern?: string(name='pattern', description='The pattern for matching a consumer. This can be a regular expression.'),
      }(name='consumerRules', description='Contains rules that override the default settings for specific consumers.'),
      level?: string(name='level', description='The default risk level for this risk type. For example: `low`, `medium`, or `high`.'),
      type?: string(name='type', description='The type of risk to configure. For example: `profanity` or `spam`.'),
    }
  ](name='riskConfig', description='Specifies general risk configurations.'),
  serviceAddress?: string(name='serviceAddress', description='The service address of the security check endpoint.'),
}

