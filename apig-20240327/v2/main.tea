/**
 *
 */
import OpenApi;
import OpenApi.OpenApiUtil;

extends OpenApi;


init(config: OpenApiUtil.Config){
  super(config);
  @endpointRule = 'regional';
  @endpointMap = {
    'us-west-1' = 'apig.us-west-1.aliyuncs.com',
    'us-east-1' = 'apig.us-east-1.aliyuncs.com',
    'me-east-1' = 'apig.me-east-1.aliyuncs.com',
    'me-central-1' = 'apig.me-central-1.aliyuncs.com',
    'eu-west-1' = 'apig.eu-west-1.aliyuncs.com',
    'eu-central-1' = 'apig.eu-central-1.aliyuncs.com',
    'cn-zhangjiakou' = 'apig.cn-zhangjiakou.aliyuncs.com',
    'cn-wulanchabu' = 'apig.cn-wulanchabu.aliyuncs.com',
    'cn-shenzhen' = 'apig.cn-shenzhen.aliyuncs.com',
    'cn-shanghai' = 'apig.cn-shanghai.aliyuncs.com',
    'cn-qingdao' = 'apig.cn-qingdao.aliyuncs.com',
    'cn-hongkong' = 'apig.cn-hongkong.aliyuncs.com',
    'cn-heyuan' = 'apig.cn-heyuan.aliyuncs.com',
    'cn-hangzhou' = 'apig.cn-hangzhou.aliyuncs.com',
    'cn-guangzhou' = 'apig.cn-guangzhou.aliyuncs.com',
    'cn-chengdu' = 'apig.cn-chengdu.aliyuncs.com',
    'cn-beijing' = 'apig.cn-beijing.aliyuncs.com',
    'ap-southeast-7' = 'apig.ap-southeast-7.aliyuncs.com',
    'ap-southeast-6' = 'apig.ap-southeast-6.aliyuncs.com',
    'ap-southeast-5' = 'apig.ap-southeast-5.aliyuncs.com',
    'ap-southeast-3' = 'apig.ap-southeast-3.aliyuncs.com',
    'ap-southeast-2' = 'apig.ap-southeast-2.aliyuncs.com',
    'ap-southeast-1' = 'apig.ap-southeast-1.aliyuncs.com',
    'ap-northeast-2' = 'apig.ap-northeast-2.aliyuncs.com',
    'ap-northeast-1' = 'apig.ap-northeast-1.aliyuncs.com',
  };

  checkConfig(config);
  @endpoint = getEndpoint('apig', @regionId, @endpointRule, @network, @suffix, @endpointMap, @endpoint);
}

function getEndpoint(productId: string, regionId: string, endpointRule: string, network: string, suffix: string, endpointMap: map[string]string, endpoint: string) throws: string{
  if (!$isNull(endpoint)) {
    return endpoint;
  }
  
  if (!$isNull(endpointMap) && !$isNull(endpointMap[regionId])) {
    return endpointMap[regionId];
  }
  return OpenApiUtil.getEndpointRules(productId, regionId, endpointRule, network, suffix);
}

model AgentServiceConfig {
  address?: string(name='address', description='The address.

This parameter is required.', example='https://dashscope.aliyuncs.com/api/v1'),
  customConfig?: {
    apiKey?: string(name='apiKey', description='apiKey', example='app-xxx'),
    apiKeyGenerateMode?: string(name='apiKeyGenerateMode', description='API key generation mode.', example='Reference'),
  }(name='customConfig', description='User-defined configuration'),
  dashScopeConfig?: {
    appCredentials?: [ 
      {
        apiKey?: string(name='apiKey', description='apiKey', example='sk-xxx'),
        appId?: string(name='appId', description='The application ID.', example='app-xxx'),
      }
    ](name='appCredentials', description='The application configuration.'),
  }(name='dashScopeConfig', description='The Model Studio service configuration.'),
  difyConfig?: {
    apiKey?: string(name='apiKey', description='API Key', example='app-xxx'),
    botType?: string(name='botType', description='The interaction type.', example='chatbot'),
  }(name='difyConfig', description='The Dify service configuration.'),
  enableHealthCheck?: boolean(name='enableHealthCheck', description='Specifies whether to enable health check.', example='true'),
  enableOutlierDetection?: boolean(name='enableOutlierDetection', description='Whether to enable outlier detection', example='true'),
  protocols?: [ string ](name='protocols', description='The protocol.'),
  provider?: string(name='provider', description='The service provider.

This parameter is required.', example='qwen'),
}

model AiCacheConfig {
  cacheKeyStrategy?: string(name='cacheKeyStrategy', description='The cache key generation strategy.', example='-'),
  cacheMode?: string(name='cacheMode', description='The cache mode.', example='exact'),
  cacheTTL?: int32(name='cacheTTL', description='The cache expiration time, in seconds.', example='3600'),
  embeddingConfig?: {
    modelName?: string(name='modelName', description='The embedding model name.', example='text-embedding-v2'),
    serviceId?: string(name='serviceId', description='The embedding service ID.', example='svc-xxx'),
    timeout?: int32(name='timeout', description='The request timeout period, in milliseconds.', example='5000'),
    type?: string(name='type', description='The embedding service type.', example='dashscope'),
  }(name='embeddingConfig', description='The embedding service configuration.'),
  pluginStatus?: AiPluginStatus(name='pluginStatus', description='The plugin running status.', nullable=true),
  redisConfig?: AiPolicyRedisConfig(name='redisConfig', description='The Redis configuration for exact cache count storage.', nullable=true),
  vectorConfig?: {
    apiKey?: string(name='apiKey', description='The API key of the vector database.', example='sk-xxx'),
    collectionId?: string(name='collectionId', description='The vector collection ID.', example='col-xxx'),
    serviceHost?: string(name='serviceHost', description='The service address of the vector database.', example='vdb-xxx.dashvector.aliyuncs.com'),
    threshold?: float(name='threshold', description='The similarity threshold.', example='0.95'),
    timeout?: int32(name='timeout', description='The request timeout period, in milliseconds.', example='5000'),
    type?: string(name='type', description='The vector database type.', example='dashvector'),
  }(name='vectorConfig', description='The vector database configuration.'),
}

model AiFallbackConfig {
  onlyRedirectUpstreamCode?: boolean(name='onlyRedirectUpstreamCode', description='When set to true, fallback is triggered only when the backend returns a 4xx/5xx status code. Status codes generated by the gateway itself (such as 503 connection failed) do not trigger fallback. Requires DPI engine version 2.1.11 or later. If the version is insufficient, this setting is silently ignored.', example='true'),
  serviceConfigs?: [ 
    {
      name?: string(name='name', description='The service name.', example='—'),
      passThroughModelName?: boolean(name='passThroughModelName', description='Specifies whether to pass through the model name from the original request.', example='false'),
      serviceId?: string(name='serviceId', description='The ID of the fallback target service.', example='svc-bbb'),
      targetModelName?: string(name='targetModelName', description='The name of the fallback target model.', example='qwen-max'),
    }
  ](name='serviceConfigs', description='The list of fallback target services, excluding the primary routing service.'),
}

model AiNetworkConfigSearchEngine {
  apiKey?: string(name='apiKey', description='The API key of the search engine.', example='sk-xxx'),
  contentMode?: string(name='contentMode', description='Quark-specific: the content mode.', example='summary'),
  count?: int32(name='count', description='The number of results returned per search.', example='5'),
  endpoint?: string(name='endpoint', description='The endpoint of the search engine.', example='https://cloud-iqs.aliyuncs.com'),
  industry?: string(name='industry', description='Quark-specific: the industry filter.', example='互联网'),
  optionArgs?: map[string]string(name='optionArgs', description='The search engine-specific parameters in key-value pair format.'),
  start?: int32(name='start', description='The offset of search results.', example='0'),
  timeRange?: string(name='timeRange', description='Quark-specific: the time range filter.', example='7d'),
  timeoutMillisecond?: int32(name='timeoutMillisecond', description='The API call timeout period, in milliseconds.', example='5000'),
  type?: string(name='type', description='The search engine type.', example='aliyunQuark'),
}

model AiNetworkSearchConfig {
  defaultEnable?: boolean(name='defaultEnable', description='Specifies whether the plug-in feature is enabled by default.', example='true'),
  defaultLang?: string(name='defaultLang', description='The default search language code.', example='zh-CN'),
  needReference?: boolean(name='needReference', description='Specifies whether to add reference sources in the answer.', example='true'),
  pluginStatus?: AiPluginStatus(name='pluginStatus', description='The plug-in running status.', nullable=true),
  referenceFormat?: string(name='referenceFormat', description='The format template for reference content. The template must contain at least one %s placeholder.', example='参考来源:\\\\n%s'),
  referenceLocation?: string(name='referenceLocation', description='The reference location.', example='head'),
  searchEngineConfig?: AiNetworkConfigSearchEngine(name='searchEngineConfig', description='The search engine configuration.'),
  searchFrom?: [
    AiNetworkConfigSearchEngine
  ](name='searchFrom', description='The list of search engines (multi-engine configuration).'),
  searchRewrite?: {
    enable?: boolean(name='enable', description='Specifies whether to enable search query rewriting.', example='true'),
    maxCount?: int32(name='maxCount', description='The maximum number of search queries after rewriting.', example='3'),
    modelName?: string(name='modelName', description='The name of the model used for rewriting.', example='qwen-max'),
    serviceId?: string(name='serviceId', description='The ID of the rewriting service.', example='svc-xxx'),
    timeoutMillisecond?: int32(name='timeoutMillisecond', description='The timeout period for the rewriting request, in milliseconds.', example='5000'),
  }(name='searchRewrite', description='The search term rewriting configuration.'),
}

model AiPluginStatus {
  errorLogs?: [ map[string]any ](name='errorLogs', description='The list of plug-in runtime error logs. Each item is a map[string]any key-value pair.'),
  pluginId?: string(name='pluginId', description='The plug-in instance ID.', example='pi-xxx'),
  serviceHealthy?: boolean(name='serviceHealthy', description='Indicates whether the backend service that the plug-in depends on is healthy.', example='true'),
}

model AiPolicyRedisConfig {
  databaseNumber?: int32(name='databaseNumber', description='The Redis database number.', example='0'),
  host?: string(name='host', description='The Redis host address.', example='r-xxx.redis.rds.aliyuncs.com'),
  password?: string(name='password', description='The Redis password.', example='pass'),
  port?: int32(name='port', description='The Redis port.', example='6379'),
  timeout?: int32(name='timeout', description='The timeout period, in milliseconds.', example='5000'),
  username?: string(name='username', description='The Redis username.', example='user'),
}

