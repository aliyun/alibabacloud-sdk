model AiStatisticsConfig {
  logRequestContent?: boolean(name='logRequestContent', description='Specifies whether to log request content (controls whether question-related attributes are generated).', example='true'),
  logResponseContent?: boolean(name='logResponseContent', description='Specifies whether to log response content (controls whether answer-related attributes are generated).', example='true'),
  pathFieldConfigs?: [ 
    {
      fieldPaths?: map[string]AiStatisticsPathField(name='fieldPaths', description='The field collection configuration.'),
      path?: string(name='path', description='The API path.', example='/v1/chat/completions'),
    }
  ](name='pathFieldConfigs', description='The list of custom field collection configurations, configured by API path.'),
}

model AiStatisticsPathField {
  category?: string(name='category', description='The secondary category.', example='conversation'),
  description?: string(name='description', description='The field description.', example='用户输入的问题内容'),
  fieldKey?: string(name='fieldKey', description='The log key.', example='question'),
  io?: string(name='io', description='The request or response direction.', example='request'),
  jsonPath?: string(name='jsonPath', description='The corresponding JSON path (GJSON syntax).', example='messages.#.content'),
  name?: string(name='name', description='The display name of the field.', example='问题内容'),
  recordEnabled?: boolean(name='recordEnabled', description='Specifies whether collection is enabled.', example='true'),
  rule?: string(name='rule', description='The rule used for streaming response extraction. Valid values:
- append: appends content
- first: retrieves the first value
- replace: retrieves the last value', example='append'),
  sensitive?: boolean(name='sensitive', description='Indicates whether the field is sensitive.', example='false'),
  source?: string(name='source', description='The data source.', example='request_body'),
}

model AiTokenRateLimitConfig {
  enableGlobalRules?: boolean(name='enableGlobalRules', description='Specifies whether to enable global (API-level) throttling rules. Default value: false.', example='true'),
  globalRules?: [
    AiTokenRateLimitConfigRule
  ](name='globalRules', description='The list of global throttling rules. Only the LimitByGlobal type is allowed.'),
  pluginStatus?: AiPluginStatus(name='pluginStatus', description='The running status of the plugin.', nullable=true),
  redisConfig?: AiPolicyRedisConfig(name='redisConfig', description='The Redis configuration.', nullable=true),
  rules?: [
    AiTokenRateLimitConfigRule
  ](name='rules', description='The list of throttling rules.'),
}

model AiTokenRateLimitConfigRule {
  limitMode?: string(name='limitMode', description='The throttling mode.', example='TokenPerMinute'),
  limitType?: string(name='limitType', description='The throttling type.', example='Consumer'),
  limitValue?: int32(name='limitValue', description='The throttling value.', example='1000'),
  matchKey?: string(name='matchKey', description='The match key name.', example='X-API-Key'),
  matchType?: string(name='matchType', description='The matching method.', example='Exact'),
  matchValue?: string(name='matchValue', description='The match value.', example='consumer-a'),
}

model AiToolSelectionConfig {
  enableConditions?: {
    toolCountThreshold?: int32(name='toolCountThreshold', description='The tool count threshold.', example='10'),
  }(name='enableConditions', description='The enable conditions configuration. Controls when the overall feature is triggered.'),
  pluginStatus?: AiPluginStatus(name='pluginStatus', description='The plug-in running status.', nullable=true),
  queryRewriting?: {
    contextSelection?: {
      type?: string(name='type', description='The context selection method.', example='allMessages'),
      value?: int32(name='value', description='The number of retained messages or characters.', example='5'),
    }(name='contextSelection', description='The context selection configuration.'),
    enabled?: boolean(name='enabled', description='Specifies whether query rewrite is enabled.', example='true'),
    fallbackStrategy?: string(name='fallbackStrategy', description='The fallback strategy.', example='skip'),
    maxOutputTokens?: int32(name='maxOutputTokens', description='The maximum number of output tokens for rewriting.', example='50'),
    modelService?: {
      modelName?: string(name='modelName', description='The model name.', example='gte-rerank-v2'),
      serviceId?: string(name='serviceId', description='The model service ID.', example='svc-xxx'),
      timeoutMillisecond?: int32(name='timeoutMillisecond', description='The request timeout period, in milliseconds.', example='5000'),
    }(name='modelService', description='The rewriting model service configuration.'),
    promptConfig?: {
      customPrompt?: string(name='customPrompt', description='The custom prompt content.', example='请将以下用户问题改写为...'),
      type?: string(name='type', description='The prompt type.', example='builtIn'),
    }(name='promptConfig', description='The prompt configuration.'),
    triggerConditions?: {
      messageCountThreshold?: int32(name='messageCountThreshold', description='The number of conversation turns after which rewriting is triggered.', example='1'),
    }(name='triggerConditions', description='The trigger condition configuration.'),
  }(name='queryRewriting', description='The query rewrite configuration. Rewrites user queries before tool reranking to improve matching precision.'),
  toolReranking?: {
    fallbackStrategy?: string(name='fallbackStrategy', description='The fallback strategy upon failure.', example='skip'),
    filteringMethod?: string(name='filteringMethod', description='The filtering method.', example='topN'),
    modelService?: {
      modelName?: string(name='modelName', description='The model name.', example='gte-rerank-v2'),
      serviceId?: string(name='serviceId', description='The model service ID.', example='svc-xxx'),
      timeoutMillisecond?: int32(name='timeoutMillisecond', description='The request timeout period, in milliseconds.', example='5000'),
    }(name='modelService', description='The reranking model service configuration.'),
    scoreThreshold?: float(name='scoreThreshold', description='The score threshold.', example='0.5'),
    topKPercent?: int32(name='topKPercent', description='The retention percentage.', example='50'),
    topNCount?: int32(name='topNCount', description='The retention count.', example='5'),
  }(name='toolReranking', description='The tool reranking configuration. Uses a model to rank and filter candidate tools.'),
}

