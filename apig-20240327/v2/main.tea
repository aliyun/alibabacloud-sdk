model AiStatisticsConfig {
  logRequestContent?: boolean(name='logRequestContent', description='Specifies whether to record the body of incoming requests.'),
  logResponseContent?: boolean(name='logResponseContent', description='Specifies whether to record the body of outgoing responses.'),
  pathFieldConfigs?: [ 
    {
      fieldPaths?: map[string]AiStatisticsPathField(name='fieldPaths', description='A key-value map for extracting fields. Keys are custom names, and values are paths to the data within the request or response body.'),
      path?: string(name='path', description='The API endpoint path to which this configuration applies, such as /user/id.'),
    }
  ](name='pathFieldConfigs', description='An array of configurations for extracting data from specific paths.'),
}

model AiStatisticsPathField {
  category?: string(name='category', description='The category to which the field belongs, used for grouping and organizing fields.'),
  description?: string(name='description', description='A detailed description that provides additional context about the field\\\\"s purpose and usage.'),
  fieldKey?: string(name='fieldKey', description='The unique key used to identify the field in statistical results.'),
  io?: string(name='io', description='Specifies whether the field is an input or an output. Valid values are typically `IN` or `OUT`.'),
  jsonPath?: string(name='jsonPath', description='The JSONPath expression to extract the field value from the source data.'),
  name?: string(name='name', description='The display name of the field, used for labeling in user interfaces or reports.'),
  recordEnabled?: boolean(name='recordEnabled', description='Specifies whether logging is enabled for this field. If set to `true`, the system records the field\\\\"s value in logs.'),
  rule?: string(name='rule', description='A rule or condition applied to the extracted field. The rule\\\\"s format and effect are implementation-specific.'),
  sensitive?: boolean(name='sensitive', description='Indicates whether the field contains sensitive information. If set to `true`, the system may apply masking or other security measures.'),
  source?: string(name='source', description='The data source from which the field is extracted. For example, `Request` or `Response`.'),
}

model AiTokenRateLimitConfig {
  enableGlobalRules?: boolean(name='enableGlobalRules', description='Controls whether global rules are enabled. If set to `true`, the rules in `globalRules` are applied. Defaults to `false`.'),
  globalRules?: [
    AiTokenRateLimitConfigRule
  ](name='globalRules', description='A list of global rate limit rules. These rules are applied when no specific rule in `rules` is matched.'),
  pluginStatus?: AiPluginStatus(name='pluginStatus', description='Specifies the status of the plugin, such as `enabled` or `disabled`.', nullable=true),
  redisConfig?: AiPolicyRedisConfig(name='redisConfig', description='Specifies the Redis configuration for distributed rate limiting.', nullable=true),
  rules?: [
    AiTokenRateLimitConfigRule
  ](name='rules', description='A list of specific rate limit rules.'),
}

model AiTokenRateLimitConfigRule {
  limitMode?: string(name='limitMode', description='The action to take when a request exceeds the token rate limit.'),
  limitType?: string(name='limitType', description='The scope of the rate limit, such as per user or per project.'),
  limitValue?: int32(name='limitValue', description='The maximum number of tokens allowed within the defined time period. For example, if the time unit is one minute, this value represents the tokens-per-minute (TPM) limit.'),
  matchKey?: string(name='matchKey', description='The key that identifies the request source. Its value is extracted from the request context to apply the rule.'),
  matchType?: string(name='matchType', description='The matching logic applied to the value of `matchKey`.'),
  matchValue?: string(name='matchValue', description='The value to match. The rate limit applies only when the value of `matchKey` in the request matches this value, according to the `matchType`.'),
}

model AiToolSelectionConfig {
  enableConditions?: {
    toolCountThreshold?: int32(name='toolCountThreshold', description='The minimum number of tools required to activate tool selection.'),
  }(name='enableConditions', description='Conditions for activating the tool selection feature.'),
  pluginStatus?: AiPluginStatus(name='pluginStatus', description='The status of the AI tool selection plugin.', nullable=true),
  queryRewriting?: {
    contextSelection?: {
      type?: string(name='type', description='The strategy for selecting the conversation context.'),
      value?: int32(name='value', description='The value associated with the context selection strategy, such as the number of messages to include.'),
    }(name='contextSelection', description='Method for selecting the conversation context for query rewriting.'),
    enabled?: boolean(name='enabled', description='Whether to enable query rewriting.'),
    fallbackStrategy?: string(name='fallbackStrategy', description='The fallback strategy used if query rewriting fails or returns no results.'),
    maxOutputTokens?: int32(name='maxOutputTokens', description='The maximum number of tokens to generate for the rewritten query.'),
    modelService?: {
      modelName?: string(name='modelName', description='The name of the model used for query rewriting.'),
      serviceId?: string(name='serviceId', description='The ID of the model service used for query rewriting.'),
      timeoutMillisecond?: int32(name='timeoutMillisecond', description='The request timeout in milliseconds for the query rewriting model service.'),
    }(name='modelService', description='Model service configuration for query rewriting.'),
    promptConfig?: {
      customPrompt?: string(name='customPrompt', description='The custom prompt template for query rewriting. This parameter is required if `type` is set to `custom`.'),
      type?: string(name='type', description='The type of prompt, such as default or custom.'),
    }(name='promptConfig', description='Prompt configuration for query rewriting.'),
    triggerConditions?: {
      messageCountThreshold?: int32(name='messageCountThreshold', description='The minimum number of messages in the conversation history required to activate query rewriting.'),
    }(name='triggerConditions', description='Conditions for activating query rewriting.'),
  }(name='queryRewriting', description='Configuration for query rewriting, which optimizes user queries before tool selection.'),
  toolReranking?: {
    fallbackStrategy?: string(name='fallbackStrategy', description='The fallback strategy used if tool reranking fails or returns no results.'),
    filteringMethod?: string(name='filteringMethod', description='The method for filtering tools after reranking.'),
    modelService?: {
      modelName?: string(name='modelName', description='The name of the model used for reranking.'),
      serviceId?: string(name='serviceId', description='The ID of the model service used for reranking.'),
      timeoutMillisecond?: int32(name='timeoutMillisecond', description='The request timeout in milliseconds for the reranking model service.'),
    }(name='modelService', description='Model service configuration for tool reranking.'),
    scoreThreshold?: float(name='scoreThreshold', description='The minimum score a tool must have to be selected. Tools with scores below this threshold are filtered out.'),
    topKPercent?: int32(name='topKPercent', description='The percentage of top-ranked tools to select. This parameter only applies when `filteringMethod` is set to a percentage-based method.'),
    topNCount?: int32(name='topNCount', description='The number of top-ranked tools to select. This parameter only applies when `filteringMethod` is set to a count-based method.'),
  }(name='toolReranking', description='Configuration for tool reranking, which controls how tools are scored and filtered.'),
}

