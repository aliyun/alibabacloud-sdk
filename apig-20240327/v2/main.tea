  }
  if (!$isNull(request.dryRun)) {
    body['dryRun'] = request.dryRun;
  }
  if (!$isNull(request.overwrite)) {
    body['overwrite'] = request.overwrite;
  }
  if (!$isNull(request.periodMultiplier)) {
    body['periodMultiplier'] = request.periodMultiplier;
  }
  if (!$isNull(request.periodType)) {
    body['periodType'] = request.periodType;
  }
  if (!$isNull(request.quotaLimit)) {
    body['quotaLimit'] = request.quotaLimit;
  }
  if (!$isNull(request.timezone)) {
    body['timezone'] = request.timezone;
  }
  if (!$isNull(request.windowAlignment)) {
    body['windowAlignment'] = request.windowAlignment;
  }

  var req = new OpenApiUtil.OpenApiRequest{ 
    headers = headers,
    body = OpenApiUtil.parseToMap(body),
  };
  var params = new OpenApiUtil.Params{
    action = 'ResetGatewayQuotaRule',
    version = '2024-03-27',
    protocol = 'HTTPS',
    pathname = `/v1/gateways/${$URL.percentEncode(gatewayId)}/quota-rules/${$URL.percentEncode(ruleId)}/reset`,
    method = 'POST',
    authType = 'AK',
    style = 'ROA',
    reqBodyType = 'json',
    bodyType = 'json',
  };
  return callApi(params, req, runtime);
}

