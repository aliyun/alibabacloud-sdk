  requestId?: string(name='RequestId', description='The ID of the request.', example='880F84CB-9B54-4413-A8A3-8832C82D1BC4'),
  sourceCidr?: string(name='SourceCidr', description='The source CIDR block.

The value of this parameter is specified in CIDR notation. Example: 192.168.1.0/24.', example='192.168.20.0/24'),
