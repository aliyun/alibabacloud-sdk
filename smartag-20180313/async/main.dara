  resourceOwnerAccount?: string(name='ResourceOwnerAccount', position='Query'),
  resourceOwnerId?: long(name='ResourceOwnerId', position='Query'),
  smartAGId: string(name='SmartAGId', description='The ID of the SAG instance.

This parameter is required.', example='sag-ke3kq4evpi8p6******', position='Query'),
}

