model AddSmartAccessGatewayDnsForwardRequest {
  domain: string(name='Domain', description='The domain name.

> 
*   Wildcard domain names are supported. You can use the wildcard character asterisk (\\*) to specify a wildcard domain name.

For example, you can enter \\*.baidu.com to specify the domain name baidu.com.

This parameter is required.', example='www.aliyun.com', position='Query'),
  masterIp: string(name='MasterIp', description='The primary DNS server.

This parameter is required.', example='114.114.114.114', position='Query'),
  mode?: string(name='Mode', description='The forwarding mode.

> 
*   This parameter is not in use. Ignore this parameter.', example='first', position='Query'),
  outboundPortIndex?: string(name='OutboundPortIndex', description='The number of the egress port.

> 
*   This parameter is optional if OutboundPortType is set to PhysicalPort. Ignore this parameter if OutboundPortType is set to Tunnel.
*   The value of OutboundPortIndex is the unique index of the port name specified by poOutboundPortName. For example, 0 is the index for the port named eth0, and 2 is the index for the port named lte.', example='0', position='Query'),
  outboundPortName?: string(name='OutboundPortName', description='The egress port.

> 
*   This parameter is optional if OutboundPortType is set to PhysicalPort. Ignore this parameter if OutboundPortType is set to Tunnel.
*   The value of OutboundPortIndex is the unique index of the port name specified by poOutboundPortName. For example, 0 is the index for the port named eth0, and 2 is the index for the port named lte.', example='eth0', position='Query'),
  outboundPortType?: string(name='OutboundPortType', description='The type of the egress port.

> 
*   A value of Tunnel specifies a tunnel, and a value of PhysicalPort specifies a physical port.', example='Tunnel', position='Query'),
  regionId: string(name='RegionId', description='The ID of the region where the instance is deployed.

This parameter is required.', example='cn-shanghai', position='Query'),
  sagInsId: string(name='SagInsId', description='The ID of the instance.

This parameter is required.', example='sag-v9un1ccz22owd76lf8', position='Query'),
  sagSn: string(name='SagSn', description='The serial number (SN) of the device.

This parameter is required.', example='sagf4dkqh78', position='Query'),
  slaveIp?: string(name='SlaveIp', description='The secondary DNS server.', example='172.16.0.14', position='Query'),
}

