model AddACLRuleRequest {
  aclId: string(name='AclId', description='The ID of the ACL.

This parameter is required.', example='acl-xhwhyuo43l0n*****', position='Query'),
  description?: string(name='Description', description='The description of the ACL rule.

The description must be **1 to 512** characters in length.', example='desctest', position='Query'),
  destCidr: string(name='DestCidr', description='The range of the destination IP addresses.

Specify the value of this parameter in CIDR notation. Example: 192.168.10.0/24.

This parameter is required.', example='192.168.10.0/24', position='Query'),
  destPortRange: string(name='DestPortRange', description='The destination port range.

Valid values: **1** to **65535** and **-1**.

Set the destination port range in one of the following formats: 1/200 or 80/80. A value of -1/-1 indicates all ports.

This parameter is required.', example='1/200', position='Query'),
  direction: string(name='Direction', description='The direction of traffic in which the ACL rule is applied. Valid values:

*   **in**: The ACL rule controls inbound network traffic of the on-premises network that is associated with the Smart Access Gateway (SAG) instance.
*   **out**: The ACL rule controls outbound network traffic of the on-premises network that is associated with the SAG instance.

This parameter is required.', example='in', position='Query'),
  dpiGroupIds?: [ string ](name='DpiGroupIds', example='20', position='Query'),
  dpiSignatureIds?: [ string ](name='DpiSignatureIds', example='1', position='Query'),
  ipProtocol: string(name='IpProtocol', description='The protocol used by the ACL rule.

The protocols that are provided in this topic are for reference only. The protocols available in the SAG console may vary. The value of the parameter is not case-sensitive.

This parameter is required.', example='tcp', position='Query'),
  name?: string(name='Name', description='The name of the ACL rule.

The name must be 2 to 100 characters in length, and can contain letters, digits, periods (.), underscores (_), and hyphens (-). It must start with a letter.', example='doctest', position='Query'),
  ownerAccount?: string(name='OwnerAccount', position='Query'),
  ownerId?: long(name='OwnerId', position='Query'),
  policy: string(name='Policy', description='The action policy of the ACL rule. Valid values:

*   **accept**: allows network traffic.
*   **drop**: blocks the network traffic.

This parameter is required.', example='accept', position='Query'),
  priority?: int32(name='Priority', description='The priority of the ACL rule.

A smaller value indicates a higher priority. If rules have the same priority, whichever applied to the SAG devices earlier takes effect.

Valid values: **1 to 100**. Default value: **1**.', example='12', position='Query'),
  regionId: string(name='RegionId', description='The ID of the region where the ACL is deployed.

You can call the [DescribeRegions](https://help.aliyun.com/document_detail/69813.html) operation to query the most recent region list.

This parameter is required.', example='cn-shanghai', position='Query'),
  resourceOwnerAccount?: string(name='ResourceOwnerAccount', position='Query'),
  resourceOwnerId?: long(name='ResourceOwnerId', position='Query'),
  sourceCidr: string(name='SourceCidr', description='The range of the source IP addresses.

Specify the value of this parameter in CIDR notation. Example: 192.168.1.0/24.

This parameter is required.', example='192.168.20.0/24', position='Query'),
  sourcePortRange: string(name='SourcePortRange', description='The source port range.

Valid values: **1** to **65535** and **-1**.

Set the source port range in one of the following formats: 1/200 or 80/80. A value of -1/-1 indicates all ports.

This parameter is required.', example='1/200', position='Query'),
  type?: string(name='Type', description='The type of the ACL rule: Valid values:

*   **LAN**: The ACL rule controls network traffic transmitted through private IP addresses.
*   **WAN**: The ACL rule controls network traffic transmitted through public IP addresses.', example='LAN', position='Query'),
}

