  aclId?: string(name='AclId', description='The ID of the ACL.', example='acl-xhwhyuo43l0*******'),
  acrId?: string(name='AcrId', description='The ID of the ACL rule.', example='acr-c1hkd054qywi******'),
  description?: string(name='Description', description='The description of the ACL rule.', example='test'),
  destCidr?: string(name='DestCidr', description='The destination CIDR block.

