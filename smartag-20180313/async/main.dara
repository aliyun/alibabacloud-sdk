model AddDnatEntryRequest {
  externalIp?: string(name='ExternalIp', description='The public IP address.

>  If the DNAT entry is used to forward packets transmitted over the Internet, the DNAT entry automatically recognizes the current public IP address.', example='10.10.1.xx', position='Query'),
  externalPort: string(name='ExternalPort', description='The public port.

Valid values: **1 to 65535**.

This parameter is required.', example='80', position='Query'),
  internalIp: string(name='InternalIp', description='The destination private IP address.

This parameter is required.', example='192.168.0.1', position='Query'),
  internalPort: string(name='InternalPort', description='The destination private port.

Valid values: **1 to 65535**.

This parameter is required.', example='80', position='Query'),
  ipProtocol: string(name='IpProtocol', description='The protocol used in DNAT. Valid values:

*   **TCP**: forwards TCP packets.
*   **UDP**: The NAT gateway forwards UDP packets.
*   **Any**: forwards packets of all protocols.

This parameter is required.', example='TCP', position='Query'),
  ownerAccount?: string(name='OwnerAccount', position='Query'),
  ownerId?: long(name='OwnerId', position='Query'),
  regionId: string(name='RegionId', description='The ID of the region where the SAG instance is deployed.

This parameter is required.', example='cn-hangzhou', position='Query'),
  resourceOwnerAccount?: string(name='ResourceOwnerAccount', position='Query'),
  resourceOwnerId?: long(name='ResourceOwnerId', position='Query'),
  sagId: string(name='SagId', description='The ID of the SAG instance.

>  Only SAG instances used to manage SAG devices support DNAT.

This parameter is required.', example='sag-kdhg*******', position='Query'),
  type?: string(name='Type', description='The type of the DNAT entry. Valid values:

*   **Intranet**: translates the destination IP address to a specific internal IP address. This is the default value.
*   **Internet**: translates the destination IP address to a specific public IP address.', example='Intranet', position='Query'),
}

model AddDnatEntryResponseBody = {
  dnatEntryId?: string(name='DnatEntryId', description='The ID of the DNAT entry.', example='fwd-kxe4fq3xuzczze****'),
  requestId?: string(name='RequestId', description='The ID of the request.', example='56BF6C79-C77D-41A0-86DD-A4B156E784EA'),
}

