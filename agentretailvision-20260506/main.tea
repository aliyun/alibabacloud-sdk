model ImportProductsRequest {
  deviceId?: string(name='DeviceId', description='The device ID. This ID is used to establish an association between the device and product vectors.', example='DEVICE_001'),
  extraImages?: [ string ](name='ExtraImages', description='The list of additional image URLs that can be provided.'),
  imageTitle?: string(name='ImageTitle', description='The product title.', example='可口可乐330ml'),
  itemUniqueId?: string(name='ItemUniqueId', description='The product ID assigned by the business party. This ID must be unique within the same business party.', example='ITEM_001'),
  mainImage?: [ string ](name='MainImage', description='The list of main product image URLs. At least one URL is required.', example='["https://img.example.com/item1.jpg"]'),
  multiViewImages?: [ 
    {
      angle?: string(name='Angle', description='The digital human angle. Valid values:

- 0: front view, which is the default angle
- 1: left side at 30 degrees
- 2: right side at 30 degrees

For a preview of each angle, refer to [3D Digital Human Video Synthesis User Guide](https://help.aliyun.com/document_detail/447834.html#a989eb5075t9y).', example='0'),
      url?: string(name='Url', description='The task URL.', example='https://img5-parcel.oss-cn-hangzhou.aliyuncs.com/2026/01/12/78568805914464s.jpeg?07'),
    }
  ](name='MultiViewImages', description='The list of multi-angle product images.'),
}

model ImportProductsShrinkRequest {
