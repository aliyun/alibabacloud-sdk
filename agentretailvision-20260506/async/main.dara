import BaseClientBuilder;
import TeaAsyncHandler;
import TeaRequest;
import AsyncRequestBody;
import RequestBody;
import AsyncResponseHandler;
import ClientConfiguration;
import ClientExecutionParams;
extends BaseClientBuilder;
type @product = string
type @version = string
type @endpointRule = string
type @endpointMap = map[string]string
type @REQUEST = TeaRequest
type @handler = TeaAsyncHandler

init(configuration: ClientConfiguration){
  @handler = new TeaAsyncHandler(configuration);
  @product = 'AgentRetailVision';
  @version = '2026-05-06';
  @endpointRule = 'regional';
  @endpointMap = {
    'cn-beijing' = 'agentretailvision.cn-beijing.aliyuncs.com',
  };
}

function close(): void {
  @handler.close();
}

model GenerateGroupImageRequest {
  callbackSecret?: string(name='CallbackSecret', example='your_secret_key', position='Query'),
  callbackUrl?: string(name='CallbackUrl', example='https://xxx.com', position='Query'),
  groupId?: string(name='GroupId', example='a5561c14-b5cd-49a4-ab79-01a63b10d99c', position='Query'),
  groupType?: int32(name='GroupType', example='1', position='Query'),
  platformItemIdList?: [ string ](name='PlatformItemIdList', shrink='json', position='Query'),
}

model GenerateGroupImageResponseBody = {
  code?: string(name='Code', example='202'),
  data?: {
    groupId?: string(name='GroupId', example='a5561c14-b5cd-49a4-ab79-01a63b10d99c'),
  }(name='Data'),
  message?: string(name='Message', example='OK'),
  requestId?: string(name='RequestId', description='Id of the request', example='E1AD60F1-BAC7-546B-9533-E7AD02B16E3F'),
  success?: boolean(name='Success', example='True'),
}

model GenerateGroupImageResponse = {
  headers?: map[string]string(name='headers'),
  statusCode?: int32(name='statusCode'),
  body?: GenerateGroupImageResponseBody(name='body'),
}

/**
  * @param request  the request parameters of GenerateGroupImage  GenerateGroupImageRequest
  * @return GenerateGroupImageResponse
 */
async function generateGroupImage(request: GenerateGroupImageRequest): GenerateGroupImageResponse {
  @handler.validateRequestModel(request);
  return @handler.do('RPC', 'GenerateGroupImage', 'POST', '/', 'json', false, 'json', request);
}

