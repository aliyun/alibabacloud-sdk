model CreateMmsJobRequest {
  columnMapping?: map[string]string(name='columnMapping', description='{Source column name: Destination column name}'),
  dstDbName?: string(name='dstDbName', description='The destination MaxCompute project.', example='mms_test'),
  dstSchemaName?: string(name='dstSchemaName', description='The destination MaxCompute schema.', example='default'),
  enableDataMigration?: boolean(name='enableDataMigration', description='Specifies whether to migrate table data.', example='true'),
  enableSchemaMigration?: boolean(name='enableSchemaMigration', description='Specifies whether to migrate table schemas.', example='true'),
  enableVerification?: boolean(name='enableVerification', description='Specifies whether to enable data verification. The current verification method is to execute SELECT COUNT(\\\\*) on the source and destination to compare the number of rows.', example='false'),
  eta?: string(name='eta', description='The expected completion time of the migration. Note: A smaller eta value gives the migration task higher priority.', example='2025-02-04'),
  increment?: boolean(name='increment', description='Specifies whether to perform an incremental migration. In an incremental migration, only new or changed partitions are migrated. Note that changed partitions are re-migrated.', example='true'),
  name?: string(name='name', description='The name of the migration job.', example='migrate_db_1'),
  others?: map[string]any(name='others', description='Other configuration information.'),
  partitionFilters?: map[string]string(name='partitionFilters', description='{Table name: Partition filter expression}'),
  partitions?: [ long ](name='partitions', description='The list of partition IDs.'),
  schemaOnly?: boolean(name='schemaOnly', description='Specifies whether to migrate only metadata.', example='false'),
  sourceId?: long(name='sourceId', description='The ID of the data source.', example='2000014'),
  sourceName?: string(name='sourceName', description='The name of the data source.', example='demo'),
  srcDbName?: string(name='srcDbName', description='The name of the source database.', example='src_db'),
  srcSchemaName?: string(name='srcSchemaName', description='The name of the source schema. This is the schema in a Layer 3 namespace.', example='default'),
  tableBlackList?: [ string ](name='tableBlackList', description='The blacklist of tables.'),
  tableMapping?: map[string]string(name='tableMapping', description='{Source table: Destination table}'),
  tableWhiteList?: [ string ](name='tableWhiteList', description='The whitelist of tables. Note: If you configure both a whitelist and a blacklist, only the blacklist takes effect.'),
  tables?: [ string ](name='tables', description='The list of table names.'),
  taskType?: string(name='taskType', description='The type of the migration task.', example='BIGQUERY'),
}

model CreateMmsJobResponseBody = {
  data?: {
    asyncTaskId?: long(name='asyncTaskId', description='The ID of the asynchronous task that is created for the migration job.', example='100'),
  }(name='data', description='The returned data.'),
  requestId?: string(name='requestId', description='The request ID.', example='73207140-0FD5-588A-B11A-3CE093924196'),
}

model CreateMmsJobResponse = {
