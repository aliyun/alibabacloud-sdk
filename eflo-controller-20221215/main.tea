 * @return ChangeNodeGroupResponse
 */
async function changeNodeGroup(request: ChangeNodeGroupRequest): ChangeNodeGroupResponse {
  var runtime = new Util.RuntimeOptions{};
  return changeNodeGroupWithOptions(request, runtime);
}

