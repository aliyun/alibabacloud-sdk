model ChatRequest {
  agentKey?: string(name='AgentKey', description='The key for the business space. If omitted, the request is routed to the default business space. You can get this key from the **Business Management** page of your main account.', example='ac627989eb4f8a98ed05fd098bbae5_p_beebot_public'),
  instanceId?: string(name='InstanceId', description='The unique ID of the chatbot instance. To get this ID, log in to the Alibaba Cloud Chatbot console and go to **Chatbot Details** > **Session API**.', example='chatbot-cn-mp90s2lrk00050'),
  intentName?: string(name='IntentName', description='The name of an intent within a dialog flow. If specified, the chatbot directly activates this intent to process the user\\\\"s request.', example='查天气意图'),
  knowledgeId?: string(name='KnowledgeId', description='The ID of an entry in the knowledge base. If you specify this ID, the chatbot directly returns the corresponding answer.', example='30002406051'),
  perspective?: [ string ](name='Perspective', description='An array of perspective codes. Use these codes to retrieve answers from different perspectives for the same knowledge entry. Example: `Perspective=["FZJBY3raWr"]`. When using an SDK, refer to its parameter definitions.'),
  sandBox?: boolean(name='SandBox', description='Specifies the environment to use. The default value is `false`, which indicates the production environment.

- `true`: The test environment. This environment is for testing only. Do not use it in production due to potential instability and QPS limitations.

- `false`: The production environment.', example='true'),
  senderId?: string(name='SenderId', description='The unique ID of the user in the current session.', example='custumer_123456'),
  senderNick?: string(name='SenderNick', description='The nickname of the user in the current session.', example='用户123456'),
  sessionId?: string(name='SessionId', description='The session ID, used to identify a user session and maintain context. For a new user, omit this parameter in the first call to the `Chat` API. The chatbot automatically starts a session and returns the `SessionId` in the response. To continue the conversation, include this `SessionId` in all subsequent requests. The maximum length is 64 characters.', example='9c6ebdc6e66f46ecadab3434314f6959'),
  utterance?: string(name='Utterance', description='The user\\\\"s input text.', example='今天天气怎么样？'),
  vendorParam?: string(name='VendorParam', description='A JSON-formatted string containing custom parameters to pass to various dialog engines.', example='{"phone":123456789}'),
}

