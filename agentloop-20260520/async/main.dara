async function cancelPipelineRun(request: CancelPipelineRunRequest): CancelPipelineRunResponse {
  @handler.validateRequestModel(request);
  return @handler.do('RESTFUL', 'CancelPipelineRun', 'POST', '/agentspace/{agentSpace}/pipeline/{pipelineName}/runs/{runId}/cancel', 'json', false, 'json', request);
}

