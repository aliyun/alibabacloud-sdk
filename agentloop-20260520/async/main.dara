import BaseClientBuilder;
import TeaAsyncHandler;
import TeaRequest;
import AsyncRequestBody;
import RequestBody;
import AsyncResponseHandler;
import ClientConfiguration;
import ClientExecutionParams;
extends BaseClientBuilder;
type @product = string
type @version = string
type @endpointRule = string
type @endpointMap = map[string]string
type @REQUEST = TeaRequest
type @handler = TeaAsyncHandler

init(configuration: ClientConfiguration){
  @handler = new TeaAsyncHandler(configuration);
  @product = 'AgentLoop';
  @version = '2026-05-20';
  @endpointRule = '';
  @endpointMap = {
  };
}

function close(): void {
  @handler.close();
}

model BackfillStrategy {
  enabled?: boolean(name='enabled'),
  endTime?: long(name='endTime'),
  immediate?: boolean(name='immediate'),
  startTime?: long(name='startTime'),
}

model BatchGroup {
  batchId?: string(name='batchId'),
  records?: [
    ExperimentRecord
  ](name='records'),
}

model ContinuousStrategy {
  dataDelayMinutes?: int32(name='dataDelayMinutes'),
  enabled?: boolean(name='enabled'),
  intervalUnit?: string(name='intervalUnit'),
  intervalValue?: int32(name='intervalValue'),
}

model DataFilter {
  endTime?: long(name='endTime'),
  maxRecords?: int32(name='maxRecords'),
  provided?: map[string]any(name='provided'),
  query?: string(name='query'),
  samplingRate?: int32(name='samplingRate'),
  startTime?: long(name='startTime'),
}

model Evaluator {
  config?: map[string]any(name='config'),
  evaluatorRef?: string(name='evaluatorRef'),
  filters?: map[string]any(name='filters'),
  name?: string(name='name'),
  resultName?: string(name='resultName'),
  resultType?: string(name='resultType'),
  type?: string(name='type'),
  variableMapping?: map[string]string(name='variableMapping'),
}

model ExperimentConfig {
  endpointConnectorId?: string(name='endpointConnectorId'),
  label?: string(name='label'),
  modelName?: string(name='modelName'),
  modelParameters?: ModelParameters(name='modelParameters'),
  modelProvider?: string(name='modelProvider'),
  name?: string(name='name'),
  promptTemplate?: [
    PromptTemplateItem
  ](name='promptTemplate'),
  requestBodyTemplate?: string(name='requestBodyTemplate'),
  requestMethod?: string(name='requestMethod'),
}

model ExperimentPlanData {
  createdAt?: long(name='createdAt'),
  datasetId?: string(name='datasetId'),
  description?: string(name='description'),
  experimentCount?: int32(name='experimentCount'),
  planId?: string(name='planId'),
  planName?: string(name='planName'),
  status?: string(name='status'),
  updatedAt?: long(name='updatedAt'),
}

model ExperimentRecord {
  batchId?: string(name='batchId'),
  completedAt?: long(name='completedAt'),
  completedTasks?: int32(name='completedTasks'),
  dataSourceType?: string(name='dataSourceType'),
  datasetId?: string(name='datasetId'),
  datasetProject?: string(name='datasetProject'),
  errorMessage?: string(name='errorMessage'),
  evaluators?: [
    Evaluator
  ](name='evaluators'),
  executedAt?: long(name='executedAt'),
  experimentConfig?: ExperimentConfig(name='experimentConfig'),
  experimentName?: string(name='experimentName'),
  failedTasks?: int32(name='failedTasks'),
  input?: map[string]any(name='input'),
  modelName?: string(name='modelName'),
  planId?: string(name='planId'),
  planName?: string(name='planName'),
  progress?: float(name='progress'),
  recordId?: string(name='recordId'),
  selectedItemIds?: [ string ](name='selectedItemIds'),
  status?: string(name='status'),
  totalTasks?: int32(name='totalTasks'),
}

model IndexJsonKey {
  chn?: boolean(name='chn'),
  type?: string(name='type'),
}

model IndexKey {
  chn?: boolean(name='chn'),
  embedding?: string(name='embedding'),
  jsonKeys?: map[string]IndexJsonKey(name='jsonKeys'),
  type?: string(name='type'),
}

model ModelParameters {
  frequencyPenalty?: float(name='frequencyPenalty'),
  maxTokens?: long(name='maxTokens'),
  presencePenalty?: float(name='presencePenalty'),
  stopSequences?: [ string ](name='stopSequences'),
  temperature?: float(name='temperature'),
  topK?: int32(name='topK'),
  topP?: float(name='topP'),
}

model PromptTemplateItem {
  content?: string(name='content'),
  role?: string(name='role'),
}

model RunStrategies {
  backfill?: BackfillStrategy(name='backfill'),
  continuous?: ContinuousStrategy(name='continuous'),
}

