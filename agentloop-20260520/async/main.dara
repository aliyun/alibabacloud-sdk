/**
  *
  */
import BaseClientBuilder;
import TeaAsyncHandler;
import TeaRequest;
import AsyncRequestBody;
import RequestBody;
import AsyncResponseHandler;
import ClientConfiguration;
import ClientExecutionParams;
extends BaseClientBuilder;
type @product = string
type @version = string
type @endpointRule = string
type @endpointMap = map[string]string
type @REQUEST = TeaRequest
type @handler = TeaAsyncHandler

init(configuration: ClientConfiguration){
  @handler = new TeaAsyncHandler(configuration);
  @product = 'AgentLoop';
  @version = '2026-05-20';
  @endpointRule = 'regional';
  @endpointMap = {
    'cn-zhangjiakou' = 'agentloop.cn-zhangjiakou.aliyuncs.com',
    'cn-shenzhen' = 'agentloop.cn-shenzhen.aliyuncs.com',
    'cn-shanghai' = 'agentloop.cn-shanghai.aliyuncs.com',
    'cn-hongkong' = 'agentloop.cn-hongkong.aliyuncs.com',
    'cn-hangzhou' = 'agentloop.cn-hangzhou.aliyuncs.com',
    'cn-guangzhou' = 'agentloop.cn-guangzhou.aliyuncs.com',
    'cn-chengdu' = 'agentloop.cn-chengdu.aliyuncs.com',
    'cn-beijing' = 'agentloop.cn-beijing.aliyuncs.com',
    'ap-southeast-1' = 'agentloop.ap-southeast-1.aliyuncs.com',
  };
}

function close(): void {
  @handler.close();
}

model BackfillStrategy {
  enabled?: boolean(name='enabled'),
  endTime?: long(name='endTime'),
  startTime?: long(name='startTime'),
}

model BatchGroup {
  batchId?: string(name='batchId'),
  records?: [
    ExperimentRecord
  ](name='records'),
}

model ConnectorProperties {
  channelType?: string(name='channelType'),
  dryRunRequestBody?: string(name='dryRunRequestBody'),
  modelList?: string(name='modelList'),
  network?: string(name='network'),
  protocol?: string(name='protocol'),
  region?: string(name='region'),
  responseBodyPath?: string(name='responseBodyPath'),
  securityGroupId?: string(name='securityGroupId'),
  vSwitchId?: string(name='vSwitchId'),
  vpcId?: string(name='vpcId'),
}

model ContinuousStrategy {
  dataDelayMinutes?: int32(name='dataDelayMinutes'),
  enabled?: boolean(name='enabled'),
  intervalUnit?: string(name='intervalUnit'),
  intervalValue?: int32(name='intervalValue'),
}

model DataFilter {
  maxRecords?: int32(name='maxRecords'),
  provided?: map[string]any(name='provided'),
  query?: string(name='query'),
  samplingRate?: int32(name='samplingRate'),
  serviceNames?: [ string ](name='serviceNames'),
}

model Evaluator {
  config?: map[string]any(name='config'),
  evaluatorRef?: string(name='evaluatorRef'),
  filters?: map[string]any(name='filters'),
  name?: string(name='name'),
  resultName?: string(name='resultName'),
  resultType?: string(name='resultType'),
  type?: string(name='type'),
  variableMapping?: map[string]string(name='variableMapping'),
}

model ExperimentConfig {
  endpointConnectorId?: string(name='endpointConnectorId'),
  label?: string(name='label'),
  modelName?: string(name='modelName'),
  modelParameters?: ModelParameters(name='modelParameters'),
  modelProvider?: string(name='modelProvider'),
  name?: string(name='name'),
  promptTemplate?: [
    PromptTemplateItem
  ](name='promptTemplate'),
  requestBodyTemplate?: string(name='requestBodyTemplate'),
  requestMethod?: string(name='requestMethod'),
}

model ExperimentPlanData {
  createdAt?: long(name='createdAt'),
  datasetId?: string(name='datasetId'),
  description?: string(name='description'),
  experimentCount?: int32(name='experimentCount'),
  experimentType?: string(name='experimentType'),
  planId?: string(name='planId'),
  planName?: string(name='planName'),
  querySql?: string(name='querySql'),
  status?: string(name='status'),
  updatedAt?: long(name='updatedAt'),
}

model ExperimentRecord {
  completedAt?: long(name='completedAt'),
  completedTasks?: int32(name='completedTasks'),
  dataSourceType?: string(name='dataSourceType'),
  datasetId?: string(name='datasetId'),
  datasetProject?: string(name='datasetProject'),
  errorMessage?: string(name='errorMessage'),
  evaluationTaskId?: string(name='evaluationTaskId'),
  evaluators?: [
    Evaluator
  ](name='evaluators'),
  executedAt?: long(name='executedAt'),
  experimentConfig?: [
    ExperimentConfig
  ](name='experimentConfig'),
  experimentPlanId?: string(name='experimentPlanId'),
  failedTasks?: int32(name='failedTasks'),
  input?: map[string]any(name='input'),
  modelNames?: [ string ](name='modelNames'),
  planName?: string(name='planName'),
  progress?: float(name='progress'),
  querySql?: string(name='querySql'),
  recordId?: string(name='recordId'),
  recordName?: string(name='recordName'),
  selectedItemIds?: [ string ](name='selectedItemIds'),
  status?: string(name='status'),
  totalTasks?: int32(name='totalTasks'),
}

model IndexJsonKey {
  chn?: boolean(name='chn'),
  type?: string(name='type'),
}

model IndexKey {
  chn?: boolean(name='chn'),
  embedding?: string(name='embedding'),
  jsonKeys?: map[string]IndexJsonKey(name='jsonKeys'),
  type?: string(name='type'),
}

model ModelParameters {
  frequencyPenalty?: float(name='frequencyPenalty'),
  maxTokens?: long(name='maxTokens'),
  presencePenalty?: float(name='presencePenalty'),
  stopSequences?: [ string ](name='stopSequences'),
  temperature?: float(name='temperature'),
  topK?: int32(name='topK'),
  topP?: float(name='topP'),
}

model OfflineExperimentConfig {
  desc?: string(name='desc'),
  label?: string(name='label'),
  name?: string(name='name'),
}

model PromptTemplateItem {
  content?: string(name='content'),
  role?: string(name='role'),
}

model RunStrategies {
  backfill?: BackfillStrategy(name='backfill'),
  continuous?: ContinuousStrategy(name='continuous'),
}

model AddDatasetDataRequest {
  agentSpace?: string(name='agentSpace', example='sop-agent', position='Path'),
  datasetName?: string(name='datasetName', example='product_faq_dataset', position='Path'),
  dataArray?: [ map[string]any ](name='dataArray', position='Body'),
  clientToken?: string(name='clientToken', example='a1b2c3d4-1234-5678-90ab-cdef12345678', position='Query'),
}

model AddDatasetDataResponseBody = {
  affectedRows?: int32(name='affectedRows', example='100'),
  requestId?: string(name='requestId', description='Id of the request', example='D0173835-9E0F-508F-8BFA-9F556E59C302'),
}

model AddDatasetDataResponse = {
  headers?: map[string]string(name='headers'),
  statusCode?: int32(name='statusCode'),
  body?: AddDatasetDataResponseBody(name='body'),
}

/**
  * @param request  the request parameters of AddDatasetData  AddDatasetDataRequest
  * @return AddDatasetDataResponse
 */
async function addDatasetData(request: AddDatasetDataRequest): AddDatasetDataResponse {
  @handler.validateRequestModel(request);
  return @handler.do('RESTFUL', 'AddDatasetData', 'POST', '/agentspace/{agentSpace}/dataset/{datasetName}/rows', 'json', false, 'json', request);
}

model CancelPipelineRunRequest {
  agentSpace?: string(name='agentSpace', example='my-agent-space', position='Path'),
  pipelineName?: string(name='pipelineName', example='my-pipeline', position='Path'),
  runId?: string(name='runId', example='run-20260101-0001', position='Path'),
}

model CancelPipelineRunResponseBody = {
  finishTime?: string(name='finishTime', description='Use the UTC time format: yyyy-MM-ddTHH:mm:ss.SSSZ', example='2026-01-01T00:00:05.000Z'),
