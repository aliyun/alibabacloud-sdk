model CreatePipelineRequest {
  agentSpace?: string(name='agentSpace', example='my-agent-space', position='Path'),
  description?: string(name='description', example='从 SLS 采集 Trace 数据清洗入 Dataset', position='Body'),
  executePolicy?: {
    mode?: string(name='mode', example='RunOnce'),
    runOnce?: {
      fromTime?: long(name='fromTime', example='1735660800'),
      toTime?: long(name='toTime', example='1735747200'),
    }(name='runOnce'),
    scheduled?: {
      fromTime?: long(name='fromTime', example='1735660800000'),
      interval?: string(name='interval', example='1h'),
    }(name='scheduled'),
  }(name='executePolicy', position='Body'),
  pipeline?: {
    nodes?: [ 
      {
        id?: string(name='id', example='node-1'),
        parameters?: map[string]any(name='parameters'),
        type?: string(name='type', example='transform'),
      }
    ](name='nodes'),
  }(name='pipeline', position='Body'),
  pipelineName?: string(name='pipelineName', example='my-pipeline', position='Body'),
  sink?: {
    dataset?: {
      agentSpace?: string(name='agentSpace', example='my-agent-space'),
      dataset?: string(name='dataset', example='my-dataset'),
    }(name='dataset'),
    type?: string(name='type', example='Dataset'),
  }(name='sink', position='Body'),
  source?: {
    logstore?: {
      logstore?: string(name='logstore', example='my-sls-logstore'),
      project?: string(name='project', example='my-sls-project'),
      query?: string(name='query', example='* | SELECT *'),
    }(name='logstore'),
    type?: string(name='type', example='SLS'),
  }(name='source', position='Body'),
  clientToken?: string(name='clientToken', example='a1b2c3d4-1234-5678-90ab-cdef12345678', position='Query'),
}

model CreatePipelineResponseBody = {
  requestId?: string(name='requestId', example='9ACFB10A-1B2C-3D4E-5F6G-7H8I9J0K1L2M'),
}

model CreatePipelineResponse = {
