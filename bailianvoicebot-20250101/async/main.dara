  caller?: string(name='Caller', example='13052253537', position='Query'),
  deviceId: string(name='DeviceId', description='This parameter is required.', example='467539456766097392-cn-shenzhen', position='Query'),
  sampleRate?: int32(name='SampleRate', example='8000', position='Query'),
  sandbox?: boolean(name='Sandbox', example='true', position='Query'),
  tags?: string(name='Tags', example='{\\"ENV\\": \\"production\\"}', position='Query'),
