    token?: string(name='Token', example='83480f806b48f022313de37b691e167e'),
  }(name='Data'),
  errorMsg?: string(name='ErrorMsg', example='connect timed out'),
  httpStatusCode?: string(name='HttpStatusCode', example='200'),
  requestId?: string(name='RequestId', example='CF6D3484-19A1-5C77-863B-AC8B5754D37C'),
  success?: boolean(name='Success', example='True'),
}

model BridgeWebCallResponse = {
  headers?: map[string]string(name='headers'),
  statusCode?: int32(name='statusCode'),
  body?: BridgeWebCallResponseBody(name='body'),
}

/**
  * @param request  the request parameters of BridgeWebCall  BridgeWebCallRequest
  * @return BridgeWebCallResponse
 */
async function bridgeWebCall(request: BridgeWebCallRequest): BridgeWebCallResponse {
  @handler.validateRequestModel(request);
  return @handler.do('RPC', 'BridgeWebCall', 'POST', '/', 'json', false, 'json', request);
}

