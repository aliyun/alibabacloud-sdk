    'ap-northeast-2' = 'aiworkspace.ap-northeast-2.aliyuncs.com',
    'ap-northeast-1' = 'aiworkspace.ap-northeast-1.aliyuncs.com',
  };

  checkConfig(config);
  @endpoint = getEndpoint('aiworkspace', @regionId, @endpointRule, @network, @suffix, @endpointMap, @endpoint);
}

function getEndpoint(productId: string, regionId: string, endpointRule: string, network: string, suffix: string, endpointMap: map[string]string, endpoint: string) throws: string{
  if (!$isNull(endpoint)) {
    return endpoint;
  }
  
  if (!$isNull(endpointMap) && !$isNull(endpointMap[regionId])) {
    return endpointMap[regionId];
  }
  return OpenApiUtil.getEndpointRules(productId, regionId, endpointRule, network, suffix);
}

model CodeSourceItem {
  accessibility?: string(name='Accessibility', description='The visibility of the code source. Valid values:

- `PRIVATE`: Visible only to you and workspace administrators.

- `PUBLIC`: Visible to all workspace members.', example='PUBLIC'),
  cloneType?: int32(name='CloneType', description='The clone type.'),
  codeBranch?: string(name='CodeBranch', description='The code branch.', example='master'),
  codeCommit?: string(name='CodeCommit', description='The commit ID.', example='44da10**********'),
  codeRepo?: string(name='CodeRepo', description='The code repository URL.', example='https://code.aliyun.com/****'),
  codeRepoAccessToken?: string(name='CodeRepoAccessToken', description='The access token for the code repository.'),
  codeRepoUserName?: string(name='CodeRepoUserName', description='The username for the code repository.', example='user'),
  codeSourceId?: string(name='CodeSourceId', description='The code source ID.', example='code-202**********'),
  description?: string(name='Description', description='The description of the code source.', example='code source of dlc examples'),
  displayName?: string(name='DisplayName', description='The display name of the code source.', example='MyCodeSourceName1'),
  gmtCreateTime?: string(name='GmtCreateTime', description='The time when the code source was created.', example='2021-01-18T12:52:15Z'),
  gmtModifyTime?: string(name='GmtModifyTime', description='The time when the code source was last modified.', example='2021-01-18T12:52:15Z'),
  mountPath?: string(name='MountPath', description='The local mount path for the code repository.', example='/root/code/'),
  userId?: string(name='UserId', description='The ID of the creator.', example='1157290171663117'),
  workspaceId?: string(name='WorkspaceId', description='The workspace ID.', example='1234'),
}

model Collection {
  collectionName?: string(name='CollectionName', description='The name of the collection. The name must be globally unique.', example='AI4D'),
  gmtCreateTime?: string(name='GmtCreateTime', description='The creation time.', example='2021-01-21T17:12:35Z'),
  gmtModifiedTime?: string(name='GmtModifiedTime', description='The last update time.', example='2021-01-21T17:12:35Z'),
  ownerId?: string(name='OwnerId', description='The ID of the Alibaba Cloud account.', example='155770209******'),
  userId?: string(name='UserId', description='The ID of the user that created the collection.', example='155770209******'),
}

model Connection {
  accessibility?: string(name='Accessibility', description='The workspace visibility. Valid values:

- PRIVATE (default): The connection is visible only to you and administrators in the workspace.

- PUBLIC: The connection is visible to all users in the workspace.', example='PRIVATE'),
  configs?: map[string]string(name='Configs', description='The connection configurations.'),
  connectionId?: string(name='ConnectionId', description='The connection ID.', example='conn-pai9m***mi47'),
  connectionName?: string(name='ConnectionName', description='The name of the connection.', example='lindorm-connection'),
  connectionType?: string(name='ConnectionType', description='The connection type. Valid values:

- DashScopeConnection: A service connection to Alibaba Cloud Model Studio.

- OpenLLMConnection: An open source model connection.

- MilvusConnection: A Milvus connection.

- OpenSearchConnection: An OpenSearch connection.

- LindormConnection: A Lindorm connection.

- ElasticsearchConnection: An Elasticsearch connection.

- HologresConnection: A Hologres connection.

- RDSConnection: An RDS connection.

- CustomConnection: A custom connection.', example='ElasticsearchConnection'),
  creator?: string(name='Creator', description='The creator of the connection.', example='20925961****557803'),
  description?: string(name='Description', description='The connection description.', example='This is a description of a database connection.'),
  gmtCreateTime?: string(name='GmtCreateTime', description='The time when the connection was created. The time is in UTC and follows the ISO 8601 format.', example='2025-03-07T07:54:56Z'),
  gmtModifiedTime?: string(name='GmtModifiedTime', description='The time when the connection was last modified. The time is in UTC and follows the ISO 8601 format.', example='2025-03-07T07:54:56Z'),
  models?: [ 
    {
      displayName?: string(name='DisplayName', description='The model\\\\"s display name.', example='BGE model deploy.'),
      model?: string(name='Model', description='The model identifier.', example='model_001'),
      modelType?: string(name='ModelType', description='The model type. Valid values:

- LLM (large language model)

- Embedding (Embedding model)

- ReRank (ReRank model)', example='LLM'),
      toolCall?: boolean(name='ToolCall', description='Indicates whether tool calling is supported. Valid values:

- true: Supported

- false: Not supported', example='true'),
    }
  ](name='Models', description='The model list.'),
  resourceMeta?: {
    extra?: string(name='Extra', description='Extra configuration information.', example='{"vpcId":"vpc-xxxx"}'),
    instanceId?: string(name='InstanceId', description='The instance ID.', example='ld-2vc1***v1zaqgzol'),
    instanceName?: string(name='InstanceName', description='The instance name.', example='lindorm-xxxxxxx'),
  }(name='ResourceMeta', description='The resource information for the connection. This usually applies to database connection configurations.'),
  secrets?: map[string]string(name='Secrets', description='The key-value configurations to encrypt, such as database logon passwords and model connection keys.'),
  workspaceId?: string(name='WorkspaceId', description='The workspace ID.', example='228**'),
}

model Dataset {
  accessibility?: string(name='Accessibility', description='The visibility of the dataset in the workspace. Valid values:

- `PRIVATE`: Visible only to the dataset\\\\"s owner and administrators.

- `PUBLIC`: The dataset is visible to all users in the workspace.

- `ROLE_PUBLIC`: Visible to specified workspace roles (see `AccessibleRoleIdList`). The owner and administrators also have visibility.', example='PRIVATE'),
  accessibleRoleIdList?: [ string ](name='AccessibleRoleIdList', description='If `Accessibility` is `ROLE_PUBLIC`, this parameter lists the IDs of workspace roles that can view the dataset. Role IDs that start with `PAI` are built-in roles, and those that start with `role-` are custom roles.'),
  dataSourceType?: string(name='DataSourceType', description='The type of the data source.', example='NAS'),
  dataType?: string(name='DataType', description='The data type of the dataset. Valid values:

- `COMMON`: (Default) Common data.

- `PIC`: Images.

- `TEXT`: Text.

- `VIDEO`: Videos.

- `AUDIO`: Audio.', example='COMMON'),
  datasetId?: string(name='DatasetId', description='The ID of the dataset.', example='d-c0h44g3****j8o4348'),
  description?: string(name='Description', description='The description of the dataset.', example='This is a description of a dataset.'),
  edition?: string(name='Edition', description='The edition of the dataset. Valid values:

`BASIC`: The basic edition. This edition does not support file metadata management.
`ADVANCED`: The advanced edition. This edition is supported only for OSS datasets and allows metadata management for up to 1 million files per version.', example='BASIC'),
  gmtCreateTime?: string(name='GmtCreateTime', description='The creation time.', example='2021-01-21T17:12:35.232Z'),
  gmtModifiedTime?: string(name='GmtModifiedTime', description='The update time.', example='2021-01-21T17:12:35.232Z'),
  importInfo?: string(name='ImportInfo', description='The configuration for importing data from a storage source. Supported sources include OSS, NAS, and CPFS.

<details>

<summary>

OSS

</summary>

{
"region": "${region}",// The region ID.
"bucket": "${bucket}",// The bucket name.
"path": "${path}" // The file path.
}

</details>

<details>

<summary>

NAS

</summary>

</details>

<details>

<summary>

CPFS

</summary>

Content

</details>

<details>

<summary>

Intelligent Computing CPFS

</summary>

Content

</details>', example='{
    "region": "cn-wulanchabu",
    "fileSystemId": "bmcpfs-xxxxxxxxxxx",
    "path": "/mnt",
    "mountTarget": "cpfs-xxxxxxxxxxxx-vpc-gacs9f.cn-wulanchabu.cpfs.aliyuncs.com",
    "isVpcMount": true
}'),
  isShared?: boolean(name='IsShared', description='Indicates whether the dataset is shared.', example='false'),
  labels?: [
    Label
  ](name='Labels', description='A list of labels.'),
  latestVersion?: DatasetVersion(name='LatestVersion', description='Details of the latest dataset version.'),
  mountAccess?: string(name='MountAccess', description='The mount access permissions.', example='RO RW'),
  mountAccessReadWriteRoleIdList?: [ string ](name='MountAccessReadWriteRoleIdList', description='A list of IDs for workspace roles with read and write permissions on the dataset. Role IDs that start with `PAI` are built-in roles, and role IDs that start with `role-` are custom roles. An asterisk (`*`) indicates that all roles have read and write permissions.'),
  name?: string(name='Name', description='The name of the dataset.', example='myName'),
  options?: string(name='Options', description='A JSON string of extended options. When you use the dataset in a Data Lake Compute job, you can configure the `mountPath` field to specify the default mount path for the dataset.', example='{
  "mountPath": "/mnt/data/"
}'),
  ownerId?: string(name='OwnerId', description='The ID of the Alibaba Cloud account.', example='1631044****3440'),
  property?: string(name='Property', description='Indicates whether the dataset corresponds to a single file or a directory. Valid values:

- `FILE`: The dataset is a file.

- `DIRECTORY`: The dataset is a directory.', example='DIRECTORY'),
  providerType?: string(name='ProviderType', description='The type of the data source provider. Valid values:

- `ECS` (Default)

- `Lingjun`', example='Ecs'),
  sharedFrom?: DatasetShareRelationship(name='SharedFrom', description='The source of the shared dataset. This parameter is valid only when `IsShared` is `true`.'),
  sharingConfig?: {
    sharedTo?: [
      DatasetShareRelationship
    ](name='SharedTo', description='A list of sharing relationships.'),
  }(name='SharingConfig', description='The sharing configuration for the dataset.'),
  sourceDatasetId?: string(name='SourceDatasetId', description='The ID of the source dataset for the annotated dataset.', example='d-bvfasdfxxxxj8o411'),
  sourceDatasetVersion?: string(name='SourceDatasetVersion', description='The version of the source dataset for the annotated dataset.', example='v2'),
  sourceId?: string(name='SourceId', description='The source ID.', example='jdnhf***fnrimv'),
  sourceType?: string(name='SourceType', description='The source type.', example='USER'),
  tagTemplateType?: string(name='TagTemplateType', description='The annotation template for the iTAG annotated dataset.', example='text-classification'),
  uri?: string(name='Uri', description='URI examples:

- OSS data source:
  `oss://bucket.endpoint/object`

- General-purpose NAS data source:
  `nas://<nasfisid>.region/subpath/to/dir/`

- CPFS 1.0 data source:
  `nas://<cpfs-fsid>.region/subpath/to/dir/`

- CPFS 2.0 data source:
  `nas://<cpfs-fsid>.region/<protocolserviceid>/`

> The format of the `fsid` distinguishes CPFS 1.0 from CPFS 2.0. A CPFS 1.0 `fsid` has the format `cpfs-<8-character ASCII string>`, and a CPFS 2.0 `fsid` has the format `cpfs-<16-character ASCII string>`.', example='nas://09f****f2.cn-hangzhou/'),
  userId?: string(name='UserId', description='The user ID.', example='2485765****023475'),
  workspaceId?: string(name='WorkspaceId', description='The ID of the workspace where the dataset is located.', example='478**'),
}

model DatasetFileMeta {
  contentType?: string(name='ContentType', description='The MIME type of the file. It includes a type and a subtype.', example='image/jpeg'),
  dataSize?: long(name='DataSize', description='The size of the file in bytes.', example='120000'),
  datasetFileMetaId?: string(name='DatasetFileMetaId', description='The ID of the dataset file metadata.', example='07914c9534586e4e7aa6e9dbca5009082df******fd8a0d857b33296c59bf6'),
  downloadUrl?: string(name='DownloadUrl', description='The download URL of the file.', example='https://test-bucket.oss-cn-shanghai.aliyuncs.com/dataset/cat.png?Expires=171280****&OSSAccessKeyId=LTAI************&Signature=****jZcXOn7FHMCT1DLE22NuNjs%3D'),
  fileCreateTime?: string(name='FileCreateTime', description='The time when the file was created. The time is in UTC and in ISO 8601 format.

Use the UTC time format: yyyy-MM-ddTHH:mmZ', example='2021-01-12T14:36:01.000Z'),
  fileFingerPrint?: string(name='FileFingerPrint', description='The file fingerprint. This value ensures the uniqueness of the file content and changes if the content is modified. The ETag is used for OSS files, and the MD5 value is used for NAS files.', example='D41D8CD98F*****E9800998ECF8'),
  fileName?: string(name='FileName', description='The name of the file.', example='cat.png'),
  fileType?: string(name='FileType', description='The type of the file. This corresponds to the main type of a Multipurpose Internet Mail Extensions (MIME) type.', example='image'),
  fileUpdateTime?: string(name='FileUpdateTime', description='The time when the file was last modified. The time is in Coordinated Universal Time (UTC) and in ISO 8601 format.

Use the UTC time format: yyyy-MM-ddTHH:mmZ', example='2025-01-12T14:36:01Z'),
  metaAttributes?: string(name='MetaAttributes', description='Specific metadata for the file, such as the width and height of an image or the bitrate and resolution of a video. Currently, this metadata cannot be used for retrieval. The format is a JSON string.', example='{     "ImageHeight": 400,     "ImageWidth": 800 }'),
  score?: float(name='Score', description='The similarity score.', example='0.6'),
  semanticIndexJobId?: string(name='SemanticIndexJobId', description='The ID of the job that last built the semantic index.', example='dsjob-klfwtjto****scvt3'),
  semanticIndexUpdateTime?: string(name='SemanticIndexUpdateTime', description='The time when the semantic index was last updated. The time is in UTC and in ISO 8601 format.

Use the UTC time format: yyyy-MM-ddTHH:mmZ', example='2021-01-12T14:36:01.000Z'),
  status?: string(name='Status', description='The current status of the metadata:
\\\\- ACTIVE: Active.
\\\\- DELETED: Deleted.', example='ACTIVE'),
  tags?: string(name='Tags', description='A collection of tags for the metadata, in JSON string format. The collection includes the following groups:

- Algorithm tag group:

  - ai: A list of tag names aggregated from all algorithm-based tagging tasks for a single metadata record.

- User-defined tag group:

  - user: A list of tag names that a user adds to a single metadata record.

  - user-delete-ai-tags: A list of tag names from the algorithm tag group that the user deletes from a single metadata record.', example='{
    "ai":
    [
        "Lane line",
        "Water horse",
        "Sunny day"
    ],
    "user":
    [
        "Everett",
        "Intelligent driving Dataset 1",
        "Cloudy day"
    ],
    "user-delete-ai-tags":
    [
        "Sunny day"
    ]
}'),
  thumbnailUrl?: string(name='ThumbnailUrl', description='The URL of the thumbnail.', example='https://test-bucket.oss-cn-shanghai.aliyuncs.com/dataset/cat.png?Expires=171280****&OSSAccessKeyId=LTAI************&Signature=****jZcXOn7FHMCT1DLE22NuNjs%3D'),
  uri?: string(name='Uri', description='The unique URI of the file. It records the unique path of the file. Paths for files in OSS and NAS are supported.

<details>

<summary>

OSS

</summary>

oss\\\\://${bucket}/${path}

</details>

<details>

<summary>

NAS

</summary>

nas\\\\://${fileSystemId}/${path}

</details>', example='oss://test-bucket/dataset/cat.png'),
}

model DatasetFileMetaConentUpdate {
  comment?: string(name='Comment', description='The file comment.', example='The first image file in the dataset.'),
  contentType?: string(name='ContentType', description='The MIME type of the file. It includes a type and a subtype.', example='image/jpeg'),
  dataSize?: long(name='DataSize', description='The file size in bytes.', example='10000'),
  datasetFileMetaId?: string(name='DatasetFileMetaId', description='The ID of the dataset file metadata.

This parameter is required.', example='07914c9534586e4e7aa6e9dbca5009082df******fd8a0d857b33296c59bf6'),
  fileCreateTime?: string(name='FileCreateTime', description='The time when the file was created, in ISO 8601 format.

Use the UTC time format: yyyy-MM-ddTHH:mmZ', example='2025-01-12T14:36:01.001Z'),
  fileFingerPrint?: string(name='FileFingerPrint', description='The file fingerprint information.', example='124FB71******7BE45608CDEA4DE54B3'),
  fileName?: string(name='FileName', description='The file name.', example='00001.jpeg'),
  fileType?: string(name='FileType', description='The file type. This is the primary type from the Multipurpose Internet Mail Extensions (MIME) type.', example='image'),
  fileUpdateTime?: string(name='FileUpdateTime', description='The time when the file was last modified, in ISO 8601 format.

Use the UTC time format: yyyy-MM-ddTHH:mmZ', example='2025-01-12T14:36:01.001Z'),
  metaAttributes?: string(name='MetaAttributes', description='Specific file metadata, such as the width and height of an image, and the bitrate and resolution of a video. Retrieval based on this metadata is not yet supported. The value is a JSON string.', example='{
    "Image":
    {
        "Width": 1920,
        "Height": 1080,
        "Channel": 3
    }
}'),
  semanticIndexJobId?: string(name='SemanticIndexJobId', description='The ID of the job that builds the semantic index.', example='dsjob-klfwt*****l0escvt3'),
  semanticIndexUpdateTime?: string(name='SemanticIndexUpdateTime', description='The time when the semantic index was built.

Use the UTC time format: yyyy-MM-ddTHH:mmZ', example='2021-01-12T14:36:01.000Z'),
  tags?: string(name='Tags', description='The tag groups to update.

- Update tags using an algorithm. Set a valid TagJobId.

```
{
   "ai":["lane line", "water barrier", "sunny day"]
}
```

- Manual tagging: Use add or remove to add or delete tags within a tag group. The modifiable tag groups are:

  - user: A list of tag names to add to or delete from a single metadata entry.

  - user-delete-ai-tags: A list of tag names to delete from the algorithm-generated tag group for a single metadata entry.

```
{
    "user":{
        "add":["lane line","sunny day"],
        "remove":["water barrier"]
    },
    "user-delete-ai-tags":{
        "add": ["ground shade"],
        "remove": []
    }
}
```', example='{
    "user":{
        "add":["Lane line","Sunny day"],
        "remove":["Water horse"]
    },
    "user-delete-ai-tags":{
        "add": ["Ground shadow"],
        "remove": []
    }
}'),
}

model DatasetFileMetaContentCreate {
  comment?: string(name='Comment', description='The comment on the file.', example='The first image file in the dataset.'),
  contentType?: string(name='ContentType', description='The MIME type of the file. It includes a type and a subtype.

This parameter is required.', example='image/jpeg'),
  dataSize?: long(name='DataSize', description='The size of the file in bytes.', example='10000'),
  fileCreateTime?: string(name='FileCreateTime', description='The time when the file was created. The time is in ISO 8601 format.

Use the UTC time format: yyyy-MM-ddTHH:mmZ', example='2025-01-12T14:36:01Z'),
  fileFingerPrint?: string(name='FileFingerPrint', description='The fingerprint of the file. This value ensures the uniqueness of the file content and changes if the content is modified. For OSS files, this is the ETag. For NAS files, this is the MD5 value.

This parameter is required.', example='D41D8CD98F*****E9800998ECF8'),
  fileName?: string(name='FileName', description='The name of the file.', example='00001.jpeg'),
  fileType?: string(name='FileType', description='The type of the file. This is the same as the Multipurpose Internet Mail Extensions (MIME) type.

This parameter is required.', example='image'),
  fileUpdateTime?: string(name='FileUpdateTime', description='The time when the file was last modified. The time is in ISO 8601 format.

This parameter is required.

Use the UTC time format: yyyy-MM-ddTHH:mmZ', example='2025-01-12T14:36:01Z'),
  metaAttributes?: string(name='MetaAttributes', description='The specific metadata of the file. This metadata cannot be used for retrieval. The value must be a JSON string.', example='{
    "ImageHeight": 1080,
    "ImageWidth": 1920
}'),
  tags?: string(name='Tags', description='The tags that are manually added by users. The \\\\`add\\\\` operation is used to add tags to a tag group. The value must be a JSON string.
The following tag group is available:

- user: A list of tag names added to a single piece of metadata.

```
{
    "user":{
        "add":["Lane line","Sunny day"]
    }
}
```', example='{
    "user":{
        "add":["Lane line","Sunny day"]
    }
}'),
