    'cn-hangzhou-internal-test-3' = 'aiworkspace.aliyuncs.com',
    'cn-hangzhou-test-306' = 'aiworkspace.aliyuncs.com',
    'cn-hongkong-finance-pop' = 'aiworkspace.aliyuncs.com',
