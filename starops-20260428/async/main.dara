model CreateChatRequest {
  regionId?: string(name='RegionId', position='Host'),
  action?: string(name='action', example='create', position='Body'),
  digitalEmployeeName?: string(name='digitalEmployeeName', example='test', position='Body'),
  messages?: [ 
    {
      contents?: [ 
        {
          type?: string(name='type', example='text'),
          value?: string(name='value', example='test'),
        }
      ](name='contents'),
      messageId?: string(name='messageId', example='message_id02'),
      role?: string(name='role', example='system'),
      tools?: [  map[string]any ](name='tools'),
    }
  ](name='messages', position='Body'),
  threadId?: string(name='threadId', example='thread_id01', position='Body'),
  variables?: map[string]any(name='variables', example='{
  "workspace": "test",
  "region": "cn-beijing",
  "project": "test",
  "language": "zh",
  "timeZone": "Asia/Shanghai",
  "timeStamp": "1768893948",
  "startTime": 1768887171,
  "endTime": 1768890771,
  "skill": "trace"
}', position='Body'),
}

model CreateChatResponseBody = {
  messages?: [ 
    {
      agents?: [  map[string]any ](name='agents'),
      artifacts?: [  map[string]any ](name='artifacts'),
      callId?: string(name='callId', example='call_search_001'),
      contents?: [  map[string]any ](name='contents'),
      detail?: string(name='detail', example='test'),
      events?: [  map[string]any ](name='events'),
      parentCallId?: string(name='parentCallId', example='sess_abc123'),
      role?: string(name='role', example='tool'),
      seq?: int32(name='seq', example='1'),
      timestamp?: string(name='timestamp', example='1765000005'),
      tools?: [  map[string]any ](name='tools'),
      type?: string(name='type', example='done'),
      version?: string(name='version', example='v0.1.0'),
    }
  ](name='messages'),
  requestId?: string(name='requestId', example='0CEC5375-XXXX-XXXX-XXXX-9A629907C1F0'),
  traceId?: string(name='traceId', example='21504600000008405622576e3b48'),
}

model CreateChatResponse = {
  headers?: map[string]string(name='headers'),
  statusCode?: int32(name='statusCode'),
  body?: CreateChatResponseBody(name='body'),
}

/**
  * @param request  the request parameters of CreateChat  CreateChatRequest
  * @return CreateChatResponse
 */
async function createChat(request: CreateChatRequest): CreateChatResponse {
  @handler.validateRequestModel(request);
  return @handler.do('RESTFUL', 'CreateChat', 'POST', '/chat', 'json', false, 'json', request);
}

async function createChatWithRequestBody(request: CreateChatRequest, requestBody: RequestBody): CreateChatResponse {
  @handler.validateRequestModel(request);
  return @handler.doRequestBody('RESTFUL', 'CreateChat', 'POST', '/chat', 'json', false, 'json', request, requestBody);
}

