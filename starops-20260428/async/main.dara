  @handler.validateRequestModel(request);
  return @handler.doResponseHandler('RESTFUL', 'CreateChat', 'POST', '/chat', 'json', false, 'json', request, responseHandler);
}

function createChatWithResponseIterable(request: CreateChatRequest): iterator[CreateChatResponseBody] {
  @handler.validateRequestModel(request);
  yield @handler.doSSERequest('SSE', 'CreateChat', 'POST', '/chat', 'json', false, 'json', request);
}

