model CreateScriptVersionRequest {
  instanceId?: string(name='InstanceId', example='abb4aa26-3a8e-43dd-82f8-0c3898c9c67f'),
  interactionConfig?: {
    backgroundMusicId?: string(name='BackgroundMusicId', example='office-ambience'),
    endConversationConfig?: {
      delay?: int32(name='Delay', example='1'),
      triggers?: [ 
        {
          closingStatement?: string(name='ClosingStatement', example='感谢您的接听，祝您生活愉快，再见!'),
          keyWords?: [ string ](name='KeyWords'),
          triggerType?: string(name='TriggerType', example='TurnLimit'),
          turnLimit?: int32(name='TurnLimit', example='20'),
        }
      ](name='Triggers'),
    }(name='EndConversationConfig'),
    initialGreetingDelayMilliseconds?: int32(name='InitialGreetingDelayMilliseconds', example='2000'),
    silenceDetectionConfig?: {
      maxRepeats?: int32(name='MaxRepeats', example='3'),
      timeout?: int32(name='Timeout', example='5000'),
    }(name='SilenceDetectionConfig'),
  }(name='InteractionConfig'),
  labelConfig?: [ 
    {
      candidateValues?: [ string ](name='CandidateValues'),
      description?: string(name='Description'),
      name?: string(name='Name'),
    }
  ](name='LabelConfig'),
  scriptId?: string(name='ScriptId', example='64241e64-190c-45d1-af66-06f51c07b090'),
  scriptProfile?: {
    agentKey?: string(name='AgentKey', example='1309723684579735_p_beebot_public'),
    agentProfile?: {
      promptsJson?: string(name='PromptsJson'),
      scriptProfileTemplateId?: string(name='ScriptProfileTemplateId', example='CCC_PROMPTS_DEFAULT'),
    }(name='AgentProfile'),
    chatbotId?: string(name='ChatbotId', example='chatbot-cn-MQuyjjb666'),
    functionMeta?: {
      functionId?: string(name='FunctionId', example='9b752bbb-805a-4d3e-9013-eab5555c3fef'),
      functionName?: string(name='FunctionName', example='my_funciton'),
      httpTriggerName?: string(name='HttpTriggerName', example='defaultTrigger'),
      httpTriggerUrl?: string(name='HttpTriggerUrl', example='http://chat-xxxxx-v-yewiundukb.cn-hangzhou-xxx.run'),
      regionId?: string(name='RegionId', example='cn-hangzhou'),
    }(name='FunctionMeta'),
    model?: string(name='Model', example='qwen-plus'),
    nluAccessProfile?: {
      accessProfileId?: string(name='AccessProfileId', example='c2c9baae-9351-4c49-a8cb-6f24a83a8718'),
    }(name='NluAccessProfile'),
    nluAccessType?: string(name='NluAccessType', example='MANAGED'),
    omniModel?: boolean(name='OmniModel', example='true'),
  }(name='ScriptProfile'),
  sourceVersionId?: string(name='SourceVersionId'),
  synthesizerConfig?: {
    model?: string(name='Model', example='CosyVoice'),
    nlsAccessProfile?: {
