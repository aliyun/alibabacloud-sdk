  flowEndpointId?: string(name='flowEndpointId', description='工作流端点的唯一标识符', example='fe-1234567890abcdef'),
  flowEndpointName?: string(name='flowEndpointName', description='工作流端点的名称', example='my-flow-endpoint'),
  flowId?: string(name='flowId', description='工作流的唯一标识符', example='flow-1234567890abcdef'),
  lastUpdatedAt?: string(name='lastUpdatedAt', description='工作流端点最后一次更新的时间，采用ISO 8601格式', example='2025-01-10T11:45:00Z'),
  routingConfiguration?: [
    FlowEndpointRoutingConfig
  ](name='routingConfiguration', description='工作流端点的版本路由配置', example='[]'),
  targetVersion?: string(name='targetVersion', description='工作流端点指向的目标版本号', example='1'),
}

