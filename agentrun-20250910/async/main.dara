model ArmsConfiguration {
  armsLicenseKey?: string(name='armsLicenseKey', description='应用实时监控服务（ARMS）的许可证密钥', example='arms-license-key-123456'),
  cmsWorkspace?: string(name='cmsWorkspace'),
  enableArms?: boolean(name='enableArms', description='是否启用应用实时监控服务（ARMS）', example='true'),
