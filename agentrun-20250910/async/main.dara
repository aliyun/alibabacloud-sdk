}

model CertConfig {
  certName?: string(name='certName', description='证书的名称。支持字母、数字、下划线（_）和短划线（-），不能以数字和短划线（-）开头。长度范围为 1~128 个字符。', example='my-cert', minimum=1, maximum=128),
  certificate?: string(name='certificate', description='证书，如果是证书链，则需要依次填写多个证书。', example='-----BEGIN CERTIFICATE-----\\nxxxxx\\n-----END CERTIFICATE-----'),
  privateKey?: string(name='privateKey', description='私钥。', example='-----BEGIN RSA PRIVATE KEY-----\\nxxxxx\\n-----END RSA PRIVATE KEY-----'),
}

