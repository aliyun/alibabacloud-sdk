  oldResourceGroupId?: string(name='oldResourceGroupId'),
  resourceId?: string(name='resourceId'),
}

model CodeConfiguration {
  checksum?: string(name='checksum', description='代码包的CRC-64校验值。如果提供了checksum，则函数计算会校验代码包的checksum是否和提供的一致', example='1234567890123456789'),
  command?: [ string ](name='command', description='在运行时中运行的命令（例如：[\\"python\\"]）', example='python,main.py'),
  language?: string(name='language', description='代码运行时的编程语言，如 python3、nodejs 等', example='python3.12'),
  ossBucketName?: string(name='ossBucketName', example='my-agent-code-bucket'),
  ossObjectName?: string(name='ossObjectName', example='agent-code-v1.0.zip'),
  zipFile?: string(name='zipFile', description='智能体代码ZIP包的Base64编码', example='UEsDBAoAAAAAANF'),
}

