model FlowResult {
  code?: string(name='code', description='SUCCESS 为成功，失败情况返回对应错误类型，比如 ERR_BAD_REQUEST ERR_VALIDATION_FAILED ERR_INTERNAL_SERVER_ERROR', example='SUCCESS'),
  data?: Flow(name='data', description='工作流的详细信息', example='{}'),
  requestId?: string(name='requestId', description='唯一的请求标识符，用于问题追踪', example='F8A0F5F3-0C3E-4C82-9D4F-5E4B6A7C8D9E'),
}

model FlowVersion {
  createdAt?: string(name='createdAt', description='工作流版本的创建时间，采用ISO 8601格式', example='2025-01-10T10:30:00Z'),
  definition?: string(name='definition', description='工作流版本的定义内容（完整快照，仅在 GetFlowVersion 时返回）', example='Type: StateMachine\\nName: my-flow\\n...'),
  description?: string(name='description', description='工作流版本的描述信息', example='Version 1.0 - Initial release'),
  environmentConfiguration?: EnvironmentConfiguration(name='environmentConfiguration', description='工作流版本的环境变量配置（完整快照，仅在 GetFlowVersion 时返回）'),
  externalStorageLocation?: string(name='externalStorageLocation', description='工作流版本的外部存储位置（完整快照，仅在 GetFlowVersion 时返回）', example='oss://bucket/path'),
  flowId?: string(name='flowId', description='工作流的唯一标识符', example='flow-1234567890abcdef'),
  flowName?: string(name='flowName'),
  flowVersion?: string(name='flowVersion', description='工作流版本号', example='1'),
  loggingConfiguration?: LoggingConfiguration(name='loggingConfiguration', description='工作流版本的日志配置（完整快照，仅在 GetFlowVersion 时返回）'),
  tracingConfiguration?: TracingConfiguration(name='tracingConfiguration', description='工作流版本的链路追踪配置（完整快照，仅在 GetFlowVersion 时返回）'),
}

