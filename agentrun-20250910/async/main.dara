model AttachPolicyConfig {
  className?: string(name='className'),
  config?: string(name='config'),
  name?: string(name='name'),
}

model BatchEvaluateWorkspacePermissionsInput {
  actions: [ string ](name='actions', description='RAM List 类 action 列表；支持带 agentrun: 前缀或不带（服务端归一化）；顺序与每条 permissions 一致；上限 20 条

This parameter is required.'),
  workspaceIds: [ string ](name='workspaceIds', description='Workspace 资源 ID 列表（UUID 字符串）；顺序与响应 results 一致；上限 50 条

This parameter is required.'),
}

model BatchEvaluateWorkspacePermissionsOutput {
  results?: [
    WorkspacePermissionEvaluateResult
  ](name='results', description='各 workspace 的权限校验结果列表；顺序与请求 workspaceIds 一致'),
}

model BatchEvaluateWorkspacePermissionsResult {
  code?: string(name='code', description='OK 表示成功'),
  data?: BatchEvaluateWorkspacePermissionsOutput(name='data'),
  requestId?: string(name='requestId', description='与响应头 x-funagent-request-id 对应'),
}

model BoundConfiguration {
  boundTools?: [
    BoundTool
  ](name='boundTools', description='绑定的工具配置列表，每个配置项定义一个工具与特定 HTTP 路径和方法的绑定关系'),
}

model BoundTool {
  apis?: [
    BoundToolApi
  ](name='apis'),
  method?: string(name='method', description='绑定的 HTTP 请求方法，支持：GET、PUT、POST、PATCH、DELETE、OPTIONS', example='POST', deprecated='true'),
  path?: string(name='path', description='绑定的 URL 路径，用于路由匹配', example='/api/v1/tools', deprecated='true'),
  toolName?: string(name='toolName', description='要绑定的工具名称', example='my-tool'),
}

model BoundToolApi {
  method?: string(name='method'),
  path?: string(name='path'),
}

model Browser {
  browserId?: string(name='browserId', example='browser-1234567890abcdef'),
  browserName?: string(name='browserName', example='my-browser'),
  cpu?: float(name='cpu', example='2.0'),
  createdAt?: string(name='createdAt', example='2025-01-10T10:30:00Z'),
  credentialId?: string(name='credentialId', example='cred-1234567890abcdef'),
  description?: string(name='description', example='Web automation browser for testing'),
  executionRoleArn?: string(name='executionRoleArn', example='acs:ram::1760720386195983:role/BrowserExecutionRole'),
  lastUpdatedAt?: string(name='lastUpdatedAt', example='2025-01-10T11:45:00Z'),
  memory?: int32(name='memory', description='内存资源配置（单位：MB）', example='2048'),
  networkConfiguration?: NetworkConfiguration(name='networkConfiguration'),
  recording?: BrowserRecordingConfiguration(name='recording'),
  status?: string(name='status', example='READY'),
  statusReason?: string(name='statusReason', description='当前状态的原因说明（如适用）', example='Browser is ready for use'),
  tenantId?: string(name='tenantId', example='tenant-1234567890abcdef'),
}

model BrowserAutomationStream {
  streamEndpoint?: string(name='streamEndpoint', example='wss://browser-automation.cn-hangzhou.agentrun.aliyuncs.com/stream/bs-1234567890abcdef'),
