/**
 *
 */
import OpenApi;
import OpenApi.OpenApiUtil;

extends OpenApi;


init(config: OpenApiUtil.Config){
  super(config);
  @endpointRule = 'regional';
  @endpointMap = {
    'cn-shenzhen' = 'agentrun.cn-shenzhen.aliyuncs.com',
    'cn-shanghai' = 'agentrun.cn-shanghai.aliyuncs.com',
    'cn-hangzhou' = 'agentrun.cn-hangzhou.aliyuncs.com',
    'cn-beijing' = 'agentrun.cn-beijing.aliyuncs.com',
    'ap-southeast-1' = 'agentrun.ap-southeast-1.aliyuncs.com',
  };

  checkConfig(config);
  @endpoint = getEndpoint('agentrun', @regionId, @endpointRule, @network, @suffix, @endpointMap, @endpoint);
}

function getEndpoint(productId: string, regionId: string, endpointRule: string, network: string, suffix: string, endpointMap: map[string]string, endpoint: string) throws: string{
  if (!$isNull(endpoint)) {
    return endpoint;
  }
  
  if (!$isNull(endpointMap) && !$isNull(endpointMap[regionId])) {
    return endpointMap[regionId];
  }
  return OpenApiUtil.getEndpointRules(productId, regionId, endpointRule, network, suffix);
}

model AccessDeniedDetail {
  authAction?: string(name='authAction', description='被拒绝的 RAM action，如 agentrun:ListTemplates', nullable=true),
  authPrincipalDisplayName?: string(name='authPrincipalDisplayName', description='鉴权主体展示名', nullable=true),
  authPrincipalOwnerId?: string(name='authPrincipalOwnerId', description='鉴权主体所属账号 ID', nullable=true),
  authPrincipalType?: string(name='authPrincipalType', description='鉴权主体类型，如 SubUser、AssumedRoleUser', nullable=true),
  encodedDiagnosticInfo?: string(name='encodedDiagnosticInfo', description='Base64 编码的诊断信息，可用于 RAM 控制台自诊断', nullable=true),
  noPermissionType?: string(name='noPermissionType', description='无权限类型：ImplicitDeny 或 ExplicitDeny', nullable=true),
  policyType?: string(name='policyType', description='策略类型，如 ResourceBasedPolicy、IdentityBasedPolicy', nullable=true),
}

model AgentEndpointConfig {
  agentName?: string(name='agentName'),
  customDomainUrl?: string(name='customDomainUrl'),
  endpointName?: string(name='endpointName', description='端点名称'),
  endpointUrl?: string(name='endpointUrl'),
}

model AgentResource {
  flow?: Flow(name='flow', description='当 resourceType 为 Flow 时，此字段包含完整的工作流对象，包括所有配置和状态信息；当 resourceType 为 AgentRuntime 时，此字段为空'),
  latestVersion?: {
    createdAt?: string(name='createdAt', description='版本发布时间，采用ISO 8601格式', example='2025-03-15T08:30:00Z'),
    description?: string(name='description', description='该版本的描述信息', example='修复了消息处理的并发问题'),
    publisher?: string(name='publisher', description='版本发布者（仅 AgentRuntime 类型资源返回）', example='admin'),
    version?: string(name='version', description='最新发布的版本号', example='3'),
  }(name='latestVersion', description='资源的最新发布版本摘要，包含版本号、描述和创建时间。如果资源没有已发布版本，则此字段为空'),
  resourceType?: string(name='resourceType', description='资源类型标识符，用于区分资源是智能体运行时（AgentRuntime）还是工作流（Flow）', example='AgentRuntime'),
  runtime?: AgentRuntime(name='runtime', description='当 resourceType 为 AgentRuntime 时，此字段包含完整的智能体运行时对象，包括所有配置和状态信息；当 resourceType 为 Flow 时，此字段为空'),
}

model AgentRuntime {
  agentRuntimeArn?: string(name='agentRuntimeArn', description='The Alibaba Cloud Resource Name (ARN) of the agent runtime.', example='acs:agentrun:cn-hangzhou:1760720386195983:runtimes/7a1b6d39-9f8f-4ce2-b9c9-6db1b0b9e169'),
  agentRuntimeId?: string(name='agentRuntimeId', description='The unique identifier of the agent runtime.', example='ar-1234567890abcdef'),
  agentRuntimeName?: string(name='agentRuntimeName', description='The name of the agent runtime.', example='my-agent-runtime'),
  agentRuntimeVersion?: string(name='agentRuntimeVersion', description='The version number of the agent runtime.', example='1'),
  artifactType?: string(name='artifactType', description='The deployment type of the agent runtime. Valid values: `Code` and `Container`.', example='Code'),
  codeConfiguration?: CodeConfiguration(name='codeConfiguration', description='The code configuration details. This parameter is applicable when `artifactType` is set to `Code`.', example='{}'),
  containerConfiguration?: ContainerConfiguration(name='containerConfiguration', description='The container configuration details. This parameter is applicable when `artifactType` is set to `Container`.', example='{}'),
  cpu?: float(name='cpu', description='The amount of CPU allocated to the agent runtime, in vCPUs.', example='2.0'),
  createdAt?: string(name='createdAt', description='The creation time of the agent runtime, in ISO 8601 format.', example='2025-01-10T10:30:00Z'),
  credentialName?: string(name='credentialName', description='The name of the credential used to authenticate requests to the agent runtime.', example='my-credential'),
  description?: string(name='description', description='The description of the agent runtime.', example='AI agent runtime for customer service automation'),
  disableOndemand?: boolean(name='disableOndemand', description='Specifies whether to disable on-demand elasticity. Default: `false`.', example='false'),
  disableSessionAffinity?: boolean(name='disableSessionAffinity', description='Specifies whether to disable session affinity. Default: `false`.', example='false'),
  diskSize?: integer(name='diskSize', description='The disk size.'),
  edition?: string(name='edition', description='The edition of the agent runtime.'),
  enableSessionIsolation?: boolean(name='enableSessionIsolation', description='Specifies whether to enable session isolation. If enabled, each session runs in an isolated environment.', example='false'),
  environmentVariables?: map[string]string(name='environmentVariables', description='The environment variables for the agent runtime.', example='ENV_VAR1=value1,ENV_VAR2=value2'),
  executionRoleArn?: string(name='executionRoleArn', description='The ARN of the execution role that grants the agent runtime permission to access cloud services.', example='acs:ram::1760720386195983:role/AgentRunExecutionRole'),
  externalAgentEndpointUrl?: string(name='externalAgentEndpointUrl', description='The endpoint URL of an externally deployed agent service.', example='https://external-agent.example.com/api'),
  headerFieldName?: string(name='headerFieldName', description='The name of the request header used for session affinity when `sessionAffinityType` is `HEADER_FIELD`.', example='x-agentrun-session-id'),
  healthCheckConfiguration?: HealthCheckConfiguration(name='healthCheckConfiguration', description='The health check configuration.', example='{}'),
  lastUpdatedAt?: string(name='lastUpdatedAt', description='The last update time of the agent runtime, in ISO 8601 format.', example='2025-01-10T11:45:00Z'),
  logConfiguration?: LogConfiguration(name='logConfiguration', description='The Log Service configuration.', example='{}'),
  memory?: integer(name='memory', description='The amount of memory allocated to the agent runtime, in MB.', example='2048'),
  nasConfig?: NASConfig(name='nasConfig', description='The NAS file system configuration.', example='{}'),
  networkConfiguration?: NetworkConfiguration(name='networkConfiguration', description='The network configuration of the agent runtime.', example='{}'),
  ossMountConfig?: OSSMountConfig(name='ossMountConfig', description='The OSS bucket mount configuration.', example='{}'),
  port?: integer(name='port', description='The port on which the agent runtime listens.', example='8080'),
  protocolConfiguration?: ProtocolConfiguration(name='protocolConfiguration', description='The communication protocol configuration for the agent runtime.', example='{}'),
  resourceGroupId?: string(name='resourceGroupId', description='The ID of the resource group to which the agent runtime belongs.', deprecated=true),
  sessionAffinityType?: string(name='sessionAffinityType', description='The session affinity mode. Valid values: `NONE`, `HEADER_FIELD`, and `GENERATED_COOKIE`. `COOKIE` is a compatibility alias for `GENERATED_COOKIE`.', example='GENERATED_COOKIE'),
  sessionConcurrencyLimitPerInstance?: integer(name='sessionConcurrencyLimitPerInstance', description='The maximum number of concurrent sessions allowed per runtime instance.', example='100'),
  sessionIdleTimeoutSeconds?: int32(name='sessionIdleTimeoutSeconds', description='The idle timeout period for a session, in seconds. After this period of inactivity, the session expires and can no longer be used.', example='3600'),
  status?: string(name='status', description='The current status of the agent runtime. Possible values: `READY`, `CREATING`, and `FAILED`.', example='READY'),
  statusReason?: string(name='statusReason', description='The reason for the current status.', example='Runtime is ready for use'),
  systemTags?: [ string ](name='systemTags', description='The system tags for the agent runtime.', example='system-tag-1,system-tag-2'),
  workspaceId?: string(name='workspaceId', description='The ID of the workspace for the agent runtime.', example='ws-1234567890abcdef'),
}

model AgentRuntimeEndpoint {
