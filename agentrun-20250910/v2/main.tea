  disablePublicNetworkAccess?: boolean(name='disablePublicNetworkAccess', description='If `true`, public access for this endpoint is disabled.'),
  endpointPublicUrl?: string(name='endpointPublicUrl', description='The public access address for the agent runtime endpoint.', example='https://ar-1234567890abcdef.cn-hangzhou.agentrun.aliyuncs.com'),
  routingConfiguration?: RoutingConfiguration(name='routingConfiguration', description='The configuration for weight-based routing across multiple agent versions.'),
  scalingStatus?: ScalingStatus(name='scalingStatus', description='端点的弹性伸缩状态，包括最小/目标/当前实例数及定时策略（复用 ScalingStatus）'),
  status?: string(name='status', description='The current status of the agent runtime endpoint.', example='ACTIVE'),
  statusReason?: string(name='statusReason', description='The reason for the current status of the endpoint.', example='Endpoint is active and ready'),
  targetVersion?: string(name='targetVersion', description='The agent version that the endpoint targets.', example='LATEST'),
}

