  createDate?: string(name='createDate', description='The order creation time.', example='2023-09-11T12:22:24.000+08:00'),
  distributorId?: string(name='distributorId', description='The distributor ID.', example='12****01'),
  logisticsStatus?: string(name='logisticsStatus', description='The logistics status. Valid values: 1 (Awaiting Seller\\\\"s Shipment), 2 (Awaiting Buyer\\\\"s Confirmation), 3 (Received), 4 (Returned), 5 (Partially Received), 6 (Partially Shipped), and 8 (Logistics Order Not Created).', example='1'),
