model UpdateBackupPolicyRequest {
  backupPeriod?: string(name='BackupPeriod', description='The backup cycle. You must specify at least 2 days. The value is a 7-digit number. From left to right, each digit indicates whether backup is enabled from Monday to Sunday. A value of 0 indicates that backup is disabled, and a value of 1 indicates that backup is enabled:

- First digit: Monday
- Second digit: Tuesday
- Third digit: Wednesday
- Fourth digit: Thursday
- Fifth digit: Friday
- Sixth digit: Saturday
- Seventh digit: Sunday.', example='1001000'),
  backupPlanBegin?: string(name='BackupPlanBegin', description='The start time of the daily backup, in UTC.', example='03:00Z'),
  backupSetRetention?: int32(name='BackupSetRetention', description='The retention period of backup sets. Unit: days.', example='30'),
  backupType?: string(name='BackupType', description='The backup type. Currently, only "0" is supported, which indicates fast backup.', example='0'),
  backupWay?: string(name='BackupWay', description='The backup method. Valid values:

- **P**: physical backup
- **L**: logical backup.', example='P'),
  coldDataBackupInterval?: int32(name='ColdDataBackupInterval', description='The interval for cold data backups. Unit: days. Valid values: 1 to 59.', example='30'),
  coldDataBackupRetention?: int32(name='ColdDataBackupRetention', description='The retention period for cold data backups. Unit: days. Valid values: 30 to 730.', example='30'),
  crossRegionDataBackupRetention?: int32(name='CrossRegionDataBackupRetention', description='The retention period for cross-region data backups. Unit: days.', example='30'),
  crossRegionFilterValue?: string(name='CrossRegionFilterValue'),
  crossRegionLogBackupRetention?: int32(name='CrossRegionLogBackupRetention', description='The retention period for cross-region log backups. Unit: days.', example='30'),
  DBInstanceName?: string(name='DBInstanceName', description='The instance ID.

This parameter is required.', example='pxc-hzjasdyuoo'),
  destCrossRegion?: string(name='DestCrossRegion', description='The destination region for cross-region backup.', example='cn-shanghai'),
  forceCleanOnHighSpaceUsage?: int32(name='ForceCleanOnHighSpaceUsage', description='Specifies whether to forcibly clean up binary logs when the total space usage of the instance exceeds 80% or the remaining space is less than 50 GB. The cleanup starts from the earliest logs until the total space usage drops below 80% and the remaining space exceeds 50 GB. Valid values:

- **1**: yes
- **0**: no.', example='1'),
  isCrossRegionDataBackupEnabled?: boolean(name='IsCrossRegionDataBackupEnabled', description='Specifies whether to enable cross-region data backup. Default value: false.', example='false'),
  isCrossRegionLogBackupEnabled?: boolean(name='IsCrossRegionLogBackupEnabled', description='Specifies whether to enable cross-region log backup. Default value: false.', example='false'),
  isEnabled?: int32(name='IsEnabled', description='Specifies whether to enable backup. The value is fixed to 1, which indicates that backup is enabled.', example='1'),
  localLogRetention?: int32(name='LocalLogRetention', description='The number of hours that log backups are retained locally. Valid values: 0 to 168 (7 × 24 hours). A value of 0 indicates that log backups are not retained locally. Default value: 7.', example='7'),
  localLogRetentionNumber?: int32(name='LocalLogRetentionNumber', description='The number of binary logs retained locally. Default value: 60. Valid values: 6 to 100.', example='60'),
  logLocalRetentionSpace?: int32(name='LogLocalRetentionSpace', description='The maximum space usage for binary logs, expressed as a percentage. Valid values: 0 to 50. This parameter specifies a loop space. Default value: 30.', example='30'),
  regionId?: string(name='RegionId', description='The region ID.

This parameter is required.', example='cn-hangzhou'),
  removeLogRetention?: int32(name='RemoveLogRetention', description='The number of days that log backups are retained remotely. Valid values: 7 to 730. Unit: days. Default value: 7.', example='7'),
}

