  previewCount?: long(name='PreviewCount', description='The number of times that the shared file is previewed.', example='0'),
  previewLimit?: long(name='PreviewLimit', description='The maximum number of times that the shared file can be previewed.', example='100'),
  reportCount?: long(name='ReportCount', description='The number of times that the shared file is reported due to content violation.', example='0'),
  saveCount?: long(name='SaveCount', description='The number of times that the shared files can be dumped.', example='100'),
  saveLimit?: long(name='SaveLimit', description='The maximum number of times that the shared file can be saved.', example='100'),
  shareId?: string(name='ShareId', description='The file sharing task ID.', example='7JQX1Fs****'),
  shareLink?: string(name='ShareLink', description='The file sharing link.', example='https://stg109960.apps.aliyunpds.com/disk/s/7uLJanz****'),
  shareName?: string(name='ShareName', description='The shared file name. By default, the name of the first shared file is used.', example='view.txt'),
  sharePwd?: string(name='SharePwd', description='The access code. It must contain up to 64 characters in length. 0 characters indicates that there is no access code.', example='12345678'),
  status?: string(name='Status', description='The status of the file sharing link.

Valid values:

*   forbidden_disabled

    <!-- -->

    : The file sharing link is canceled

    <!-- -->

    after it

    <!-- -->

    is not allowed.

*   forbidden

    <!-- -->

    :

    <!-- -->

    The file sharing link is not allowed

    <!-- -->

    .

*   disabled

    <!-- -->

    :

    <!-- -->

    The file sharing link is canceled.

    <!-- -->

*   enabled

    <!-- -->

    :

    <!-- -->

    The file sharing link is valid.

    <!-- -->', example='disabled'),
  videoPreviewCount?: long(name='VideoPreviewCount', description='The number of times that the audio and video file is played.', example='0'),
}

