  identityCsr?: string(name='IdentityCsr', description='The Certificate Signing Request (CSR) for the identity certificate. You can generate the CSR by following the instructions provided in Step 3 of the Register Agent process in the ATS console.

This parameter is required.', example='-----BEGIN CERTIFICATE-----
MIIDrzCCApegAwIBAgIQCDvgVpBCRrGhdWrJWZHHSjANBgkqhkiG9w0BAQUFAD...
（中间是一长串经过 Base64 编码的数据）
...
-----END CERTIFICATE-----'),
  serverCertPem?: string(name='ServerCertPem', description='The server certificate, which is the certificate corresponding to the domain name (host address) used by the registered Agent.

This parameter is required.', example='-----BEGIN CERTIFICATE-----
KsdeFSAwIBAgIQCDvgVpBCRrGhdWrJWZHHSjANBgkqhkiG9w0BAQUFAD...
（中间是一长串经过 Base64 编码的数据）
...
-----END CERTIFICATE-----'),
}

model SubmitAtiAgentRegisterInfoResponseBody = {
  accessDeniedDetail?: {
    authAction?: string(name='AuthAction', description='The unauthorized operation that was attempted.', example='AddRspDomainServerHoldStatusForGateway'),
    authPrincipalDisplayName?: string(name='AuthPrincipalDisplayName', description='The display name of the authorized principal.', example='2015555733387XXXX'),
    authPrincipalOwnerId?: string(name='AuthPrincipalOwnerId', description='The owner ID of the authorized principal.', example='10469733312XXX'),
    authPrincipalType?: string(name='AuthPrincipalType', description='The identity type.', example='SubUser'),
    encodedDiagnosticMessage?: string(name='EncodedDiagnosticMessage', description='The encrypted diagnostic message.', example='AQEAAAAAaNIARXXXXUQwNjE0LUQzN0XXXXVEQy1BQzExLTMzXXXXNTkxRjk1Ng=='),
    noPermissionType?: string(name='NoPermissionType', description='The reason why the authentication failed. Valid values:
- ExplicitDeny: Explicit denial.
- ImplicitDeny: Implicit denial.', example='ImplicitDeny'),
    policyType?: string(name='PolicyType', description='The policy type.', example='DlpSend'),
  }(name='AccessDeniedDetail', description='The details about the access denial. This field is returned only when the RAM authentication fails.'),
  requestId?: string(name='RequestId', description='The request ID.', example='6856BCF6-11D6-4D7E-AC53-FD579933522B'),
  status?: boolean(name='Status', description='The Agent status. Valid values:

- Draft: The Agent registration form is being filled out and has not been formally submitted. In the Draft state, only modification and detail viewing are supported. Other operations are not supported.
- Private CA Pending Issuance: The Agent registration has been formally submitted. Alibaba Cloud has completed the ACME DNS-01 pre-check and submitted the registration information along with the generated DNS records to CNNIC. The system is waiting for CNNIC to approve and issue the Private CA certificate and complete the TL sealing.
- DNS Pending Verification: CNNIC has approved and issued the Private CA certificate and completed the TL sealing, but the DNS records of the user have not been verified. The user needs to add the corresponding DNS records in the domain name resolution and complete the verification.
- Active: All processes are complete. The Private CA certificate has been issued, the TL has been sealed, and the DNS records have been verified. The Agent is activated and can be discovered and trusted across the network.
- Expired: The Agent identity certificate has expired because the user did not complete the certificate renewal within the validity period.
- Revoked: The Agent certificate has been revoked, the DNS records have been cleaned up, and the Agent can no longer be discovered or trusted. The Agent cannot be restored to the Active state.', example='Private CA 待签发'),
}

