      cityCode?: string(name='CityCode', description='The city code of the detection point.', example='503'),
      ispCode?: string(name='IspCode', description='The carrier code of the detection point.', example='465'),
    }
  ](name='IspCityNodes', description='The list of detection points. Call [ListCloudGtmMonitorNodes](https://help.aliyun.com/document_detail/2797327.html) to obtain the information.'),
