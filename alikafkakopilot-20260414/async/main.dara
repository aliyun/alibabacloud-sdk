  @handler.validateRequestModel(request);
  return @handler.do('RPC', 'KopilotChatStream', 'POST', '/', 'json', false, 'json', request);
}

function kopilotChatStreamWithResponseIterable(request: KopilotChatStreamRequest): iterator[KopilotChatStreamResponseBody] {
  @handler.validateRequestModel(request);
  yield @handler.doSSERequest('SSE', 'KopilotChatStream', 'POST', '/', 'json', false, 'json', request);
}

