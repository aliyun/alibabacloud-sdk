  messageId?: string(name='MessageId', example='4b209618fd066c4354037b4b0634ffc9'),
  requestId?: string(name='RequestId', example='76E1F1AA-6046-5074-96E2-79A37AFBD2FA'),
  role?: string(name='Role', example='assistant'),
  runId?: string(name='RunId', example='5737d000********'),
  threadId?: string(name='ThreadId', example='thread_abc123xyz'),
  toolCallId?: string(name='ToolCallId', example='call_xyz789012'),
  toolCallName?: string(name='ToolCallName', example='search_knowledge_base'),
  type?: string(name='Type', example='delta'),
