model KopilotChatStreamRequest {
  message?: string(name='Message', example='hello', position='Query'),
  regionId: string(name='RegionId', description='This parameter is required.', example='cn-beijing', position='Query'),
  sessionId?: string(name='SessionId', example='efff104e-c0b1-4005-8c73-*********', position='Query'),
}

model KopilotChatStreamResponseBody = {
  content?: string(name='Content', example='test'),
  delta?: string(name='Delta', example='hello'),
