  snapshot?: {
    partitions?: map[string]FeatureViewConfigValueSnapshotPartitionsValue(name='Partitions', description='The partition configuration for the snapshot.'),
    table?: string(name='Table', description='The name of the snapshot table.', example='table_name'),
