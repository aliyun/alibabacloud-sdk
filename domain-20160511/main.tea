model QueryDomainListRequest {
  deadEndDate?: long(name='DeadEndDate', description='The end of the time range to query based on the time when domain names expire.', example='1696435200000'),
  deadStartDate?: long(name='DeadStartDate', description='The beginning of the time range to query based on the time when domain names expire.', example='1694016000000'),
  domainName?: string(name='DomainName', description='The domain name.', example='test003.cn'),
  domainType?: string(name='DomainType', description='The type of the domain name. Valid values:

GUOJI, TONGYONG, GUONEI, NAME, and WEIBO.', example='GUONEI'),
  endDate?: string(name='EndDate', description='The end of the time range to query based on the time when domain names expire.', example='2023-01-11 00:00:00'),
