}

model BatchPeekMessageRequest {
  numOfMessages?: int32(name='numOfMessages', example='16'),
  peekonly?: boolean(name='peekonly'),
}

model BatchPeekMessageResponseBody = {
  messages?: [ 
    {
      dequeueCount?: long(name='DequeueCount', example='5'),
      enqueueTime?: long(name='EnqueueTime', example='1250700979248'),
      firstDequeueTime?: long(name='FirstDequeueTime', example='1250700979348'),
      messageBody?: string(name='MessageBody', example='This is a test message'),
      messageBodyMD5?: string(name='MessageBodyMD5', example='F9360F391579E71CA77BC5D50242****'),
      messageGroupId?: string(name='MessageGroupId', example='test-group'),
      messageId?: string(name='MessageId', example='C0A80255D7D1163042EA3F2814D055F1'),
      priority?: long(name='Priority', example='1'),
      userProperties?: map[string]MessagesUserPropertiesValue(name='UserProperties', example='{"properties1":"value"}'),
    }
  ](name='Messages'),
}

model BatchPeekMessageResponse = {
  headers?: map[string]string(name='headers'),
  statusCode?: int32(name='statusCode'),
  body?: BatchPeekMessageResponseBody(name='body'),
}

/**
 * @summary 批量查看消息
 *
 * @description ## 请求说明
 * - 该接口用于批量查看指定队列中的消息，一次最多可以查看16条消息。
 * - 使用此接口不会改变消息的状态，消息仍保持为Active状态。
 * - 不支持长轮询功能。
 * - 需要提供`queueName`作为路径参数，并通过查询参数设置`peekonly=true`及指定要查看的消息数量`numOfMessages`（范围在1到16之间）。
 * - 成功响应将返回一个包含所请求消息详细信息的数组，包括但不限于消息ID、正文、入队时间等。
 * - 如果指定的队列不存在或队列中没有可见消息，则会返回相应的错误码。
 *
 * @param request BatchPeekMessageRequest
 * @param headers map
 * @param runtime runtime options for this request RuntimeOptions
 * @return BatchPeekMessageResponse
 */
@context("batchPeekMessageWithContext")
async function batchPeekMessageWithOptions(queueName: string, request: BatchPeekMessageRequest, headers: map[string]string, runtime: $RuntimeOptions): BatchPeekMessageResponse {
  request.validate();
  var query : map[string]any = {};
  if (!$isNull(request.numOfMessages)) {
    query['numOfMessages'] = request.numOfMessages;
  }
  if (!$isNull(request.peekonly)) {
    query['peekonly'] = request.peekonly;
  }

  var req = new OpenApiUtil.OpenApiRequest{ 
    headers = headers,
    query = OpenApiUtil.query(query),
  };
  var params = new OpenApiUtil.Params{
    action = 'BatchPeekMessage',
    version = '2026-04-09',
    protocol = 'HTTPS',
    pathname = `/queues/${queueName}/messages`,
    method = 'GET',
    authType = 'AK',
    style = 'ROA',
    reqBodyType = 'json',
    bodyType = 'json',
  };
  return execute(params, req, runtime);
}

/**
 * @summary 批量查看消息
