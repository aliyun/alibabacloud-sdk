}

model BatchReceiveMessageRequest {
  numOfMessages?: int32(name='numOfMessages', example='10'),
  waitseconds?: int32(name='waitseconds', example='0'),
}

model BatchReceiveMessageResponseBody = {
  messages?: [ 
    {
      dequeueCount?: long(name='DequeueCount', example='1'),
      enqueueTime?: long(name='EnqueueTime', example='1250700979348'),
      firstDequeueTime?: long(name='FirstDequeueTime', example='1250700979348'),
      messageBody?: string(name='MessageBody', example='This is test message 1.'),
      messageBodyMD5?: string(name='MessageBodyMD5', example='C5DD56A39F5F7BB8B3337C6D11B6D8BE'),
      messageGroupId?: string(name='MessageGroupId', example='test-group'),
      messageId?: string(name='MessageId', example='5F290C926D472878214D9529A8FA200000001'),
      nextVisibleTime?: long(name='NextVisibleTime', example='1250700979348'),
      priority?: long(name='Priority', example='1'),
      receiptHandle?: string(name='ReceiptHandle', example='1-ODU4OTkzNDU5My0xNDMyNzI3ODI3LTItOA=='),
      userProperties?: map[string]MessagesUserPropertiesValue(name='UserProperties', example='{"properties1":"value"}'),
    }
  ](name='Messages'),
}

model BatchReceiveMessageResponse = {
  headers?: map[string]string(name='headers'),
  statusCode?: int32(name='statusCode'),
  body?: BatchReceiveMessageResponseBody(name='body'),
}

/**
 * @summary 批量消费消息
 *
 * @description ## 请求说明
 * - 该操作会将取得的消息状态变为 Inactive，Inactive 持续时间由队列属性 `VisibilityTimeout` 决定。
 * - 消费者需在 VisibilityTimeout 时间内调用 DeleteMessage 删除消息，否则消息会重新变为 Active。
 * - 支持长轮询（Long Polling）：设置 `waitseconds > 0` 后，若队列为空则等待至有消息到达或超时返回。
 * >Notice: 进入长轮询后，建议您降低外部调用长轮询的并发数，选择合适的长轮询时间。目前服务端会根据长轮询数量、长轮询等待时间、访问 IP 数量等因素动态调整长轮询防攻击的并发上限值。当队列无消息时，超过长轮询上限值的请求将无法被监听到，并直接返回 404 MessageNotExist（按请求量正常计费）。如果您有临时提升长轮询上限值的需求，请及时提交工单。
 *
 * @param request BatchReceiveMessageRequest
 * @param headers map
 * @param runtime runtime options for this request RuntimeOptions
 * @return BatchReceiveMessageResponse
 */
@context("batchReceiveMessageWithContext")
async function batchReceiveMessageWithOptions(queueName: string, request: BatchReceiveMessageRequest, headers: map[string]string, runtime: $RuntimeOptions): BatchReceiveMessageResponse {
  request.validate();
  var query : map[string]any = {};
  if (!$isNull(request.numOfMessages)) {
    query['numOfMessages'] = request.numOfMessages;
  }
  if (!$isNull(request.waitseconds)) {
    query['waitseconds'] = request.waitseconds;
  }

  var req = new OpenApiUtil.OpenApiRequest{ 
    headers = headers,
    query = OpenApiUtil.query(query),
  };
  var params = new OpenApiUtil.Params{
    action = 'BatchReceiveMessage',
    version = '2026-04-09',
    protocol = 'HTTPS',
    pathname = `/queues/${queueName}/messages`,
    method = 'GET',
    authType = 'AK',
    style = 'ROA',
    reqBodyType = 'json',
    bodyType = 'json',
  };
  return execute(params, req, runtime);
}

