model SendMessageRequest {
  delaySeconds?: int32(name='DelaySeconds', example='0'),
  messageBody?: string(name='MessageBody', example='"Hello MNS"'),
  messageGroupId?: string(name='MessageGroupId', example='group-123'),
  priority?: int32(name='Priority', example='2'),
  userProperties?: string(name='UserProperties', example='{"key1":"value1", "key2":"value2"}'),
}

model SendMessageResponseBody = {
  messageBodyMD5?: string(name='MessageBodyMD5'),
  messageId?: string(name='MessageId'),
  receiptHandle?: string(name='ReceiptHandle'),
}

model SendMessageResponse = {
  headers?: map[string]string(name='headers'),
  statusCode?: int32(name='statusCode'),
  body?: SendMessageResponseBody(name='body'),
}

/**
 * @summary 发送消息
 *
 * @description ## 请求说明
 * - **SendMessage** 接口用于将消息发送至指定队列。
 * - 消息可以立即被消费或通过设置 `DelaySeconds` 参数来延迟消费。
 * - 发送的消息可以指定优先级，数值越小表示优先级越高。
 * - 对于 FIFO 队列，可以通过 `MessageGroupId` 来保证同一分组内消息的顺序投递。
 * - 用户还可以自定义属性 `UserProperties`，以 JSON 格式字符串形式提供额外信息。
 * - 当 `DelaySeconds` 大于 0 时，API 返回的 `ReceiptHandle` 可用来在消息变为 Active 状态前删除该延迟消息。
 *
 * @param request SendMessageRequest
 * @param headers map
 * @param runtime runtime options for this request RuntimeOptions
 * @return SendMessageResponse
 */
@context("sendMessageWithContext")
async function sendMessageWithOptions(queueName: string, request: SendMessageRequest, headers: map[string]string, runtime: $RuntimeOptions): SendMessageResponse {
  request.validate();
  var body : map[string]any = {};
  if (!$isNull(request.delaySeconds)) {
    body['DelaySeconds'] = request.delaySeconds;
  }
  if (!$isNull(request.messageBody)) {
    body['MessageBody'] = request.messageBody;
  }
  if (!$isNull(request.messageGroupId)) {
    body['MessageGroupId'] = request.messageGroupId;
  }
  if (!$isNull(request.priority)) {
    body['Priority'] = request.priority;
  }
  if (!$isNull(request.userProperties)) {
    body['UserProperties'] = request.userProperties;
  }

  var req = new OpenApiUtil.OpenApiRequest{ 
    headers = headers,
    body = OpenApiUtil.parseToMap(body),
  };
  var params = new OpenApiUtil.Params{
    action = 'SendMessage',
    version = '2026-04-09',
    protocol = 'HTTPS',
    pathname = `/queues/${queueName}/messages`,
    method = 'POST',
    authType = 'AK',
    style = 'ROA',
    reqBodyType = 'json',
    bodyType = 'json',
  };
  return execute(params, req, runtime);
}

/**
 * @summary 发送消息
 *
 * @description ## 请求说明
 * - **SendMessage** 接口用于将消息发送至指定队列。
 * - 消息可以立即被消费或通过设置 `DelaySeconds` 参数来延迟消费。
 * - 发送的消息可以指定优先级，数值越小表示优先级越高。
 * - 对于 FIFO 队列，可以通过 `MessageGroupId` 来保证同一分组内消息的顺序投递。
 * - 用户还可以自定义属性 `UserProperties`，以 JSON 格式字符串形式提供额外信息。
 * - 当 `DelaySeconds` 大于 0 时，API 返回的 `ReceiptHandle` 可用来在消息变为 Active 状态前删除该延迟消息。
 *
 * @param request SendMessageRequest
 * @return SendMessageResponse
 */
async function sendMessage(queueName: string, request: SendMessageRequest): SendMessageResponse {
  var runtime = new $RuntimeOptions{};
  var headers : map[string]string = {};
  return sendMessageWithOptions(queueName, request, headers, runtime);
}

