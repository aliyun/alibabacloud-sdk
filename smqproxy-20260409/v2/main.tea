    protocol = 'HTTPS',
    pathname = `/queues/${queueName}/messages`,
    method = 'DELETE',
    authType = 'AK',
    style = 'ROA',
    reqBodyType = 'json',
    bodyType = 'json',
  };
  return execute(params, req, runtime);
}

