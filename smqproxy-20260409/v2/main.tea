model PublishMessageRequest {
  messageAttributes?: {
    directMail?: string(name='DirectMail', example='详见 https://help.aliyun.com/zh/direct-mail/singlesendmail'),
    directSMS?: string(name='DirectSMS', example='{"FreeSignName":"阿里云","TemplateCode":"SMS_123456","Type":"singleContent","Receiver":"13800000000","SmsParams":"{\\\\"code\\\\":\\\\"1234\\\\"}"}'),
    push?: string(name='Push', example='移动推送属性示例值'),
  }(name='MessageAttributes'),
  messageBody?: string(name='MessageBody', example='hello topic'),
  messageTag?: string(name='MessageTag', example='order-event'),
}

model PublishMessageResponseBody = {
  messageBodyMD5?: string(name='MessageBodyMD5'),
  messageId?: string(name='MessageId'),
}

model PublishMessageResponse = {
  headers?: map[string]string(name='headers'),
  statusCode?: int32(name='statusCode'),
  body?: PublishMessageResponseBody(name='body'),
}

/**
 * @summary 发布消息
 *
 * @description ## 请求说明
 * - 消息发布后会被推送到该 Topic 下所有 Subscription 的 Endpoint。
 * - 推送到 Queue 和 HTTP Endpoint 时不需要设置 `MessageAttributes`。
 * - 推送到邮件、短信或移动推送时需要设置对应的 `MessageAttributes` 子属性。
 * - 消息内容建议事先进行 Base64 编码以避免特殊字符问题。
 *
 * @param request PublishMessageRequest
 * @param headers map
 * @param runtime runtime options for this request RuntimeOptions
 * @return PublishMessageResponse
 */
@context("publishMessageWithContext")
async function publishMessageWithOptions(topicName: string, request: PublishMessageRequest, headers: map[string]string, runtime: $RuntimeOptions): PublishMessageResponse {
  request.validate();
  var body : map[string]any = {};
  if (!$isNull(request.messageAttributes)) {
    body['MessageAttributes'] = request.messageAttributes;
  }
  if (!$isNull(request.messageBody)) {
    body['MessageBody'] = request.messageBody;
  }
  if (!$isNull(request.messageTag)) {
    body['MessageTag'] = request.messageTag;
  }

  var req = new OpenApiUtil.OpenApiRequest{ 
    headers = headers,
    body = OpenApiUtil.parseToMap(body),
  };
  var params = new OpenApiUtil.Params{
    action = 'PublishMessage',
    version = '2026-04-09',
    protocol = 'HTTPS',
    pathname = `/topics/${topicName}/messages`,
    method = 'POST',
    authType = 'AK',
    style = 'ROA',
    reqBodyType = 'json',
    bodyType = 'json',
  };
  return execute(params, req, runtime);
}

/**
 * @summary 发布消息
 *
 * @description ## 请求说明
 * - 消息发布后会被推送到该 Topic 下所有 Subscription 的 Endpoint。
