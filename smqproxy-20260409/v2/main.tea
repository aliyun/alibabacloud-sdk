import GatewayClient;
import OpenApi;
import OpenApi.OpenApiUtil;

extends OpenApi;


init(config: OpenApiUtil.Config){
  super(config);
  @productId = 'SMQProxy';
  var gatewayClient = new GatewayClient();
  @spi = gatewayClient;
  @endpointRule = 'regional';
  }

model MessagesUserPropertiesValue = {
  dataType?: string(name='DataType'),
  stringValue?: string(name='StringValue'),
  binaryValue?: string(name='BinaryValue'),
}

model UserPropertiesValue = {
  dataType?: string(name='DataType'),
  stringValue?: string(name='StringValue'),
  binaryValue?: string(name='BinaryValue'),
}

model BatchDeleteMessageRequest {
  receiptHandles?: [ string ](name='ReceiptHandles'),
}

model BatchDeleteMessageResponse = {
  headers?: map[string]string(name='headers'),
  statusCode?: int32(name='statusCode'),
}

/**
 * @summary 批量删除消息
 *
 * @param request BatchDeleteMessageRequest
 * @param headers map
 * @param runtime runtime options for this request RuntimeOptions
 * @return BatchDeleteMessageResponse
 */
@context("batchDeleteMessageWithContext")
async function batchDeleteMessageWithOptions(queueName: string, request: BatchDeleteMessageRequest, headers: map[string]string, runtime: $RuntimeOptions): BatchDeleteMessageResponse {
  request.validate();
  var body : map[string]any = {};
  if (!$isNull(request.receiptHandles)) {
