model BatchSendMessageRequest {
  messages?: [ 
    {
      delaySeconds?: int32(name='DelaySeconds', example='60'),
      messageBody?: string(name='MessageBody', example='This is test message 1.'),
      messageGroupId?: string(name='MessageGroupId', example='group1'),
      priority?: int32(name='Priority', example='1'),
      userProperties?: map[string]MessagesUserPropertiesValue(name='UserProperties'),
    }
  ](name='Messages'),
}

model BatchSendMessageResponseBody = {
  messages?: [ 
    {
      messageBodyMD5?: string(name='MessageBodyMD5'),
