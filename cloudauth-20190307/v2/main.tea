  metaInfo?: string(name='MetaInfo', description='The Metainfo environment parameter, which must be obtained through the client SDK.', example='{"zimVer":"3.0.0","appVersion": "1","bioMetaInfo": "4.1.0:11501568,0","appName": "com.aliyun.antcloudauth","deviceType": "ios","osVersion": "iOS 10.3.2","apdidToken": "","deviceModel": "iPhone9,1"}'),
  mobile?: string(name='Mobile', description='The mobile phone number of the user.', example='130xxxxxxxx'),
  mode?: string(name='Mode', description='The method for obtaining passport NFC verification elements:

- **1**: user input. The end user manually enters certificate element information using the UI provided by the Alibaba Cloud SDK.

- **3**: external parameter input. Certificate element information is passed in externally.

