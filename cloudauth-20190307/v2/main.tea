  userId?: string(name='UserId', description='The custom user ID defined by the business. Keep this value unique.', example='123456789'),
  validityDate?: string(name='ValidityDate', description='The certificate expiration date.

This field is required when **CertType** is set to **PASSPORT** and **Mode** is set to **3**.', example='2039-06-10'),
  videoEvidence?: string(name='VideoEvidence', description='Specifies whether to enable video evidence:

- **true**: enabled.

- **false**: disabled (default).

