  sourceOssBucketName?: string(name='SourceOssBucketName', description='The bucket name of the authorized OSS space.

> You can use one of the following four methods to submit a face photo: FaceContrastPicture, FaceContrastPictureUrl, CertifyId, or OSS. Select one method.', example='cn-shanghai-aliyun-cloudauth-xxxxx'),
