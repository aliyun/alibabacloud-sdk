}

model CompareFacesRequest {
  sourceImageType?: string(name='SourceImageType', description='The type of image 1. Valid values:

- **FacePic**: A face photo of the user.
- **IDPic**: A headshot photo from the chip of the user\\\\"s second-generation ID card (typically read and decoded by a second-generation ID card reader device).', example='FacePic'),
