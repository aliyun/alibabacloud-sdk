  targetOssBucketName?: string(name='TargetOssBucketName', description='The bucket name of the authorized OSS space.

> You can use one of the following four methods to submit a reference face photo: FaceContrastPicture, FaceContrastPictureUrl, CertifyId, or OSS. Select one method.', example='cn-shanghai-aliyun-cloudauth-xxxxx'),
  targetOssObjectName?: string(name='TargetOssObjectName', description='The file name in the authorized OSS space.

> You can use one of the following four methods to submit a reference face photo: FaceContrastPicture, FaceContrastPictureUrl, CertifyId, or OSS. Select one method.', example='verify/xxxxx/xxxxxx.jpeg'),
}

