  greaterThanOrEqual?: int32(name='GreaterThanOrEqual', description='大于等于。', example='1'),
  lessThan?: int32(name='LessThan', description='小于。', example='1'),
  lessThanOrEqual?: int32(name='LessThanOrEqual', description='小于等于。', example='1'),
}

model WafQuotaString {
  regexp?: string(name='Regexp', description='正则表达式。', example='^\\\\d+$'),
}

