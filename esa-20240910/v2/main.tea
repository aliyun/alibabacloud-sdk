model WafTimer {
  periods?: [ 
    {
      end?: string(name='End', description='结束时间，值为RFC3339格式的UTC时间。', example='2025-01-01T01:00:00Z'),
      start?: string(name='Start', description='起始时间，值为RFC3339格式的UTC时间。', example='2025-01-01T00:00:00Z'),
    }
  ](name='Periods', description='生效时间段。'),
  scopes?: string(name='Scopes', description='定时类型：永久生效（permanent/<空>）/时间段生效（periods）/weekly（周期生效）。', example='permanent'),
  weeklyPeriods?: [ 
    {
      dailyPeriods?: [ 
        {
          end?: string(name='End', description='结束时间，格式为HH:mm:ss。', example='01:00:00'),
          start?: string(name='Start', description='起始时间，格式为HH:mm:ss。', example='00:00:00'),
        }
      ](name='DailyPeriods', description='该周期内的生效时间。'),
      days?: string(name='Days', description='周期，多个使用逗号分隔，1-7分别代表周一-周日。<br>例：周一，周三值为"1,3"。', example='1'),
    }
  ](name='WeeklyPeriods', description='每周生效时间段。'),
  zone?: int32(name='Zone', description='时区，不填则默认为UTC+00:00。<br>例：8表示东8区，-8表示西8区<br>范围：-12 - +14。', example='8'),
}

