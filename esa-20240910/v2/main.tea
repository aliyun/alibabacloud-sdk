      code?: int32(name='Code', description='The custom response code.', example='403'),
      id?: long(name='Id', description='The ID of the custom response page.', example='50000001'),
    }(name='Response', description='The custom response.'),
  }(name='Actions', description='The extended action configurations.'),
  crossSiteId?: long(name='CrossSiteId', description='Specifies the cross-domain website ID.', example='10000001'),
  expression?: string(name='Expression', description='The expression.', example='ip.src eq 1.1.1.1'),
  match?: WafRuleMatch2(name='Match', description='The matching rule.'),
  mode?: string(name='Mode', description='Web SDK integration method: automatic integration (automatic) or manual integration (manual).', example='automatic'),
  name?: string(name='Name', description='The ruleset name.', example='example'),
  target?: string(name='Target', description='Protection type: web or app.', example='web'),
}

model WafQuotaInteger {
