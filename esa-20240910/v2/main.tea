  edgeCacheTtl?: string(name='EdgeCacheTtl', description='The edge cache TTL, in seconds.', example='300'),
  edgeStatusCodeCacheTtl?: string(name='EdgeStatusCodeCacheTtl', description='The status code cache TTL, in seconds.

