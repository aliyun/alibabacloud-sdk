    bypass?: {
      customRules?: [ long ](name='CustomRules', description='The IDs of custom rules.'),
      regularRules?: [ long ](name='RegularRules', description='The IDs of managed rules.'),
      regularTypes?: [ string ](name='RegularTypes', description='The types of managed rules.'),
      skip?: string(name='Skip', description='The skip scope applied when requests match conditions defined in the whitelist rule.', example='part'),
      tags?: [ string ](name='Tags', description='The skipped rule categories when requests match conditions defined in the whitelist rule.'),
    }(name='Bypass', description='The skip configuration specified by the whitelist rule.'),
    response?: {
      code?: int32(name='Code', description='The custom response code.', example='403'),
      id?: long(name='Id', description='The ID of the custom error page, which can be obtained by calling the [ListPages](https://help.aliyun.com/document_detail/2850223.html) operation.', example='50000001'),
    }(name='Response', description='The custom error page.'),
  }(name='Actions', description='The extended action configurations.'),
  appPackage?: {
    packageSigns?: [ 
      {
        name?: string(name='Name', description='The valid package name.', example='name'),
        sign?: string(name='Sign', description='The valid package signature.', example='sign'),
      }
    ](name='PackageSigns', description='The package signatures.'),
  }(name='AppPackage', description='The configuration of secondary package detection.'),
  appSdk?: {
    customSign?: {
      key?: string(name='Key', description='The field name.', example='sign'),
      value?: string(name='Value', description='The field value.', example='examplesignvalue'),
    }(name='CustomSign', description='The custom signature field.'),
    customSignStatus?: string(name='CustomSignStatus', description='Indicates whether to configure the custom signature field.', example='on'),
    featureAbnormal?: [ string ](name='FeatureAbnormal', description='The app anomalies.'),
  }(name='AppSdk', description='The SDK configuration for apps.'),
  expression?: string(name='Expression', description='The match expression.', example='ip.src eq 1.1.1.1'),
  id?: long(name='Id', description='The ID of the WAF rule.', example='20000001'),
  managedGroupId?: long(name='ManagedGroupId', description='The ID of the managed rule group, which is deprecated.', example='30000001'),
  managedList?: string(name='ManagedList', description='The managed list.', example='intelligence_crawler'),
  managedRulesets?: [ 
    {
      action?: string(name='Action', description='The action.', example='deny'),
      attackType?: int32(name='AttackType', description='The attack type.', example='11'),
      managedRules?: [ 
        {
          action?: string(name='Action', description='The action performed on requests that match the managed rule.', example='deny'),
          id?: long(name='Id', description='The ID of the managed rule.', example='100001'),
          status?: string(name='Status', description='The status of the managed rule.', example='on'),
        }
      ](name='ManagedRules', description='The managed rules.'),
      numberEnabled?: int32(name='NumberEnabled', description='The number of enabled rules.', example='50'),
      numberTotal?: int32(name='NumberTotal', description='The total number of rules.', example='100'),
      protectionLevel?: int32(name='ProtectionLevel', description='The protection level.', example='4'),
    }
  ](name='ManagedRulesets', description='The managed rulesets.'),
  name?: string(name='Name', description='The name of the WAF rule.', example='example'),
  notes?: string(name='Notes', description='The remarks.', example='example notes'),
  rateLimit?: {
    characteristics?: WafRatelimitCharacteristics(name='Characteristics', description='The statistical objects to which the rule applies.'),
    interval?: int32(name='Interval', description='The statistical interval.', example='10'),
    onHit?: boolean(name='OnHit', description='Indicates whether to apply the rule to requests that hit the cache.', example='true'),
    TTL?: int32(name='TTL', description='The timeout period for creating the stack.', example='10'),
    threshold?: {
      distinctManagedRules?: int32(name='DistinctManagedRules', description='The maximum number of managed rules that are triggered.', example='10'),
      managedRulesBlocked?: int32(name='ManagedRulesBlocked', description='The maximum number of times that the managed rule is triggered.', example='10'),
      request?: int32(name='Request', description='The request threshold.', example='10'),
      responseStatus?: {
        code?: int32(name='Code', description='The HTTP status code.', example='404'),
        count?: int32(name='Count', description='The maximum number of times that the status code is returned.', example='10'),
        ratio?: int32(name='Ratio', description='The percentage of the occurrences of the status code to total status codes.', example='10'),
      }(name='ResponseStatus', description='The configuration of the status code threshold.'),
      traffic?: string(name='Traffic', description='The traffic threshold, which is deprecated.', example='10Gb'),
    }(name='Threshold', description='The thresholds.'),
  }(name='RateLimit', description='The configuration of the rate limiting rule.'),
  securityLevel?: {
    value?: string(name='Value', description='Valid value:

*   off
*   essentially_off
*   low
*   medium
*   high
*   under_attack', example='low'),
  }(name='SecurityLevel', description='The security level.'),
  sigchl?: [ string ](name='Sigchl', description='The token verification configurations.'),
  status?: string(name='Status', description='The status of the WAF rule.', example='on'),
  timer?: WafTimer(name='Timer', description='The timer.'),
  type?: string(name='Type', description='The name of the WAF rule.', example='http_custom'),
  value?: string(name='Value', description='Defines whether the IP can access.', example='10.0.0.1'),
}

