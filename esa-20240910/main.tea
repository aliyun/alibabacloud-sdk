  edgeCacheTtl?: string(name='EdgeCacheTtl', description='The edge node cache TTL (Time to Live), in seconds.', example='300'),
  edgeStatusCodeCacheTtl?: string(name='EdgeStatusCodeCacheTtl', description='The cache TTL for specific status codes, in seconds.

