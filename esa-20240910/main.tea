      FCP?: float(name='FCP', description='The time from when the page starts loading to when any part of the page content is rendered on the screen. Unit: ms.', example='123'),
      FID?: float(name='FID', description='The time from when a user first interacts with a page to when the browser is actually able to begin processing event handlers in response to that interaction. Unit: ms.', example='123'),
      INP?: float(name='INP', description='The responsiveness of a page, specifically how long it takes for the page to visibly respond to user input. Unit: ms.', example='123'),
