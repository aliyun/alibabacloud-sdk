model CreateCacheRuleRequest {
  additionalCacheablePorts?: string(name='AdditionalCacheablePorts', description='- Specifies additional ports on which caching is enabled.

- Valid values: 8880, 2052, 2082, 2086, 2095, 2053, 2083, 2087, and 2096.

