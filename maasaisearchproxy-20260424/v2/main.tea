 */
@context("openDatasetImportDataWithContext")
async function openDatasetImportDataWithOptions(request: OpenDatasetImportDataRequest, headers: map[string]string, runtime: $RuntimeOptions): OpenDatasetImportDataResponse {
  request.validate();
  var body : map[string]any = {};
  if (!$isNull(request.datasetId)) {
    body['datasetId'] = request.datasetId;
  }
