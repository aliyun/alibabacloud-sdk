/**
 *
 */
import OpenApi;
import OpenApi.OpenApiUtil;

extends OpenApi;


init(config: OpenApiUtil.Config){
  super(config);
  @endpointRule = 'regional';
  @endpointMap = {
    'cn-hangzhou' = 'computenest.cn-hangzhou.aliyuncs.com',
    'ap-southeast-1' = 'computenest.ap-southeast-1.aliyuncs.com',
  };

  checkConfig(config);
  @endpoint = getEndpoint('computenest', @regionId, @endpointRule, @network, @suffix, @endpointMap, @endpoint);
}

function getEndpoint(productId: string, regionId: string, endpointRule: string, network: string, suffix: string, endpointMap: map[string]string, endpoint: string) throws: string{
  if (!$isNull(endpoint)) {
    return endpoint;
  }
  
  if (!$isNull(endpointMap) && !$isNull(endpointMap[regionId])) {
    return endpointMap[regionId];
  }
  return OpenApiUtil.getEndpointRules(productId, regionId, endpointRule, network, suffix);
}

model CommodityValue = {
  result?: {
    order?: {
      currency?: string(name='Currency', description='The currency code.', example='CNY'),
      tradeAmount?: string(name='TradeAmount', description='The amount after the discount is applied.', example='9.99'),
      discountAmount?: string(name='DiscountAmount', description='The discount amount.', example='1.99'),
      originalAmount?: string(name='OriginalAmount', description='The original amount.', example='11.98'),
    }(name='Order', description='The order information.'),
    inquiryType?: string(name='InquiryType', description='The inquiry type. Valid values:

1. Buy: an inquiry for a new purchase.

2. ModificationBuy: an inquiry for an upgrade or downgrade.', example='Buy'),
    subOrders?: {
      subOrder?: [ 
        {
          moduleInstance?: [ 
            {
              moduleId?: long(name='ModuleId', description='The module ID.', example='1234'),
              moduleName?: string(name='ModuleName', description='The module name.', example='数据库类型'),
              moduleCode?: string(name='ModuleCode', description='The module code.', example='rds_dbtype'),
              totalProductFee?: double(name='TotalProductFee', description='The original price of the product, in CNY.', example='10.00'),
              discountFee?: double(name='DiscountFee', description='The discount, in CNY.', example='1.99'),
              payFee?: double(name='PayFee', description='The amount payable, in CNY.', example='8.01'),
              priceUnit?: string(name='PriceUnit', description='The unit of the price.', example='元/GB/小时'),
              isPricingModule?: boolean(name='IsPricingModule', description='Indicates whether the module is a billing item.', example='true'),
              needOrderPay?: boolean(name='NeedOrderPay', description='Indicates whether payment is required for the module in the order.', example='true'),
              priceType?: string(name='PriceType', description='The pricing type.', example='hourPrice'),
              moduleAttrs?: [ 
                {
                  type?: long(name='Type', description='The attribute type. Valid values:

1. 1: product attribute

2. 2: specification attribute

3. 3: module attribute

4. 4: external parameter (reserved)', example='3'),
                  name?: string(name='Name', description='The attribute name.', example='20GB'),
                  code?: string(name='Code', description='The attribute code.', example='rds_storage'),
                  value?: string(name='Value', description='The attribute value.', example='20'),
                  unit?: string(name='Unit', description='The unit of the value.', example='GB'),
                }
              ](name='ModuleAttrs', description='The module attributes.'),
              moduleNameEn?: string(name='ModuleNameEn', description='The English name of the module.', example='数据单元'),
              priceUnitEn?: string(name='PriceUnitEn', description='The English name of the price unit.', example='元/月'),
            }
          ](name='ModuleInstance', description='The module or instance information.'),
        }
      ](name='SubOrder', description='The sub-orders.'),
    }(name='SubOrders', description='The sub-orders.'),
    coupons?: [ 
      {
        canPromFee?: double(name='CanPromFee', description='The payable amount.', example='9.99'),
        couponDesc?: string(name='CouponDesc', description='The description of the coupon.', example='10元优惠券（有效期至2024年9月8日）'),
        couponName?: string(name='CouponName', description='The name of the coupon.', example='10元优惠券'),
        couponOptionNo?: string(name='CouponOptionNo', description='The coupon number.', example='50008800000xxxx'),
        selected?: boolean(name='Selected', description='Indicates whether the coupon is selected.', example='true'),
      }
    ](name='Coupons', description='The coupons.'),
  }(name='Result', description='The Result model.'),
}

