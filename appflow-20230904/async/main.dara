}

function invokeActionWithResponseIterable(request: InvokeActionRequest): iterator[InvokeActionResponseBody] {
  @handler.validateRequestModel(request);
  yield @handler.doSSERequest('SSE', 'InvokeAction', 'POST', '/', 'json', false, 'json', request);
