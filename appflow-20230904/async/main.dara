  connectorId: string(name='ConnectorId', description='This parameter is required.', example='connector-xxx', position='Query'),
  connectorVersion?: string(name='ConnectorVersion', example='1', position='Query'),
  headers?: map[string]string(name='Headers', shrink='json', position='Query'),
