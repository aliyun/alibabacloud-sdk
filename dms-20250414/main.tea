/**
 *
 */
import Util;
import OpenApi;
import OpenApiUtil;
import EndpointUtil;

extends OpenApi;


init(config: OpenApi.Config){
  super(config);
  @endpointRule = 'regional';
  @endpointMap = {
    'us-west-1' = 'dms.us-west-1.aliyuncs.com',
    'us-east-1' = 'dms.us-east-1.aliyuncs.com',
    'cn-shenzhen' = 'dms.cn-shenzhen.aliyuncs.com',
    'cn-shanghai' = 'dms.cn-shanghai.aliyuncs.com',
    'cn-hongkong' = 'dms.cn-hongkong.aliyuncs.com',
    'cn-hangzhou' = 'dms.cn-hangzhou.aliyuncs.com',
    'cn-beijing' = 'dms.cn-beijing.aliyuncs.com',
    'ap-southeast-1' = 'dms.ap-southeast-1.aliyuncs.com',
  };

  checkConfig(config);
  @endpoint = getEndpoint('dms', @regionId, @endpointRule, @network, @suffix, @endpointMap, @endpoint);
}

function getEndpoint(productId: string, regionId: string, endpointRule: string, network: string, suffix: string, endpointMap: map[string]string, endpoint: string) throws: string{
  if (!Util.empty(endpoint)) {
    return endpoint;
  }
  
  if (!Util.isUnset(endpointMap) && !Util.empty(endpointMap[regionId])) {
    return endpointMap[regionId];
  }
  return EndpointUtil.getEndpointRules(productId, regionId, endpointRule, network, suffix);
}

model AgentServiceOrderSummaryVO {
  agentService?: string(name='AgentService', description='The name of the agent service.'),
  deepResearchQuota?: long(name='DeepResearchQuota', description='The deep research quota for the service.'),
  modelCallQuota?: long(name='ModelCallQuota', description='The model call quota for the service.'),
  orderCount?: int32(name='OrderCount', description='The order count for the agent service.'),
  serviceNumTotal?: int32(name='ServiceNumTotal', description='The total number of services.'),
  skillPlanCallQuota?: long(name='SkillPlanCallQuota', description='The skill plan call quota for the service.'),
}

model AgentServiceOrderVO {
  agentService?: string(name='AgentService', description='The agent service.'),
  deepResearchQuota?: int32(name='DeepResearchQuota', description='The deep research quota.'),
  deepResearchUsed?: int32(name='DeepResearchUsed', description='The quantity of deep research used.'),
  expireTime?: string(name='ExpireTime', description='The service expiration time, specified in UTC.'),
  gmtCreate?: string(name='GmtCreate', description='The order creation time, specified in UTC.'),
  gmtModified?: string(name='GmtModified', description='The order modification time, specified in UTC.'),
  modelCallQuota?: int32(name='ModelCallQuota', description='The model call quota.'),
  modelCallUsed?: int32(name='ModelCallUsed', description='The number of model calls used.'),
  orderInstanceId?: string(name='OrderInstanceId', description='The order instance ID.'),
  serviceNum?: int32(name='ServiceNum', description='The number of services.'),
  skillPlanCallQuota?: int32(name='SkillPlanCallQuota', description='The skill plan call quota.'),
  skillPlanCallUsed?: int32(name='SkillPlanCallUsed', description='The number of skill plan calls used.'),
  status?: string(name='Status', description='The order status.'),
}

model AgenticCatalog {
  catalogBizAttrs?: map[string]any(name='CatalogBizAttrs', description='A collection of key-value pairs that represents business attributes for the catalog, such as the data owner or department.'),
  catalogType?: string(name='CatalogType', description='The type of the catalog. For example, `INTERNAL_METADATA` or `THIRD_PARTY`.'),
  catalogUuid?: string(name='CatalogUuid', description='The unique identifier (UUID) of the catalog. This parameter is system-generated and output-only.'),
  dataSourceType?: string(name='DataSourceType', description='The type of the data source associated with the catalog. For example, `MySQL`, `PostgreSQL`, or `OSS`.'),
  dataSourceUuid?: string(name='DataSourceUuid', description='The unique identifier (UUID) of the associated data source.'),
  description?: string(name='Description', description='The description of the catalog. It can be up to 2,048 characters long.'),
  name?: string(name='Name', description='The display name of the catalog. The name can be up to 256 characters long.'),
  properties?: map[string]any(name='Properties', description='A collection of key-value pairs that represents additional technical properties for the catalog.'),
  regionId?: string(name='RegionId', description='The ID of the region where the catalog is located. For example, `cn-hangzhou`.'),
  state?: int32(name='State', description='The current state of the catalog. Valid values are: `0` (Creating), `1` (Active), `2` (Deleting), and `3` (Error).'),
  storageLocation?: string(name='StorageLocation', description='The storage location for the catalog\\\\"s metadata, such as a database name or a file path.'),
}

