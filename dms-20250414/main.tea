  location?: string(name='Location', description='The storage path of the table.', example='oss://xxx'),
  modifierId?: long(name='ModifierId', description='The user who last modified the table.', example='1410769'),
  name?: string(name='Name', description='The name of the table.', example='100g_customer'),
  owner?: string(name='Owner', description='The name of the table owner.', example='zhangsan'),
  ownerType?: string(name='OwnerType', description='The type of the owner. Valid values: USER, ROLE, and GROUP.', example='USER'),
