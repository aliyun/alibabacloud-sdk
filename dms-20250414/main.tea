model AgenticTableColumnEngineMeta {
  autoIncrement?: boolean(name='AutoIncrement', description='Indicates whether the column uses auto-increment.'),
  dataLength?: long(name='DataLength', description='The data length of the column. This parameter typically applies to string and binary data types.'),
  dataPrecision?: int32(name='DataPrecision', description='The data precision of the column, which is the total number of digits in a numeric type.'),
  dataScale?: int32(name='DataScale', description='The data scale of the column, which is the number of digits to the right of the decimal point in a numeric type.'),
  defaultValue?: string(name='DefaultValue', description='The default value of the column.'),
  encoding?: string(name='Encoding', description='The character encoding of the column.'),
  extra?: string(name='Extra', description='Engine-specific attributes or flags for the column.'),
  generationColumn?: boolean(name='GenerationColumn', description='Indicates whether the column is a generated column.'),
  generationExpression?: string(name='GenerationExpression', description='The expression used to generate the column\\\\"s value. Applies only if `GenerationColumn` is `true`.'),
  nullable?: boolean(name='Nullable', description='Indicates whether the column is nullable.'),
}

