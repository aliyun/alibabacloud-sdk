  databaseUuid?: string(name='DatabaseUuid', description='The unique identifier (UUID) of the database that contains the object.'),
  ddlSql?: string(name='DdlSql', description='The Data Definition Language (DDL) SQL statement that defines the object\\\\"s structure.'),
  objectName?: string(name='ObjectName', description='The name of the database object, such as a table, view, or index.'),
