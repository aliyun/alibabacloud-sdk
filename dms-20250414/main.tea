  ](name='PartitionKeys', description='The list of partition keys.'),
  retention?: int32(name='Retention', description='The retention period of the table.', example='300'),
  storageDescriptor?: DLStorageDescriptor(name='StorageDescriptor', description='The storage description, including the storage features and format details of the table.'),
  tableType?: string(name='TableType', description='The type of the metadata table, such as MANAGED_TABLE, EXTERNAL_TABLE, VIRTUAL_VIEW, INDEX_TABLE, or MATERIALIZED_VIEW.', example='EXTERNAL_TABLE'),
  viewExpandedText?: string(name='ViewExpandedText', description='The expanded text of the view if the table is a view.', example='""'),
  viewOriginalText?: string(name='ViewOriginalText', description='The original text of the view if the table is a view.', example='""'),
}

