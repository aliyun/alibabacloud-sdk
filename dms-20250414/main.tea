  engine?: string(name='Engine', description='The table\\\\"s storage engine, such as `InnoDB`.'),
  fullChecksum?: string(name='FullChecksum', description='A checksum of the table\\\\"s data and indexes.'),
  indexBytes?: long(name='IndexBytes', description='The total size of the table\\\\"s indexes, in bytes.'),
  lastDdlTime?: string(name='LastDdlTime', description='The timestamp of the last DDL (Data Definition Language) operation, in UTC format (`YYYY-MM-DDThh:mm:ssZ`).'),
  numRows?: long(name='NumRows', description='The number of rows in the table.'),
  refInfo?: string(name='RefInfo', description='The table\\\\"s reference information.'),
  storageCapacity?: long(name='StorageCapacity', description='The table\\\\"s total storage capacity, in bytes.'),
  tableSchemaName?: string(name='TableSchemaName', description='The name of the table schema.'),
}

model AgenticTableIndex {
  columnNames?: [ string ](name='ColumnNames', description='An array of column names included in the index.'),
  description?: string(name='Description', description='An optional, user-defined description for the index.'),
  indexName?: string(name='IndexName', description='The unique name of the index within the table.'),
  indexType?: string(name='IndexType', description='The type of the index, such as PRIMARY, UNIQUE, or NORMAL.'),
  primary?: boolean(name='Primary', description='Specifies if the index is the primary key. A table can have only one primary key.'),
  realColumnNames?: [ string ](name='RealColumnNames', description='An array of physical column names from the database. Use this parameter when the names in ColumnNames are aliases or logical names.'),
  unique?: boolean(name='Unique', description='Specifies if the index enforces a unique constraint, requiring all its values to be unique across rows.'),
}

