}

model DLSerdeInfo {
  description?: string(name='Description', description='The description of the serialization.', example='"serialize"'),
  deserializerClass?: string(name='DeserializerClass', description='The name of the class used for deserialization.', example='org.apache.hadoop.hive.serde2.OpenCSVSerde'),
  name?: string(name='Name', description='The name of the serialization.', example='name'),
  parameters?: map[string]any(name='Parameters', description='The key-value pairs of parameters related to serialization.', example='{
  "serialization.format": "1"
}'),
  serdeType?: int32(name='SerdeType', description='The type of serialization.', example='0'),
  serializationLib?: string(name='SerializationLib', description='The class name of the serialization library.', example='org.apache.hadoop.hive.serde2.lazy.LazySimpleSerDe'),
  serializerClass?: string(name='SerializerClass', description='The name of the class used for serialization.', example='org.apache.hadoop.hive.serde2.lazy.LazySimpleSerDe'),
}

model DLSkewedInfo {
  skewedColNames?: [ string ](name='SkewedColNames', description='A list of skewed column names.'),
  skewedColValueLocationMaps?: map[string]any(name='SkewedColValueLocationMaps', description='A mapping of skewed column values to their locations.', example='{“col1”:"val1"}'),
  skewedColValues?: [[ string ]  ](name='SkewedColValues', description='A list of skewed column values. Each list provides a set of associated values.'),
}

model DLStorageDescriptor {
  bucketCols?: [ string ](name='BucketCols', description='A list of bucket column names that determine the hash distribution of the data.'),
  columns?: [
    DLColumn
  ](name='Columns', description='The description of the data columns in the table.'),
  inputFormat?: string(name='InputFormat', description='The name of the input format class used to read data.', example='org.apache.hadoop.mapred.SequenceFileInputFormat'),
  isCompressed?: boolean(name='IsCompressed', description='Specifies whether the data is compressed.', example='false'),
  location?: string(name='Location', description='The specific location of the data storage.', example='oss://xxx'),
  numBuckets?: int32(name='NumBuckets', description='The number of buckets.', example='-1'),
  originalColumns?: [
    DLColumn
  ](name='OriginalColumns', description='The description of the original columns.'),
  outputFormat?: string(name='OutputFormat', description='The name of the output format class used to write data.', example='org.apache.hadoop.hive.ql.io.HiveSequenceFileOutputFormat'),
  parameters?: map[string]any(name='Parameters', description='Other parameter mappings for data storage.', example='key/value'),
  serdeInfo?: DLSerdeInfo(name='SerdeInfo', description='The serialization and deserialization information.'),
  skewedInfo?: DLSkewedInfo(name='SkewedInfo', description='The data structure that stores information about skewed columns.'),
  sortCols?: [
    DLOrder
  ](name='SortCols', description='The description of the sorted columns.'),
}

