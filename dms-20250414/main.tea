  checksum?: string(name='Checksum', description='A checksum to verify the table\\\\"s data integrity.'),
  createTime?: string(name='CreateTime', description='The time the table was created, in UTC format (`YYYY-MM-DDThh:mm:ssZ`).'),
  dataBytes?: long(name='DataBytes', description='The total size of the table\\\\"s data, in bytes.'),
