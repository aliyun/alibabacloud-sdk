model AddUserToDataAgentWorkspaceRequest {
  DMSUnit?: string(name='DMSUnit', example='cn-hangzhou', position='Query'),
  memberId?: string(name='MemberId', example='20282*****7591', position='Query'),
  roleName?: string(name='RoleName', example='admin', position='Query'),
  workspaceId?: string(name='WorkspaceId', example='20923*****7291', position='Query'),
}

model AddUserToDataAgentWorkspaceResponseBody = {
  data?: {
    joinTime?: long(name='JoinTime', example='1765960516'),
    memberId?: string(name='MemberId', example='20282*****7591'),
    roleName?: string(name='RoleName', example='admin'),
    runningTaskNumber?: long(name='RunningTaskNumber', example='2'),
    totalTaskNumber?: long(name='TotalTaskNumber', example='5'),
    userName?: string(name='UserName', example='agentTest'),
  }(name='Data'),
  errorCode?: string(name='ErrorCode', example='DMS-DA-40114'),
  errorMessage?: string(name='ErrorMessage', example='Specified parameter is not valid.'),
  requestId?: string(name='RequestId', example='67E910F2-***-695C'),
  success?: boolean(name='Success', example='true'),
}

model AddUserToDataAgentWorkspaceResponse = {
  headers?: map[string]string(name='headers'),
  statusCode?: int32(name='statusCode'),
  body?: AddUserToDataAgentWorkspaceResponseBody(name='body'),
}

/**
  * @param request  the request parameters of AddUserToDataAgentWorkspace  AddUserToDataAgentWorkspaceRequest
  * @return AddUserToDataAgentWorkspaceResponse
 */
async function addUserToDataAgentWorkspace(request: AddUserToDataAgentWorkspaceRequest): AddUserToDataAgentWorkspaceResponse {
  @handler.validateRequestModel(request);
  return @handler.do('RPC', 'AddUserToDataAgentWorkspace', 'POST', '/', 'json', false, 'json', request);
}

