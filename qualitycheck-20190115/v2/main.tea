  checkNumber?: long(name='CheckNumber', description='The number of checked sessions.', example='1'),
  comments?: string(name='Comments', description='The comments.', example='测试'),
  createEmpName?: string(name='CreateEmpName', description='The name of the creator.', example='张三'),
  createEmpid?: string(name='CreateEmpid', description='The employee ID of the creator.', example='1'),
  createTime?: string(name='CreateTime', description='The creation time.', example='1615133575000'),
  deny?: int32(name='Deny', description='You can set this parameter to 1 to reject rule edits, or to 0 or null to allow rule edits.', example='1'),
  effective?: int32(name='Effective', description='Indicates if the rule is active. \\\\`0\\\\`: No. \\\\`1\\\\`: Yes.', example='1'),
  effectiveEndTime?: string(name='EffectiveEndTime', description='The effective end time.', example='1662685868850'),
  effectiveStartTime?: string(name='EffectiveStartTime', description='The effective start time.', example='1662685868850'),
  endTime?: string(name='EndTime', description='The end time.', example='1650092585176'),
  fullCycle?: int32(name='FullCycle', description='Indicates if the rule is active for the entire lifecycle. \\\\`0\\\\`: No. \\\\`1\\\\`: Yes.', example='1'),
  graphFlow?: any(name='GraphFlow', description='The flow canvas, in JSON format.', example='较复杂，忽略'),
  hitNumber?: long(name='HitNumber', description='The number of hit sessions.', example='1'),
  hitRate?: float(name='HitRate', description='The hit rate.', example='1'),
  hitRealViolationRate?: float(name='HitRealViolationRate', description='The hit rate of actual violations.', example='1'),
  isDelete?: int32(name='IsDelete', description='Indicates if the rule is deleted.', example='1'),
  isSelect?: boolean(name='IsSelect', description='Indicates if the rule is selected.', example='true'),
  jobName?: string(name='JobName', description='The scheduled task name.', example='job-1-20221012-105943'),
  lastUpdateEmpName?: string(name='LastUpdateEmpName', description='The name of the user who last updated the rule.', example='张三'),
  lastUpdateEmpid?: string(name='LastUpdateEmpid', description='The employee ID of the user who last updated the rule.', example='1'),
  lastUpdateTime?: string(name='LastUpdateTime', description='The last update time.', example='1648200901000'),
  name?: string(name='Name', description='The rule name.', example='0801转封装测试'),
  operationMode?: int32(name='OperationMode', description='The operation mode.', example='1'),
  preReviewNumber?: long(name='PreReviewNumber', description='The number of items pending review.', example='1'),
  problemNumber?: long(name='ProblemNumber', description='The number of problems found.', example='1'),
  qualityCheckType?: int32(name='QualityCheckType', description='The quality check type.

- 0: Offline

- 1: Real-time', example='1'),
  realViolationNumber?: int32(name='RealViolationNumber', description='The number of actual violations after review.', example='1'),
  reviewAccuracyRate?: float(name='ReviewAccuracyRate', description='The review accuracy rate.', example='1'),
  reviewNumber?: long(name='ReviewNumber', description='The number of reviewed items.', example='1'),
  reviewRate?: float(name='ReviewRate', description='The review rate.', example='1'),
  reviewStatusName?: string(name='ReviewStatusName', description='The review status name.', example='通过'),
  rid?: long(name='Rid', description='The rule ID.', example='123'),
  ruleScoreSingleType?: int32(name='RuleScoreSingleType', description='The scoring type. \\\\`8\\\\`: No score is set.', example='1'),
  ruleScoreType?: int32(name='RuleScoreType', description='Specifies if a score is calculated.

- 1: No

- 3: Yes', example='1'),
  ruleType?: int32(name='RuleType', description='The rule origin. For example, a built-in rule or a user-created rule.', example='1'),
  scoreSubId?: long(name='ScoreSubId', description='The sub-item ID.', example='1'),
  startTime?: string(name='StartTime', description='The start time.', example='1662685868850'),
  status?: int32(name='Status', description='The status of the rule.

- 0: Pending

- 1: Active

- 2: Expired', example='1'),
  targetType?: int32(name='TargetType', description='The rule category.

- 10: Standard

- 11: Flow-based', example='10'),
  type?: int32(name='Type', description='The rule type.', example='1'),
  typeName?: string(name='TypeName', description='The type name.', example='全部类别'),
  unReviewNumber?: long(name='UnReviewNumber', description='The number of unreviewed items.', example='1'),
  userGroup?: string(name='UserGroup', description='The user group.', example='xxxx'),
}

model RuleInfo {
  autoReview?: int32(name='AutoReview', description='The review option. This parameter is used for compatibility with the v4.0 protocol. Valid values: `1` (Manual review) and `3` (Automatic review).', example='1'),
  businessCategoryNameList?: [ string ](name='BusinessCategoryNameList', description='A list of business category names.'),
  checkType?: long(name='CheckType', description='The check type. Valid values: `0` (Service compliance check), `1` (Service attitude check), `2` (Service professionalism check), `3` (Customer attitude check), and `4` (Service process correctness check).', example='3'),
  comments?: string(name='Comments', description='Remarks on the rule.', example='违规'),
  configType?: int32(name='ConfigType', description='The configuration type. This parameter is used for compatibility with the v4.0 protocol. Valid values: `1` (Simple condition configuration) and `2` (Advanced configuration). Default: `1`.', example='1'),
  createEmpName?: string(name='CreateEmpName', description='The name of the creator.', example='张三'),
  createEmpid?: string(name='CreateEmpid', description='The employee ID of the creator.', example='1'),
  createTime?: string(name='CreateTime', description='The creation time. This value is a Unix timestamp in milliseconds.', example='1641277321000'),
  deny?: int32(name='Deny', description='Indicates whether editing the rule is denied. Valid values: `1` (denied), `0` or `null` (allowed).', example='1'),
  dialogues?: [
    RuleTestDialogue
  ](name='Dialogues', description='A list of test dialogues.'),
  effective?: int32(name='Effective', description='Indicates whether the rule is in effect. Valid values: `0` (No) and `1` (Yes).', example='1'),
  effectiveEndTime?: string(name='EffectiveEndTime', description='The effective end time of the rule.', example='OperationMode'),
  effectiveStartTime?: string(name='EffectiveStartTime', description='The effective start time of the rule.', example='OperationMode'),
  endTime?: string(name='EndTime', description='The end time. This value is a Unix timestamp in milliseconds.', example='1641277321000'),
  externalProperty?: int32(name='ExternalProperty', description='The external property.', example='1'),
  fullCycle?: int32(name='FullCycle', description='Indicates whether the rule is effective throughout its lifecycle. Valid values: `0` (No) and `1` (Yes).', example='1'),
  graphFlow?: any(name='GraphFlow', description='The graph flow.', example='{}'),
  isDelete?: int32(name='IsDelete', description='Indicates whether the rule is deleted.', example='1'),
  isOnline?: int32(name='IsOnline', description='Indicates whether the rule is online.', example='1'),
  lambda?: string(name='Lambda', description='The conditional expression, such as `a&&b`.', example='a&&b'),
  lastUpdateEmpName?: string(name='LastUpdateEmpName', description='The name of the employee who last updated the rule.', example='张三'),
  lastUpdateEmpid?: string(name='LastUpdateEmpid', description='The ID of the employee who last updated the rule.', example='1'),
  lastUpdateTime?: string(name='LastUpdateTime', description='The last update time. This value is a Unix timestamp in milliseconds.', example='1641277321000'),
  level?: int32(name='Level', description='The severity level of the rule. Valid values: `0` (Severe violation), `1` (Moderate violation), and `2` (Minor violation).', example='1'),
  meet?: int32(name='Meet', description='Indicates whether the conditions are met.', example='1'),
  modifyType?: int32(name='ModifyType', description='Indicates whether the rule has been modified within the quality check scheme.', example='1'),
  name?: string(name='Name', description='The rule name.', example='开头语规则'),
  operationMode?: int32(name='OperationMode', description='The operation mode.', example='1'),
  preqRule?: {
    rid?: string(name='Rid'),
  }(name='PreqRule'),
  qualityCheckType?: int32(name='QualityCheckType', description='The quality check type. This parameter is used for compatibility with the v4.0 protocol. Valid values: `0` (offline quality check) and `1` (real-time quality check).', example='1'),
  rid?: string(name='Rid', description='The rule ID.', example='1'),
  ruleCategoryName?: string(name='RuleCategoryName', description='The name of the rule category.', example='正向规则'),
  ruleScoreType?: int32(name='RuleScoreType', description='Specifies whether to score the rule. This parameter is used for compatibility with the v4.0 protocol. Valid values: `1` (Do not score) and `3` (Score).', example='3'),
  ruleType?: int32(name='RuleType', description='The rule type. This parameter is used for compatibility with the v4.0 protocol. Valid values: `0` (Default) and `1` (User-created).', example='1'),
  schemeCheckType?: SchemeCheckType(name='SchemeCheckType', description='The quality check dimension object.'),
  schemeId?: long(name='SchemeId', description='The ID of the quality check scheme to which the rule belongs.', example='1'),
  schemeName?: string(name='SchemeName', description='The name of the quality check scheme.', example='通用方案'),
  schemeRuleMappingId?: long(name='SchemeRuleMappingId', description='The mapping ID between the quality check scheme and the rule.', example='1'),
  scoreDeleted?: boolean(name='ScoreDeleted', description='Indicates whether the scoring item is deleted. A deleted item may be displayed as grayed out.', example='true'),
  scoreId?: long(name='ScoreId', description='The ID of the main scoring item.', example='1'),
  scoreName?: string(name='ScoreName', description='The name of the main scoring item.', example='违规'),
  scoreNum?: float(name='ScoreNum', description='The score value.', example='1'),
  scoreNumType?: int32(name='ScoreNumType', description='The scoring method. This parameter is used for compatibility with the v4.0 protocol. Valid values: `0` (Add/deduct points when the rule is triggered) and `1` (Assign a one-time score when the rule is triggered).', example='1'),
  scoreRuleHitType?: int32(name='ScoreRuleHitType', description='The scoring trigger. Valid values: `0` (Score when a node is hit).', example='0'),
  scoreSubId?: long(name='ScoreSubId', description='The ID of the scoring subitem.', example='1'),
  scoreSubName?: string(name='ScoreSubName', description='The name of the scoring subitem.', example='1'),
  scoreType?: int32(name='ScoreType', description='Indicates whether to add or deduct points.', example='1'),
  sortIndex?: int32(name='SortIndex', description='The sort order of the rule in the quality check dimension.', example='1'),
