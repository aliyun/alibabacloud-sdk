/**
 *
 */
import OpenApi;
import OpenApi.OpenApiUtil;

extends OpenApi;


init(config: OpenApiUtil.Config){
  super(config);
  @endpointRule = 'regional';
  @endpointMap = {
    'cn-hangzhou' = 'qualitycheck.cn-hangzhou.aliyuncs.com',
  };

  checkConfig(config);
  @endpoint = getEndpoint('qualitycheck', @regionId, @endpointRule, @network, @suffix, @endpointMap, @endpoint);
}

function getEndpoint(productId: string, regionId: string, endpointRule: string, network: string, suffix: string, endpointMap: map[string]string, endpoint: string) throws: string{
  if (!$isNull(endpoint)) {
    return endpoint;
  }
  
  if (!$isNull(endpointMap) && !$isNull(endpointMap[regionId])) {
    return endpointMap[regionId];
  }
  return OpenApiUtil.getEndpointRules(productId, regionId, endpointRule, network, suffix);
}

model AgentInfo {
  agentDescription?: string(name='AgentDescription'),
  agentName?: string(name='AgentName'),
  id?: long(name='Id'),
  inputType?: string(name='InputType'),
  instructionType?: string(name='InstructionType'),
  instructionTypeParam?: {
    customPromptParam?: {
      customPrompt?: string(name='CustomPrompt'),
      nameDescPairList?: [ 
        {
          name?: string(name='Name'),
          value?: string(name='Value'),
        }
      ](name='NameDescPairList'),
    }(name='CustomPromptParam'),
    fieldsParam?: {
      nameDescPairList?: [ 
        {
          desc?: string(name='Desc'),
          name?: string(name='Name'),
          value?: string(name='Value'),
        }
      ](name='NameDescPairList'),
    }(name='FieldsParam'),
    serviceInspectionParam?: {
      dimensions?: [ 
        {
          desc?: string(name='Desc'),
          dimension?: string(name='Dimension'),
        }
      ](name='Dimensions'),
      sceneDescription?: string(name='SceneDescription'),
      sceneName?: string(name='SceneName'),
    }(name='ServiceInspectionParam'),
    tagCategoryParam?: {
      nameDescPairList?: [ 
        {
          desc?: string(name='Desc'),
          name?: string(name='Name'),
          valueList?: [ string ](name='ValueList'),
        }
      ](name='NameDescPairList'),
    }(name='TagCategoryParam'),
  }(name='InstructionTypeParam'),
  modelType?: string(name='ModelType'),
}

model BusinessCategoryBasicInfo {
  bid?: int32(name='Bid', description='Business ID', example='1'),
  name?: string(name='Name', description='Business name', example='全部'),
  originalId?: long(name='OriginalId', description='originalId', example='1'),
  serviceType?: int32(name='ServiceType', description='Service Type (ServiceCategory).', example='1'),
}

model ConditionBasicInfo {
  checkRange?: {
    absolute?: boolean(name='Absolute', description='false: relative position; the sentence position is determined in combination with the anchor and the role', example='true'),
    allSentencesSatisfy?: boolean(name='AllSentencesSatisfy', description='true: Every sentence must satisfy the condition;', example='true'),
    anchor?: {
      cid?: string(name='Cid', description='Condition ID', example='a'),
      hitTime?: int32(name='Hit_time', description='Hit count', example='1'),
      location?: string(name='Location', description='Location', example='BEFORE'),
    }(name='Anchor', description='Precondition and postcondition'),
    range?: {
      from?: int32(name='From', description='Start index of the conversation', example='1'),
      to?: int32(name='To', description='End index of the conversation', example='2'),
    }(name='Range', description='Relative range'),
    role?: string(name='Role', description='Corresponds to RoleType.type', example='客服'),
    roleId?: int32(name='RoleId', description='Corresponds to RoleType.id', example='1'),
  }(name='Check_range', description='Detection range'),
  cid?: string(name='Cid', description='Condition ID, which may be the primary key in the database or a transformed identifier such as a, b, or c', example='a'),
  exclusion?: int32(name='Exclusion', description='Exclude', example='0'),
  id?: long(name='Id', description='Primary key in the database', example='1'),
  lambda?: string(name='Lambda', description='Lambda expression; for example: a&&b', example='a'),
  name?: string(name='Name', description='Condition name', example='xx'),
  operators?: [
    OperatorBasicInfo
  ](name='Operators', description='List of operators'),
  rid?: string(name='Rid', description='ID of the rule to which the condition belongs', example='1'),
  userGroup?: string(name='UserGroup', description='User group', example='xxxx'),
}

model GraphFlowNode {
  conditions?: [
    ConditionBasicInfo
  ](name='Conditions', description='Operator information.'),
  content?: string(name='Content', description='Used for frontend display.', example='{}'),
  id?: long(name='Id', description='Node ID.', example='1'),
  index?: int32(name='Index', description='Index', example='1'),
  name?: string(name='Name', description='Node name', example='开始节点'),
  nextNodes?: [ 
    {
      checkType?: int32(name='CheckType', description='Quality check dimension', example='1'),
      index?: int32(name='Index', description='Flow branch priority. A smaller value indicates higher priority.', example='1'),
      lambda?: string(name='Lambda', description='Lambda expression for the next hop.', example='a'),
      name?: string(name='Name', description='Conditional branch name.', example='a'),
      nextNodeId?: long(name='NextNodeId', description='Next node ID.', example='31533'),
      triggers?: [ string ](name='Triggers', description='Operators to follow.'),
    }
  ](name='NextNodes', description='Child nodes'),
  nodeType?: string(name='NodeType', description='Node Type', example='startNode'),
  properties?: {
    autoReview?: int32(name='AutoReview', description='1: Do not auto-review.', example='1'),
    branchJudge?: boolean(name='BranchJudge', description='Enable branch judgment.', example='true'),
    checkMoreSize?: int32(name='CheckMoreSize', description='Maximum N sentences to check.', example='1'),
    checkType?: int32(name='CheckType', description='Quality check dimension', example='1'),
    lambda?: string(name='Lambda', description='General operator logic.', example='a'),
    role?: string(name='Role', description='Role when the type is \\\\`single\\\\`.', example='客户'),
    ruleScoreType?: int32(name='RuleScoreType', description='Is scored.', example='1'),
    sayType?: string(name='SayType', description='Indicates expression when the type is \\\\`single\\\\`.'),
    scoreNum?: int32(name='ScoreNum', description='Score value', example='1'),
    scoreNumType?: int32(name='ScoreNumType', description='0: Add or deduct points after the rule is triggered; 1: Score once after the rule is triggered.', example='1'),
    scoreRuleHitType?: int32(name='ScoreRuleHitType', description='0: Score when the node is hit.', example='0'),
    scoreType?: int32(name='ScoreType', description='1: Add points; 3: Deduct points; default is 1.', example='1'),
    triggers?: [ string ](name='Triggers', description='Operators to follow.'),
    type?: string(name='Type', description='Property type', example='xx'),
  }(name='Properties', description='Node properties'),
  rid?: long(name='Rid', description='Rule ID. \\\\`rid\\\\` is empty if the rule is not persisted. If the rule is persisted, \\\\`rid\\\\` equals \\\\`ID\\\\`.', example='1'),
  useConditions?: boolean(name='UseConditions', description='Whether to use operator matching or legacy matching.', example='true'),
}

model JudgeNodeMetaDesc {
  actualValue?: string(name='ActualValue', description='Actual value', example='xx'),
  dataType?: int32(name='DataType', description='Data type', example='1'),
  expressionMetaDesc?: {
    leftFieldType?: int32(name='LeftFieldType'),
    leftOperand?: string(name='LeftOperand'),
    operator?: string(name='Operator'),
    rightFieldType?: int32(name='RightFieldType'),
    rightOperand?: string(name='RightOperand'),
    roundingMode?: string(name='RoundingMode'),
  }(name='ExpressionMetaDesc'),
  field?: string(name='Field', description='System field', example='remark1'),
  fieldType?: int32(name='FieldType', description='Field data source type: 1: System predefined field. 2: Quality inspection field for passed parameters.', example='1'),
  symbol?: int32(name='Symbol', description='Expression', example='1'),
  value?: string(name='Value', description='Preset value', example='xxx'),
}

model NextNodeSituations {
  conditionGroup?: [ 
    {
      conditions?: [
        JudgeNodeMetaDesc
      ](name='Conditions', description='Collection of matching conditions'),
      type?: string(name='Type', description='The matching relationship between conditions', example='1'),
    }
  ](name='ConditionGroup', description='Judgment Conditions'),
  type?: string(name='Type', description='The matching relationship between conditions: currently all are OR relationships.', example='1'),
}

model OperatorBasicInfo {
  id?: long(name='Id', description='The primary key ID.', example='1'),
  name?: string(name='Name', description='The operator name.', example='a'),
  oid?: string(name='Oid', description='The ID. This can be the primary key ID or an ID generated by the frontend.', example='a'),
  param?: {
    answerThreshold?: string(name='AnswerThreshold', description='The threshold for answer hits.', example='90'),
    antModelInfo?: map[string]string(name='AntModelInfo', description='The Ant model information.'),
    average?: boolean(name='Average', description='For speech rate detection: specifies whether to calculate the average speech rate for the entire dialogue. The default is \\\\`false\\\\`.', example='true'),
    beginType?: string(name='BeginType', description='For the duration operator: the start type for the duration calculation. The calculation can start from the beginning of the recording or the beginning of a specific sentence.', example='1'),
    botId?: string(name='BotId', description='The robot ID.', example='chatbot-cn-xxx'),
    caseSensitive?: boolean(name='Case_sensitive', description='Specifies whether the matching is case-sensitive.', example='true'),
    categoryPathCode?: string(name='CategoryPathCode', description='The knowledge category path.', example='xx'),
    checkFirstSentence?: boolean(name='CheckFirstSentence', description='For silence detection: specifies whether to check the first sentence.', example='true'),
    checkType?: int32(name='CheckType', description='The detection method. The default is 1.

- 1: Energy fluctuation between contiguous sentences.

- 2: Maximum energy span.', example='1'),
    compareOperator?: string(name='CompareOperator', description='The comparison operator. Valid values are \\\\`gt\\\\` (greater than) and \\\\`lt\\\\` (less than).', example='gt'),
    contextChatMatch?: boolean(name='ContextChatMatch', description='Specifies whether to match a single sentence.', example='true'),
    customerParam?: JudgeNodeMetaDesc(name='CustomerParam', description='Parameters for the recording-related operator.'),
    delayTime?: int32(name='DelayTime', description='For the interruption operator: the delay duration.', example='10'),
    differentRole?: boolean(name='Different_role', description='Used for the time interval operator. If set to \\\\`true\\\\`, the target sentence is not included in the calculation if it is spoken by the same role as the current sentence.', example='true'),
    dimensions?: [ 
      {
        desc?: string(name='Desc'),
        dimension?: string(name='Dimension'),
        excludeCondition?: string(name='ExcludeCondition'),
        includeCondition?: string(name='IncludeCondition'),
      }
    ](name='Dimensions'),
    endType?: string(name='EndType', description='For the duration operator: the end type for the duration calculation. The calculation can end at the end of the recording or the end of a specific sentence.', example='2'),
    excludes?: [ string ](name='Excludes', description='For the contextual repetition operator: the dialogues to exclude.'),
    from?: int32(name='From', description='For the contextual repetition operator: checks for repetitions within the \\\\`from\\\\` number of sentences before the current sentence. A value of \\\\`0\\\\` indicates all preceding sentences.', example='0'),
    fromEnd?: boolean(name='From_end', description='Used for the time interval operator. Specifies whether to calculate the time interval by subtracting the end time of the target sentence from the end time of the current sentence.', example='true'),
    hitCondition?: string(name='HitCondition'),
    hitTime?: int32(name='Hit_time', description='For the contextual repetition operator: the number of repetitions.', example='2'),
    inSentence?: boolean(name='In_sentence', description='The effective sentences. \\\\`true\\\\` indicates a single sentence. \\\\`false\\\\` indicates multiple sentences.', example='true'),
    interval?: int32(name='Interval', description='The start of the interval.', example='1'),
    intervalEnd?: int32(name='IntervalEnd', description='The end of the interval.', example='2'),
    keywordExtension?: int32(name='KeywordExtension', description='The keyword extension.', example='1'),
    keywordMatchSize?: int32(name='KeywordMatchSize', description='The number of matched keywords.', example='1'),
    keywords?: [ string ](name='Keywords', description='The keywords.'),
    knowledgeInfo?: string(name='KnowledgeInfo', description='The knowledge information.', example='下单'),
    knowledgeSentenceNum?: int32(name='KnowledgeSentenceNum', description='The number of sentences after a question is hit within which to detect the answer.', example='1'),
    knowledgeTargetId?: string(name='KnowledgeTargetId', description='The knowledge category or knowledge ID.', example='1'),
    knowledgeTargetName?: string(name='KnowledgeTargetName', description='The name of the knowledge category or knowledge.', example='订单'),
    knowledgeTargetType?: int32(name='KnowledgeTargetType', description='0: Category. 1: Knowledge.', example='1'),
    knowledges?: string(name='Knowledges'),
    lgfSentences?: [ string ](name='LgfSentences', description='The LGF sentences.'),
    llmModelCode?: string(name='LlmModelCode'),
    maxEmotionChangeValue?: int32(name='MaxEmotionChangeValue', description='The change in energy value. The default is 3. The range is 1 to 9.', example='3'),
    minWordSize?: int32(name='MinWordSize', description='The minimum number of words in a sentence. Sentences with fewer words than this value are not checked.', example='1'),
    nearDialogue?: boolean(name='Near_dialogue', description='\\\\`true\\\\` indicates that the two contiguous sentences from different roles are used. \\\\`false\\\\` indicates that the first sentence from each role is used to compare the response time. The default is \\\\`false\\\\`.', example='true'),
    notRegex?: string(name='NotRegex', description='The regular expression to exclude.', example='优秀.*'),
    phrase?: string(name='Phrase', description='The statement.', example='你好，请问'),
    pkey?: string(name='Pkey', description='The variable required for foreign-related properties.', example='xx'),
    poutputType?: int32(name='Poutput_type', description='The poutput type.', example='1'),
    pvalues?: [ string ](name='Pvalues', description='The model detection type.'),
    questionThreshold?: string(name='QuestionThreshold', description='The threshold for question hits.', example='90'),
    references?: [ string ](name='References', description='The references.'),
    regex?: string(name='Regex', description='The regular expression.', example='质疑.*'),
    roleId?: int32(name='RoleId', description='The role used in the operator. This parameter is currently used for the contextual repetition operator in conjunction with \\\\`Target_role\\\\`.', example='1'),
    sceneName?: string(name='SceneName'),
    score?: int32(name='Score', description='The score.', example='70'),
    similarityThreshold?: double(name='Similarity_threshold', description='The similarity threshold.', example='90'),
    similarlySentences?: [ string ](name='SimilarlySentences', description='Similar questions.'),
    synonyms?: map[string][ string ](name='Synonyms', description='The synonyms.'),
    target?: int32(name='Target', description='The target sentence, specified as the number of sentences before the current one. If set to 0, the time interval is calculated as the end time of the current sentence minus its start time.', example='1'),
    targetRole?: string(name='Target_role', description='Used for the repetition operator. If the current sentence matches the regular expression, the matched part is searched for in the sentences spoken by the specified \\\\`Target_role\\\\` that appear before the current sentence.', example='客服'),
    threshold?: float(name='Threshold', description='The threshold.', example='90'),
    useEasAlgorithm?: boolean(name='UseEasAlgorithm', description='Specifies whether to use the EAS algorithm.', example='true'),
    velocity?: double(name='Velocity', description='Used for the speech rate operator. The speech rate value per unit of time. It determines whether the speech rate of the current sentence exceeds the specified value. The time unit depends on the time units of the \\\\`start\\\\` and \\\\`end\\\\` parameters.', example='111'),
    velocityInMint?: int32(name='VelocityInMint', description='Used for the speech rate operator. The speech rate value per minute. It determines whether the speech rate of the current sentence exceeds the specified value.', example='1'),
  }(name='Param', description='The operator parameters.'),
  qualityCheckType?: int32(name='QualityCheckType', description='The quality check type:

- 0: Offline check

- 1: Real-time check', example='0'),
  type?: string(name='Type', description='The operator category.', example='HIT_ANY_KEYWORDS'),
  userGroup?: string(name='UserGroup', description='The user group.', example='xxx'),
}

model RuleCountInfo {
  autoReview?: int32(name='AutoReview', description='The review option.

- 1: Manual review

- 3: Automatic review', example='1'),
  businessCategoryBasicInfoList?: [
    BusinessCategoryBasicInfo
  ](name='BusinessCategoryBasicInfoList', description='A list of basic information about business categories.'),
  businessCategoryNameList?: [ string ](name='BusinessCategoryNameList', description='A list of business category names.'),
