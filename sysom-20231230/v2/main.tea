 */
@context("createInstanceInspectionWithContext")
async function createInstanceInspectionWithOptions(request: CreateInstanceInspectionRequest, headers: map[string]string, runtime: $RuntimeOptions): CreateInstanceInspectionResponse {
  request.validate();
  var body : map[string]any = {};
  if (!$isNull(request.instance)) {
    body['instance'] = request.instance;
  }
  if (!$isNull(request.items)) {
    body['items'] = request.items;
  }
  if (!$isNull(request.metricSource)) {
    body['metricSource'] = request.metricSource;
