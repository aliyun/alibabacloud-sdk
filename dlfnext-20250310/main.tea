/**
 *
 */
import Util;
import OpenApi;
import OpenApiUtil;
import EndpointUtil;

extends OpenApi;


init(config: OpenApi.Config){
  super(config);
  @endpointRule = 'regional';
  @endpointMap = {
    'us-west-1' = 'dlfnext.us-west-1.aliyuncs.com',
    'us-east-1' = 'dlfnext.us-east-1.aliyuncs.com',
    'eu-central-1' = 'dlfnext.eu-central-1.aliyuncs.com',
    'cn-wulanchabu' = 'dlfnext.cn-wulanchabu.aliyuncs.com',
    'cn-shenzhen' = 'dlfnext.cn-shenzhen.aliyuncs.com',
    'cn-shanghai' = 'dlfnext.cn-shanghai.aliyuncs.com',
    'cn-hongkong' = 'dlfnext.cn-hongkong.aliyuncs.com',
    'cn-hangzhou' = 'dlfnext.cn-hangzhou.aliyuncs.com',
    'cn-beijing' = 'dlfnext.cn-beijing.aliyuncs.com',
    'ap-southeast-5' = 'dlfnext.ap-southeast-5.aliyuncs.com',
    'ap-southeast-1' = 'dlfnext.ap-southeast-1.aliyuncs.com',
    'ap-northeast-1' = 'dlfnext.ap-northeast-1.aliyuncs.com',
  };

  checkConfig(config);
  @endpoint = getEndpoint('dlfnext', @regionId, @endpointRule, @network, @suffix, @endpointMap, @endpoint);
}

function getEndpoint(productId: string, regionId: string, endpointRule: string, network: string, suffix: string, endpointMap: map[string]string, endpoint: string) throws: string{
  if (!Util.empty(endpoint)) {
    return endpoint;
  }
  
  if (!Util.isUnset(endpointMap) && !Util.empty(endpointMap[regionId])) {
    return endpointMap[regionId];
  }
  return EndpointUtil.getEndpointRules(productId, regionId, endpointRule, network, suffix);
}

model CacheCluster {
  clusterId?: string(name='clusterId', description='Cluster ID', example='dc-wqewqr*****'),
  clusterName?: string(name='clusterName', description='Cluster name', example='cluster_name'),
  createdAt?: long(name='createdAt', description='Creation time', example='1744970111419'),
  createdBy?: string(name='createdBy', description='Creator name', example='acs:ram::[accountId]:root'),
  deployInstanceVersion?: string(name='deployInstanceVersion', description='Version of the deployed instance', example='1.0.0'),
  deployOptionsVersion?: long(name='deployOptionsVersion', description='Deployed options version', example='1.0.0'),
  instanceVersion?: string(name='instanceVersion', description='Milvus Version', example='1.0.0'),
  options?: map[string]string(name='options', description='Cache cluster configuration'),
  optionsVersion?: long(name='optionsVersion', description='Options version', example='1.0.0'),
  status?: string(name='status', description='Cache cluster status. Valid values:
● NEW: Newly created and not started.
● STARTING: Starting.
● START_FAILED: Start failed.
● RUNNING: Running.
● PENDING_RESTART: Pending restart.
● PENDING_TERMINATE: Pending termination.
● TERMINATING: Terminating.
● TERMINATE_FAILED: Termination failed.
● TERMINATED: Terminated.', example='RUNNING'),
  updatedAt?: long(name='updatedAt', description='Update time', example='1764555848748'),
  updatedBy?: string(name='updatedBy', description='Updater name', example='acs:ram::[accountId]:root'),
  vSwitches?: [ 
    {
      vSwitchId?: string(name='vSwitchId', description='vSwitch ID', example='vsw-bp1thxw8sgypzj2j*****'),
      zone?: string(name='zone', description='Instance zone', example='cn-hangzhou-e'),
    }
  ](name='vSwitches', description='vSwitch list'),
  vpcId?: string(name='vpcId', description='VPC ID', example='vpc-2ze****'),
}

model Catalog {
  createdAt?: long(name='createdAt', description='The time when the catalog was created.', example='1744970111419'),
  createdBy?: string(name='createdBy', description='The user who created the catalog.', example='acs:ram::[accountId]:root'),
  id?: string(name='id', description='The ID of the catalog.', example='clg-paimon-xxxx'),
  isShared?: boolean(name='isShared', description='Whether the data catalog is shared.', example='false'),
  name?: string(name='name', description='The name of the catalog.', example='test_catalog'),
  options?: map[string]string(name='options', description='The extension options.'),
  owner?: string(name='owner', description='The catalog owner.', example='acs:ram::[accountId]:root'),
  shareId?: string(name='shareId', description='Share ID.', example='share-xxxx'),
  status?: string(name='status', description='The status of the catalog.', example='NEW
INITIALIZING
INITIALIZE_FAILED
RUNNING
TERMINATED
DELETING
DELETE_FAILED 
DELETED
STORAGE_RESTRICTED'),
  type?: string(name='type', description='Type.', example='PAIMON'),
  updatedAt?: long(name='updatedAt', description='The time when the catalog was last modified.', example='1744970111419'),
  updatedBy?: string(name='updatedBy', description='The user who last modified the catalog.', example='acs:ram::[accountId]:root'),
}

model CatalogSummary {
  apiVisitCountMonthly?: long(name='apiVisitCountMonthly', description='The total number of metadata requests in the current month.', example='1000'),
  databaseCount?: MoMValues(name='databaseCount', description='The month-over-month data on the total number of databases.'),
  fileAccessCountMonthly?: long(name='fileAccessCountMonthly', description='The total number of file requests for the current month.', example='10000'),
  generatedDate?: string(name='generatedDate', description='The date when the storage overview data was updated.', example='2025-01-01'),
  objTypeArchiveSize?: long(name='objTypeArchiveSize', description='The storage usage for Archive data files.', example='10240'),
  objTypeColdArchiveSize?: long(name='objTypeColdArchiveSize', description='The storage usage for Cold Archive data files.', example='10240'),
  objTypeIaSize?: long(name='objTypeIaSize', description='The storage usage for Infrequent Access (IA) data files.', example='10240'),
  objTypeStandardSize?: long(name='objTypeStandardSize', description='The storage usage for Standard data files.', example='10240'),
  partitionCount?: MoMValues(name='partitionCount', description='The month-over-month data on the total number of partitions.'),
  tableCount?: MoMValues(name='tableCount', description='The month-over-month data on the total number of tables.'),
  throughputMonthly?: long(name='throughputMonthly', description='The data access traffic for the current month, in bytes.', example='1024'),
  totalFileCount?: MoMValues(name='totalFileCount', description='The month-over-month data on the total number of files.'),
  totalFileSizeInBytes?: MoMValues(name='totalFileSizeInBytes', description='The change in storage capacity from the previous period, in bytes.'),
  totalMetaFileCount?: MoMValues(name='totalMetaFileCount', description='The month-over-month data for the total number of metadata files.'),
  totalMetaSizeInBytes?: MoMValues(name='totalMetaSizeInBytes', description='The month-over-month data for the storage usage of metadata files, in bytes.'),
}

