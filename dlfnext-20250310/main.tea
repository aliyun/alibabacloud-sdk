model FullDataType {
  element?: FullDataType(name='element', description='The data type.'),
  fields?: [
    DataField
  ](name='fields', description='The list of field definitions. This parameter is required when `type` is `ROW`.'),
  key?: FullDataType(name='key', description='The data type of the key. This parameter is required when `type` is `MAP`.'),
  type?: string(name='type', description='The data type. This parameter is required when `type` is `ARRAY` or `MULTISET`.', example='STRING'),
  value?: FullDataType(name='value', description='The data type of the value. This parameter is required when `type` is `MAP`.'),
}

