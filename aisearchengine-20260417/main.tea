/**
 *
 */
import Util;
import OpenApi;
import OpenApiUtil;
import EndpointUtil;

extends OpenApi;


init(config: OpenApi.Config){
  super(config);
  @endpointRule = '';
  
  checkConfig(config);
  @endpoint = getEndpoint('aisearchengine', @regionId, @endpointRule, @network, @suffix, @endpointMap, @endpoint);
}

function getEndpoint(productId: string, regionId: string, endpointRule: string, network: string, suffix: string, endpointMap: map[string]string, endpoint: string) throws: string{
  if (!Util.empty(endpoint)) {
    return endpoint;
  }
  
  if (!Util.isUnset(endpointMap) && !Util.empty(endpointMap[regionId])) {
    return endpointMap[regionId];
  }
  return EndpointUtil.getEndpointRules(productId, regionId, endpointRule, network, suffix);
}

model EngineSearchRequest {
  appId?: string(name='appId', description='This parameter is required.', example='507218'),
  grey?: boolean(name='grey', example='false'),
  query?: {
    excludeIds?: [ string ](name='excludeIds', example='["24234111","12423525"]'),
    imageUrls?: [ string ](name='imageUrls', example='["https://paperreview.oss-cn-hangzhou.aliyuncs.com/59dd424f-97ed-4855-942e-c961f1f5b67e.jpeg"]'),
    pageNo?: int32(name='pageNo', example='1'),
    pageSize?: int32(name='pageSize', example='10'),
    texts?: [ string ](name='texts', example='["梅花图片"]'),
  }(name='query', description='This parameter is required.'),
  recall?: {
    closeRecallAsr?: boolean(name='closeRecallAsr', example='false'),
    needMergeSegments?: boolean(name='needMergeSegments', example='true'),
  }(name='recall'),
  sessionId?: string(name='sessionId', example='2e95ef4fbc28437db5008a910bd392a4'),
  strategyId?: string(name='strategyId', example='507218'),
  user?: {
    userId?: string(name='userId', example='"123456"'),
  }(name='user'),
  version?: string(name='version', example='默认1.0'),
}

model EngineSearchResponseBody = {
  code?: int32(name='code', example='SUCCESS'),
  data?: {
    errorMessage?: string(name='errorMessage', example='搜索词违禁'),
    extra?: map[string]any(name='extra', example='{}'),
    items?: [ 
      {
        algorithm?: map[string]any(name='algorithm', example='{"rankScore":1.0}'),
        content?: map[string]any(name='content', example='{"titile":"大疆无人机"}'),
        id?: string(name='id', example='iceberg-tbl-b7420156-6d23-4555-8e05-12285b36d6ca'),
        score?: float(name='score', example='1.75'),
        traceInfo?: map[string]any(name='traceInfo', example='{"traceId":"12285b36d6ca"}'),
      }
    ](name='items'),
    page?: int32(name='page', example='1'),
    requestId?: string(name='requestId', example='62CC3999-5380-5344-ABC7-46453625A910'),
    size?: int32(name='size', example='10'),
    status?: string(name='status', example='200'),
    total?: int32(name='total', example='121'),
    traceInfo?: map[string]any(name='traceInfo', example='{"traceId":"234234324"}'),
  }(name='data'),
  message?: string(name='message', example='successful'),
}

model EngineSearchResponse = {
  headers?: map[string]string(name='headers'),
  statusCode?: int32(name='statusCode'),
  body?: EngineSearchResponseBody(name='body'),
}

/**
 * @summary AI搜索
 *
 * @param request EngineSearchRequest
 * @param headers map
 * @param runtime runtime options for this request RuntimeOptions
 * @return EngineSearchResponse
 */
async function engineSearchWithOptions(request: EngineSearchRequest, headers: map[string]string, runtime: Util.RuntimeOptions): EngineSearchResponse {
  Util.validateModel(request);
  var body : map[string]any = {};
  if (!Util.isUnset(request.appId)) {
    body['appId'] = request.appId;
  }
  if (!Util.isUnset(request.grey)) {
    body['grey'] = request.grey;
  }
  if (!Util.isUnset(request.query)) {
    body['query'] = request.query;
  }
  if (!Util.isUnset(request.recall)) {
    body['recall'] = request.recall;
  }
  if (!Util.isUnset(request.sessionId)) {
    body['sessionId'] = request.sessionId;
  }
  if (!Util.isUnset(request.strategyId)) {
    body['strategyId'] = request.strategyId;
  }
  if (!Util.isUnset(request.user)) {
    body['user'] = request.user;
  }
  if (!Util.isUnset(request.version)) {
    body['version'] = request.version;
  }

  var req = new OpenApi.OpenApiRequest{ 
    headers = headers,
    body = OpenApiUtil.parseToMap(body),
  };
  var params = new OpenApi.Params{
    action = 'EngineSearch',
    version = '2026-04-17',
    protocol = 'HTTPS',
    pathname = `/api/v1/platform/app/search`,
    method = 'POST',
    authType = 'AK',
    style = 'ROA',
    reqBodyType = 'json',
    bodyType = 'json',
  };
  return callApi(params, req, runtime);
}

/**
 * @summary AI搜索
 *
 * @param request EngineSearchRequest
 * @return EngineSearchResponse
 */
async function engineSearch(request: EngineSearchRequest): EngineSearchResponse {
  var runtime = new Util.RuntimeOptions{};
  var headers : map[string]string = {};
  return engineSearchWithOptions(request, headers, runtime);
}

