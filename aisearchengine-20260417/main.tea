model QaChatRequest {
  appId?: string(name='appId', description='This parameter is required.', example='2047140750220754946'),
  message?: {
    parts?: [ 
      {
        data?: any(name='data', example='{
  "templateId": "456789"
}'),
        mediaType?: string(name='mediaType', example='image/png'),
        text?: string(name='text', example='帮我搜索下今天的天气'),
        type?: string(name='type', example='text'),
        url?: string(name='url', example='https://meeting.dingtalk.com/j/4sSPAxWaPbM'),
      }
    ](name='parts'),
    role?: string(name='role', example='user'),
  }(name='message', description='This parameter is required.'),
  options?: map[string]any(name='options', example='{
  "debug": true
}'),
  sessionId?: string(name='sessionId', example='b2a979e79799489fbde56119bf8c4dc7'),
}

model QaChatResponseBody = {
  data?: {
    data?: string(name='data', example='{
  "items": [
    {
      "title": "MacBook Neo 深度测评：全面超越，最轻盈的生产力",
      "videoUrl": "https://video.example.com/macbook-neo-review.mp4",
      "coverUrl": "https://images.unsplash.com/photo-1529139574466-a303027c1d8b?auto=format&fit=crop&w=800&q=80",
      "tags": [
        "数码产品",
        "评测",
        "MacBook",
        "生产力"
      ]
    }
  ]
}'),
    delta?: string(name='delta', example='如果你想更快看到上身效果，这 3 条短视频会更直观。\\\\n\\\\n**第一条：完整通勤 look**\\\\n\\\\n3 套通勤到周末无缝切换的浅色运动鞋穿搭。'),
    errorCode?: string(name='errorCode', example='400'),
    errorText?: string(name='errorText', example='参数错误'),
    finishReason?: string(name='finishReason', example='stop'),
    id?: string(name='id', example='2a127bc9-9474-405d-916d-8bc4475fa459'),
    requestId?: string(name='requestId', example='2a127bc9-9474-405d-916d-8bc4475fa459'),
    retryable?: boolean(name='retryable', example='true'),
    type?: string(name='type', example='v'),
  }(name='data'),
  event?: string(name='event', example='start'),
  id?: string(name='id', example='2a127bc9-9474-405d-916d-8bc4475fa459'),
}

model QaChatResponse = {
  headers?: map[string]string(name='headers'),
  statusCode?: int32(name='statusCode'),
  body?: QaChatResponseBody(name='body'),
}

