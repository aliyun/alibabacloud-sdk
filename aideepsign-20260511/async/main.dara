 */
async function createImageDetectionTask(request: CreateImageDetectionTaskRequest): CreateImageDetectionTaskResponse {
  @handler.validateRequestModel(request);
  return @handler.do('RPC', 'CreateImageDetectionTask', 'POST', '/', 'json', false, 'json', request);
}

