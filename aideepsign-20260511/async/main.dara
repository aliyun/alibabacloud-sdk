model VerifyImageSignatureRequest {
  imageUrl?: string(name='ImageUrl', example='https://example.com/signed-photo.jpg', position='Query'),
  objectKey?: string(name='ObjectKey', example='deepsign/123456789/image-generation/abc12345-def6-7890-abcd-ef1234567890.png', position='Query'),
}

model VerifyImageSignatureResponseBody = {
  code?: string(name='Code'),
  httpStatusCode?: long(name='HttpStatusCode'),
  issuer?: {
    commonName?: string(name='CommonName', example='AIDeepSign User Certificate'),
    organization?: string(name='Organization', example='Alibaba Cloud'),
  }(name='Issuer'),
  issuerTrusted?: boolean(name='IssuerTrusted'),
  manifest?: {
    assertions?: [ 
      {
        data?: string(name='Data'),
        label?: string(name='Label', example='c2pa.actions'),
      }
    ](name='Assertions'),
    signatureInfo?: {
      alg?: string(name='Alg', example='ps256'),
      issuer?: string(name='Issuer', example='CN=AIDeepSign CA,O=Alibaba Cloud'),
      time?: string(name='Time', example='2026-06-18T10:30:00Z'),
    }(name='SignatureInfo'),
  }(name='Manifest'),
  message?: string(name='Message'),
  requestId?: string(name='RequestId', example='A1B2C3D4-E5F6-7890-ABCD-EF1234567890'),
  success?: boolean(name='Success'),
  verificationState?: string(name='VerificationState', example='Valid'),
}

model VerifyImageSignatureResponse = {
  headers?: map[string]string(name='headers'),
  statusCode?: int32(name='statusCode'),
  body?: VerifyImageSignatureResponseBody(name='body'),
}

/**
  * @param request  the request parameters of VerifyImageSignature  VerifyImageSignatureRequest
  * @return VerifyImageSignatureResponse
 */
async function verifyImageSignature(request: VerifyImageSignatureRequest): VerifyImageSignatureResponse {
  @handler.validateRequestModel(request);
  return @handler.do('RPC', 'VerifyImageSignature', 'POST', '/', 'json', false, 'json', request);
}

