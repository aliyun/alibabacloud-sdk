      androidHuaweiBusinessType?: int32(name='AndroidHuaweiBusinessType', description='Sets the parameters for Huawei quick notifications

- **0**: Send a normal Huawei notification (default).

- **1**: Send a Huawei quick notification.', example='1'),
      androidHuaweiLiveNotificationPayload?: string(name='AndroidHuaweiLiveNotificationPayload', description='A JSON string of the Huawei Android Live Notification data structure [LiveNotificationPayload](https://developer.huawei.com/consumer/cn/doc/HMSCore-References/rest-live-0000001562939968#ZH-CN_TOPIC_0000001700850537__p195121620102511). For development and integration, see the [Huawei Live Notification Push Guide](https://help.aliyun.com/document_detail/2983768.html).', example='{
