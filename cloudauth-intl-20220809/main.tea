  documentNumber?: string(name='DocumentNumber', description='The document number.

Required when **MRTDInput = 2**.', example='-'),
  editOcrResult?: string(name='EditOcrResult', description='Specifies whether the recognition result page is editable during the document OCR recognition step:

- **0**: not editable

- **1** (default): editable.', example='0'),
  email?: string(name='Email', description='The Indonesian email address. This field takes effect only when Authorize=T.

>Note:
This field is required only when the Indonesian data source is enabled.', example='evxxx@imigxxxxx.go.id'),
  experienceCode?: string(name='ExperienceCode', description='The experience code.', example='9be7b7d0180041219e5ab03ac6dab5fb'),
  faceGroupCodes?: string(name='FaceGroupCodes', description='The face libraries for comparison.', example='0e0c34a77f'),
  facePictureBase64?: string(name='FacePictureBase64', description='The Base64-encoded face photo. If you use FacePictureBase64 to pass in the face photo, check the photo size and do not pass in an excessively large photo.', example='Base64'),
  facePictureFile?: string(name='FacePictureFile', description='The file stream of the face photo.', example='InputStream'),
  facePictureUrl?: string(name='FacePictureUrl', description='The URL of the face photo. The URL must be a publicly accessible HTTP or HTTPS link.', example='https://digital-face-prod8.oss-cn-hangzhou.aliyuncs.com/1669520556530-expo/default/face/20221127114236530_w3kx2e6t.jpg'),
  faceRegisterGroupCode?: string(name='FaceRegisterGroupCode', description='The face registration library.', example='0e0c34a77f'),
  faceVerifyThreshold?: string(name='FaceVerifyThreshold', description='The face verification threshold.', example='0.5'),
  idFaceQuality?: string(name='IdFaceQuality', description='The face image quality. This is an input parameter for the IDV product.', example='Y'),
  idSpoof?: string(name='IdSpoof', description='Specifies whether to enable document anti-forgery detection. This is an input parameter for the IDV product.', example='Y'),
  idThreshold?: string(name='IdThreshold', description='The custom OCR quality detection threshold mode:

