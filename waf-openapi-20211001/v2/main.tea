model DescribeThreatEventTopMetricRequest {
  eventId?: string(name='EventId', description='The ID of the security event.

This parameter is required.', example='0b7ab137a065aab7656986***11db'),
  instanceId?: string(name='InstanceId', description='The ID of the WAF instance.

