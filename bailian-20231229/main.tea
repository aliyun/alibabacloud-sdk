  rerankTopN?: int32(name='RerankTopN', description='The number of top-ranked text chunks to return after reranking. The value must be an integer from 1 to 20. Default value: 5.', example='5'),
  rewriteShrink?: string(name='Rewrite', description='Configuration for conversational query rewriting.'),
