  parentCategoryId?: string(name='ParentCategoryId', description='The ID of the parent category under which the new category is created. If you leave this parameter empty, a top-level category is created.', example='cate_cdd11b1b79a74e8bbd675c356a91ee3xxxxxxxx'),
