 * @return AddConnectorResponse
 */
async function addConnectorWithOptions(WorkspaceId: string, tmpReq: AddConnectorRequest, headers: map[string]string, runtime: Util.RuntimeOptions): AddConnectorResponse {
  Util.validateModel(tmpReq);
  var request = new AddConnectorShrinkRequest{};
  OpenApiUtil.convert(tmpReq, request);
  if (!Util.isUnset(tmpReq.fileConnectorConfig)) {
    request.fileConnectorConfigShrink = OpenApiUtil.arrayToStringWithSpecifiedStyle(tmpReq.fileConnectorConfig, 'FileConnectorConfig', 'json');
  }
  var body : map[string]any = {};
  if (!Util.isUnset(request.connectorName)) {
    body['ConnectorName'] = request.connectorName;
  }
  if (!Util.isUnset(request.connectorType)) {
    body['ConnectorType'] = request.connectorType;
  }
  if (!Util.isUnset(request.description)) {
    body['Description'] = request.description;
  }
  if (!Util.isUnset(request.fileConnectorConfigShrink)) {
    body['FileConnectorConfig'] = request.fileConnectorConfigShrink;
  }

  var req = new OpenApi.OpenApiRequest{ 
    headers = headers,
    body = OpenApiUtil.parseToMap(body),
  };
  var params = new OpenApi.Params{
    action = 'AddConnector',
    version = '2023-12-29',
    protocol = 'HTTPS',
