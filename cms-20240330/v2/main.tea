    TransformAction
  ](name='transformerSetting', description='The transformation settings.'),
  type?: string(name='type', description='The type.', example='ALERT_CUSTOM'),
  updateTime?: string(name='updateTime', description='The time when the policy was last updated.', example='2024-12-16T02:00:23Z'),
  userId?: string(name='userId', description='The user ID.', example='123123'),
  workspace?: string(name='workspace', description='The workspace.', example='workspace-test'),
}

model AlertRuleAction {
  actions?: [ string ](name='actions', description='A list of action integration IDs.'),
}

model AlertRuleAlertMetricFilterDef {
  dim?: string(name='dim', description='The dimension in APM metrics.', example='status'),
  dimDisabled?: boolean(name='dimDisabled', description='If set to \\\\`true\\\\`, the filter item does not appear in the \\\\`group by\\\\` clause of a PromQL query.', example='true'),
  displayNameCn?: string(name='displayNameCn', description='The display name in Chinese.', example='应用状态'),
  displayNameEn?: string(name='displayNameEn', description='The display name in English.', example='Application Status'),
  hidden?: boolean(name='hidden', description='Specifies whether to hide the filter. If hidden, the filter does not appear in the frontend UI. However, its value can be uploaded when rendering a PromQL query. For example, in an Application Performance Management (APM) scenario, the pid filter is typically hidden from the configuration UI. The frontend displays it as a separate application search list.', example='true'),
  labelDisabled?: boolean(name='labelDisabled', description='If set to \\\\`true\\\\`, the filter item does not appear in the label filter of a PromQL query.', example='true'),
  opt?: string(name='opt', description='The operator for the filter condition.', example='='),
  supportedOpts?: [ 
    {
      displayNameCn?: string(name='displayNameCn', description='The display name in Chinese.', example='在线'),
      displayNameEn?: string(name='displayNameEn', description='The display name in English.', example='Online'),
      value?: string(name='value', description='The matching value.', example='online'),
    }
  ](name='supportedOpts', description='A list of supported options.'),
}

model AlertRuleAlertMetricInput {
  filterValues?: [
    AlertRuleAlertMetricInputFilterValue
  ](name='filterValues', description='A list of filter conditions. Call the ListAlertMetrics operation to query the lists of parameters and filter conditions that the metric supports.'),
  groupId?: string(name='groupId', description='The key of the metric group.', example='apm.jvm'),
  metricId?: string(name='metricId', description='The key of the predefined metric.', example='appstat.jvm.GcPsMarkSweepCount'),
  paramValues?: [
    AlertRuleAlertMetricInputParamValue
  ](name='paramValues', description='A list of parameters. Call the ListAlertMetrics operation to query the lists of parameters and filter conditions that the metric supports.'),
}

model AlertRuleAlertMetricInputFilterValue {
  dim?: string(name='dim', description='The dimension of the filter condition.

This parameter is required.', example='rootIp'),
  opt?: string(name='opt', description='The operator for the filter condition.

This parameter is required.', example='ALL'),
  value?: string(name='value', description='The value of the filter condition.', example='127.0.0.1'),
}

model AlertRuleAlertMetricInputParamValue {
  name?: string(name='name', description='The name of the predefined metric parameter.

This parameter is required.', example='paramName'),
  value?: string(name='value', description='The value of the predefined metric parameter.

This parameter is required.', example='paramValue'),
}

model AlertRuleAlertMetricParamDef {
  maxWidth?: int32(name='maxWidth', description='The maximum width of the input control. This parameter is valid only for SELECT_PARAM and INPUT_PARAM.', example='200'),
  minWidth?: int32(name='minWidth', description='The minimum width of the input control. This parameter is valid only for SELECT_PARAM and INPUT_PARAM.', example='100'),
  name?: string(name='name', description='The name.', example='env'),
  placeholderCn?: string(name='placeholderCn', description='The Chinese placeholder text displayed on the frontend. This parameter is valid only for INPUT_PARAM.', example='请输入值'),
  placeholderEn?: string(name='placeholderEn', description='The English placeholder text displayed on the frontend. This parameter is valid only for INPUT_PARAM.', example='Enter value'),
  type?: string(name='type', description='● TEXT_PARAM: A read-only text parameter defined by the backend. No user input control is displayed on the frontend.● INPUT_PARAM: An input box parameter.● SELECT_PARAM: A selection box parameter.', example='TEXT_PARAM'),
  value?: string(name='value', description='The value.', example='staging'),
  values?: [ 
    {
      labelCn?: string(name='labelCn', description='The Chinese display name of the option.', example='测试环境'),
      labelEn?: string(name='labelEn', description='The English display name of the option.', example='Staging'),
      value?: string(name='value', description='The value.', example='staging'),
    }
  ](name='values', description='The list of available options in the drop-down list. This parameter is valid only for SELECT_PARAM.'),
}

model AlertRuleCondition {
  alertCount?: int32(name='alertCount', description='Applicable condition type: SLS_CONDITION.

The number of times the condition must be met before an alert is triggered. Default value: 1.', example='1'),
  caseList?: [ 
    {
      condition?: string(name='condition', description='The match expression. Example: logLevel: error.', example='logLevel: error'),
      countCondition?: string(name='countCondition', description='The count match expression. Examples:
Range combination: __count__ >= 3 && __count__ <= 10
Single range: __count__ >= 3', example='count >= 3'),
      level?: string(name='level', description='The alert level when the condition is met.', example='INFO'),
      type?: string(name='type', description='The match type: has data, has a specific number of data entries, has data match, or has a specific number of data matches.

Valid values:
- HasData: has data
- HasDataCount: has a specific number of data entries
- HasDataMatch: has data match
- HasDataMatchCount: has a specific number of data matches', example='HasData'),
    }
  ](name='caseList', description='Applicable condition type: SLS_CONDITION.

The list of Simple Log Service alert conditions.'),
  compareList?: [ 
    {
      aggregate?: string(name='aggregate', description='The aggregate functions applied after time series aggregation.

- count
- sum
- avg
- min
- max
- p90
- p95
- p99', example='count'),
      baseUnit?: string(name='baseUnit', description='The data unit.', example='%'),
      displayUnit?: string(name='displayUnit', description='The display unit.', example='%'),
      oper?: string(name='oper', description='The comparison operator. Determines whether year-over-year or period-over-period comparison is used.

- Greater than: GT
- Greater than or equal to: GTE
- Less than: LT
- Less than or equal to: LTE
- Equal to: EQ
- Not equal to: NE
- Year-over-year increase: YOY_UP
- Year-over-year decrease: YOY_DOWN', example='GT'),
      value?: double(name='value', description='The comparison threshold.', example='50'),
      valueLevelList?: [ 
        {
          level?: string(name='level', description='The level corresponding to the threshold.', example='INFO'),
          value?: double(name='value', description='The comparison threshold.', example='120'),
        }
      ](name='valueLevelList', description='The list of alert levels for different values.'),
      yoyTimeUnit?: string(name='yoyTimeUnit', description='The time unit for year-over-year comparison. Valid only when oper is set to YOY_UP or YOY_DOWN.
Valid values: minute, hour, day, week, month.', example='month'),
      yoyTimeValue?: int32(name='yoyTimeValue', description='The value of the year-over-year time period. Used together with yoyTimeUnit.', example='1'),
    }
  ](name='compareList', description='Applicable condition type: APM_CONDITION.

The list of Application Performance Monitoring (APM) alert comparison conditions.'),
  compositeEscalation?: {
    escalations?: [ 
      {
        comparisonOperator?: string(name='comparisonOperator', description='The threshold comparison operator. Valid values:

- GreaterThanOrEqualToThreshold: Greater than or equal to.
- GreaterThanThreshold: Greater than.
- LessThanOrEqualToThreshold: Less than or equal to.
- LessThanThreshold: Less than.
- NotEqualToThreshold: Not equal to.
- EqualToThreshold: Equal to.
- GreaterThanYesterday: Year-over-year increase compared with the same time yesterday.
- LessThanYesterday: Year-over-year decrease compared with the same time yesterday.
- GreaterThanLastWeek: Year-over-year increase compared with the same time last week.
- LessThanLastWeek: Year-over-year decrease compared with the same time last week.
- GreaterThanLastPeriod: Period-over-period increase compared with the previous period.
- LessThanLastPeriod: Period-over-period decrease compared with the previous period.', example='GreaterThanOrEqualToThreshold'),
        metricName?: string(name='metricName', description='The metric name.', example='cpu_total'),
        period?: long(name='period', description='The time window of the metric.', example='60'),
        statistics?: string(name='statistics', description='The statistical method. The value of this parameter is determined by the Statistics column corresponding to the MetricName of the specified cloud service. Example values for the statistical method of a metric:

- $Maximum: Maximum value.
- $Minimum: Minimum value.
- $Average: Average value.
- $Availability: Availability rate (typically used for site monitoring).

Note: $ is the unified prefix symbol for metrics.', example='$Maximum'),
        threshold?: double(name='threshold', description='The alert threshold.', example='50'),
      }
    ](name='escalations', description='The list of composite conditions for multiple metrics.'),
    level?: string(name='level', description='The alert level triggered when the condition is met. Composite metric alerts support only one level.', example='INFO'),
    relation?: string(name='relation', description='The relationship between multiple metric conditions. Valid values: and, or.', example='and'),
    times?: int32(name='times', description='The number of times the condition must be met to trigger an alert.', example='3'),
  }(name='compositeEscalation', description='Applicable condition type: CMS_BASIC_CONDITION.

This parameter takes effect only when escalationType is set to composite. The composite metric alert condition.'),
  countOperator?: string(name='countOperator'),
  countThreshold?: long(name='countThreshold'),
  enableSeveritySuppression?: boolean(name='enableSeveritySuppression'),
  escalationType?: string(name='escalationType', description='Applicable condition type: CMS_BASIC_CONDITION.

Valid values:

- simple: simple metric condition.
- composite: composite metric condition.
- express: expression condition.', example='simple'),
  expressEscalation?: {
    level?: string(name='level', description='The alert level triggered when the condition is met. Expression-based alerts support only one level.

- CRITICAL
- WARNING
- INFO', example='INFO'),
    rawExpression?: string(name='rawExpression', description='The alert condition expression.', example='@cpu_total[60].$Average > 60'),
    times?: int32(name='times', description='The number of times the condition must be met to trigger an alert.', example='3'),
  }(name='expressEscalation', description='Applicable condition type: CMS_BASIC_CONDITION.

This parameter takes effect only when escalationType is set to composite. The multi-metric composite alert condition.'),
  matchField?: string(name='matchField'),
  matchOperator?: string(name='matchOperator'),
  matchValue?: string(name='matchValue'),
  max?: double(name='max'),
  min?: double(name='min'),
  noDataAlertLevel?: string(name='noDataAlertLevel', description='Applicable condition type: APM_CONDITION.

The alert level when no data is available. If this parameter is not specified, no alert is triggered when no data is available.', example='INFO'),
  noDataAppendValue?: string(name='noDataAppendValue', description='Applicable condition type: APM_CONDITION.

The compensation value when no data is available.', example='1'),
  noDataPolicy?: string(name='noDataPolicy', description='Applicable condition type: CMS_BASIC_CONDITION.

The method used to handle alerts when no monitoring data is available. Valid values:

- KEEP_LAST_STATE (default): No action is taken.
- INSUFFICIENT_DATA: The alert content indicates that no data is available.
- OK: Normal.', example='KEEP_LAST_STATE'),
  oper?: string(name='oper', description='The comparison operator. Specifies whether to use year-over-year or period-over-period comparison. Valid values:

- GT: greater than.
- GTE: greater than or equal to.
- LT: less than.
- LTE: less than or equal to.
- EQ: equal to.
- NE: not equal to.
- YOY_UP: year-over-year increase.
- YOY_DOWN: year-over-year decrease.', example='LT'),
  relation?: string(name='relation', description='Applicable condition type: APM_CONDITION.

The logical relationship between multiple conditions. Valid values:
- and
- or', example='and'),
  simpleEscalation?: {
    escalations?: [ 
      {
        comparisonOperator?: string(name='comparisonOperator', description='The threshold comparison operator. Valid values:

- GreaterThanOrEqualToThreshold: Greater than or equal to.
- GreaterThanThreshold: Greater than.
- LessThanOrEqualToThreshold: Less than or equal to.
- LessThanThreshold: Less than.
- NotEqualToThreshold: Not equal to.
- EqualToThreshold: Equal to.
- GreaterThanYesterday: Year-over-year increase compared with the same time yesterday.
- LessThanYesterday: Year-over-year decrease compared with the same time yesterday.
- GreaterThanLastWeek: Year-over-year increase compared with the same time last week.
- LessThanLastWeek: Year-over-year decrease compared with the same time last week.
- GreaterThanLastPeriod: Period-over-period increase compared with the previous period.
- LessThanLastPeriod: Period-over-period decrease compared with the previous period.', example='GreaterThanOrEqualToThreshold'),
        level?: string(name='level', description='The alert level triggered when the condition is met. Expression-based alerts support only one level.

- CRITICAL
- WARNING
- INFO', example='INFO'),
        statistics?: string(name='statistics', description='The statistical method. The value of this parameter is determined by the Statistics column corresponding to the MetricName of the specified cloud service. Examples: Maximum, Minimum, and Average.', example='Average'),
        threshold?: double(name='threshold', description='The alert threshold.', example='100'),
        times?: int32(name='times', description='The number of times the condition must be met to trigger an alert.', example='3'),
      }
    ](name='escalations', description='The list of conditions. When an alert rule corresponds to multiple levels, each level has a condition object.'),
    metricName?: string(name='metricName', description='Applicable condition type: CMS_BASIC_CONDITION.

The metric associated with the alert condition.', example='cpu_total'),
    period?: long(name='period', description='The time window of the metric. Unit: seconds.', example='60'),
  }(name='simpleEscalation', description='Applicable condition type: CMS_BASIC_CONDITION.

This parameter takes effect only when escalationType is set to simple. The alert condition configured for a single metric.'),
  thresholdList?: [ 
    {
      max?: double(name='max'),
      min?: double(name='min'),
      severity?: string(name='severity'),
      threshold?: double(name='threshold'),
    }
  ](name='thresholdList'),
  triggers?: [ 
    {
      durationSecs?: int32(name='durationSecs'),
      expression?: {
        conditions?: [ 
          {
            expressionType?: string(name='expressionType'),
            operator?: string(name='operator'),
            queryName?: string(name='queryName'),
            threshold?: double(name='threshold'),
          }
        ](name='conditions'),
        expressionType?: string(name='expressionType'),
        logicOperator?: string(name='logicOperator'),
      }(name='expression'),
      severity?: string(name='severity'),
    }
  ](name='triggers'),
  type?: string(name='type', description='The rule condition type. Valid values:
- SLS_CONDITION: Simple Log Service alert condition.
- APM_CONDITION: APM alert condition.
- CMS_BASIC_CONDITION: CloudMonitor Basic monitoring alert condition.

This parameter is required.', example='SLS_CONDITION'),
  value?: double(name='value', description='The threshold that triggers the alert.', example='60'),
}

model AlertRuleDataSource {
  appType?: string(name='appType', description='Applies to the APM_DS data source type.

The type of the application. Valid value:

- apm', example='apm'),
  dsList?: [ 
    {
      project?: string(name='project', description='The SLS project.', example='mySlsProject'),
      regionId?: string(name='regionId', description='The region where the SLS project is located.', example='cn-hangzhou'),
