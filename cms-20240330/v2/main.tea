    ](name='filters', description='A list of filter conditions to further screen resources.'),
    type?: string(name='type', description='The resource type.', example='apm'),
  }(name='entityFilter', description='A resource filter used to screen target resources.'),
  expr?: string(name='expr', description='Applicable query type: PROMQL_QUERY.

The query expression (PromQL).', example='sum(sum(max_over_time(kube_pod_status_phase{phase=~\\\\"Pending\\\\",job=\\\\"_kube-state-metrics\\\\"}[5m])) by (pod)) > 1000'),
  firstJoin?: AlertRuleSlsQueryJoin(name='firstJoin', description='Applicable query type: SLS_MULTI_QUERY.

The configuration for the join operation on the result sets of subquery 1 (queries[0]) and subquery 2 (queries[1]).'),
  groupFieldList?: [ string ](name='groupFieldList', description='Applicable query type: SLS_MULTI_QUERY.

A list of grouping field names.'),
  groupId?: string(name='groupId', description='Applicable query type: CMS_BASIC_QUERY.

The ID of the associated application group. This parameter is valid only when relationType is set to GROUP.', example='23423'),
  groupType?: string(name='groupType', description='Applicable query type: SLS_MULTI_QUERY.

The grouping type. Valid values:

- none: No grouping.

- label: Automatic grouping by tag.

- custom: Custom grouping by tag.', example='label'),
  labelFilters?: [ 
    {
      name?: string(name='name', description='The name of the label.', example='app'),
      operator?: string(name='operator', description='The comparison operator that determines how to match the label value.', example='='),
      value?: string(name='value', description='The value of the label.', example='web'),
    }
  ](name='labelFilters', description='An array of label filters.'),
  markTags?: [ 
    {
      key?: string(name='key'),
      value?: string(name='value'),
    }
  ](name='markTags'),
  metric?: string(name='metric', description='The name of the metric.', example='memory'),
  metricSet?: string(name='metricSet', description='The collection of metrics.', example='cpu_usage'),
  namespace?: string(name='namespace', description='Applicable query type: CMS_BASIC_QUERY.

The namespace of the metric.', example='acs_ecs_dashboard'),
  queries?: [ 
    {
      apmAlertMetricId?: string(name='apmAlertMetricId', description='Applicable query type: APM_MULTI_QUERY.

The ID of the predefined Application Performance Management (APM) metric.', example='appstat.jvm.ThreadNewCount'),
      apmFilters?: [ 
        {
          dim?: string(name='dim', description='The dimension in the APM metric.', example='rpcType'),
          type?: string(name='type', description='The filter operation type:

- eq: Equal to

- neq: Not equal to

- match: Regular expression match

- nmatch: Regular expression non-match', example='eq'),
          value?: string(name='value', description='The value that corresponds to the filter operation.', example='h3ji7a0y9i@2ac80e27fdfd0a2'),
        }
      ](name='apmFilters', description='Applicable query type: ARMS_MULTI_QUERY.

The dimension filter configuration for the APM metric. This parameter must be used with apmAlertMetricId.'),
      apmGroupBy?: [ string ](name='apmGroupBy', description='Applicable query type: ARMS_MULTI_QUERY.

A list of aggregation dimensions for the query. This specifies the metric dimensions to use for aggregation.'),
      duration?: long(name='duration', description='Applicable query type: ARMS_MULTI_QUERY.

The duration of the alert data.', example='120'),
      end?: long(name='end', description='Applicable query type: SLS_MULTI_QUERY.

The relative end time of the time offset.

If you specify start and end, do not specify window.', example='0'),
      expr?: string(name='expr', description='Applicable query types: APM_MULTI_QUERY and SLS_MULTI_QUERY.

The query expression.

- For APM_MULTI_QUERY, this parameter is optional. It is the PromQL expression generated for a predefined metric, used for data preview.

- For SLS_MULTI_QUERY, this parameter is the SQL search statement.', example='sum by (rpc,acs_arms_service_id,pid,rpcType) (sum_over_time_lorc(arms_app_requests_count_ign_destid_endpoint_parent_ppid_prpc{callKind=~\\\\"http|rpc|custom_entry|server|consumer\\\\",pid=\\\\"gaddp9ap8q@cb005ffdf44b8ac\\\\",source=\\\\"apm\\\\"}[1m]))'),
      name?: string(name='name'),
      promQl?: string(name='promQl'),
      start?: long(name='start', description='Applicable query type: SLS_MULTI_QUERY.

The relative start time of the time offset for an SLS query.

If you specify start and end, do not specify window. For example, if start is 15 and timeUnit is minute, the time offset starts 15 minutes ago.', example='15'),
      timeUnit?: string(name='timeUnit', description='Applicable query type: SLS_MULTI_QUERY.

The time unit for the start, end, and window parameters. Valid values: day, hour, minute, and second.', example='hour'),
      window?: long(name='window', description='Applicable query type: SLS_MULTI_QUERY.

The query interval for a time frame. If you specify window, do not specify start and end.', example='1'),
    }
  ](name='queries', description='Applicable query types: SLS_MULTI_QUERY and APM_MULTI_QUERY.

A list of subqueries.

For the SLS_MULTI_QUERY type, you can include up to three subqueries. The number and order of subqueries must match the sub-datasource configurations in datasource.dsList.'),
  relationType?: string(name='relationType', description='Applicable query type: CMS_BASIC_QUERY.

The resource scope for the rule query. Valid values:

- USER: All resources under the user ID.

- GROUP: An application group.

- INSTANCE: A list of specified instances.', example='USER'),
  secondJoin?: AlertRuleSlsQueryJoin(name='secondJoin', description='Applicable query type: SLS_MULTI_QUERY.

The configuration for the join operation on the result sets of subquery 2 (queries[2]) and subquery 3 (queries[3]).'),
  serviceIds?: [ string ](name='serviceIds', description='A list of service IDs.'),
  type?: string(name='type', description='The query type.

Valid values:

- PROMQL_QUERY: A PromQL query.

- SLS_MULTI_QUERY: A Simple Log Service (SLS) query.

- APM_MULTI_QUERY: An APM query.

- CMS_BASIC_QUERY: A basic CloudMonitor query.

Different query types have different valid parameters in the query object. For more information, see the "Applicable query type" description for each parameter.

The query type must match the data source type. The mappings are as follows:

- Prometheus data source (PROMETHEUS_DS): PROMQL_QUERY

- APM data source (APM_DS): APM_MULTI_QUERY

- SLS data source (SLS_MULTI_DS): SLS_MULTI_QUERY

- Basic CloudMonitor data source (CMS_BASIC_DS): CMS_BASIC_QUERY

This parameter is required.', example='PROMQL_QUERY'),
}

