  resource?: EventResourceForEventView(name='resource', description='Information about the resource associated with the event, such as the instance ID, IP address, and region.'),
  severity?: string(name='severity', description='The severity level of the event.', example='"CRITICAL"'),
  source?: string(name='source', description='The name of the source system or service, such as ECS, RDS, or VPC.', example='"ECS"'),
  sourcetype?: string(name='sourcetype', description='The type of event source. It distinguishes between sources such as monitoring systems, Simple Log Service, and application observability.', example='"CloudMonitor"'),
  status?: string(name='status', description='The current status of the event.', example='Running'),
  subject?: string(name='subject', description='The subject or title of the event. It briefly describes the event.', example='"Instance cpu usage exceeds threshold"'),
  subtype?: string(name='subtype', description='The event subtype.', example='"HighCPUUsage"'),
  sysId?: string(name='sysId', description='The internal system event ID. It is used for internal tracking and log association.', example='"sys-event-987654321"'),
  time?: string(name='time', description='The time when the event occurred.', example='"2025-04-05T10:30:00Z"'),
  timestamp?: long(name='timestamp', description='The timestamp of the event occurrence.', example='1743846600000'),
  type?: string(name='type', description='The event type.', example='"Alert"'),
  workspace?: string(name='workspace', description='The ID or name of the workspace. It is used for multi-tenant or organization fencing.', example='"ws-abc123"'),
