A list of filter dimensions for the resource.'),
  domain?: string(name='domain', description='The realm to which the resource belongs.', example='rum'),
  duration?: long(name='duration', description='Applicable query type: PROMQL_QUERY.

The duration for which the alert data persists, in seconds.', example='60'),
  entityFields?: [ 
    {
      field?: string(name='field', description='The name of the entity field.', example='instanceId'),
      value?: string(name='value', description='The value of the field.', example='i-abc123'),
    }
  ](name='entityFields', description='An array of entity field filters.'),
  entityFilter?: {
    domain?: string(name='domain', description='The domain of the resource type.', example='rum'),
    filters?: [ 
      {
        field?: string(name='field', description='The field.', example='instanceId'),
        operator?: string(name='operator', description='The comparison operator.', example='='),
