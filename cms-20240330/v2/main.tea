}

model AlertEventIntegrationPolicyForView {
  alertEventIntegrationPolicyId?: string(name='alertEventIntegrationPolicyId', description='The universally unique identifier (UUID).', example='123123123'),
  alertEventIntegrationPolicyName?: string(name='alertEventIntegrationPolicyName', description='The name.

This parameter is required.', example='集成名'),
  createTime?: string(name='createTime', description='The time when the policy was created.', example='2025-03-11T08:21:58Z'),
