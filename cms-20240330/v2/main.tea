model AlertRuleQuery {
  checkAfterDataComplete?: boolean(name='checkAfterDataComplete', description='Applicable query type: PROMQL_QUERY.
Whether to perform alert evaluation only after data completeness is ensured.', example='true'),
  dimensions?: [ map[string]string ](name='dimensions', description='Applicable query type: CMS_BASIC_QUERY.
List of filtering dimensions for the resource.'),
  domain?: string(name='domain', description='资源所属的领域。', example='rum'),
  duration?: long(name='duration', description='Applicable query type: PROMQL_QUERY.
Duration of alert data, in seconds.', example='60'),
  entityFields?: [ 
    {
      field?: string(name='field'),
      value?: string(name='value'),
    }
  ](name='entityFields'),
  entityFilter?: {
    domain?: string(name='domain', description='资源类型域。', example='rum'),
    filters?: [ 
      {
        field?: string(name='field', description='字段', example='instanceId'),
        operator?: string(name='operator', description='比较运算符。', example='='),
        value?: string(name='value', description='匹配的值。', example='wait_throw'),
      }
    ](name='filters', description='过滤条件列表，用于进一步筛选资源。'),
    type?: string(name='type', description='资源类型。', example='apm'),
  }(name='entityFilter', description='资源过滤器，用于筛选目标资源。'),
  expr?: string(name='expr', description='Applicable query type: PROMQL_QUERY.
Query expression (PromQL).', example='sum(sum(max_over_time(kube_pod_status_phase{phase=~\\\\"Pending\\\\",job=\\\\"_kube-state-metrics\\\\"}[5m])) by (pod)) > 1000'),
  firstJoin?: AlertRuleSlsQueryJoin(name='firstJoin', description='Applicable query type: SLS_MULTI_QUERY.
Configuration for the set join operation between the results of subquery 1 (queries[0]) and subquery 2 (queries[1]).'),
  groupFieldList?: [ string ](name='groupFieldList', description='Applicable query type: SLS_MULTI_QUERY.
List of grouping field names.'),
  groupId?: string(name='groupId', description='Applicable query type: CMS_BASIC_QUERY.
Associated application group ID, valid only when relationType = GROUP.', example='23423'),
  groupType?: string(name='groupType', description='Applicable query type: SLS_MULTI_QUERY.
Grouping type, with the following possible values:

- none: No grouping.
- label: Automatic label grouping.
- custom: Custom label grouping.', example='label'),
  labelFilters?: [ 
    {
      name?: string(name='name'),
      operator?: string(name='operator'),
      value?: string(name='value'),
    }
  ](name='labelFilters'),
  markTags?: [ 
    {
      key?: string(name='key'),
      value?: string(name='value'),
    }
  ](name='markTags'),
  metric?: string(name='metric', description='指标名。', example='memory'),
  metricSet?: string(name='metricSet', description='监控指标集合。', example='cpu_usage'),
  namespace?: string(name='namespace', description='Applicable query type: CMS_BASIC_QUERY.
Namespace of the metric.', example='acs_ecs_dashboard'),
  queries?: [ 
    {
      apmAlertMetricId?: string(name='apmAlertMetricId', description='Applicable query type: APM_MULTI_QUERY.
ID of the APM predefined metric.', example='appstat.jvm.ThreadNewCount'),
      apmFilters?: [ 
        {
          dim?: string(name='dim', description='Dimension in APM metrics.', example='rpcType'),
          type?: string(name='type', description='Filter operation types:

- eq: equals.
- neq: not equals.
- match: regular expression match.
- nmatch: regular expression not match.', example='eq'),
          value?: string(name='value', description='The corresponding value for the filter operation.', example='h3ji7a0y9i@2ac80e27fdfd0a2'),
        }
      ](name='apmFilters', description='Applicable query type: ARMS_MULTI_QUERY.
Dimension filter configuration for APM metrics. Must be used in conjunction with apmAlertMetricId.'),
      apmGroupBy?: [ string ](name='apmGroupBy', description='Applicable query type: ARMS_MULTI_QUERY.
List of aggregation dimensions for the query, i.e., the dimensions by which the metric is aggregated.'),
      duration?: long(name='duration', description='Applicable query type: ARMS_MULTI_QUERY.
Alert (data) duration.', example='120'),
      end?: long(name='end', description='Applicable query type: SLS_MULTI_QUERY.
Time offset end time (relative).
If start and end are specified, do not specify window.', example='0'),
      expr?: string(name='expr', description='Applicable query types: APM_MULTI_QUERY, SLS_MULTI_QUERY.
Query expression.

- For APM_MULTI_QUERY, this field is optional and contains the PromQL generated for predefined metrics (used for data preview).
- For SLS_MULTI_QUERY, this field contains the SQL query statement.', example='sum by (rpc,acs_arms_service_id,pid,rpcType) (sum_over_time_lorc(arms_app_requests_count_ign_destid_endpoint_parent_ppid_prpc{callKind=~\\\\"http|rpc|custom_entry|server|consumer\\\\",pid=\\\\"gaddp9ap8q@cb005ffdf44b8ac\\\\",source=\\\\"apm\\\\"}[1m]))'),
      name?: string(name='name'),
      promQl?: string(name='promQl'),
      start?: long(name='start', description='Applicable query type: SLS_MULTI_QUERY.
SLS query time offset start time (relative).
If start and end are specified, do not specify window. For example: start=15, timeUnit=minute, which means 15 minutes ago.', example='15'),
      timeUnit?: string(name='timeUnit', description='Applicable query type: SLS_MULTI_QUERY.
Time units for the start, end, and window parameters: day/hour/minute/second.', example='hour'),
      window?: long(name='window', description='Applicable query type: SLS_MULTI_QUERY.
Exact-hour time query interval. If window is specified, start and end should not be specified.', example='1'),
    }
  ](name='queries', description='Applicable query types: SLS_MULTI_QUERY, APM_MULTI_QUERY.
List of subqueries.

For the SLS_MULTI_QUERY type, the list can contain up to three subqueries, and the number and order of subqueries must match the sub-datasource configurations in datasource.dsList.'),
  relationType?: string(name='relationType', description='Applicable query type: CMS_BASIC_QUERY.
Resource scope for the rule query, with the following allowed values:
- USER: All resources under the user\\\\"s UID.
- GROUP: Application group.
- INSTANCE: Specified list of instances.', example='USER'),
  secondJoin?: AlertRuleSlsQueryJoin(name='secondJoin', description='Applicable query type: SLS_MULTI_QUERY.
Configuration for the set join operation between the results of subquery 2 (queries[2]) and subquery 3 (queries[3]).'),
  serviceIds?: [ string ](name='serviceIds', description='Service ID list.'),
  type?: string(name='type', description='Query type.

Valid values:

- PROMQL_QUERY: PromQL query
- SLS_MULTI_QUERY: SLS query
- APM_MULTI_QUERY: APM query
- CMS_BASIC_QUERY: Basic CloudMonitor query

The valid fields within the query object vary depending on the query type. Refer to the "Applicable query type" description in each field\\\\"s documentation for details.

The query type must match the data source type, with the following correspondences:

- Prometheus data source (PROMETHEUS_DS): PROMQL_QUERY
- APM data source (APM_DS): APM_MULTI_QUERY
- SLS data source (SLS_MULTI_DS): SLS_MULTI_QUERY
- Basic CloudMonitor data source (CMS_BASIC_DS): CMS_BASIC_QUERY.

This parameter is required.', example='PROMQL_QUERY'),
}

