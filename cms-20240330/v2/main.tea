model AlertRuleAlertMetricFilterDef {
  dim?: string(name='dim', description='Dimension in APM metrics.', example='status'),
  dimDisabled?: boolean(name='dimDisabled', description='When true, the filter item will not appear in the GROUP BY clause of the PromQL.', example='true'),
  displayNameCn?: string(name='displayNameCn', description='Display Name (Chinese).', example='Application Status'),
  displayNameEn?: string(name='displayNameEn', description='Display Name (English).', example='Application Status'),
  hidden?: boolean(name='hidden', description='Whether to hide. If hidden, it will not be displayed in the frontend UI, but its value can still be included when rendering the PromQL. A typical example is the "pid" filter condition in APM scenarios, which is generally not exposed through configurable UI elements but instead presented as a separate application search list in the frontend.', example='true'),
  labelDisabled?: boolean(name='labelDisabled', description='When true, the filter item will not appear in the label filter of the PromQL.', example='true'),
  opt?: string(name='opt', description='Filter Condition Operator.', example='='),
  supportedOpts?: [ 
    {
      displayNameCn?: string(name='displayNameCn', description='Display Name (Chinese).', example='Online'),
      displayNameEn?: string(name='displayNameEn', description='Display Name (English).', example='Online'),
      value?: string(name='value', description='Matching value.', example='online'),
    }
  ](name='supportedOpts', description='List of supported options.'),
}

