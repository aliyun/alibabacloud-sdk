  ogEntityInfoPromInstances?: [
    ObserveGroupPromInstance
  ](name='ogEntityInfoPromInstances', description='The set of Prometheus instances to which og_entity_info is written. Includes two source types: system (automatically identified by the system) and custom (user-defined).'),
  originGroupId?: string(name='originGroupId', description='The product_group.id of the version 1.0 application group. This parameter is valid only when sourceOrigin is set to synced_from_1_0.'),
  regionId?: string(name='regionId', description='The region ID to which the group belongs.'),
  resourceGroupId?: string(name='resourceGroupId', description='The Alibaba Cloud resource group ID.'),
  sourceOrigin?: string(name='sourceOrigin', description='The data source. Valid values:
- native_2_0: created natively in version 2.0.
- synced_from_1_0: synchronized from a version 1.0 application group.'),
  tags?: [ 
    {
      tagKey?: string(name='tagKey', description='The tag key.'),
      tagValue?: string(name='tagValue', description='The tag value.'),
    }
  ](name='tags', description='The resource tags (Alibaba Cloud standard tags) as an array of key-value pairs.'),
  workspaceId?: string(name='workspaceId', description='The workspace ID to which the group belongs. This value is set at the workspace level and cannot be changed after creation.'),
