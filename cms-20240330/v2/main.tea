model AlertRuleCondition {
  alertCount?: int32(name='alertCount', description='Applicable condition type: SLS_CONDITION.
Number of times the condition must be met before triggering an alert, default is 1.', example='1'),
  caseList?: [ 
    {
      condition?: string(name='condition', description='Matching expression, example: logLevel: error.', example='logLevel: error'),
      countCondition?: string(name='countCondition', description='Count matching expression, examples: range combination: count >= 3 && count <= 10; single range: count >= 3.', example='count >= 3'),
      level?: string(name='level', description='Alert severity level after condition is met.', example='INFO'),
      type?: string(name='type', description='Matching type: Has data / Has a specific number of data entries / Has matching data / Has a specific number of matching entries.

Valid values:

- HasData: Has data.
- HasDataCount: Has a specific number of data entries.
- HasDataMatch: Has matching data.
- HasDataMatchCount: Has a specific number of matching entries.', example='HasData'),
    }
  ](name='caseList', description='Applicable condition type: SLS_CONDITION.
SLS alert condition list.'),
  compareList?: [ 
    {
      aggregate?: string(name='aggregate', description='Time series post-aggregation functions:
- count
-  sum 
-  avg
-  min
-  max
-  p90
-  p95
-  p99', example='count'),
      baseUnit?: string(name='baseUnit', description='Data unit.', example='%'),
      displayUnit?: string(name='displayUnit', description='Display unit.', example='%'),
      oper?: string(name='oper', description='Comparison operations to determine whether it is year-over-year (YoY) or month-over-month (MoM):
- Greater than (GT),
- Greater than or equal to (GTE),
- Less than (LT),
- Less than or equal to (LTE),
- Equal to (EQ),
- Not equal to (NE),
- Year-over-year increase (YOY_UP),
- Year-over-year decrease (YOY_DOWN).', example='GT'),
      value?: double(name='value', description='Comparison threshold.', example='50'),
      valueLevelList?: [ 
        {
          level?: string(name='level', description='Severity level corresponding to the threshold.', example='INFO'),
          value?: double(name='value', description='Comparison threshold.', example='120'),
        }
      ](name='valueLevelList', description='List of alert severity levels for different values.'),
      yoyTimeUnit?: string(name='yoyTimeUnit', description='Year-over-year time unit (only applicable when oper=YOY_UP/YOY_DOWN): minute, hour, day, week, month.', example='month'),
      yoyTimeValue?: int32(name='yoyTimeValue', description='Year-over-year time value, used in conjunction with yoyTimeUnit.', example='1'),
    }
  ](name='compareList', description='Applicable condition type: APM_CONDITION.
APM alert comparison condition list.'),
  compositeEscalation?: {
    escalations?: [ 
      {
        comparisonOperator?: string(name='comparisonOperator', description='Threshold comparison operator, valid values:
- GreaterThanOrEqualToThreshold: greater than or equal to.
- GreaterThanThreshold: greater than.
- LessThanOrEqualToThreshold: less than or equal to.
- LessThanThreshold: less than.
- NotEqualToThreshold: not equal to.
- EqualToThreshold: equal to.
- GreaterThanYesterday: increased compared to the same time yesterday.
- LessThanYesterday: decreased compared to the same time yesterday.
- GreaterThanLastWeek: increased compared to the same time last week.
- LessThanLastWeek: decreased compared to the same time last week.
- GreaterThanLastPeriod: increased compared to the previous period (MoM).
- LessThanLastPeriod: decreased compared to the previous period (MoM).', example='GreaterThanOrEqualToThreshold'),
        metricName?: string(name='metricName', description='Metric name.', example='cpu_total'),
        period?: long(name='period', description='Metric time window.', example='60'),
        statistics?: string(name='statistics', description='Statistical method; the value of this parameter is determined by the Statistics column corresponding to the specified cloud product\\\\"s MetricName. This represents the statistical method for the monitoring metric. Example values:
- $Maximum: maximum value.
- $Minimum: minimum value.
- $Average: average value.
- $Availability: availability (typically used for site monitoring).
Note: "$" is a unified prefix symbol for monitoring metrics.', example='$Maximum'),
        threshold?: double(name='threshold', description='Alert threshold.', example='50'),
      }
    ](name='escalations', description='List of multi-metric composite conditions.'),
    level?: string(name='level', description='Alert severity level triggered when the condition is met (multi-metric composite alerts support only one level).', example='INFO'),
    relation?: string(name='relation', description='Relationship between multiple metric conditions; valid values are "and" or "or".', example='and'),
    times?: int32(name='times', description='Number of times the condition must be met to trigger an alert.', example='3'),
  }(name='compositeEscalation', description='Applicable condition type: CMS_BASIC_CONDITION.
Valid only when escalationType=composite; composite metric alert condition.'),
  enableSeveritySuppression?: boolean(name='enableSeveritySuppression'),
  escalationType?: string(name='escalationType', description='Applicable condition type: CMS_BASIC_CONDITION.
Valid values:
- simple: Simple metric condition,
- composite: Composite metric condition,
- express: Expression condition.', example='simple'),
  expressEscalation?: {
    level?: string(name='level', description='Alert severity level triggered when the condition is met (expression-based alerts support only one level): 

- CRITICAL 
- WARNING 
- INFO', example='INFO'),
    rawExpression?: string(name='rawExpression', description='Alert condition expression.', example='@cpu_total[60].$Average > 60'),
    times?: int32(name='times', description='Number of times the condition must be met to trigger an alert.', example='3'),
  }(name='expressEscalation', description='Applicable condition type: CMS_BASIC_CONDITION.
Valid only when escalationType=composite; multi-metric composite alert condition.'),
  noDataAlertLevel?: string(name='noDataAlertLevel', description='Applicable condition type: APM_CONDITION.
Alert severity level when no data is available; if not specified, no alert will be triggered for missing data.', example='INFO'),
  noDataAppendValue?: string(name='noDataAppendValue', description='Applicable condition type: APM_CONDITION.
Fallback value when no data is available.', example='1'),
  noDataPolicy?: string(name='noDataPolicy', description='Applicable condition type: CMS_BASIC_CONDITION.
Handling method when no monitoring data is available. Valid values:

- KEEP_LAST_STATE (default): No action is taken.
- INSUFFICIENT_DATA: Alert with "insufficient data" message.
- OK: Treat as normal.', example='KEEP_LAST_STATE'),
  oper?: string(name='oper', description='Comparison operations to determine whether it is year-over-year (YoY) or month-over-month (MoM):

- Greater than (GT),
- Greater than or equal to (GTE),
- Less than (LT),
- Less than or equal to (LTE),
- Equal to (EQ),
- Not equal to (NE),
- Year-over-year increase (YOY_UP),
- Year-over-year decrease (YOY_DOWN).', example='LT'),
  relation?: string(name='relation', description='Applicable condition type: APM_CONDITION.
Logical relationship between multiple conditions. Valid values: and, or.', example='and'),
  simpleEscalation?: {
    escalations?: [ 
      {
        comparisonOperator?: string(name='comparisonOperator', description='Threshold comparison operator, valid values:

- GreaterThanOrEqualToThreshold: greater than or equal to.
- GreaterThanThreshold: greater than.
- LessThanOrEqualToThreshold: less than or equal to.
- LessThanThreshold: less than.
- NotEqualToThreshold: not equal to.
- EqualToThreshold: equal to.
- GreaterThanYesterday: increased compared to the same time yesterday.
- LessThanYesterday: decreased compared to the same time yesterday.
- GreaterThanLastWeek: increased compared to the same time last week.
- LessThanLastWeek: decreased compared to the same time last week.
- GreaterThanLastPeriod: increased compared to the previous period (MoM).
- LessThanLastPeriod: decreased compared to the previous period (MoM).', example='GreaterThanOrEqualToThreshold'),
        level?: string(name='level', description='Alert severity level triggered when the condition is met (expression-based alerts support only one level): 
- CRITICAL 
- WARNING 
- INFO', example='INFO'),
        statistics?: string(name='statistics', description='Statistical method; the value of this parameter is determined by the Statistics column corresponding to the specified cloud product\\\\"s MetricName, for example: Maximum, Minimum, and Average.', example='Average'),
        threshold?: double(name='threshold', description='Alert threshold.', example='100'),
        times?: int32(name='times', description='Number of times the condition must be met to trigger an alert.', example='3'),
      }
    ](name='escalations', description='List of conditions; for an alert rule with multiple severity levels, each level corresponds to one condition object.'),
    metricName?: string(name='metricName', description='Applicable condition type: CMS_BASIC_CONDITION.
Metric associated with the alert condition.', example='cpu_total'),
    period?: long(name='period', description='Metric time window, in seconds.', example='60'),
  }(name='simpleEscalation', description='Applicable condition type: CMS_BASIC_CONDITION.
Only valid when escalationType=simple; specifies the alert condition for a single metric.'),
  triggers?: [ 
    {
      durationSecs?: int32(name='durationSecs'),
      expression?: {
        conditions?: [ 
          {
            expressionType?: string(name='expressionType'),
            operator?: string(name='operator'),
            queryName?: string(name='queryName'),
            threshold?: double(name='threshold'),
          }
        ](name='conditions'),
        expressionType?: string(name='expressionType'),
        logicOperator?: string(name='logicOperator'),
      }(name='expression'),
      severity?: string(name='severity'),
    }
  ](name='triggers'),
  type?: string(name='type', description='Rule condition type, valid values:

SLS_CONDITION (SLS alert condition),
APM_CONDITION (APM alert condition),
CMS_BASIC_CONDITION (Basic Cloud Monitoring alert condition).

This parameter is required.', example='SLS_CONDITION'),
  value?: double(name='value', description='Alert triggering threshold.', example='60'),
}

model AlertRuleDataSource {
  appType?: string(name='appType', description='Applicable data source type: APM_DS.
Application type: 

- apm.', example='apm'),
  dsList?: [ 
    {
      project?: string(name='project', description='SLS project', example='mySlsProject'),
      regionId?: string(name='regionId', description='The region where the SLS project is located.', example='cn-hangzhou'),
      store?: string(name='store', description='LogStore/MetricStore name.', example='mySlsLogStore'),
      type?: string(name='type', description='Type of SLS data sub-source:

- SLS_LOG_DS: LogStore data source.
- SLS_METRIC_DS: MetricStore data source.', example='SLS_LOG_DS'),
    }
  ](name='dsList', description='Applicable data source type: SLS_MULTI_DS.
List of sub-data sources.'),
  instanceId?: string(name='instanceId', description='Applicable data source type: PROMETHEUS_DS.
Prometheus instance ID.', example='rw-bbe8961b4a59be0'),
  namespace?: string(name='namespace', description='Applicable data source type: ENTERPRISE_DS.
Name of the enterprise cloud monitoring metric repository.', example='aliyun-default'),
  regionId?: string(name='regionId', description='Applicable data source types: APM_DS, PROMETHEUS_DS.
The regionId to which the data source belongs.', example='cn-hangzhou'),
  tenantId?: string(name='tenantId'),
  type?: string(name='type', description='Data source type.
Valid values:
- PROMETHEUS_DS: Prometheus data source.
- SLS_MULTI_DS: SLS data source.
- APM_DS: Application monitoring data source.
- CMS_BASIC_DS: Basic cloud monitoring data source.
- ENTERPRISE_DS: Enterprise cloud monitoring data source.

This parameter is required.', example='PROMETHEUS_DS'),
}

