model AlertRuleCondition {
  alertCount?: int32(name='alertCount', description='Applicable to the SLS_CONDITION type.

The number of times the condition must be met to trigger an alert. The default value is 1.', example='1'),
  caseList?: [ 
    {
      condition?: string(name='condition', description='The matching expression. Example: logLevel: error', example='logLevel: error'),
      countCondition?: string(name='countCondition', description='The expression for matching a quantity. Examples:
Combined range: **count** >= 3 && **count** <= 10
Single range: **count** >= 3', example='count >= 3'),
      level?: string(name='level', description='The alert level when the condition is met.', example='INFO'),
      type?: string(name='type', description='The match type. It can be data availability, a specific number of data entries, a data match, or a specific number of data entry matches.

Valid values:

- HasData: Data is available.

- HasDataCount: A specific number of data entries are available.

- HasDataMatch: Data matches the condition.

- HasDataMatchCount: A specific number of data entries match the condition.', example='HasData'),
    }
  ](name='caseList', description='Applicable to the SLS_CONDITION type.

A list of SLS alert conditions.'),
  compareList?: [ 
    {
      aggregate?: string(name='aggregate', description='The aggregate function for the time series.

- count

- sum

- avg

- min

- max

- p90

- p95

- p99', example='count'),
      baseUnit?: string(name='baseUnit', description='The unit of the data.', example='%'),
      displayUnit?: string(name='displayUnit', description='The unit for display.', example='%'),
      oper?: string(name='oper', description='The comparison operation. It determines whether to perform a year-over-year or period-over-period comparison.

- GT: Greater than.

- GTE: Greater than or equal to.

- LT: Less than.

- LTE: Less than or equal to.

- EQ: Equal to.

- NE: Not equal to.

- YOY_UP: Year-over-year increase.

- YOY_DOWN: Year-over-year decrease.', example='GT'),
      value?: double(name='value', description='The threshold for comparison.', example='50'),
      valueLevelList?: [ 
        {
          level?: string(name='level', description='The level corresponding to the threshold.', example='INFO'),
          value?: double(name='value', description='The threshold for comparison.', example='120'),
        }
      ](name='valueLevelList', description='A list of alert levels for different values.'),
      yoyTimeUnit?: string(name='yoyTimeUnit', description='The time unit for year-over-year comparison. This parameter is valid only when oper is set to YOY_UP or YOY_DOWN. Valid values: minute, hour, day, week, and month.', example='month'),
      yoyTimeValue?: int32(name='yoyTimeValue', description='The time value for year-over-year comparison. Used with yoyTimeUnit.', example='1'),
    }
  ](name='compareList', description='Applicable to the APM_CONDITION type.

A list of Application Performance Management (APM) alert comparison conditions.'),
  compositeEscalation?: {
    escalations?: [ 
      {
        comparisonOperator?: string(name='comparisonOperator', description='The comparison operator for the threshold. Valid values:

- GreaterThanOrEqualToThreshold: Greater than or equal to.

- GreaterThanThreshold: Greater than.

- LessThanOrEqualToThreshold: Less than or equal to.

- LessThanThreshold: Less than.

- NotEqualToThreshold: Not equal to.

- EqualToThreshold: Equal to.

- GreaterThanYesterday: Higher than the value at the same time yesterday.

- LessThanYesterday: Lower than the value at the same time yesterday.

- GreaterThanLastWeek: Higher than the value at the same time last week.

- LessThanLastWeek: Lower than the value at the same time last week.

- GreaterThanLastPeriod: Higher than the value in the previous period.

- LessThanLastPeriod: Lower than the value in the previous period.', example='GreaterThanOrEqualToThreshold'),
        metricName?: string(name='metricName', description='The name of the metric.', example='cpu_total'),
        period?: long(name='period', description='The time window for the metric.', example='60'),
        statistics?: string(name='statistics', description='The statistical method. The valid values for this parameter are determined by the Statistics column that corresponds to the MetricName of the specified cloud product. Examples of statistical methods for metrics:

- $Maximum: The maximum value.

- $Minimum: The minimum value.

- $Average: The average value.

- $Availability: The availability rate. This is typically used for site monitoring.

Note: The dollar sign ($) is a standard prefix for metrics.', example='$Maximum'),
        threshold?: double(name='threshold', description='The alert threshold.', example='50'),
      }
    ](name='escalations', description='A list of composite conditions for multiple metrics.'),
    level?: string(name='level', description='The alert level that is triggered when the condition is met. Composite metric alerts support only one level.', example='INFO'),
    relation?: string(name='relation', description='The relationship between multiple metric conditions. Valid values: and or or.', example='and'),
    times?: int32(name='times', description='The number of times the condition must be met to trigger an alert.', example='3'),
  }(name='compositeEscalation', description='Applicable to the CMS_BASIC_CONDITION type.

This parameter is valid only when escalationType is set to composite. It specifies the alert condition for composite metrics.'),
  enableSeveritySuppression?: boolean(name='enableSeveritySuppression'),
  escalationType?: string(name='escalationType', description='Applicable to the CMS_BASIC_CONDITION type.

Valid values:

- simple: A simple metric condition.

- composite: A composite metric condition.

- express: An expression-based condition.', example='simple'),
  expressEscalation?: {
    level?: string(name='level', description='The alert level that is triggered when the condition is met. Expression-based alerts support only one level.

- CRITICAL

- WARNING

- INFO', example='INFO'),
    rawExpression?: string(name='rawExpression', description='The alert condition expression.', example='@cpu_total[60].$Average > 60'),
    times?: int32(name='times', description='The number of times the condition must be met to trigger an alert.', example='3'),
  }(name='expressEscalation', description='This parameter is applicable only to the CMS_BASIC_CONDITION condition type.

This parameter takes effect when escalationType is set to composite. It defines the conditions for a composite alert based on multiple metrics.'),
  noDataAlertLevel?: string(name='noDataAlertLevel', description='Applicable to the APM_CONDITION type.

The alert level for when no data is available. If you do not specify this parameter, no alert is triggered when no data is available.', example='INFO'),
  noDataAppendValue?: string(name='noDataAppendValue', description='Applicable to the APM_CONDITION type.

The value to use when no data is available.', example='1'),
  noDataPolicy?: string(name='noDataPolicy', description='Applicable to the CMS_BASIC_CONDITION type.

The method for handling alerts when no monitoring data is available. Valid values:

- KEEP_LAST_STATE (default): No action is taken.

- INSUFFICIENT_DATA: The alert content indicates that no data is available.

- OK: The status is normal.', example='KEEP_LAST_STATE'),
  oper?: string(name='oper', description='The comparison operation. It determines whether to perform a year-over-year or period-over-period comparison.

- GT: Greater than.

- GTE: Greater than or equal to.

- LT: Less than.

- LTE: Less than or equal to.

- EQ: Equal to.

- NE: Not equal to.

- YOY_UP: Year-over-year increase.

- YOY_DOWN: Year-over-year decrease.', example='LT'),
  relation?: string(name='relation', description='Applicable to the APM_CONDITION type.

The logical relationship between multiple conditions. Valid values:

- and

- or', example='and'),
  simpleEscalation?: {
    escalations?: [ 
      {
        comparisonOperator?: string(name='comparisonOperator', description='The comparison operator for the threshold. Valid values:

- GreaterThanOrEqualToThreshold: Greater than or equal to.

- GreaterThanThreshold: Greater than.

- LessThanOrEqualToThreshold: Less than or equal to.

- LessThanThreshold: Less than.

- NotEqualToThreshold: Not equal to.

- EqualToThreshold: Equal to.

- GreaterThanYesterday: Higher than the value at the same time yesterday.

- LessThanYesterday: Lower than the value at the same time yesterday.

- GreaterThanLastWeek: Higher than the value at the same time last week.

- LessThanLastWeek: Lower than the value at the same time last week.

- GreaterThanLastPeriod: Higher than the value in the previous period.

- LessThanLastPeriod: Lower than the value in the previous period.', example='GreaterThanOrEqualToThreshold'),
        level?: string(name='level', description='The alert level that is triggered when the condition is met. Expression-based alerts support only one level.

- CRITICAL

- WARNING

- INFO', example='INFO'),
        statistics?: string(name='statistics', description='The statistical method. The valid values for this parameter are determined by the Statistics column that corresponds to the MetricName of the specified cloud product. Examples: Maximum, Minimum, and Average.', example='Average'),
        threshold?: double(name='threshold', description='The alert threshold.', example='100'),
        times?: int32(name='times', description='The number of times the condition must be met to trigger an alert.', example='3'),
      }
    ](name='escalations', description='A list of conditions. If an alert rule has multiple levels, each level has a corresponding condition object.'),
    metricName?: string(name='metricName', description='Applicable to the CMS_BASIC_CONDITION type.

The metric associated with the alert condition.', example='cpu_total'),
    period?: long(name='period', description='The time window for the metric, in seconds.', example='60'),
  }(name='simpleEscalation', description='Applicable to the CMS_BASIC_CONDITION type.

This parameter is valid only when escalationType is set to simple. It specifies the alert condition for a single metric.'),
  triggers?: [ 
    {
      durationSecs?: int32(name='durationSecs'),
      expression?: {
        conditions?: [ 
          {
            expressionType?: string(name='expressionType'),
            operator?: string(name='operator'),
            queryName?: string(name='queryName'),
            threshold?: double(name='threshold'),
          }
        ](name='conditions'),
        expressionType?: string(name='expressionType'),
        logicOperator?: string(name='logicOperator'),
      }(name='expression'),
      severity?: string(name='severity'),
    }
  ](name='triggers'),
  type?: string(name='type', description='The type of the rule condition. Valid values:

- SLS_CONDITION: An SLS alert condition.

- APM_CONDITION: An APM alert condition.

- CMS_BASIC_CONDITION: A basic Cloud Monitor alert condition.

This parameter is required.', example='SLS_CONDITION'),
  value?: double(name='value', description='The threshold that triggers an alert.', example='60'),
}

model AlertRuleDataSource {
  appType?: string(name='appType', description='Applies to the APM_DS data source type.

The type of the application. Valid value:

- apm', example='apm'),
  dsList?: [ 
    {
      project?: string(name='project', description='The SLS project.', example='mySlsProject'),
      regionId?: string(name='regionId', description='The region where the SLS project is located.', example='cn-hangzhou'),
      store?: string(name='store', description='The name of the LogStore or MetricStore.', example='mySlsLogStore'),
      type?: string(name='type', description='The type of the SLS sub-data source. Valid values:

- SLS_LOG_DS: A LogStore data source.

- SLS_METRIC_DS: A MetricStore data source.', example='SLS_LOG_DS'),
    }
  ](name='dsList', description='Applies to the SLS_MULTI_DS data source type.

A list of sub-data sources.'),
  instanceId?: string(name='instanceId', description='Applies to the PROMETHEUS_DS data source type.

The ID of the Prometheus instance.', example='rw-bbe8961b4a59be0'),
  namespace?: string(name='namespace', description='Applies to the ENTERPRISE_DS data source type.

The name of the Hybrid Cloud Monitoring metric repository.', example='aliyun-default'),
  regionId?: string(name='regionId', description='Applies to the APM_DS and PROMETHEUS_DS data source types.

The ID of the region where the data source is located.', example='cn-hangzhou'),
  tenantId?: string(name='tenantId'),
  type?: string(name='type', description='The data source type.

Valid values:

- PROMETHEUS_DS: A Prometheus data source.

- SLS_MULTI_DS: An SLS data source.

- APM_DS: An Application Monitoring data source.

- CMS_BASIC_DS: A basic Cloud Monitor data source.

- ENTERPRISE_DS: A Hybrid Cloud Monitoring data source.

This parameter is required.', example='PROMETHEUS_DS'),
}

