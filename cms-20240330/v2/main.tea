  contentTemplate?: string(name='contentTemplate', description='The template for the alert notification content.'),
  createdAt?: string(name='createdAt', description='The time the alert rule was created.'),
  datasourceConfig?: DatasourceConfigUnified(name='datasourceConfig', description='The configuration for the data source to be evaluated.'),
  datasourceType?: string(name='datasourceType', description='The data source type. Examples: `sls`, `prometheus`.'),
  displayName?: string(name='displayName', description='The user-defined display name for the alert rule.'),
  enabled?: boolean(name='enabled', description='Indicates whether the alert rule is active. Set to `true` to enable the rule, or `false` to disable it.'),
  labels?: map[string]string(name='labels', description='A set of key-value pairs that serve as labels to filter and group alert rules.'),
  notifyConfig?: NotifyConfigUnified(name='notifyConfig', description='The configuration for sending notifications when an alert is triggered.'),
  notifyStrategyId?: string(name='notifyStrategyId', description='The ID of the notification strategy to use for this alert rule.'),
  observeResourceGlobalScope?: boolean(name='observeResourceGlobalScope', description='Indicates whether the alert rule monitors all resources of the specified type. If `true`, the rule applies globally within the workspace.'),
  observeResourceList?: [ string ](name='observeResourceList', description='A list of specific resource IDs to monitor, used only when `observeResourceGlobalScope` is `false`.'),
  observeResourceType?: string(name='observeResourceType', description='The type of resource that the alert rule monitors.'),
  partitionKey?: string(name='partitionKey', description='The partition key used to group alerts. Alerts with the same partition key are treated as a single incident.'),
  queryConfig?: QueryConfigUnified(name='queryConfig', description='The configuration for querying and processing data from the data source.'),
  scheduleConfig?: ScheduleConfigUnified(name='scheduleConfig', description='The configuration for how often the alert rule is evaluated.'),
  severityLevels?: string(name='severityLevels', description='The severity level of the alert. Examples: `critical`, `warning`.'),
  status?: string(name='status', description='The current status of the alert rule. Examples: `RUNNING`, `STOPPED`.'),
  updatedAt?: string(name='updatedAt', description='The time the alert rule was last updated.'),
  uuid?: string(name='uuid', description='The unique identifier for the alert rule.'),
  workspace?: string(name='workspace', description='The ID of the workspace that contains the alert rule.'),
}

model ApmCompositeCompareConfig {
  aggregate?: string(name='aggregate', description='The aggregation method for metric data. For example, `AVG`, `SUM`, or `MAX`.

This parameter is required.'),
  operator?: string(name='operator', description='The operator for comparing the aggregated metric data against the `threshold`. For example, `GREATER_THAN` or `LESS_THAN`.

This parameter is required.'),
  threshold?: float(name='threshold', description='The value to compare the aggregated metric data against. An alert is triggered when the metric data meets the condition defined by the `operator`.

This parameter is required.'),
  yoyTimeUnit?: string(name='yoyTimeUnit', description='The time unit for the year-over-year (YoY) comparison. Use this parameter with `yoyTimeValue` to define the comparison period. Valid values are `day` and `week`.'),
  yoyTimeValue?: int32(name='yoyTimeValue', description='The time value for the YoY comparison. For example, if `yoyTimeUnit` is `day` and `yoyTimeValue` is `7`, the system compares current data with data from 7 days ago.'),
}

