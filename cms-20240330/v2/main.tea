model AlertRuleSlsQueryJoin {
  conditions?: [ 
    {
      firstField?: string(name='firstField', description='The left operand of the condition. The format is $\\\\<query_idx>.\\\\<field_name_in_result_set>.', example='$0.__topic__'),
      oper?: string(name='oper', description='The comparison operator. Valid values are <, >, ==, !=, <=, and >=.', example='=='),
      secondField?: string(name='secondField', description='The right operand of the condition. The format is $\\\\<query_idx>.\\\\<field_name_in_result_set>.', example='$0.__topic__'),
    }
  ](name='conditions', description='The list of join conditions.'),
  type?: string(name='type', description='The type of the collection operation.

- CrossJoin: The Cartesian product.

- FullJoin: The full join.

- InnerJoin: The inner join.

- LeftExclude: The left exclusion.

- RightExclude: The right exclusion.

- LeftJoin: The left join.

- RightJoin: The right join.

- NoJoin: No merge operation is performed.

- Concat: Concatenation.

For more information, see https\\\\://www\\\\.alibabacloud.com/help/en/sls/user-guide/set-operations.

This parameter is required.', example='CrossJoin'),
}

