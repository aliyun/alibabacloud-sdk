/**
 *
 */
import OpenApi;
import OpenApi.OpenApiUtil;

extends OpenApi;


init(config: OpenApiUtil.Config){
  super(config);
  @endpointRule = '';
  
  checkConfig(config);
  @endpoint = getEndpoint('cms', @regionId, @endpointRule, @network, @suffix, @endpointMap, @endpoint);
}

function getEndpoint(productId: string, regionId: string, endpointRule: string, network: string, suffix: string, endpointMap: map[string]string, endpoint: string) throws: string{
  if (!$isNull(endpoint)) {
    return endpoint;
  }
  
  if (!$isNull(endpointMap) && !$isNull(endpointMap[regionId])) {
    return endpointMap[regionId];
  }
  return OpenApiUtil.getEndpointRules(productId, regionId, endpointRule, network, suffix);
}

model ActionIntegrationConfig {
  actions?: [ string ](name='actions', description='行动集成 ID 列表'),
  enabled?: boolean(name='enabled', description='是否启用行动集成'),
}

model AddonMeta {
  alias?: string(name='alias'),
  categories?: [ string ](name='categories'),
  dashboards?: [ 
    {
      description?: string(name='description'),
      name?: string(name='name'),
      url?: string(name='url', example='assets/dashboards/ecs.png'),
    }
  ](name='dashboards'),
  description?: string(name='description', example='The out-of-the-box and comprehensive ECS observe dashboards and alarm rules. Based on AliYun CloudMonitor agentless metrics, exporter agent metrics, host audit logs, host events and other data.'),
  environments?: [ 
    {
      commonSchemaRefs?: [ 
        {
          group?: string(name='group', example='acs-ecs'),
          version?: string(name='version', example='0.1.0'),
        }
      ](name='commonSchemaRefs'),
      dependencies?: {
        clusterTypes?: [ string ](name='clusterTypes'),
        features?: map[string]boolean(name='features'),
        services?: [ string ](name='services'),
      }(name='dependencies'),
      description?: string(name='description'),
      enable?: boolean(name='enable', example='true/false'),
      label?: string(name='label'),
      name?: string(name='name', example='CS/ECS/Cloud/Client'),
      policies?: {
        alertDefaultStatus?: string(name='alertDefaultStatus', example='RUNNING'),
        bindDefaultPolicy?: boolean(name='bindDefaultPolicy', example='true/false'),
        bindEntity?: {
          entityGroupMode?: boolean(name='entityGroupMode', example='true/false'),
          entityType?: string(name='entityType', example='acs.ecs.instance'),
          singleEntityMode?: boolean(name='singleEntityMode', example='true/false'),
          vpcIdFieldKey?: string(name='vpcIdFieldKey', example='vpcId'),
        }(name='bindEntity'),
        defaultInstall?: boolean(name='defaultInstall', example='true/false'),
        enableServiceAccount?: boolean(name='enableServiceAccount', example='true/false'),
        metricCheckRule?: {
          promQL?: [ string ](name='promQL'),
        }(name='metricCheckRule'),
        needRestartAfterIntegration?: boolean(name='needRestartAfterIntegration', example='true/false'),
        protocols?: [ 
          {
            description?: string(name='description'),
            icon?: string(name='icon', example='assets/logos/ecs.svg'),
            label?: string(name='label'),
            name?: string(name='name', example='Prometheus'),
          }
        ](name='protocols'),
        targetAddonName?: string(name='targetAddonName', example='cloud-acs-ecs'),
      }(name='policies'),
      policyType?: string(name='policyType', example='ECS'),
    }
  ](name='environments'),
  icon?: string(name='icon', example='assets/logos/ecs.svg'),
  keywords?: [ string ](name='keywords'),
  language?: string(name='language', example='zh'),
  latestReleaseCreateTime?: string(name='latestReleaseCreateTime', example='2025-10-25 09:12:12'),
  name?: string(name='name', example='cloud-acs-ecs'),
  once?: boolean(name='once', example='true/false'),
  scene?: string(name='scene', example='feature'),
  version?: string(name='version', example='0.0.1'),
  weight?: int32(name='weight', example='1000'),
}

