/**
 *
 */
import OpenApi;
import OpenApi.OpenApiUtil;

extends OpenApi;


init(config: OpenApiUtil.Config){
  super(config);
  @endpointRule = '';
  
  checkConfig(config);
  @endpoint = getEndpoint('cms', @regionId, @endpointRule, @network, @suffix, @endpointMap, @endpoint);
}

function getEndpoint(productId: string, regionId: string, endpointRule: string, network: string, suffix: string, endpointMap: map[string]string, endpoint: string) throws: string{
  if (!$isNull(endpoint)) {
    return endpoint;
  }
  
  if (!$isNull(endpointMap) && !$isNull(endpointMap[regionId])) {
    return endpointMap[regionId];
  }
  return OpenApiUtil.getEndpointRules(productId, regionId, endpointRule, network, suffix);
}

model ActionIntegrationConfig {
  actions?: [ string ](name='actions', description='A list of actions to perform.'),
  enabled?: boolean(name='enabled', description='Indicates whether action integration is enabled.'),
}

model AddonMeta {
  alias?: string(name='alias', description='The alias of the component. This is the display name.', example='ECS 监控'),
  categories?: [ string ](name='categories', description='The categorization information of the component.'),
  dashboards?: [ 
    {
      description?: string(name='description', description='The description.', example='描述信息'),
      name?: string(name='name', description='The name of the diagram.', example='ECS 监控概览大盘'),
      url?: string(name='url', description='The URL of the diagram.', example='assets/dashboards/ecs.png'),
    }
  ](name='dashboards', description='A list of component diagrams.'),
  description?: string(name='description', description='The description.', example='The out-of-the-box and comprehensive ECS observe dashboards and alarm rules. Based on AliYun CloudMonitor agentless metrics, exporter agent metrics, host audit logs, host events and other data.'),
  environments?: [ 
    {
      commonSchemaRefs?: [ 
        {
          group?: string(name='group', description='The group name of the CommonSchema.', example='acs-ecs'),
          version?: string(name='version', description='The group version of the CommonSchema.', example='0.1.0'),
        }
      ](name='commonSchemaRefs', description='The list of attached CommonSchemas.'),
      dependencies?: {
        clusterTypes?: [ string ](name='clusterTypes', description='The supported cluster types.'),
        features?: map[string]boolean(name='features', description='The probe dependency description. This is the component name. In later versions, this field is replaced by the collectors field.'),
        services?: [ string ](name='services', description='The list of dependent services.'),
      }(name='dependencies', description='The dependency description.'),
      description?: string(name='description', description='The description of the environment type.', example='支持容器集群的工作覆盖监控'),
      enable?: boolean(name='enable', description='Indicates whether the environment type is enabled.', example='true/false'),
      label?: string(name='label', description='The display name of the environment type.', example='容器环境'),
      name?: string(name='name', description='The name of the environment type.', example='CS/ECS/Cloud/Client'),
      policies?: {
        alertDefaultStatus?: string(name='alertDefaultStatus', description='Indicates whether the alert rule is enabled by default after installation.', example='RUNNING'),
        bindDefaultPolicy?: boolean(name='bindDefaultPolicy', description='The default mode. This integration mode does not require attaching an entity.', example='true/false'),
        bindEntity?: {
          entityGroupMode?: boolean(name='entityGroupMode', description='Indicates whether group mode is used.', example='true/false'),
          entityType?: string(name='entityType', description='The entity type.', example='acs.ecs.instance'),
          singleEntityMode?: boolean(name='singleEntityMode', description='Indicates whether single-entity mode is used.', example='true/false'),
          vpcIdFieldKey?: string(name='vpcIdFieldKey', description='The field in the entity from which to fetch the VPC ID.', example='vpcId'),
        }(name='bindEntity', description='Information about the attached target entity.'),
        defaultInstall?: boolean(name='defaultInstall', description='Indicates whether the component is installed by default.', example='true/false'),
        enableServiceAccount?: boolean(name='enableServiceAccount', description='Indicates whether to enable internal authorization token allocation.', example='true/false'),
        metricCheckRule?: {
          promQL?: [ string ](name='promQL', description='The Prometheus Query Language (PromQL) for the check rule.'),
        }(name='metricCheckRule', description='The data check rule after the component is integrated.'),
        needRestartAfterIntegration?: boolean(name='needRestartAfterIntegration', description='Indicates whether to prompt for a workload restart after integration.', example='true/false'),
        protocols?: [ 
          {
            description?: string(name='description', description='The description of the protocol.', example='使用 Prometheus 协议写入指标数据'),
            icon?: string(name='icon', description='The display icon for the protocol.', example='assets/logos/ecs.svg'),
            label?: string(name='label', description='The display name of the protocol.', example='Prometheus 协议'),
            name?: string(name='name', description='The name of the protocol.', example='Prometheus'),
          }
        ](name='protocols', description='The list of supported client protocols.'),
        targetAddonName?: string(name='targetAddonName', description='The name of the target component for redirection.', example='cloud-acs-ecs'),
      }(name='policies', description='Information about the control policy group for the component.'),
      policyType?: string(name='policyType', description='The policy type.', example='ECS'),
    }
  ](name='environments', description='The list of supported environment types.'),
  icon?: string(name='icon', description='The icon of the component.', example='assets/logos/ecs.svg'),
  keywords?: [ string ](name='keywords', description='The list of keywords.'),
  language?: string(name='language', description='The language. Valid values:

- zh: Chinese (default)

- en: English', example='zh'),
  latestReleaseCreateTime?: string(name='latestReleaseCreateTime', description='The last time the component was integrated.', example='2025-10-25 09:12:12'),
  name?: string(name='name', description='The name of the component.', example='cloud-acs-ecs'),
  once?: boolean(name='once', description='Indicates whether the component can be installed only once under a policy.', example='true/false'),
  scene?: string(name='scene', description='The scenario.', example='feature'),
  version?: string(name='version', description='The version number.', example='0.0.1'),
  weight?: int32(name='weight', description='The sorting weight of the component.', example='1000'),
}

