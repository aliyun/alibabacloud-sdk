  groupId?: string(name='groupId', description='The globally unique ID of the observability group. Format: og-<16-character hash>. Used uniformly across metrics, alerts, and consoles.'),
  groupName?: string(name='groupName', description='The name of the observability group. Must be unique within the same workspace.'),
