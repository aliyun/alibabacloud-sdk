model CmsEventForView {
  annotations?: map[string]any(name='annotations', description='Additional annotations for the event. This is an unstructured description field.', example='{ "description": "High load detected on server", "operator": "auto" }'),
  data?: any(name='data', description='The raw data of the event. The format depends on the event type and dataschema.', example='{ "metricName": "cpu_usage", "value": 95.2, "threshold": 80 }'),
  datacontenttype?: string(name='datacontenttype', description='The content type of the data field.', example='"application/json"'),
  dataschema?: string(name='dataschema', description='The data schema definition, which describes the structure of the data field.', example='"https://schema.alibabacloud.com/cms/alert/v1"'),
  dedupId?: string(name='dedupId', description='The deduplication ID. It identifies different instances of the same event, such as a repeatedly reported event.', example='"dedup-abc123"'),
  id?: string(name='id', description='The unique identifier for the event. The system generates this globally unique ID.', example='"event-1234567890"'),
  integrationUuid?: string(name='integrationUuid', description='The unique integration identifier. It is used for identity recognition in cross-system integrations.', example='"integration-xyz"'),
  labels?: map[string]any(name='labels', description='The key-value pairs of the event labels.', example='{\\\\"source\\\\": \\\\"system\\\\"}'),
  receiveTime?: long(name='receiveTime', description='The timestamp when the event was received and processed.', example='1743846610000'),
  resource?: EventResourceForEventView(name='resource', description='Information about the resource associated with the event, such as the instance ID, IP address, and region.'),
  severity?: string(name='severity', description='The severity level of the event.', example='"CRITICAL"'),
  source?: string(name='source', description='The name of the source system or service, such as ECS, RDS, or VPC.', example='"ECS"'),
  sourcetype?: string(name='sourcetype', description='The type of event source. It distinguishes between sources such as monitoring systems, Simple Log Service, and application observability.', example='"CloudMonitor"'),
  status?: string(name='status', description='The current status of the event.', example='Running'),
  subject?: string(name='subject', description='The subject or title of the event. It briefly describes the event.', example='"Instance cpu usage exceeds threshold"'),
  subtype?: string(name='subtype', description='The event subtype.', example='"HighCPUUsage"'),
  sysId?: string(name='sysId', description='The internal system event ID. It is used for internal tracking and log association.', example='"sys-event-987654321"'),
  time?: string(name='time', description='The time when the event occurred.', example='"2025-04-05T10:30:00Z"'),
  timestamp?: long(name='timestamp', description='The timestamp of the event occurrence.', example='1743846600000'),
  type?: string(name='type', description='The event type.', example='"Alert"'),
  workspace?: string(name='workspace', description='The ID or name of the workspace. It is used for multi-tenant or organization fencing.', example='"ws-abc123"'),
  workspaceTags?: map[string]any(name='workspaceTags', description='The workspace tags. They help you manage events by tag.', example='{ "department": "finance", "project": "payment-gateway" }'),
}

